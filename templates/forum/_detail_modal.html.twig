<div class="p-4 p-md-5">
    <div class="d-flex justify-content-between align-items-start gap-3 mb-4">
        <div class="d-flex align-items-center gap-3">
            <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold shadow-sm"
                 style="width:64px;height:64px;background:linear-gradient(135deg,#1E8449 0%,#52BE80 100%);font-size:1.4rem;">
                {% if forum.image %}
                    <img src="{{ forum.image }}" class="w-100 h-100 rounded-circle object-fit-cover" loading="lazy" decoding="async" onerror="this.style.display='none';">
                {% else %}
                    {{ forum.name|first|upper }}
                {% endif %}
            </div>
            <div>
                <p class="text-uppercase text-success fw-semibold mb-1">Forum</p>
                <h2 class="h3 fw-bold mb-1">{{ forum.name }}</h2>
                <p class="text-muted mb-0">Créé le {{ forum.dateCreation|date('d/m/Y') }}</p>
            </div>
        </div>
        <button type="button" class="btn-close" aria-label="Fermer" onclick="bootstrap.Modal.getInstance(document.getElementById('detailModal')).hide()"></button>
    </div>

    <div class="p-4 rounded-4" style="background: linear-gradient(135deg, rgba(82,190,128,0.10), rgba(82,190,128,0.04)); border: 1px solid rgba(82,190,128,0.12);">
        <p class="text-secondary mb-0">{{ forum.description|default('Explorez et discutez des dernières tendances avec la communauté.') }}</p>
    </div>

    <div class="row g-3 mt-4">
        <div class="col-md-4"><div class="p-3 rounded-4 bg-light text-center"><div class="fw-bold fs-4">{{ forum.nbrMembers }}</div><div class="text-muted small text-uppercase">Membres</div></div></div>
        <div class="col-md-4"><div class="p-3 rounded-4 bg-light text-center"><div class="fw-bold fs-4">{{ postes|length }}</div><div class="text-muted small text-uppercase">Sujets</div></div></div>
        <div class="col-md-4"><div class="p-3 rounded-4 bg-light text-center"><div class="fw-bold fs-4">{{ forum.createdBy ? forum.createdBy.prenom : 'GoVibe' }}</div><div class="text-muted small text-uppercase">Auteur</div></div></div>
    </div>

    <div class="d-flex flex-wrap gap-2 justify-content-end mt-4">
        <a href="{{ path('app_forum_show', {'forumId': forum.forumId}) }}" class="btn btn-outline-success rounded-pill px-4">Ouvrir le forum</a>
        {% if is_granted('ROLE_USER') and not isMember %}
            <form action="{{ path('app_forum_join', {'forumId': forum.forumId}) }}" method="POST">
                <button type="submit" class="btn btn-success rounded-pill px-4">Rejoindre</button>
            </form>
        {% endif %}
    </div>
</div>

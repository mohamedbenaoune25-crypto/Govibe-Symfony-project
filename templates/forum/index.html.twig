{% extends is_granted('ROLE_ADMIN') ? 'admin/base_admin.html.twig' : 'base.html.twig' %}

{% block page_title %}Communautés Forums{% endblock %}

{% block title %}Explorez les Communautés Forums{% endblock %}

{% block body %}
<!-- Forum Hero Header -->
<div class="container-fluid bg-white {% if is_granted('ROLE_ADMIN') %}py-4 mb-4{% else %}py-5 mb-5{% endif %} shadow-sm border-bottom rounded-bottom-5 px-lg-5 position-relative overflow-hidden">
    <div class="row align-items-center justify-content-center">
        <div class="col-lg-8">
            <h1 class="display-3 fw-bold text-dark mb-3 animate-fade-in-up">Communautés <span style="color: #52BE80;">GoVibe</span></h1>
            <p class="text-secondary fs-5 mb-5 opacity-75">Connectez-vous avec des milliers de passionnés à travers nos forums thématiques.</p>
            
            <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center align-items-center mb-4">
                {% if is_granted('ROLE_USER') %}
                    <button type="button" onclick="openForumModal('{{ path('app_forum_new') }}')"
                            class="btn btn-success rounded-pill px-5 py-3 fw-bold shadow transition-all hover-lift-2 border-0" 
                            style="background-color: #52BE80; font-size: 1.1rem;">
                        <i class="bi bi-plus-lg me-2"></i>Lancer mon Forum
                    </button>
                {% endif %}
                <div class="dropdown">
                    <button class="btn btn-outline-secondary rounded-pill px-4 py-3 fw-bold dropdown-toggle border-2 shadow-sm" type="button" data-bs-toggle="dropdown">
                        Trier par : 
                        {% if current_sort == 'popular' %}Les plus populaires
                        {% elseif current_sort == 'newest' %}Nouveautés
                        {% elseif current_sort == 'private' %}Privés
                        {% elseif current_sort == 'mine' %}Mes Forums
                        {% else %}Tous{% endif %}
                    </button>
                    <ul class="dropdown-menu shadow-lg border-0 rounded-4 p-2">
                        {% if app.user %}
                            <li><a class="dropdown-item rounded-3 py-2 {{ current_sort == 'mine' ? 'active bg-success text-white fw-bold' : '' }}" href="{{ path('app_forum_index', {'sort': 'mine'}) }}">Mes Forums</a></li>
                            <li><hr class="dropdown-divider opacity-10"></li>
                        {% endif %}
                        <li><a class="dropdown-item rounded-3 py-2 {{ current_sort == 'popular' ? 'active bg-success' : '' }}" href="{{ path('app_forum_index', {'sort': 'popular'}) }}">Les plus populaires</a></li>
                        <li><a class="dropdown-item rounded-3 py-2 {{ current_sort == 'newest' ? 'active bg-success' : '' }}" href="{{ path('app_forum_index', {'sort': 'newest'}) }}">Nouveautés</a></li>
                        <li><a class="dropdown-item rounded-3 py-2 {{ current_sort == 'private' ? 'active bg-success' : '' }}" href="{{ path('app_forum_index', {'sort': 'private'}) }}">Privés</a></li>
                    </ul>
                </div>
            </div>
            
            <div class="d-flex justify-content-center gap-5 mt-4 opacity-50 small fw-bold text-uppercase ls-1">
                <span><i class="bi bi-people-fill me-2 text-success"></i>{{ totalMembers }} Membres</span>
                <span><i class="bi bi-chat-left-fill me-2 text-success"></i>{{ forums|length }}+ Forums</span>
                <span><i class="bi bi-cpu-fill me-2 text-success"></i>Actif en continu</span>
            </div>
        </div>
    </div>
</div>

<!-- Main Feed -->
<div class="container mb-5 px-lg-5">
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-5">
        {% for forum in forums %}
            {% include 'forum/forumitem.html.twig' %}
        {% else %}
            <div class="col-12 text-center py-5 rounded-5 border bg-white">
                <div class="display-3 text-muted opacity-25 mb-4"><i class="bi bi-search"></i></div>
                <h3 class="text-secondary fw-bold">Aucun forum trouvé</h3>
                <p class="text-muted">Pourquoi ne pas en créer un ?</p>
                {% if is_granted('ROLE_USER') %}
                    <button onclick="openForumModal('{{ path('app_forum_new') }}')" class="btn btn-success rounded-pill px-4 mt-2 border-0" style="background-color: #52BE80;">Commencer</button>
                {% endif %}
            </div>
        {% endfor %}
    </div>
</div>



{% endblock %}

{% block javascripts %}
{{ parent() }}
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    body { background-color: #F8F9F9 !important; }
    .ls-1 { letter-spacing: 1px; }
    .animate-fade-in-up { animation: fadeInUp 0.6s ease-out; }
    @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    .hover-lift-2:hover { transform: translateY(-4px); box-shadow: 0 10px 20px rgba(82,190,128,0.3) !important; background-color: #48AC71 !important; }
    .rounded-bottom-5 { border-bottom-left-radius: 4rem !important; border-bottom-right-radius: 4rem !important; }
</style>
{% endblock %}

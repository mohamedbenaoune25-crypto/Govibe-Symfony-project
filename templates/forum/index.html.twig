{% extends is_granted('ROLE_ADMIN') ? 'admin/base_admin.html.twig' : 'base.html.twig' %}

{% block page_title %}Communautés Forums{% endblock %}

{% block title %}Explorez les Communautés Forums{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Manrope:wght@200..800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════════
   GoVibe Forums Index — Ultra Premium Design
   Matching Locations Page Aesthetic
═══════════════════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; }

body {
    font-family: 'Manrope', sans-serif !important;
    background: #fcf9f8 !important;
    color: #1c1b1b !important;
    overflow-x: hidden !important;
}

.material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24; }

/* ─── Hero Section ─── */
.gv-forums-hero {
    position: relative;
    padding: 180px 0 120px;
    background: linear-gradient(160deg, #00342d 0%, #013220 40%, #001a12 100%);
    overflow: hidden;
    text-align: center;
    border-radius: 0 0 3rem 3rem;
    box-shadow: 0 20px 50px rgba(0, 52, 45, 0.15);
}

.gv-forums-hero::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse at 25% 75%, rgba(16, 185, 129, 0.15) 0%, transparent 60%),
                radial-gradient(ellipse at 75% 25%, rgba(233, 193, 118, 0.08) 0%, transparent 50%);
    pointer-events: none;
}

.gv-forums-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(160, 242, 225, 0.06) 1px, transparent 1px);
    background-size: 24px 24px;
    pointer-events: none;
}

.gv-hero-icon-bg {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font-size: 22rem;
    color: rgba(255, 255, 255, 0.02);
    z-index: 0;
    pointer-events: none;
    font-variation-settings: 'FILL' 1;
}

.gv-hero-title {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: #fff;
    font-weight: 700;
    margin-bottom: 1rem;
    position: relative;
    z-index: 2;
    animation: gvFadeIn 0.8s ease both;
}
.gv-hero-title em { color: #a0f2e1; font-style: italic; font-weight: 300; }

.gv-hero-sub {
    color: rgba(160, 242, 225, 0.7);
    font-size: 1.15rem;
    max-width: 600px;
    margin: 0 auto 2rem;
    line-height: 1.6;
    position: relative;
    z-index: 2;
    animation: gvFadeIn 0.8s ease 0.2s both;
}

.gv-hero-actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    position: relative;
    z-index: 2;
    animation: gvFadeIn 0.8s ease 0.4s both;
    margin-bottom: 2rem;
}

.gv-hero-stats {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
    position: relative;
    z-index: 2;
    animation: gvFadeIn 0.8s ease 0.5s both;
}
.gv-hero-stat {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(160, 242, 225, 0.5);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
}
.gv-hero-stat .material-symbols-outlined {
    font-size: 1.1rem;
    color: rgba(160, 242, 225, 0.6);
}

@keyframes gvFadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}

.gv-btn-primary {
    padding: 1rem 2rem;
    background: linear-gradient(135deg, #e9c176 0%, #ca9028 100%);
    color: #3d2a00;
    border: none;
    border-radius: 0.75rem;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s ease;
    box-shadow: 0 10px 25px -5px rgba(233, 193, 118, 0.4);
    font-family: 'Manrope', sans-serif;
    cursor: pointer;
}
.gv-btn-primary:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 15px 35px -5px rgba(233, 193, 118, 0.5);
    color: #3d2a00;
}

/* ─── Sort Dropdown ─── */
.gv-sort-dropdown {
    position: relative;
    display: inline-block;
}
.gv-sort-toggle {
    padding: 0.85rem 1.5rem;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(10px);
    color: #a0f2e1;
    border: 1.5px solid rgba(160, 242, 225, 0.25);
    border-radius: 0.75rem;
    font-weight: 700;
    font-size: 0.9rem;
    font-family: 'Manrope', sans-serif;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s ease;
}
.gv-sort-toggle:hover {
    background: rgba(255, 255, 255, 0.15);
}
.gv-sort-menu {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 50%;
    transform: translateX(-50%) scale(0.95);
    background: #fff;
    border-radius: 1rem;
    box-shadow: 0 20px 50px rgba(0, 52, 45, 0.15);
    min-width: 220px;
    padding: 0.5rem;
    opacity: 0;
    pointer-events: none;
    transition: all 0.25s ease;
    z-index: 100;
}
.gv-sort-dropdown:hover .gv-sort-menu,
.gv-sort-dropdown:focus-within .gv-sort-menu {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) scale(1);
}
.gv-sort-item {
    display: block;
    padding: 0.65rem 1rem;
    border-radius: 0.6rem;
    color: #1c1b1b;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    transition: all 0.2s ease;
}
.gv-sort-item:hover { background: rgba(0, 52, 45, 0.04); color: #00342d; }
.gv-sort-item.active {
    background: linear-gradient(135deg, #00342d, #046b5e);
    color: #fff;
}
.gv-sort-divider {
    height: 1px;
    background: rgba(0, 52, 45, 0.06);
    margin: 0.35rem 0.5rem;
}

/* ─── Main Content Container ─── */
.gv-forums-container {
    max-width: 1200px;
    margin: -50px auto 80px;
    position: relative;
    z-index: 10;
    padding: 0 2rem;
}

/* ─── Forum Cards Grid ─── */
.gv-forums-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.5rem;
}
@media (max-width: 768px) {
    .gv-forums-grid { grid-template-columns: 1fr; }
}

/* ─── Forum Card ─── */
.gv-forum-card {
    background: #fff;
    border-radius: 1.5rem;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
}
.gv-forum-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 3px;
    background: linear-gradient(90deg, #00342d, #046b5e, #10B981);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s ease;
}
.gv-forum-card:hover::before { transform: scaleX(1); }
.gv-forum-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 50px -10px rgba(0, 0, 0, 0.1);
}

/* Card Cover */
.gv-forum-cover {
    position: relative;
    height: 140px;
    background: linear-gradient(135deg, #00342d 0%, #046b5e 70%, #10B981 100%);
    overflow: hidden;
}
.gv-forum-cover img {
    width: 100%; height: 100%;
    object-fit: cover;
    opacity: 0.75;
}
.gv-forum-cover-icon {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font-size: 4rem;
    color: rgba(255, 255, 255, 0.08);
    font-variation-settings: 'FILL' 1;
}
.gv-forum-cover-badge {
    position: absolute;
    top: 0.75rem; right: 0.75rem;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.35rem 0.75rem;
    background: rgba(233, 193, 118, 0.2);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(233, 193, 118, 0.3);
    border-radius: 2rem;
    color: #e9c176;
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}
.gv-forum-cover-badge .material-symbols-outlined { font-size: 0.8rem; }

.gv-forum-avatar {
    position: absolute;
    bottom: -1.25rem; left: 1.25rem;
    width: 48px; height: 48px;
    border-radius: 50%;
    background: linear-gradient(135deg, #00342d 0%, #046b5e 100%);
    display: flex;
    align-items: center; justify-content: center;
    color: #fff;
    font-weight: 800;
    font-size: 1.1rem;
    font-family: 'Manrope', sans-serif;
    border: 3px solid #fff;
    box-shadow: 0 4px 12px rgba(0, 52, 45, 0.15);
    z-index: 2;
}

/* Card Body */
.gv-forum-body {
    padding: 2rem 1.5rem 1.5rem;
}

.gv-forum-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.5rem;
}

.gv-forum-name {
    font-family: 'Noto Serif', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #00342d;
    margin: 0;
}

/* Options menu using CSS */
.gv-forum-options {
    position: relative;
}
.gv-forum-options-btn {
    background: none;
    border: none;
    color: #bfc9c4;
    cursor: pointer;
    padding: 0.25rem;
    border-radius: 0.35rem;
    transition: all 0.2s ease;
    display: flex;
}
.gv-forum-options-btn:hover { color: #00342d; background: rgba(0, 52, 45, 0.04); }
.gv-forum-options-menu {
    position: absolute;
    top: calc(100% + 0.3rem);
    right: 0;
    background: #fff;
    border-radius: 0.75rem;
    box-shadow: 0 10px 30px rgba(0, 52, 45, 0.12);
    min-width: 170px;
    padding: 0.35rem;
    opacity: 0;
    pointer-events: none;
    transform: scale(0.95);
    transition: all 0.2s ease;
    z-index: 50;
}
.gv-forum-options:hover .gv-forum-options-menu,
.gv-forum-options:focus-within .gv-forum-options-menu {
    opacity: 1;
    pointer-events: auto;
    transform: scale(1);
}
.gv-option-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 0.75rem;
    border-radius: 0.5rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: #1c1b1b;
    text-decoration: none;
    border: none;
    background: none;
    width: 100%;
    cursor: pointer;
    font-family: 'Manrope', sans-serif;
    transition: background 0.2s;
}
.gv-option-item:hover { background: rgba(0, 52, 45, 0.04); }
.gv-option-item .material-symbols-outlined { font-size: 1.1rem; color: #546067; }
.gv-option-danger { color: #93000a; }
.gv-option-danger .material-symbols-outlined { color: #93000a; }
.gv-option-danger:hover { background: rgba(186, 26, 26, 0.06); }
.gv-option-divider {
    height: 1px;
    background: rgba(0, 52, 45, 0.06);
    margin: 0.25rem 0.5rem;
}

.gv-forum-desc {
    font-size: 0.85rem;
    color: #546067;
    line-height: 1.5;
    margin-bottom: 1.25rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 2.55rem;
}

/* Card Stats */
.gv-forum-stats {
    display: flex;
    justify-content: space-around;
    padding: 0.85rem;
    background: rgba(0, 52, 45, 0.02);
    border: 1px solid rgba(0, 52, 45, 0.04);
    border-radius: 1rem;
    margin-bottom: 1.25rem;
}
.gv-forum-stat { text-align: center; }
.gv-forum-stat-value {
    font-weight: 800;
    color: #00342d;
    font-size: 1rem;
}
.gv-forum-stat-label {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #546067;
    margin-top: 0.1rem;
}

/* Card Action */
.gv-forum-action {
    display: block;
    width: 100%;
    padding: 0.75rem;
    background: linear-gradient(135deg, #00342d 0%, #004d43 70%, #046b5e 100%);
    color: #fff;
    border: none;
    border-radius: 0.75rem;
    font-weight: 700;
    font-size: 0.9rem;
    text-align: center;
    text-decoration: none;
    font-family: 'Manrope', sans-serif;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 12px rgba(0, 52, 45, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
}
.gv-forum-action:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 52, 45, 0.25);
    color: #fff;
}

/* ─── Empty State ─── */
.gv-empty {
    text-align: center;
    padding: 5rem 2rem;
    background: #fff;
    border-radius: 1.5rem;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.04);
    grid-column: 1 / -1;
}
.gv-empty-icon {
    font-size: 4rem;
    color: #cde1db;
    margin-bottom: 1.5rem;
    font-variation-settings: 'FILL' 1;
}
.gv-empty h4 {
    font-family: 'Noto Serif', serif;
    font-size: 1.5rem;
    color: #00342d;
    font-weight: 700;
    margin-bottom: 0.5rem;
}
.gv-empty p {
    color: #546067;
    margin-bottom: 2rem;
}

/* ─── Reveal ─── */
.gv-reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s cubic-bezier(0.4, 0, 0.2, 1), transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
}
.gv-reveal.is-visible { opacity: 1; transform: translateY(0); }
</style>
{% endblock %}

{% block body %}
<!-- ─── HERO ─── -->
<div class="gv-forums-hero">
    <span class="material-symbols-outlined gv-hero-icon-bg">forum</span>
    <div class="container">
        <h1 class="gv-hero-title">Communautés <em>GoVibe</em></h1>
        <p class="gv-hero-sub">Connectez-vous avec des milliers de passionnés à travers nos forums thématiques.</p>

        <div class="gv-hero-actions">
            {% if is_granted('ROLE_USER') %}
                <button type="button" onclick="openForumModal('{{ path('app_forum_new') }}')" class="gv-btn-primary">
                    <span class="material-symbols-outlined" style="font-size:1.2rem;">add_circle</span>
                    Lancer mon Forum
                </button>
            {% endif %}

            <div class="gv-sort-dropdown">
                <button class="gv-sort-toggle" type="button">
                    <span class="material-symbols-outlined" style="font-size:1.1rem;">sort</span>
                    Trier par :
                    {% if current_sort == 'popular' %}Les plus populaires
                    {% elseif current_sort == 'newest' %}Nouveautés
                    {% elseif current_sort == 'private' %}Privés
                    {% elseif current_sort == 'mine' %}Mes Forums
                    {% else %}Tous{% endif %}
                    <span class="material-symbols-outlined" style="font-size:1rem;">expand_more</span>
                </button>
                <div class="gv-sort-menu">
                    {% if app.user %}
                        <a class="gv-sort-item {{ current_sort == 'mine' ? 'active' : '' }}" href="{{ path('app_forum_index', {'sort': 'mine'}) }}">
                            <span class="material-symbols-outlined" style="font-size:1rem;vertical-align:middle;margin-right:0.3rem;">person</span> Mes Forums
                        </a>
                        <div class="gv-sort-divider"></div>
                    {% endif %}
                    <a class="gv-sort-item {{ current_sort == 'popular' ? 'active' : '' }}" href="{{ path('app_forum_index', {'sort': 'popular'}) }}">
                        <span class="material-symbols-outlined" style="font-size:1rem;vertical-align:middle;margin-right:0.3rem;">trending_up</span> Les plus populaires
                    </a>
                    <a class="gv-sort-item {{ current_sort == 'newest' ? 'active' : '' }}" href="{{ path('app_forum_index', {'sort': 'newest'}) }}">
                        <span class="material-symbols-outlined" style="font-size:1rem;vertical-align:middle;margin-right:0.3rem;">schedule</span> Nouveautés
                    </a>
                    <a class="gv-sort-item {{ current_sort == 'private' ? 'active' : '' }}" href="{{ path('app_forum_index', {'sort': 'private'}) }}">
                        <span class="material-symbols-outlined" style="font-size:1rem;vertical-align:middle;margin-right:0.3rem;">lock</span> Privés
                    </a>
                </div>
            </div>
        </div>

        <div class="gv-hero-stats">
            <span class="gv-hero-stat">
                <span class="material-symbols-outlined">group</span> {{ totalMembers }} Membres
            </span>
            <span class="gv-hero-stat">
                <span class="material-symbols-outlined">forum</span> {{ forums|length }}+ Forums
            </span>
            <span class="gv-hero-stat">
                <span class="material-symbols-outlined">bolt</span> Actif en continu
            </span>
        </div>
    </div>
</div>

<!-- ─── MAIN CONTENT ─── -->
<div class="gv-forums-container">
    <div class="gv-forums-grid">
        {% for forum in forums %}
            <div class="gv-forum-card gv-reveal">
                <!-- Cover -->
                <div class="gv-forum-cover">
                    {% if forum.image %}
                        <img src="{{ forum.image }}" alt="{{ forum.name }}" loading="lazy" decoding="async" onerror="this.style.display='none';">
                    {% endif %}
                    <span class="material-symbols-outlined gv-forum-cover-icon">chat_bubble</span>

                    {% if forum.isPrivate %}
                        <span class="gv-forum-cover-badge">
                            <span class="material-symbols-outlined">lock</span> Privé
                        </span>
                    {% endif %}

                    <div class="gv-forum-avatar">{{ forum.name|first|upper }}</div>
                </div>

                <!-- Body -->
                <div class="gv-forum-body">
                    <div class="gv-forum-header">
                        <h3 class="gv-forum-name">{{ forum.name }}</h3>
                        <div class="gv-forum-options">
                            <button class="gv-forum-options-btn" type="button">
                                <span class="material-symbols-outlined">more_horiz</span>
                            </button>
                            <div class="gv-forum-options-menu">
                                {% if is_granted('ROLE_ADMIN') or (app.user and app.user == forum.createdBy) %}
                                    <button class="gv-option-item" type="button" onclick="openForumModal('{{ path('app_forum_edit', {'forumId': forum.forumId}) }}')">
                                        <span class="material-symbols-outlined">edit</span> Modifier
                                    </button>
                                    <div class="gv-option-divider"></div>
                                    <form method="post" action="{{ path('app_forum_delete', {'forumId': forum.forumId}) }}" onsubmit="return confirm('Confirmer la suppression ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ forum.forumId) }}">
                                        <button class="gv-option-item gv-option-danger" type="submit">
                                            <span class="material-symbols-outlined">delete</span> Supprimer
                                        </button>
                                    </form>
                                {% endif %}
                                <a class="gv-option-item" href="#">
                                    <span class="material-symbols-outlined">share</span> Partager
                                </a>
                            </div>
                        </div>
                    </div>

                    <p class="gv-forum-desc">
                        {{ forum.description|default('Explorez et discutez des dernières tendances avec la communauté.') }}
                    </p>

                    <div class="gv-forum-stats">
                        <div class="gv-forum-stat">
                            <div class="gv-forum-stat-value">{{ forum.nbrMembers }}</div>
                            <div class="gv-forum-stat-label">Membres</div>
                        </div>
                        <div class="gv-forum-stat">
                            <div class="gv-forum-stat-value">{{ forum.postes|length }}</div>
                            <div class="gv-forum-stat-label">Sujets</div>
                        </div>
                        <div class="gv-forum-stat">
                            <div class="gv-forum-stat-value">{{ forum.dateCreation|date('M Y') }}</div>
                            <div class="gv-forum-stat-label">Créé</div>
                        </div>
                    </div>

                    <a href="{{ path('app_forum_show', {'forumId': forum.forumId}) }}" onclick="openDetailModal(this.href); return false;" class="gv-forum-action">
                        Voir le Forum
                        <span class="material-symbols-outlined" style="font-size:1.1rem;">arrow_forward</span>
                    </a>
                </div>
            </div>
        {% else %}
            <div class="gv-empty gv-reveal">
                <span class="material-symbols-outlined gv-empty-icon">search</span>
                <h4>Aucun forum trouvé</h4>
                <p>Pourquoi ne pas en créer un ?</p>
                {% if is_granted('ROLE_USER') %}
                    <button onclick="openForumModal('{{ path('app_forum_new') }}')" class="gv-btn-primary">
                        <span class="material-symbols-outlined" style="font-size:1.2rem;">add_circle</span>
                        Commencer
                    </button>
                {% endif %}
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    var reveals = document.querySelectorAll('.gv-reveal');
    if (reveals.length) {
        var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
                if (entry.isIntersecting) {
                    entry.target.classList.add('is-visible');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });

        reveals.forEach(function(el, i) {
            el.style.transitionDelay = (i * 80) + 'ms';
            observer.observe(el);
        });
    }
});
</script>
{% endblock %}

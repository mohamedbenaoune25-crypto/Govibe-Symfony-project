{# Rendered directly into the Bootstrap modal body #}
<div class="px-2">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h4 class="fw-bold mb-1 text-dark">
                {% if forum.forumId %}
                    <i class="bi bi-pencil-square me-2 text-success"></i>Modifier le Forum
                {% else %}
                    <i class="bi bi-plus-circle-fill me-2 text-success"></i>Créer un Forum
                {% endif %}
            </h4>
            <p class="text-muted small mb-0">
                {% if forum.forumId %}
                    Forum <strong>{{ forum.name }}</strong> &bull; créé le {{ forum.dateCreation|date('d M Y') }}
                {% else %}
                    Lancez une nouvelle communauté sur GoVibe
                {% endif %}
            </p>
        </div>
        <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
    </div>

    {{ form_start(form, {'attr': {'class': 'needs-validation', 'enctype': 'multipart/form-data'}}) }}
        <div class="mb-4">
            {{ form_label(form.name, null, {'label_attr': {'class': 'form-label fw-bold small text-uppercase text-secondary ls-1'}}) }}
            {{ form_widget(form.name) }}
        </div>

        <div class="mb-4">
            {{ form_label(form.description, null, {'label_attr': {'class': 'form-label fw-bold small text-uppercase text-secondary ls-1'}}) }}
            {{ form_widget(form.description) }}
        </div>

        <div class="mb-4">
            {{ form_label(form.imageFile, null, {'label_attr': {'class': 'form-label fw-bold small text-uppercase text-secondary ls-1'}}) }}
            {{ form_widget(form.imageFile) }}
        </div>

        <div class="form-check form-switch mb-4">
            {{ form_widget(form.isPrivate) }}
            {{ form_label(form.isPrivate) }}
        </div>

        <div class="d-flex justify-content-end align-items-center gap-3 pt-3 border-top mt-4">
            <button type="button" class="btn btn-link link-danger fw-bold text-decoration-none" data-bs-dismiss="modal">Annuler</button>
            <button type="submit" class="btn btn-success rounded-pill px-4 py-2 fw-bold shadow-sm border-0" style="background-color: #52BE80;">
                {% if forum.forumId %}Enregistrer{% else %}Créer le Forum{% endif %}
            </button>
        </div>
    {{ form_end(form) }}
</div>

<style>
    .ls-1 { letter-spacing: 1px; }
</style>

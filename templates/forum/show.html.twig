{% extends is_granted('ROLE_ADMIN') ? 'admin/base_admin.html.twig' : 'base.html.twig' %}

{% block page_title %}{{ forum.name }} - Forum{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Manrope:wght@200..800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════════
   GoVibe Forum Show — Ultra Premium Design
   Matching Locations Page Aesthetic
═══════════════════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; }

body {
    font-family: 'Manrope', sans-serif !important;
    background: #fcf9f8 !important;
    color: #1c1b1b !important;
    overflow-x: hidden !important;
}

.material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24; }

/* ─── Hero Section ─── */
.gv-forum-hero {
    position: relative;
    padding: 180px 0 120px;
    background: linear-gradient(160deg, #00342d 0%, #013220 40%, #001a12 100%);
    overflow: hidden;
    text-align: center;
    border-radius: 0 0 3rem 3rem;
    box-shadow: 0 20px 50px rgba(0, 52, 45, 0.15);
}

.gv-forum-hero::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse at 25% 75%, rgba(16, 185, 129, 0.15) 0%, transparent 60%),
                radial-gradient(ellipse at 75% 25%, rgba(233, 193, 118, 0.08) 0%, transparent 50%);
    pointer-events: none;
}

.gv-forum-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(160, 242, 225, 0.06) 1px, transparent 1px);
    background-size: 24px 24px;
    pointer-events: none;
}

.gv-hero-icon-bg {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font-size: 22rem;
    color: rgba(255, 255, 255, 0.02);
    z-index: 0;
    pointer-events: none;
    font-variation-settings: 'FILL' 1;
}

.gv-hero-title {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: #fff;
    font-weight: 700;
    margin-bottom: 1rem;
    position: relative;
    z-index: 2;
    animation: gvFadeIn 0.8s ease both;
}
.gv-hero-title em { color: #a0f2e1; font-style: italic; font-weight: 300; }

.gv-hero-sub {
    color: rgba(160, 242, 225, 0.7);
    font-size: 1.15rem;
    max-width: 600px;
    margin: 0 auto 1.5rem;
    line-height: 1.6;
    position: relative;
    z-index: 2;
    animation: gvFadeIn 0.8s ease 0.2s both;
}

.gv-hero-meta {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    position: relative;
    z-index: 2;
    animation: gvFadeIn 0.8s ease 0.3s both;
    margin-bottom: 2rem;
}

.gv-hero-meta-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: rgba(160, 242, 225, 0.6);
    font-size: 0.85rem;
    font-weight: 600;
}
.gv-hero-meta-item .material-symbols-outlined {
    font-size: 1.1rem;
    color: #a0f2e1;
}

.gv-hero-actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    position: relative;
    z-index: 2;
    animation: gvFadeIn 0.8s ease 0.4s both;
}

.gv-hero-avatar {
    width: 90px; height: 90px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(160, 242, 225, 0.2) 0%, rgba(233, 193, 118, 0.15) 100%);
    display: flex;
    align-items: center; justify-content: center;
    margin: 0 auto 1.5rem;
    position: relative;
    z-index: 2;
    animation: gvFadeIn 0.8s ease 0.1s both;
    border: 3px solid rgba(160, 242, 225, 0.3);
    overflow: hidden;
}
.gv-hero-avatar img {
    width: 100%; height: 100%;
    object-fit: cover;
    border-radius: 50%;
}
.gv-hero-avatar span.gv-avatar-letter {
    font-size: 2.5rem;
    font-weight: 800;
    color: #a0f2e1;
    font-family: 'Manrope', sans-serif;
}

@keyframes gvFadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}

.gv-btn-primary {
    padding: 1rem 2rem;
    background: linear-gradient(135deg, #e9c176 0%, #ca9028 100%);
    color: #3d2a00;
    border: none;
    border-radius: 0.75rem;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s ease;
    box-shadow: 0 10px 25px -5px rgba(233, 193, 118, 0.4);
    font-family: 'Manrope', sans-serif;
    cursor: pointer;
}
.gv-btn-primary:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 15px 35px -5px rgba(233, 193, 118, 0.5);
    color: #3d2a00;
}

.gv-btn-outline {
    padding: 0.75rem 1.5rem;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(10px);
    color: #a0f2e1;
    border: 1.5px solid rgba(160, 242, 225, 0.3);
    border-radius: 0.75rem;
    font-weight: 700;
    font-size: 0.9rem;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s ease;
    font-family: 'Manrope', sans-serif;
    cursor: pointer;
}
.gv-btn-outline:hover {
    background: rgba(255, 255, 255, 0.15);
    transform: translateY(-2px);
    color: #a0f2e1;
}

.gv-btn-outline-danger {
    padding: 0.65rem 1.25rem;
    background: rgba(186, 26, 26, 0.1);
    color: #fca5a5;
    border: 1.5px solid rgba(186, 26, 26, 0.25);
    border-radius: 0.75rem;
    font-weight: 700;
    font-size: 0.85rem;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition: all 0.3s ease;
    font-family: 'Manrope', sans-serif;
    cursor: pointer;
}
.gv-btn-outline-danger:hover {
    background: rgba(186, 26, 26, 0.2);
    transform: translateY(-1px);
    color: #fca5a5;
}

.gv-btn-disabled {
    padding: 0.75rem 1.5rem;
    background: rgba(255, 255, 255, 0.06);
    color: rgba(160, 242, 225, 0.4);
    border: 1.5px solid rgba(160, 242, 225, 0.1);
    border-radius: 0.75rem;
    font-weight: 700;
    font-size: 0.9rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Manrope', sans-serif;
    cursor: not-allowed;
    opacity: 0.7;
}

.gv-badge-private {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.4rem 0.85rem;
    background: rgba(233, 193, 118, 0.15);
    border: 1px solid rgba(233, 193, 118, 0.3);
    border-radius: 2rem;
    color: #e9c176;
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    position: relative;
    z-index: 2;
}

/* ─── Main Content Container ─── */
.gv-forum-container {
    max-width: 1200px;
    margin: -50px auto 80px;
    position: relative;
    z-index: 10;
    padding: 0 2rem;
}

/* ─── Pending Requests Bar ─── */
.gv-pending-bar {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px) saturate(180%);
    border: 1px solid rgba(233, 193, 118, 0.15);
    border-left: 4px solid #e9c176;
    border-radius: 1.5rem;
    padding: 1.25rem 1.5rem;
    box-shadow: 0 20px 50px rgba(0, 52, 45, 0.08);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    animation: gvFadeIn 0.6s ease both;
}

.gv-pending-info {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.gv-pending-icon {
    width: 3rem; height: 3rem;
    border-radius: 1rem;
    background: rgba(233, 193, 118, 0.1);
    display: flex;
    align-items: center; justify-content: center;
    flex-shrink: 0;
}
.gv-pending-icon .material-symbols-outlined {
    font-size: 1.5rem;
    color: #ca9028;
}

.gv-pending-info h4 {
    font-family: 'Noto Serif', serif;
    font-size: 1rem;
    font-weight: 700;
    color: #00342d;
    margin: 0;
}
.gv-pending-info p {
    font-size: 0.8rem;
    color: #546067;
    margin: 0.15rem 0 0;
}

.gv-pending-users {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
}

.gv-pending-chip {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 0.75rem;
    background: rgba(0, 52, 45, 0.03);
    border: 1px solid rgba(0, 52, 45, 0.06);
    border-radius: 2rem;
}
.gv-pending-chip-name {
    font-size: 0.8rem;
    font-weight: 700;
    color: #00342d;
}
.gv-pending-chip-actions {
    display: flex;
    gap: 0.3rem;
    padding-left: 0.5rem;
    border-left: 1px solid rgba(0, 52, 45, 0.08);
}
.gv-pending-chip-actions form { margin: 0; }
.gv-chip-btn {
    width: 24px; height: 24px;
    border-radius: 50%;
    display: flex;
    align-items: center; justify-content: center;
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
}
.gv-chip-btn-accept {
    background: rgba(16, 185, 129, 0.15);
    color: #059669;
}
.gv-chip-btn-accept:hover { background: #10B981; color: #fff; }
.gv-chip-btn-reject {
    background: rgba(186, 26, 26, 0.08);
    color: #93000a;
}
.gv-chip-btn-reject:hover { background: #ba1a1a; color: #fff; }
.gv-chip-btn .material-symbols-outlined { font-size: 0.85rem; }

.gv-pending-more {
    font-size: 0.8rem;
    font-weight: 700;
    color: #ca9028;
    display: flex;
    align-items: center;
}

/* ─── Layout ─── */
.gv-forum-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 2rem;
    align-items: start;
}
@media (max-width: 992px) {
    .gv-forum-layout { grid-template-columns: 1fr; }
}

/* ─── Toolbar ─── */
.gv-toolbar {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px) saturate(180%);
    border: 1px solid rgba(0, 52, 45, 0.06);
    border-radius: 1.5rem;
    padding: 1.25rem 1.5rem;
    box-shadow: 0 20px 50px rgba(0, 52, 45, 0.08);
    margin-bottom: 1.5rem;
}

.gv-toolbar-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(0, 52, 45, 0.06);
}

.gv-toolbar-title {
    font-family: 'Noto Serif', serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: #00342d;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}
.gv-toolbar-title .material-symbols-outlined {
    color: #10B981;
    font-size: 1.3rem;
}

.gv-toolbar-exports {
    display: flex;
    gap: 0.5rem;
}

.gv-export-btn {
    padding: 0.5rem 1rem;
    border-radius: 0.6rem;
    font-size: 0.8rem;
    font-weight: 700;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    transition: all 0.25s ease;
    border: none;
    cursor: pointer;
    font-family: 'Manrope', sans-serif;
}
.gv-export-btn:hover { transform: translateY(-2px); }

.gv-export-pdf {
    background: rgba(186, 26, 26, 0.08);
    color: #93000a;
}
.gv-export-pdf:hover { background: rgba(186, 26, 26, 0.15); color: #93000a; }

.gv-export-excel {
    background: rgba(16, 185, 129, 0.1);
    color: #005046;
}
.gv-export-excel:hover { background: rgba(16, 185, 129, 0.2); color: #005046; }

.gv-toolbar-bottom {
    display: flex;
    gap: 0.75rem;
    align-items: center;
}
@media (max-width: 576px) {
    .gv-toolbar-bottom { flex-direction: column; }
}

.gv-search-form {
    flex: 1;
    position: relative;
}
.gv-search-form .material-symbols-outlined {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.2rem;
    color: #bfc9c4;
    pointer-events: none;
}
.gv-search-input {
    border: 1.5px solid rgba(0, 52, 45, 0.08);
    border-radius: 0.75rem;
    padding: 0.75rem 1rem 0.75rem 3rem;
    font-size: 0.9rem;
    font-family: 'Manrope', sans-serif;
    font-weight: 500;
    color: #1c1b1b;
    background: #fff;
    transition: all 0.25s ease;
    width: 100%;
    outline: none;
}
.gv-search-input:focus {
    border-color: #10B981;
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.12);
}

.gv-sort-group {
    display: flex;
    border: 1.5px solid rgba(0, 52, 45, 0.08);
    border-radius: 0.75rem;
    overflow: hidden;
    background: rgba(0, 52, 45, 0.02);
}
.gv-sort-btn {
    padding: 0.6rem 1.1rem;
    font-size: 0.8rem;
    font-weight: 700;
    color: #546067;
    text-decoration: none;
    transition: all 0.25s ease;
    font-family: 'Manrope', sans-serif;
    border: none;
    background: transparent;
    cursor: pointer;
}
.gv-sort-btn:hover { color: #00342d; background: rgba(0, 52, 45, 0.04); }
.gv-sort-btn.active {
    background: linear-gradient(135deg, #00342d, #046b5e);
    color: #fff;
}

/* ─── Post Feed ─── */
.gv-feed { display: grid; gap: 1rem; }

/* ─── Empty State ─── */
.gv-empty {
    text-align: center;
    padding: 5rem 2rem;
    background: #fff;
    border-radius: 1.5rem;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.04);
}
.gv-empty-icon {
    font-size: 4rem;
    color: #cde1db;
    margin-bottom: 1.5rem;
    font-variation-settings: 'FILL' 1;
}
.gv-empty h4 {
    font-family: 'Noto Serif', serif;
    font-size: 1.5rem;
    color: #00342d;
    font-weight: 700;
    margin-bottom: 0.5rem;
}
.gv-empty p {
    color: #546067;
    margin-bottom: 2rem;
}

/* ─── Locked Content ─── */
.gv-locked {
    text-align: center;
    padding: 4rem 2rem;
    background: #fff;
    border-radius: 1.5rem;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.04);
    position: relative;
    overflow: hidden;
}
.gv-locked::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 3px;
    background: linear-gradient(90deg, #00342d, #046b5e, #10B981);
}
.gv-locked-icon {
    width: 5rem; height: 5rem;
    border-radius: 50%;
    background: rgba(0, 52, 45, 0.04);
    display: flex;
    align-items: center; justify-content: center;
    margin: 0 auto 1.5rem;
}
.gv-locked-icon .material-symbols-outlined {
    font-size: 2.5rem;
    color: #cde1db;
}
.gv-locked h4 {
    font-family: 'Noto Serif', serif;
    font-size: 1.35rem;
    color: #00342d;
    font-weight: 700;
    margin-bottom: 0.75rem;
}
.gv-locked p { color: #546067; margin-bottom: 1.5rem; }

.gv-locked-pending {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.25rem;
    background: rgba(233, 193, 118, 0.1);
    border: 1px solid rgba(233, 193, 118, 0.25);
    border-radius: 2rem;
    color: #92400e;
    font-size: 0.85rem;
    font-weight: 700;
    margin-bottom: 1rem;
}

.gv-btn-join {
    padding: 1rem 2.5rem;
    background: linear-gradient(135deg, #00342d 0%, #004d43 70%, #046b5e 100%);
    color: #fff;
    border: none;
    border-radius: 0.75rem;
    font-weight: 700;
    font-size: 1rem;
    font-family: 'Manrope', sans-serif;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s ease;
    box-shadow: 0 10px 25px -5px rgba(0, 52, 45, 0.4);
}
.gv-btn-join:hover {
    transform: translateY(-2px);
    box-shadow: 0 15px 35px -5px rgba(0, 52, 45, 0.5);
}

/* ─── Sidebar ─── */
.gv-sidebar {
    position: sticky;
    top: 100px;
}
@media (max-width: 992px) {
    .gv-sidebar { position: static; }
}

.gv-sidebar-card {
    background: #fff;
    border-radius: 1.5rem;
    padding: 2rem;
    box-shadow: 0 8px 40px -10px rgba(0, 52, 45, 0.08);
    position: relative;
    overflow: hidden;
}
.gv-sidebar-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 3px;
    background: linear-gradient(90deg, #00342d, #046b5e, #10B981);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s ease;
}
.gv-sidebar-card:hover::before { transform: scaleX(1); }

.gv-sidebar-title {
    font-family: 'Noto Serif', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #00342d;
    margin-bottom: 0.35rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid #10B981;
    display: inline-block;
}

.gv-sidebar-desc {
    color: #546067;
    font-size: 0.85rem;
    margin-bottom: 1.5rem;
    line-height: 1.6;
}

.gv-rules-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
}

.gv-rule {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.75rem;
    border-radius: 0.75rem;
    transition: background 0.2s ease;
}
.gv-rule:hover { background: rgba(0, 52, 45, 0.03); }

.gv-rule-icon {
    width: 2rem; height: 2rem;
    border-radius: 0.5rem;
    background: rgba(16, 185, 129, 0.1);
    display: flex;
    align-items: center; justify-content: center;
    flex-shrink: 0;
}
.gv-rule-icon .material-symbols-outlined {
    font-size: 1rem;
    color: #10B981;
}

.gv-rule span:last-child {
    font-size: 0.85rem;
    font-weight: 600;
    color: #1c1b1b;
}

/* ─── Stats ─── */
.gv-sidebar-stats {
    display: flex;
    justify-content: space-around;
    padding: 1.25rem;
    background: rgba(0, 52, 45, 0.02);
    border: 1px solid rgba(0, 52, 45, 0.04);
    border-radius: 1rem;
}
.gv-stat-item { text-align: center; }
.gv-stat-value {
    font-size: 1.5rem;
    font-weight: 800;
    color: #00342d;
}
.gv-stat-label {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #546067;
    margin-top: 0.2rem;
}

.gv-stat-divider {
    width: 1px;
    background: rgba(0, 52, 45, 0.08);
}

/* ─── Reveal ─── */
.gv-reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s cubic-bezier(0.4, 0, 0.2, 1), transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
}
.gv-reveal.is-visible { opacity: 1; transform: translateY(0); }
</style>
{% endblock %}

{% block body %}
<!-- ─── HERO ─── -->
<div class="gv-forum-hero">
    <span class="material-symbols-outlined gv-hero-icon-bg">forum</span>
    <div class="container">
        <!-- Avatar -->
        <div class="gv-hero-avatar">
            {% if forum.image %}
                <img src="{{ forum.image }}" alt="{{ forum.name }}" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                <span class="gv-avatar-letter" style="display:none;">{{ forum.name|first|upper }}</span>
            {% else %}
                <span class="gv-avatar-letter">{{ forum.name|first|upper }}</span>
            {% endif %}
        </div>

        <!-- Breadcrumb -->
        <div style="position:relative;z-index:2;margin-bottom:0.75rem;">
            <a href="{{ path('app_forum_index') }}" style="color:rgba(160,242,225,0.5);text-decoration:none;font-size:0.85rem;font-weight:600;">
                <span class="material-symbols-outlined" style="font-size:1rem;vertical-align:middle;">arrow_back</span>
                Forums
            </a>
        </div>

        <div style="display:flex;align-items:center;justify-content:center;gap:0.75rem;flex-wrap:wrap;">
            <h1 class="gv-hero-title" style="margin-bottom:0;">{{ forum.name }}</h1>
            {% if forum.isPrivate %}
                <span class="gv-badge-private">
                    <span class="material-symbols-outlined" style="font-size:0.85rem;">lock</span> Privé
                </span>
            {% endif %}
        </div>

        <p class="gv-hero-sub">
            {{ forum.description|default('Bienvenue dans la communauté ' ~ forum.name ~ '. Participez aux discussions, partagez vos idées et connectez-vous avec d\'autres membres.') }}
        </p>

        <div class="gv-hero-meta">
            <span class="gv-hero-meta-item">
                <span class="material-symbols-outlined">group</span> {{ forum.nbrMembers }} Membres
            </span>
            <span class="gv-hero-meta-item">
                <span class="material-symbols-outlined">chat_bubble</span> {{ postes|length }} Sujets
            </span>
            <span class="gv-hero-meta-item">
                <span class="material-symbols-outlined">calendar_month</span> Créé le {{ forum.dateCreation|date('d M Y') }}
            </span>
            <span class="gv-hero-meta-item">
                <span class="material-symbols-outlined">person</span> Par {{ forum.createdBy ? forum.createdBy.prenom : 'Admin' }}
            </span>
        </div>

        <div class="gv-hero-actions">
            {% if is_granted('ROLE_USER') %}
                {% if memberStatus == 'ACCEPTED' %}
                    <button type="button" onclick="openPostModal('{{ path('app_poste_new', {'forumId': forum.forumId}) }}')" class="gv-btn-primary">
                        <span class="material-symbols-outlined" style="font-size:1.2rem;">add_circle</span>
                        Nouveau Sujet
                    </button>

                    {% if app.user != forum.createdBy %}
                        <form action="{{ path('app_forum_leave', {'forumId': forum.forumId}) }}" method="POST" style="display:inline;" onsubmit="return confirm('Voulez-vous vraiment quitter ce forum ?');">
                            <button type="submit" class="gv-btn-outline-danger">
                                <span class="material-symbols-outlined" style="font-size:1rem;">logout</span> Quitter
                            </button>
                        </form>
                    {% endif %}
                {% elseif memberStatus == 'PENDING' %}
                    <span class="gv-btn-disabled">
                        <span class="material-symbols-outlined" style="font-size:1.1rem;">pending</span>
                        Demande en attente
                    </span>
                    <form action="{{ path('app_forum_leave', {'forumId': forum.forumId}) }}" method="POST" style="display:inline;">
                        <button type="submit" class="gv-btn-outline-danger">
                            <span class="material-symbols-outlined" style="font-size:1rem;">close</span> Annuler
                        </button>
                    </form>
                {% else %}
                    <form action="{{ path('app_forum_join', {'forumId': forum.forumId}) }}" method="POST" style="display:inline;">
                        <button type="submit" class="gv-btn-primary">
                            <span class="material-symbols-outlined" style="font-size:1.2rem;">person_add</span>
                            Rejoindre le Forum
                        </button>
                    </form>
                {% endif %}

                {% if is_granted('ROLE_ADMIN') or (app.user and app.user == forum.createdBy) %}
                    <button onclick="openForumModal('{{ path('app_forum_edit', {'forumId': forum.forumId}) }}')" class="gv-btn-outline">
                        <span class="material-symbols-outlined" style="font-size:1rem;">settings</span> Gérer
                    </button>
                {% endif %}
            {% endif %}
        </div>
    </div>
</div>

<!-- ─── MAIN CONTENT ─── -->
<div class="gv-forum-container">

    <!-- Pending Requests Bar (Owner Only) -->
    {% if pendingRequests|length > 0 %}
        <div class="gv-pending-bar gv-reveal">
            <div class="gv-pending-info">
                <div class="gv-pending-icon">
                    <span class="material-symbols-outlined">person_alert</span>
                </div>
                <div>
                    <h4>Demandes d'adhésion</h4>
                    <p>{{ pendingRequests|length }} personne(s) souhaitent rejoindre la communauté.</p>
                </div>
            </div>
            <div class="gv-pending-users">
                {% for request in pendingRequests|slice(0, 3) %}
                    <div class="gv-pending-chip">
                        <span class="gv-pending-chip-name">{{ request.user.prenom }} {{ request.user.nom }}</span>
                        <div class="gv-pending-chip-actions">
                            <form action="{{ path('app_forum_member_accept', {'forumId': forum.forumId, 'userId': request.user.id}) }}" method="POST">
                                <button type="submit" class="gv-chip-btn gv-chip-btn-accept" title="Accepter">
                                    <span class="material-symbols-outlined">check</span>
                                </button>
                            </form>
                            <form action="{{ path('app_forum_member_reject', {'forumId': forum.forumId, 'userId': request.user.id}) }}" method="POST">
                                <button type="submit" class="gv-chip-btn gv-chip-btn-reject" title="Refuser">
                                    <span class="material-symbols-outlined">close</span>
                                </button>
                            </form>
                        </div>
                    </div>
                {% endfor %}
                {% if pendingRequests|length > 3 %}
                    <span class="gv-pending-more">+ {{ pendingRequests|length - 3 }} autres</span>
                {% endif %}
            </div>
        </div>
    {% endif %}

    <!-- Layout -->
    <div class="gv-forum-layout">
        <!-- Main Column -->
        <div>
            <!-- Toolbar -->
            <div class="gv-toolbar gv-reveal">
                <div class="gv-toolbar-top">
                    <span class="gv-toolbar-title">
                        <span class="material-symbols-outlined">chat_bubble</span>
                        Discussions
                    </span>
                    <div class="gv-toolbar-exports">
                        <a href="{{ path('app_forum_export_pdf', {'forumId': forum.forumId}) }}" class="gv-export-btn gv-export-pdf" title="Exporter en PDF">
                            <span class="material-symbols-outlined" style="font-size:1rem;">picture_as_pdf</span>
                            <span>PDF</span>
                        </a>
                        <a href="{{ path('app_forum_export_excel', {'forumId': forum.forumId}) }}" class="gv-export-btn gv-export-excel" title="Exporter en Excel">
                            <span class="material-symbols-outlined" style="font-size:1rem;">table_chart</span>
                            <span>Excel</span>
                        </a>
                    </div>
                </div>
                <div class="gv-toolbar-bottom">
                    <form action="{{ path('app_forum_show', {'forumId': forum.forumId}) }}" method="GET" class="gv-search-form">
                        <input type="hidden" name="sort" value="{{ current_sort }}">
                        <span class="material-symbols-outlined">search</span>
                        <input type="text" name="q" value="{{ current_query }}" placeholder="Rechercher dans ce forum…" class="gv-search-input">
                    </form>
                    <div class="gv-sort-group">
                        <a href="{{ path('app_forum_show', {'forumId': forum.forumId, 'q': current_query, 'sort': 'newest'}) }}" class="gv-sort-btn {{ current_sort == 'newest' ? 'active' : '' }}">Nouveaux</a>
                        <a href="{{ path('app_forum_show', {'forumId': forum.forumId, 'q': current_query, 'sort': 'popular'}) }}" class="gv-sort-btn {{ current_sort == 'popular' ? 'active' : '' }}">Populaires</a>
                    </div>
                </div>
            </div>

            <!-- Feed -->
            <div class="gv-feed">
                {% if canViewContent %}
                    {% for poste in postes %}
                        <div class="gv-reveal">
                            {% include 'poste/postitem.html.twig' with {'poste': poste} %}
                        </div>
                    {% else %}
                        <div class="gv-empty gv-reveal">
                            <span class="material-symbols-outlined gv-empty-icon">chat_bubble</span>
                            <h4>{% if current_query %}Aucun résultat pour "{{ current_query }}"{% else %}Aucun sujet pour le moment{% endif %}</h4>
                            <p>{% if current_query %}Essayez d'autres mots-clés ou le fil général.{% else %}Faites le premier pas et commencez une discussion !{% endif %}</p>
                            {% if memberStatus == 'ACCEPTED' and not current_query %}
                                <button onclick="openPostModal('{{ path('app_poste_new', {'forumId': forum.forumId}) }}')" class="gv-btn-primary" style="background: linear-gradient(135deg, #00342d 0%, #004d43 70%, #046b5e 100%); color: #fff; box-shadow: 0 10px 25px -5px rgba(0, 52, 45, 0.4);">
                                    <span class="material-symbols-outlined" style="font-size:1.2rem;">add_circle</span>
                                    Commencer un sujet
                                </button>
                            {% endif %}
                        </div>
                    {% endfor %}
                {% else %}
                    <div class="gv-locked gv-reveal">
                        <div class="gv-locked-icon">
                            <span class="material-symbols-outlined">lock</span>
                        </div>
                        <h4>Contenu Protégé</h4>

                        {% if memberStatus == 'PENDING' %}
                            <div class="gv-locked-pending">
                                <span class="material-symbols-outlined" style="font-size:1rem;">pending</span>
                                Votre demande est en cours de validation par le créateur.
                            </div>
                            <p>Revenez plus tard pour découvrir la communauté.</p>
                        {% else %}
                            <p style="max-width:400px;margin:0 auto 1.5rem;">
                                Ce forum est privé. Rejoignez la communauté pour accéder aux publications et participer aux échanges.
                            </p>
                            <form action="{{ path('app_forum_join', {'forumId': forum.forumId}) }}" method="POST">
                                <button type="submit" class="gv-btn-join">
                                    <span class="material-symbols-outlined" style="font-size:1.2rem;">lock_open</span>
                                    Envoyer une demande
                                </button>
                            </form>
                        {% endif %}
                    </div>
                {% endif %}
            </div>
        </div>

        <!-- Sidebar -->
        <aside class="gv-sidebar">
            <div class="gv-sidebar-card gv-reveal">
                <h3 class="gv-sidebar-title">À propos du forum</h3>
                <p class="gv-sidebar-desc">
                    Bienvenue dans cet espace d'échange. Pour maintenir une ambiance saine, veuillez suivre ces quelques règles élémentaires :
                </p>

                <div class="gv-rules-list">
                    <div class="gv-rule">
                        <div class="gv-rule-icon"><span class="material-symbols-outlined">check</span></div>
                        <span>Respect mutuel entre les membres.</span>
                    </div>
                    <div class="gv-rule">
                        <div class="gv-rule-icon"><span class="material-symbols-outlined">check</span></div>
                        <span>Pas de messages hors-sujet ou spam.</span>
                    </div>
                    <div class="gv-rule">
                        <div class="gv-rule-icon"><span class="material-symbols-outlined">check</span></div>
                        <span>Contenu sûr pour tout le monde.</span>
                    </div>
                </div>

                <div class="gv-sidebar-stats">
                    <div class="gv-stat-item">
                        <div class="gv-stat-value">{{ dynamicPostCount|default(postes|length) }}</div>
                        <div class="gv-stat-label">Posts</div>
                    </div>
                    <div class="gv-stat-divider"></div>
                    <div class="gv-stat-item">
                        <div class="gv-stat-value">{{ forum.nbrMembers }}</div>
                        <div class="gv-stat-label">Membres</div>
                    </div>
                </div>
            </div>
        </aside>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    // Expose the current forum context so the global fillPostForm (base.html.twig)
    // can open the publication modal linked to THIS forum.
    window.GV_CURRENT_FORUM_ID = {{ forum.forumId }};

    // Reveal animation on scroll
    document.addEventListener('DOMContentLoaded', function() {
        var reveals = document.querySelectorAll('.gv-reveal');
        if (reveals.length) {
            var observer = new IntersectionObserver(function(entries) {
                entries.forEach(function(entry) {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('is-visible');
                        observer.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });

            reveals.forEach(function(el, i) {
                el.style.transitionDelay = (i * 80) + 'ms';
                observer.observe(el);
            });
        }
    });
</script>
{% endblock %}

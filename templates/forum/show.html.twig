{% extends is_granted('ROLE_ADMIN') ? 'admin/base_admin.html.twig' : 'base.html.twig' %}

{% block page_title %}{{ forum.name }} - Forum{% endblock %}

{% block body %}
<!-- Forum Hero Header -->
<div class="container-fluid bg-white {% if is_granted('ROLE_ADMIN') %}py-4 mb-4{% else %}py-5 mb-5{% endif %} shadow-sm border-bottom rounded-bottom-5 px-lg-5 position-relative overflow-hidden">
    <!-- Decorative background elements -->
    <div class="position-absolute top-0 end-0 p-5 mt-5 opacity-10 d-none d-lg-block">
        <i class="bi bi-chat-dots-fill" style="font-size: 15rem; color: #52BE80;"></i>
    </div>

    <div class="container position-relative">
        <div class="row align-items-center">
            <div class="col-lg-2 text-center text-lg-start mb-4 mb-lg-0">
                <div class="forum-avatar shadow-lg rounded-circle mx-auto mx-lg-0 d-flex align-items-center justify-content-center text-white fw-bold" 
                     style="width: 120px; height: 120px; background: linear-gradient(135deg, #1E8449 0%, #52BE80 100%); font-size: 3rem;">
                    {% if forum.image %}
                        <img src="{{ forum.image }}" class="w-100 h-100 rounded-circle object-fit-cover" loading="lazy" decoding="async" onerror="this.style.display='none';">
                        <span class="fallback-letter">{{ forum.name|first|upper }}</span>
                    {% else %}
                        {{ forum.name|first|upper }}
                    {% endif %}
                </div>
            </div>
            <div class="col-lg-7 text-center text-lg-start">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-2 justify-content-center justify-content-lg-start">
                        <li class="breadcrumb-item"><a href="{{ path('app_forum_index') }}" class="text-decoration-none text-success fw-bold">Forums</a></li>
                        <li class="breadcrumb-item active" aria-current="page">{{ forum.name }}</li>
                    </ol>
                </nav>
                <div class="d-flex align-items-center justify-content-center justify-content-lg-start gap-3 mb-2">
                    <h1 class="display-5 fw-bold text-dark mb-0">{{ forum.name }}</h1>
                    {% if forum.isPrivate %}
                        <span class="badge bg-danger rounded-pill px-3 py-2 small shadow-sm"><i class="bi bi-lock-fill me-1"></i>Privé</span>
                    {% endif %}
                </div>
                <p class="text-secondary fs-5 opacity-75 mb-4 max-w-700">
                    {{ forum.description|default('Bienvenue dans la communauté ' ~ forum.name ~ '. Participez aux discussions, partagez vos idées et connectez-vous avec d\'autres membres.') }}
                </p>
                
                <div class="d-flex flex-wrap justify-content-center justify-content-lg-start gap-4 text-muted small fw-bold text-uppercase ls-1 mt-4">
                    <span><i class="bi bi-people-fill me-2 text-success"></i>{{ forum.nbrMembers }} Membres</span>
                    <span><i class="bi bi-chat-left-fill me-2 text-success"></i>{{ postes|length }} Sujets</span>
                    <span><i class="bi bi-calendar-event me-2 text-success"></i>Créé le {{ forum.dateCreation|date('d M Y') }}</span>
                    <span><i class="bi bi-person-circle me-2 text-success"></i>Par {{ forum.createdBy ? forum.createdBy.prenom : 'Admin' }}</span>
                </div>
            </div>
            <div class="col-lg-3 text-center text-lg-end mt-4 mt-lg-0">
                {% if is_granted('ROLE_USER') %}
                    {% if memberStatus == 'ACCEPTED' %}
                        <button type="button" onclick="openPostModal('{{ path('app_poste_new', {'forumId': forum.forumId}) }}')"
                                class="btn btn-success rounded-pill px-4 py-3 fw-bold shadow-lg transition-all hover-lift-2 border-0" 
                                style="background-color: #52BE80; font-size: 1rem;">
                            <i class="bi bi-plus-circle-fill me-2"></i>Nouveau Sujet
                        </button>
                        
                        {% if app.user != forum.createdBy %}
                            <div class="mt-3">
                                <form action="{{ path('app_forum_leave', {'forumId': forum.forumId}) }}" method="POST" class="d-inline" onsubmit="return confirm('Voulez-vous vraiment quitter ce forum ?');">
                                    <button type="submit" class="btn btn-outline-danger rounded-pill px-4 py-2 btn-sm fw-bold border-2 shadow-none hover-shadow transition-all">
                                        <i class="bi bi-box-arrow-right me-1"></i> Quitter le Forum
                                    </button>
                                </form>
                            </div>
                        {% endif %}
                    {% elseif memberStatus == 'PENDING' %}
                        <button class="btn btn-secondary rounded-pill px-4 py-3 fw-bold shadow-sm border-0 d-flex align-items-center justify-content-center gap-2 mx-auto ms-lg-auto" disabled style="opacity: 0.8;">
                            <div class="spinner-grow spinner-grow-sm" role="status"></div>
                            <span>Demande en attente</span>
                        </button>
                        <form action="{{ path('app_forum_leave', {'forumId': forum.forumId}) }}" method="POST" class="mt-2 text-center text-lg-end">
                            <button type="submit" class="btn btn-link link-danger p-0 small fw-bold text-decoration-none opacity-75 hover-opacity-100">
                                <i class="bi bi-x-circle me-1"></i> Annuler la demande
                            </button>
                        </form>
                    {% else %}
                        <form action="{{ path('app_forum_join', {'forumId': forum.forumId}) }}" method="POST">
                            <button type="submit" class="btn btn-success rounded-pill px-5 py-3 fw-bold shadow-lg transition-all hover-lift-2 border-0" 
                                    style="background-color: #52BE80; font-size: 1.1rem;">
                                <i class="bi bi-person-plus-fill me-2"></i> Rejoindre le Forum
                            </button>
                        </form>
                    {% endif %}
                    
                    {% if is_granted('ROLE_ADMIN') or (app.user and app.user == forum.createdBy) %}
                        <div class="mt-3">
                            <button onclick="openForumModal('{{ path('app_forum_edit', {'forumId': forum.forumId}) }}')" 
                                    class="btn rounded-pill px-3 py-2 btn-sm fw-bold border shadow-sm transition-all hover-bg-light">
                                <i class="bi bi-gear-fill me-1 opacity-75"></i> Gérer le Forum
                            </button>
                        </div>
                    {% endif %}
                {% endif %}
            </div>
        </div>
    </div>
</div>

<!-- Pending Requests Bar (Owner Only) -->
{% if pendingRequests|length > 0 %}
    <div class="container mb-4 animate-fade-in">
        <div class="bg-white rounded-5 border-start border-4 border-warning shadow-sm p-4 d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
            <div class="d-flex align-items-center gap-3">
                <div class="rounded-circle bg-warning bg-opacity-10 text-warning d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                    <i class="bi bi-person-exclamation fs-4"></i>
                </div>
                <div>
                    <h5 class="fw-bold text-dark mb-0">Demandes d'adhésion</h5>
                    <p class="text-muted small mb-0">{{ pendingRequests|length }} personne(s) souhaitent rejoindre la communauté.</p>
                </div>
            </div>
            
            <div class="d-flex flex-wrap gap-2">
                {% for request in pendingRequests|slice(0, 3) %}
                    <div class="bg-light rounded-pill px-3 py-2 d-flex align-items-center gap-3 border shadow-sm">
                        <div class="small fw-bold">{{ request.user.prenom }} {{ request.user.nom }}</div>
                        <div class="d-flex gap-1 border-start ps-2">
                            <form action="{{ path('app_forum_member_accept', {'forumId': forum.forumId, 'userId': request.user.id}) }}" method="POST">
                                <button type="submit" class="btn btn-success btn-xs rounded-circle p-0 d-flex align-items-center justify-content-center shadow-sm" style="width: 24px; height: 24px;"><i class="bi bi-check-lg" style="font-size: 12px;"></i></button>
                            </form>
                            <form action="{{ path('app_forum_member_reject', {'forumId': forum.forumId, 'userId': request.user.id}) }}" method="POST">
                                <button type="submit" class="btn btn-outline-danger btn-xs rounded-circle p-0 d-flex align-items-center justify-content-center shadow-sm" style="width: 24px; height: 24px; background: white;"><i class="bi bi-x-lg" style="font-size: 10px;"></i></button>
                            </form>
                        </div>
                    </div>
                {% endfor %}
                {% if pendingRequests|length > 3 %}
                    <div class="btn btn-link text-warning small fw-bold text-decoration-none pe-0">+ {{ pendingRequests|length - 3 }} autres</div>
                {% endif %}
            </div>
        </div>
    </div>
{% endif %}

<div class="container mb-5">
    <div class="row">
        <!-- Main Content Area -->
        <div class="col-lg-8 mx-auto">
            <!-- Professional Toolbar: Search, Sort & Export -->
            <div class="bg-white rounded-5 border p-3 shadow-sm mb-4 animate-fade-in d-flex flex-column gap-3">
                <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
                    <h4 class="fw-bold text-dark mb-0 d-flex align-items-center gap-2">
                        <i class="bi bi-chat-left-dots text-success"></i>
                        Discussions
                    </h4>
                    
                    <div class="d-flex align-items-center gap-2">
                        <!-- Export PDF -->
                        <a href="{{ path('app_forum_export_pdf', {'forumId': forum.forumId}) }}" class="btn btn-light-danger border-0 rounded-pill px-3 py-2 small fw-bold d-flex align-items-center gap-2 transition-all hover-lift" title="Exporter en PDF">
                            <i class="bi bi-file-earmark-pdf-fill"></i>
                            <span class="d-none d-md-inline">PDF</span>
                        </a>
                        <!-- Export Excel -->
                        <a href="{{ path('app_forum_export_excel', {'forumId': forum.forumId}) }}" class="btn btn-light-success border-0 rounded-pill px-3 py-2 small fw-bold d-flex align-items-center gap-2 transition-all hover-lift" title="Exporter en Excel">
                            <i class="bi bi-file-earmark-excel-fill"></i>
                            <span class="d-none d-md-inline">Excel</span>
                        </a>
                    </div>
                </div>

                <div class="d-flex flex-column flex-md-row gap-2 border-top pt-3">
                    <!-- Search -->
                    <form action="{{ path('app_forum_show', {'forumId': forum.forumId}) }}" method="GET" class="flex-grow-1 position-relative">
                        <input type="hidden" name="sort" value="{{ current_sort }}">
                        <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                        <input type="text" name="q" value="{{ current_query }}" placeholder="Rechercher dans ce forum..." 
                               class="form-control rounded-pill border-0 bg-light ps-5 py-2 small shadow-none" style="font-size: 0.9rem;">
                    </form>

                    <!-- Sorting -->
                    <div class="btn-group rounded-pill overflow-hidden border bg-light p-1" style="height: fit-content;">
                        <a href="{{ path('app_forum_show', {'forumId': forum.forumId, 'q': current_query, 'sort': 'newest'}) }}" 
                           class="btn btn-sm btn-action rounded-pill px-3 border-0 transition-all {{ current_sort == 'newest' ? 'bg-success text-white shadow-sm fw-bold' : 'text-muted' }}">
                           Nouveaux
                        </a>
                        <a href="{{ path('app_forum_show', {'forumId': forum.forumId, 'q': current_query, 'sort': 'popular'}) }}" 
                           class="btn btn-sm btn-action rounded-pill px-3 border-0 transition-all {{ current_sort == 'popular' ? 'bg-success text-white shadow-sm fw-bold' : 'text-muted' }}">
                           Populaires
                        </a>
                    </div>
                </div>
            </div>

            <!-- Feed of Posts -->
            <div class="forum-feed">
                {% if canViewContent %}
                    {% for poste in postes %}
                        {% include 'poste/postitem.html.twig' with {'poste': poste} %}
                    {% else %}
                        <div class="text-center py-5 rounded-5 border bg-white shadow-sm px-4 animate-fade-in">
                            <div class="display-4 text-muted opacity-25 mb-4">
                                <i class="bi bi-chat-dots"></i>
                            </div>
                            <h4 class="text-secondary fw-bold">{% if current_query %}Aucun résultat pour "{{ current_query }}"{% else %}Aucun sujet pour le moment{% endif %}</h4>
                            <p class="text-muted mb-4">{% if current_query %}Essayez d'autres mots-clés ou le fil général.{% else %}Faites le premier pas et commencez une discussion !{% endif %}</p>
                            {% if memberStatus == 'ACCEPTED' and not current_query %}
                                <button onclick="openPostModal('{{ path('app_poste_new', {'forumId': forum.forumId}) }}')" 
                                        class="btn btn-success rounded-pill px-5 py-2 fw-bold border-0 shadow-sm" 
                                        style="background-color: #52BE80;">
                                    Commencer un sujet
                                </button>
                            {% endif %}
                        </div>
                    {% endfor %}
                {% else %}
                    <div class="text-center py-5 rounded-5 border bg-white shadow-sm px-4 animate-fade-in" style="background: linear-gradient(to bottom, #ffffff, #f8fafc);">
                        <div class="rounded-circle bg-light d-flex align-items-center justify-content-center mx-auto mb-4 shadow-sm" style="width: 80px; height: 80px;">
                            <i class="bi bi-lock-fill text-muted fs-1 opacity-25"></i>
                        </div>
                        <h4 class="text-dark fw-bold mb-3">Contenu Protégé</h4>
                        
                        {% if memberStatus == 'PENDING' %}
                            <div class="alert alert-warning rounded-pill px-4 py-2 d-inline-block border-0 small shadow-sm mb-4">
                                <i class="bi bi-clock-history me-2"></i> Votre demande est en cours de validation par le créateur.
                            </div>
                            <p class="text-muted mb-0">Revenez plus tard pour découvrir la communauté.</p>
                        {% else %}
                            <p class="text-muted mb-4 mx-auto" style="max-width: 400px;">
                                Ce forum est privé. Rejoignez la communauté pour accéder aux publications et participer aux échanges.
                            </p>
                            <form action="{{ path('app_forum_join', {'forumId': forum.forumId}) }}" method="POST">
                                <button type="submit" class="btn btn-success rounded-pill px-5 py-3 fw-bold border-0 shadow-lg hover-lift-2 transition-all" 
                                        style="background-color: #52BE80; font-size: 1.1rem;">
                                    <i class="bi bi-unlock-fill me-2"></i> Envoyer une demande
                                </button>
                            </form>
                        {% endif %}
                    </div>
                {% endif %}
            </div>
        </div>

        <!-- Right Sidebar (Forum Info) -->
        <div class="col-lg-4 d-none d-lg-block">
            <div class="card border-0 shadow-sm rounded-5 overflow-hidden mb-4 p-4 bg-white sticky-top" style="top: 2rem;">
                <h5 class="fw-bold text-dark mb-4 p-1 border-bottom border-mint border-3 d-inline-block">À propos du forum</h5>
                <p class="text-secondary small mb-4">
                    Bienvenue dans cet espace d'échange. Pour maintenir une ambiance saine, veuillez suivre ces quelques règles élémentaires :
                </p>
                
                <div class="rules-list mb-4">
                    <div class="d-flex gap-3 mb-3 hover-bg-light p-2 rounded-3 transition-all">
                        <div class="icon-circle rounded-circle bg-success bg-opacity-10 d-flex align-items-center justify-content-center text-success" style="width: 32px; height: 32px; flex-shrink: 0;">
                            <i class="bi bi-check2"></i>
                        </div>
                        <span class="small text-dark fw-medium">Respect mutuel entre les membres.</span>
                    </div>
                    <div class="d-flex gap-3 mb-3 hover-bg-light p-2 rounded-3 transition-all">
                        <div class="icon-circle rounded-circle bg-success bg-opacity-10 d-flex align-items-center justify-content-center text-success" style="width: 32px; height: 32px; flex-shrink: 0;">
                            <i class="bi bi-check2"></i>
                        </div>
                        <span class="small text-dark fw-medium">Pas de messages hors-sujet ou spam.</span>
                    </div>
                    <div class="d-flex gap-3 mb-4 hover-bg-light p-2 rounded-3 transition-all">
                        <div class="icon-circle rounded-circle bg-success bg-opacity-10 d-flex align-items-center justify-content-center text-success" style="width: 32px; height: 32px; flex-shrink: 0;">
                            <i class="bi bi-check2"></i>
                        </div>
                        <span class="small text-dark fw-medium">Contenu sûr pour tout le monde.</span>
                    </div>
                </div>

                <div class="forum-stats-mini bg-light rounded-4 p-4 d-flex justify-content-around transition-all border">
                    <div class="text-center">
                        <div class="fs-4 fw-bold text-dark">{{ dynamicPostCount|default(postes|length) }}</div>
                        <div class="text-muted x-small uppercase fw-bold ls-1">Posts</div>
                    </div>
                    <div class="vr mx-2 text-muted opacity-10"></div>
                    <div class="text-center">
                        <div class="fs-4 fw-bold text-dark">{{ forum.nbrMembers }}</div>
                        <div class="text-muted x-small uppercase fw-bold ls-1">Membres</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Reusing Modals -->
<div class="modal fade animate-fade-in" id="postModal" tabindex="-1" aria-hidden="true" style="backdrop-filter: blur(5px);">
    <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
        <div class="modal-content border-0 rounded-5 shadow-lg">
             <div class="modal-header border-0 pb-0 px-4 pt-4 d-flex justify-content-between">
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-success bg-opacity-10 text-success d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                        <i class="bi bi-plus-lg fs-4"></i>
                    </div>
                    <h4 class="modal-title fw-bold" style="font-family: 'Outfit', sans-serif;">Nouveau Sujet</h4>
                </div>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
            </div>
            <div id="postModalBody" class="modal-body p-4 custom-scrollbar">
                <div class="text-center py-5">
                    <div class="spinner-border text-success" role="status"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade animate-fade-in" id="forumModal" tabindex="-1" aria-hidden="true" style="backdrop-filter: blur(5px);">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 rounded-5 shadow-lg">
            <div id="forumModalBody" class="modal-body p-0">
                <div class="text-center py-5">
                    <div class="spinner-border text-success" role="status"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ─── Gemini Chatbot HTML ─── -->
<button type="button" class="gv-chatbot-fab" onclick="openChatModal()">
    <span class="material-symbols-outlined">smart_toy</span>
</button>

<div class="modal fade" id="chatModal" tabindex="-1" aria-hidden="true" style="backdrop-filter: blur(8px); z-index: 1060;">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 overflow-hidden shadow-lg" style="border-radius:1.5rem;">
            <div class="modal-header border-0 p-4" style="background: linear-gradient(135deg, #00342d 0%, #013220 100%); color: white;">
                <div class="d-flex align-items-center gap-3">
                    <div class="d-flex align-items-center justify-content-center rounded-3" style="width:45px; height:45px; background:rgba(255,255,255,0.1);">
                        <span class="material-symbols-outlined" style="color:#a0f2e1;">robot_2</span>
                    </div>
                    <div>
                        <h5 class="modal-title fw-bold mb-0">AI Assistant</h5>
                        <div class="gv-ai-selector-container mt-1" id="aiSelector">
                            <div class="gv-ai-selector-btn" onclick="toggleAISelector()">
                                <span id="selectedAIName">Gemini (Google)</span>
                                <span class="material-symbols-outlined arrow">expand_more</span>
                            </div>
                            <div class="gv-ai-selector-menu" id="aiMenu">
                                <div class="gv-ai-selector-item active" onclick="selectAI('gemini', 'Gemini (Google)')">
                                    <span class="material-symbols-outlined gv-icon-gemini">auto_awesome</span>
                                    <span>Gemini</span>
                                </div>
                                <div class="gv-ai-selector-item" onclick="selectAI('groq', 'Groq (Grok Speed)')">
                                    <span class="material-symbols-outlined gv-icon-groq">bolt</span>
                                    <span>Groq</span>
                                </div>
                                <div class="gv-ai-selector-item" onclick="selectAI('voice', 'Voice Agent (Docker)')">
                                    <span class="material-symbols-outlined gv-icon-groq">mic</span>
                                    <span>Voice Agent</span>
                                </div>
                            </div>
                            <input type="hidden" id="aiModelSelectorValue" value="gemini">
                        </div>
                    </div>
                </div>
                <button type="button" class="btn-close btn-close-white shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="chat-container">
                <div id="chatMessages" class="chat-messages custom-scrollbar">
                    <div class="chat-message ai">
                        Bonjour ! Je suis Gemini, votre assistant voyage personnel. Comment puis-je vous aider dans ce forum aujourd'hui ?
                    </div>
                </div>
                <div class="chat-input-area">
                    <input type="text" id="chatInput" class="chat-input" placeholder="Posez votre question sur un voyage..." onkeypress="if(event.key === 'Enter') sendMessage()">
                    <button class="chat-send-btn" type="button" onclick="startVoiceInput()" title="Parler">
                        <span class="material-symbols-outlined">mic</span>
                    </button>
                    <button class="chat-send-btn" onclick="sendMessage()">
                        <span class="material-symbols-outlined">send</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    let forumModal;
    let postModal;

    document.addEventListener('DOMContentLoaded', () => {
        const fElem = document.getElementById('forumModal');
        const pElem = document.getElementById('postModal');
        if (fElem) forumModal = new bootstrap.Modal(fElem);
        if (pElem) postModal = new bootstrap.Modal(pElem);
    });

    function openForumModal(url) {
        if (!forumModal) forumModal = new bootstrap.Modal(document.getElementById('forumModal'));
        const body = document.getElementById('forumModalBody');
        forumModal.show();
        fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } }).then(r => r.text()).then(html => {
            body.innerHTML = html;
            const scripts = body.getElementsByTagName('script');
            for (let s of scripts) { eval(s.innerText); }
        });
    }

    function openPostModal(url) {
        if (!postModal) postModal = new bootstrap.Modal(document.getElementById('postModal'));
        const body = document.getElementById('postModalBody');
        postModal.show();
        fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } }).then(r => r.text()).then(html => {
            body.innerHTML = html;
            const scripts = body.getElementsByTagName('script');
            for (let s of scripts) { eval(s.innerText); }
        });
    }

    // --- Mentions Manager ---
    const MentionsManager = {
        activeInput: null,
        listEl: null,
        query: '',
        selectedIndex: -1,
        users: [],
        _fetchTimer: null,

        init() {
            document.addEventListener('input', (e) => {
                const tag = e.target.tagName;
                if (tag === 'TEXTAREA' || (tag === 'INPUT' && e.target.type === 'text')) {
                    this.handleInput(e);
                }
            }, true);

            document.addEventListener('keydown', (e) => this.handleKeyDown(e), true);
            document.addEventListener('click', (e) => {
                if (this.listEl && !this.listEl.contains(e.target)) this.close();
            });
        },

        handleInput(e) {
            const input = e.target;
            const cursor = input.selectionStart;
            const text = input.value.substring(0, cursor);
            const match = text.match(/@(\w*)$/);

            if (match) {
                this.activeInput = input;
                this.query = match[1];
                this.showList();
                clearTimeout(this._fetchTimer);
                this._fetchTimer = setTimeout(() => this.fetchUsers(this.query), 300);
            } else {
                if (this.listEl) this.close();
            }
        },

        async fetchUsers(q) {
            try {
                const res = await fetch(`{{ path('api_users_search') }}?q=${q}`);
                this.users = await res.json();
                this.renderList();
            } catch (err) { /* Mention fetch failed silently */ }
        },

        showList() {
            if (!this.listEl) {
                this.listEl = document.createElement('div');
                this.listEl.className = 'gv-mentions-list';
                document.body.appendChild(this.listEl);
            }
            this.positionList();
        },

        positionList() {
            if (!this.activeInput || !this.listEl) return;
            const rect = this.activeInput.getBoundingClientRect();
            this.listEl.style.top = `${window.scrollY + rect.bottom + 8}px`;
            this.listEl.style.left = `${window.scrollX + rect.left}px`;
            const listRect = this.listEl.getBoundingClientRect();
            if (listRect.right > window.innerWidth) {
                this.listEl.style.left = `${window.innerWidth - listRect.width - 20}px`;
            }
        },

        renderList() {
            if (!this.listEl) return;
            if (this.users.length === 0) {
                this.listEl.innerHTML = '<div class="p-3 text-muted small text-center">Aucun utilisateur trouvé</div>';
                return;
            }
            this.listEl.innerHTML = this.users.map((u, i) => `
                <div class="gv-mention-item ${i === this.selectedIndex ? 'active' : ''}" data-index="${i}">
                    <img src="${u.photo || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(u.name)}" class="gv-mention-avatar">
                    <div class="gv-mention-info">
                        <span class="gv-mention-name">${u.name}</span>
                        <span class="gv-mention-tag">@${u.tag}</span>
                    </div>
                </div>
            `).join('');
            this.listEl.querySelectorAll('.gv-mention-item').forEach(item => {
                item.addEventListener('click', (e) => {
                    e.preventDefault();
                    e.stopPropagation();
                    this.selectUser(parseInt(item.dataset.index));
                });
            });
        },

        handleKeyDown(e) {
            if (!this.listEl) return;
            if (e.key === 'ArrowDown') {
                e.preventDefault();
                this.selectedIndex = (this.selectedIndex + 1) % this.users.length;
                this.renderList();
            } else if (e.key === 'ArrowUp') {
                e.preventDefault();
                this.selectedIndex = (this.selectedIndex - 1 + this.users.length) % this.users.length;
                this.renderList();
            } else if (e.key === 'Enter' && this.selectedIndex >= 0) {
                e.preventDefault();
                this.selectUser(this.selectedIndex);
            } else if (e.key === 'Escape') { this.close(); }
        },

        selectUser(index) {
            const user = this.users[index];
            if (!user || !this.activeInput) return;
            const cursor = this.activeInput.selectionStart;
            const text = this.activeInput.value;
            const before = text.substring(0, cursor).replace(/@\w*$/, `@${user.tag} `);
            const after = text.substring(cursor);
            this.activeInput.value = before + after;
            this.activeInput.focus();
            this.activeInput.setSelectionRange(before.length, before.length);
            this.activeInput.dispatchEvent(new Event('input', { bubbles: true }));
            this.close();
        },

        close() {
            if (this.listEl) { this.listEl.remove(); this.listEl = null; }
            this.activeInput = null; this.users = []; this.selectedIndex = -1;
        }
    };

    /* --- Mentions Highlighting --- */
    function highlightMentions() {
        const elements = document.querySelectorAll('.post-text, .comment-bubble p');
        elements.forEach(el => {
            if (el.dataset.mentionsProcessed) return;
            el.innerHTML = el.innerHTML.replace(/(@[a-zA-Z0-9_]+)/g, '<span class="text-primary fw-bold" style="color: #2563eb !important;">$1</span>');
            el.dataset.mentionsProcessed = 'true';
        });
    }

    document.addEventListener('DOMContentLoaded', () => {
        MentionsManager.init();
        highlightMentions();
        let _mentionObserverTimer;
        const observer = new MutationObserver(() => {
            clearTimeout(_mentionObserverTimer);
            _mentionObserverTimer = setTimeout(highlightMentions, 300);
        });
        observer.observe(document.body, { childList: true, subtree: true });
    });

    // --- Gemini Chatbot Logic ---
    let chatModalObj;
    document.addEventListener('DOMContentLoaded', () => {
        chatModalObj = new bootstrap.Modal(document.getElementById('chatModal'));
        
        // Close AI menu when clicking outside
        document.addEventListener('click', (e) => {
            if (!document.getElementById('aiSelector').contains(e.target)) {
                closeAISelector();
            }
        });
    });

    function toggleAISelector() {
        const container = document.getElementById('aiSelector');
        const menu = document.getElementById('aiMenu');
        container.classList.toggle('open');
        menu.style.display = container.classList.contains('open') ? 'block' : 'none';
    }

    function closeAISelector() {
        const container = document.getElementById('aiSelector');
        const menu = document.getElementById('aiMenu');
        container.classList.remove('open');
        if(menu) menu.style.display = 'none';
    }

    function selectAI(value, name) {
        document.getElementById('aiModelSelectorValue').value = value;
        document.getElementById('selectedAIName').innerText = name;
        updateWelcomeMessage(value);
        
        // Update active class
        document.querySelectorAll('.gv-ai-selector-item').forEach(item => {
            item.classList.remove('active');
            const itemText = item.innerText;
            const isActive =
                (value === 'gemini' && itemText.includes('Gemini')) ||
                (value === 'groq' && itemText.includes('Groq')) ||
                (value === 'voice' && itemText.includes('Voice Agent'));
            if (isActive) {
                item.classList.add('active');
            }
        });
        
        closeAISelector();
    }

    function openChatModal() {
        chatModalObj.show();
    }

    function sendMessage() {
        const input = document.getElementById('chatInput');
        const text = input.value.trim();
        if (!text) return;

        appendMessage('user', text);
        input.value = '';

        const indicator = showTypingIndicator();
        const model = document.getElementById('aiModelSelectorValue').value;
        if (model === 'voice') {
            callVoiceAssistant(text, false, indicator);
            return;
        }

        const route = model === 'groq' ? '{{ path('app_groq_chat') }}' : '{{ path('app_gemini_chat') }}';

        fetch(route, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({ message: text })
        })
        .then(response => response.json())
        .then(data => {
            indicator.remove();
            if (data.error) {
                appendMessage('ai', "Erreur : " + data.error);
            } else {
                appendMessage('ai', data.response);
            }
        })
        .catch(error => {
            indicator.remove();
            appendMessage('ai', "Désolé, une erreur de connexion est survenue.");
        });
    }

    function callVoiceAssistant(text, confirmed, indicator) {
        fetch('{{ path('app_api_python_assistant_flow') }}', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({ user_input: text, confirmed: confirmed })
        })
        .then(response => response.json())
        .then(data => {
            indicator.remove();

            if (data.error) {
                appendMessage('ai', "Voice Agent: " + data.error);
                return;
            }

            const payload = data.data || {};
            const plan = payload.plan || {};

            if (payload.requires_confirmation && !confirmed) {
                const reason = payload.confirmation_prompt || plan.reason || 'Cette commande demande une confirmation.';
                appendMessage('ai', "Plan sécurisé (dry-run): " + reason);

                if (window.confirm(reason + "\n\nConfirmer l'exécution ?")) {
                    const secondIndicator = showTypingIndicator();
                    callVoiceAssistant(text, true, secondIndicator);
                } else {
                    appendMessage('ai', 'Commande annulée.');
                }

                return;
            }

            appendMessage('ai', formatVoiceAssistantResponse(payload));
            speakText(getVoiceReplyText(payload));
        })
        .catch(() => {
            indicator.remove();
            appendMessage('ai', 'Voice Agent indisponible actuellement.');
        });
    }

    function formatVoiceAssistantResponse(payload) {
        const execution = payload.execution || {};
        const intent = payload.intent || execution.intent || 'unknown';
        const plan = payload.plan || execution.plan || {};

        const textReply = getVoiceReplyText(payload);
        const blocked = plan.blocked === true ? 'oui' : 'non';
        const requires = plan.requires_confirmation === true ? 'oui' : 'non';
        const reason = plan.reason || 'Aucune raison fournie';

        return `Intent: ${intent}\nRéponse: ${textReply}\nPlan: blocked=${blocked}, requires_confirmation=${requires}\nReason: ${reason}`;
    }

    function getVoiceReplyText(payload) {
        const execution = payload.execution || {};
        return execution.response || execution.message || execution.output || execution.result || 'Commande traitée.';
    }

    function updateWelcomeMessage(model) {
        const firstMessage = document.querySelector('#chatMessages .chat-message.ai');
        if (!firstMessage) {
            return;
        }

        if (model === 'voice') {
            firstMessage.textContent = "Bonjour ! Je suis Voice Agent (Docker). Je peux préparer une commande en mode sécurisé puis demander votre confirmation avant exécution.";
            return;
        }

        if (model === 'groq') {
            firstMessage.textContent = "Bonjour ! Je suis Groq, assistant voyage rapide. Que souhaitez-vous faire ?";
            return;
        }

        firstMessage.textContent = "Bonjour ! Je suis Gemini, votre assistant voyage personnel. Comment puis-je vous aider dans ce forum aujourd'hui ?";
    }

    function startVoiceInput() {
        const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
        if (!SpeechRecognition) {
            appendMessage('ai', 'La reconnaissance vocale n\'est pas supportée sur ce navigateur.');
            return;
        }

        const recognition = new SpeechRecognition();
        recognition.lang = 'fr-FR';
        recognition.interimResults = false;
        recognition.maxAlternatives = 1;

        recognition.onresult = (event) => {
            const transcript = event.results?.[0]?.[0]?.transcript || '';
            if (transcript) {
                const input = document.getElementById('chatInput');
                input.value = transcript;
                sendMessage();
            }
        };

        recognition.onerror = () => {
            appendMessage('ai', 'Impossible de lire votre voix pour le moment.');
        };

        recognition.start();
    }

    function speakText(text) {
        if (!window.speechSynthesis || !text) {
            return;
        }

        const utterance = new SpeechSynthesisUtterance(text);
        utterance.lang = 'fr-FR';
        window.speechSynthesis.cancel();
        window.speechSynthesis.speak(utterance);
    }

    function appendMessage(type, text) {
        const container = document.getElementById('chatMessages');
        const msg = document.createElement('div');
        msg.className = `chat-message ${type}`;

        if (type === 'ai' && text.includes('[POST_SUGGESTION]')) {
            const parts = text.split('[POST_SUGGESTION]');
            const normalText = parts[0];
            let suggestionBlock = parts[1].split('[/POST_SUGGESTION]')[0];
            
            try {
                const suggestion = JSON.parse(suggestionBlock);
                const safeSuggestion = suggestionBlock.replace(/'/g, "&apos;");
                msg.innerHTML = `
                    <div>${normalText}</div>
                    <div class="mt-3 p-3 bg-white border rounded-3 shadow-sm" style="color:#00342d;">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="material-symbols-outlined text-success" style="font-size:1.1rem;">auto_awesome</span>
                            <span class="fw-bold small">Suggestion de Sujet</span>
                        </div>
                        <div class="small mb-3 text-muted" style="font-style:italic;">"${suggestion.contenu.substring(0, 80)}..."</div>
                        <button class="btn btn-sm btn-success w-100 rounded-pill py-2 fw-bold" 
                                onclick='fillPostForm(${safeSuggestion})'>
                            Remplir le formulaire
                        </button>
                    </div>
                `;
            } catch (e) {
                msg.textContent = text;
            }
        } else {
            msg.textContent = text;
        }

        container.appendChild(msg);
        container.scrollTop = container.scrollHeight;
    }

    function fillPostForm(data) {
        // En mode Forum, on utilise le forumId actuel pour le nouveau post
        openPostModal('{{ path('app_poste_new', {'forumId': forum.forumId}) }}');
        chatModalObj.hide();

        const checkExist = setInterval(() => {
            const form = document.getElementById('publication-form');
            if (form) {
                clearInterval(checkExist);
                const textarea = form.querySelector('textarea');
                const locSearch = document.getElementById('localisation-search') || document.querySelector('input[name*="[localisation]"]');
                
                if (textarea) textarea.value = data.contenu;
                if (locSearch) locSearch.value = data.localisation || '';
                
                if (data.type === 'MEDIA') {
                    const btnPhoto = document.getElementById('btn-photo-video');
                    if (btnPhoto) btnPhoto.click();
                    if (data.imageUrl) {
                        const extInput = document.getElementById('poste_externalImageUrl');
                        if (extInput) extInput.value = data.imageUrl;
                        const imgPreview = document.getElementById('image-preview');
                        const previewContainer = document.getElementById('preview-image-container');
                        const noPreview = document.getElementById('no-preview');
                        if (imgPreview) {
                            imgPreview.src = data.imageUrl;
                            if (previewContainer) previewContainer.style.display = 'block';
                            if (noPreview) noPreview.style.display = 'none';
                        }
                    }
                } else {
                    const btnText = document.getElementById('btn-status-texte');
                    if (btnText) btnText.click();
                }
                if (textarea) textarea.dispatchEvent(new Event('input'));
            }
        }, 100);
    }

    function showTypingIndicator() {
        const container = document.getElementById('chatMessages');
        const div = document.createElement('div');
        div.className = 'chat-message ai';
        div.innerHTML = `
            <div class="typing-indicator">
                <div class="typing-dot"></div>
                <div class="typing-dot"></div>
                <div class="typing-dot"></div>
            </div>
        `;
        container.appendChild(div);
        container.scrollTop = container.scrollHeight;
        return div;
    }
</script>
{% endblock %}


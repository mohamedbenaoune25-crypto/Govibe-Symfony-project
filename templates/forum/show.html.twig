{% extends 'base.html.twig' %}

{% block title %}{{ forum.name }} - GoVibe Forum{% endblock %}

{% block body %}
<!-- Forum Hero Header -->
<div class="container-fluid bg-white py-5 shadow-sm mb-5 border-bottom rounded-bottom-5 px-lg-5 position-relative overflow-hidden">
    <!-- Decorative background elements -->
    <div class="position-absolute top-0 end-0 p-5 mt-5 opacity-10 d-none d-lg-block">
        <i class="bi bi-chat-dots-fill" style="font-size: 15rem; color: #52BE80;"></i>
    </div>

    <div class="container position-relative">
        <div class="row align-items-center">
            <div class="col-lg-2 text-center text-lg-start mb-4 mb-lg-0">
                <div class="forum-avatar shadow-lg rounded-circle mx-auto mx-lg-0 d-flex align-items-center justify-content-center text-white fw-bold" 
                     style="width: 120px; height: 120px; background: linear-gradient(135deg, #1E8449 0%, #52BE80 100%); font-size: 3rem;">
                    {% if forum.image %}
                        <img src="{{ forum.image }}" class="w-100 h-100 rounded-circle object-fit-cover" onerror="this.style.display='none';">
                        <span class="fallback-letter">{{ forum.name|first|upper }}</span>
                    {% else %}
                        {{ forum.name|first|upper }}
                    {% endif %}
                </div>
            </div>
            <div class="col-lg-7 text-center text-lg-start">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-2 justify-content-center justify-content-lg-start">
                        <li class="breadcrumb-item"><a href="{{ path('app_forum_index') }}" class="text-decoration-none text-success fw-bold">Forums</a></li>
                        <li class="breadcrumb-item active" aria-current="page">{{ forum.name }}</li>
                    </ol>
                </nav>
                <div class="d-flex align-items-center justify-content-center justify-content-lg-start gap-3 mb-2">
                    <h1 class="display-5 fw-bold text-dark mb-0">{{ forum.name }}</h1>
                    {% if forum.isPrivate %}
                        <span class="badge bg-danger rounded-pill px-3 py-2 small shadow-sm"><i class="bi bi-lock-fill me-1"></i>Privé</span>
                    {% endif %}
                </div>
                <p class="text-secondary fs-5 opacity-75 mb-4 max-w-700">
                    {{ forum.description|default('Bienvenue dans la communauté ' ~ forum.name ~ '. Participez aux discussions, partagez vos idées et connectez-vous avec d\'autres membres.') }}
                </p>
                
                <div class="d-flex flex-wrap justify-content-center justify-content-lg-start gap-4 text-muted small fw-bold text-uppercase ls-1 mt-4">
                    <span><i class="bi bi-people-fill me-2 text-success"></i>{{ forum.nbrMembers }} Membres</span>
                    <span><i class="bi bi-chat-left-fill me-2 text-success"></i>{{ postes|length }} Sujets</span>
                    <span><i class="bi bi-calendar-event me-2 text-success"></i>Créé le {{ forum.dateCreation|date('d M Y') }}</span>
                    <span><i class="bi bi-person-circle me-2 text-success"></i>Par {{ forum.createdBy ? forum.createdBy.prenom : 'Admin' }}</span>
                </div>
            </div>
            <div class="col-lg-3 text-center text-lg-end mt-4 mt-lg-0">
                {% if is_granted('ROLE_USER') %}
                    {% if isMember %}
                        <button type="button" onclick="openPostModal('{{ path('app_poste_new', {'forumId': forum.forumId}) }}')"
                                class="btn btn-success rounded-pill px-4 py-3 fw-bold shadow-lg transition-all hover-lift-2 border-0" 
                                style="background-color: #52BE80; font-size: 1rem;">
                            <i class="bi bi-plus-circle-fill me-2"></i>Nouveau Sujet
                        </button>
                        
                        {# Join/Leave buttons for non-creators #}
                        {% if app.user != forum.createdBy %}
                            <div class="mt-3">
                                <form action="{{ path('app_forum_leave', {'forumId': forum.forumId}) }}" method="POST" class="d-inline" onsubmit="return confirm('Voulez-vous vraiment quitter ce forum ?');">
                                    <button type="submit" class="btn btn-outline-danger rounded-pill px-4 py-2 btn-sm fw-bold border-2">
                                        <i class="bi bi-box-arrow-right me-1"></i> Quitter
                                    </button>
                                </form>
                            </div>
                        {% endif %}
                    {% else %}
                        <form action="{{ path('app_forum_join', {'forumId': forum.forumId}) }}" method="POST">
                            <button type="submit" class="btn btn-success rounded-pill px-5 py-3 fw-bold shadow-lg transition-all hover-lift-2 border-0" 
                                    style="background-color: #52BE80; font-size: 1.1rem;">
                                <i class="bi bi-person-plus-fill me-2"></i> Rejoindre le Forum
                            </button>
                        </form>
                    {% endif %}
                    
                    {% if is_granted('ROLE_ADMIN') or (app.user and app.user == forum.createdBy) %}
                        <div class="mt-3">
                            <button onclick="openForumModal('{{ path('app_forum_edit', {'forumId': forum.forumId}) }}')" 
                                    class="btn btn-outline-secondary rounded-pill px-3 py-2 btn-sm fw-bold border-2 me-2">
                                <i class="bi bi-pencil me-1"></i> Modifier
                            </button>
                        </div>
                    {% endif %}
                {% endif %}
            </div>
        </div>
    </div>
</div>

<div class="container mb-5">
    <div class="row">
        <!-- Main Content Area -->
        <div class="col-lg-8 mx-auto">
            <div class="section-title d-flex align-items-center justify-content-between mb-4">
                <h3 class="fw-bold text-dark mb-0">Discussions Récentes</h3>
                <div class="btn-group shadow-sm rounded-pill overflow-hidden border">
                    <button class="btn btn-white btn-sm active px-3">Tout</button>
                    <button class="btn btn-white btn-sm px-3 border-start">Populaires</button>
                    <button class="btn btn-white btn-sm px-3 border-start">Nouveaux</button>
                </div>
            </div>

            <!-- Feed of Posts -->
            <div class="forum-feed">
                {% if isMember or is_granted('ROLE_ADMIN') %}
                    {% for poste in postes %}
                        {% include 'poste/postitem.html.twig' %}
                    {% else %}
                        <div class="text-center py-5 rounded-5 border bg-white shadow-sm px-4">
                            <div class="display-4 text-muted opacity-25 mb-4">
                                <i class="bi bi-send-dash"></i>
                            </div>
                            <h4 class="text-secondary fw-bold">Aucune discussion ouverte</h4>
                            <p class="text-muted mb-4">Soyez le premier à lancer une discussion dans ce forum !</p>
                            {% if is_granted('ROLE_USER') %}
                                <button onclick="openPostModal('{{ path('app_poste_new', {'forumId': forum.forumId}) }}')" 
                                        class="btn btn-success rounded-pill px-5 py-2 fw-bold border-0 shadow-sm" 
                                        style="background-color: #52BE80;">
                                    Commencer un sujet
                                </button>
                            {% endif %}
                        </div>
                    {% endfor %}
                {% else %}
                    <div class="text-center py-5 rounded-5 border bg-white shadow-sm px-4">
                        <div class="display-4 text-muted opacity-25 mb-4">
                            <i class="bi bi-lock-fill"></i>
                        </div>
                        <h4 class="text-secondary fw-bold">Contenu Protégé</h4>
                        <p class="text-muted mb-4">Vous devez rejoindre ce forum pour voir les publications et participer aux discussions.</p>
                        <form action="{{ path('app_forum_join', {'forumId': forum.forumId}) }}" method="POST">
                            <button type="submit" class="btn btn-success rounded-pill px-5 py-2 fw-bold border-0 shadow-sm" 
                                    style="background-color: #52BE80;">
                                Rejoindre Maintenant
                            </button>
                        </form>
                    </div>
                {% endif %}
            </div>
        </div>

        <!-- Right Sidebar (Optional Info) -->
        <div class="col-lg-4 d-none d-lg-block">
            <div class="card border-0 shadow-sm rounded-5 overflow-hidden mb-4 p-4 bg-white sticky-top" style="top: 2rem;">
                <h5 class="fw-bold text-dark mb-4 p-1 border-bottom border-mint border-3 d-inline-block">À propos de {{ forum.name }}</h5>
                <p class="text-secondary small mb-4">
                    Bienvenue dans cet espace dédié. Pour une meilleure expérience, merci de respecter les règles de courtoisie et de bienveillance.
                </p>
                
                <div class="rules-list mb-4">
                    <div class="d-flex gap-3 mb-3">
                        <div class="icon-circle rounded-circle bg-light d-flex align-items-center justify-content-center text-success" style="width: 32px; height: 32px; flex-shrink: 0;">
                            <i class="bi bi-check2"></i>
                        </div>
                        <span class="small text-dark fw-medium">Restez respectueux envers les autres membres.</span>
                    </div>
                    <div class="d-flex gap-3 mb-3">
                        <div class="icon-circle rounded-circle bg-light d-flex align-items-center justify-content-center text-success" style="width: 32px; height: 32px; flex-shrink: 0;">
                            <i class="bi bi-check2"></i>
                        </div>
                        <span class="small text-dark fw-medium">Évitez les messages hors-sujet.</span>
                    </div>
                    <div class="d-flex gap-3">
                        <div class="icon-circle rounded-circle bg-light d-flex align-items-center justify-content-center text-success" style="width: 32px; height: 32px; flex-shrink: 0;">
                            <i class="bi bi-check2"></i>
                        </div>
                        <span class="small text-dark fw-medium">Ne partagez pas de contenu offensant.</span>
                    </div>
                </div>

                <div class="forum-stats-mini bg-light rounded-4 p-3 d-flex justify-content-around">
                    <div class="text-center">
                        <div class="fs-4 fw-bold text-dark">{{ forum.postes|length }}</div>
                        <div class="text-muted x-small uppercase">Posts</div>
                    </div>
                    <div class="vr mx-2 text-muted opacity-25"></div>
                    <div class="text-center">
                        <div class="fs-4 fw-bold text-dark">{{ forum.nbrMembers }}</div>
                        <div class="text-muted x-small uppercase">Membres</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Reusing Post Modals -->
<div class="modal fade" id="postModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 rounded-5 shadow-lg p-4">
            <div id="postModalBody">
                <div class="text-center py-5">
                    <div class="spinner-border text-success" role="status"></div>
                    <p class="mt-3 text-muted small">Chargement...</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Reusing Forum Modals for edit -->
<div class="modal fade" id="forumModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 rounded-5 shadow-lg p-4">
            <div id="forumModalBody">
                <div class="text-center py-5">
                    <div class="spinner-border text-success" role="status"></div>
                    <p class="mt-3 text-muted small">Chargement...</p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    let forumModal;
    let postModal;

    document.addEventListener('DOMContentLoaded', () => {
        forumModal = new bootstrap.Modal(document.getElementById('forumModal'));
        postModal = new bootstrap.Modal(document.getElementById('postModal'));
    });

    function openForumModal(url) {
        if (!forumModal) { forumModal = new bootstrap.Modal(document.getElementById('forumModal')); }
        const body = document.getElementById('forumModalBody');
        body.innerHTML = `<div class="text-center py-5"><div class="spinner-border text-success" role="status"></div></div>`;
        forumModal.show();
        fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } }).then(r => r.text()).then(html => {
            const fragment = document.createRange().createContextualFragment(html);
            body.innerHTML = '';
            body.appendChild(fragment);
        });
    }

    function openPostModal(url) {
        if (!postModal) { postModal = new bootstrap.Modal(document.getElementById('postModal')); }
        const body = document.getElementById('postModalBody');
        body.innerHTML = `<div class="text-center py-5"><div class="spinner-border text-success" role="status"></div></div>`;
        postModal.show();
        fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } }).then(r => r.text()).then(html => {
            const fragment = document.createRange().createContextualFragment(html);
            body.innerHTML = '';
            body.appendChild(fragment);
        });
    }
</script>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    body { background-color: #F8F9F9 !important; }
    .ls-1 { letter-spacing: 1px; }
    .max-w-700 { max-width: 700px; }
    .border-mint { border-color: #52BE80 !important; }
    .x-small { font-size: 0.65rem; }
    .uppercase { text-transform: uppercase; }
    .rounded-bottom-5 { border-bottom-left-radius: 4rem !important; border-bottom-right-radius: 4rem !important; }
    .hover-lift-2:hover { transform: translateY(-4px); box-shadow: 0 10px 20px rgba(82,190,128,0.3) !important; background-color: #48AC71 !important; }
    .object-fit-cover { object-fit: cover; }
    .breadcrumb-item + .breadcrumb-item::before { content: "•"; color: #AAB7B8; }
</style>
{% endblock %}

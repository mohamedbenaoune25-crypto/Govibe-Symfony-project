<style>
    .modal-detail-wrapper {
        position: relative;
        overflow: hidden;
        border-radius: inherit;
        background: #000; /* Dark base for cinematic images */
    }
    
    .modal-bg-img {
        position: absolute;
        inset: -20px;
        z-index: 0;
        opacity: 0;
        animation: modalReveal 1.2s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    }

    @keyframes modalReveal {
        from { opacity: 0; transform: scale(1.15); }
        to { opacity: 1; transform: scale(1.05); }
    }

    .modal-bg-img img {
        width: calc(100% + 40px);
        height: calc(100% + 40px);
        object-fit: cover;
        filter: saturate(1.2) contrast(1.1) brightness(0.9); 
        animation: modalPan 40s ease-in-out infinite alternate;
    }

    @keyframes modalPan {
        0%   { transform: translate(0px, 0px) scale(1.05); }
        50%  { transform: translate(-20px, 20px) scale(1.12); }
        100% { transform: translate(-40px, -30px) scale(1.08); }
    }

    .modal-overlay {
        position: absolute;
        inset: 0;
        z-index: 1;
        /* Cinematic vignette and gradient */
        background: radial-gradient(circle at center, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.6) 100%),
                    linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.5) 100%);
        backdrop-filter: blur(2px);
    }

    /* Floating Light Flares */
    .flare-container {
        position: absolute;
        inset: 0;
        z-index: 1;
        pointer-events: none;
        overflow: hidden;
    }

    .flare {
        position: absolute;
        background: radial-gradient(circle, rgba(255,255,255,0.4) 0%, rgba(255,255,255,0) 70%);
        border-radius: 50%;
        filter: blur(15px);
        animation: floatFlare linear infinite;
    }

    @keyframes floatFlare {
        0% { transform: translate(0, 0) scale(1); opacity: 0; }
        20% { opacity: 0.6; }
        80% { opacity: 0.6; }
        100% { transform: translate(var(--tx), var(--ty)) scale(1.5); opacity: 0; }
    }

    .flare:nth-child(1) { width: 150px; height: 150px; left: 10%; top: 20%; --tx: 100px; --ty: -150px; animation-duration: 15s; }
    .flare:nth-child(2) { width: 250px; height: 250px; right: 5%; bottom: 10%; --tx: -200px; --ty: -100px; animation-duration: 25s; animation-delay: -5s; }
    .flare:nth-child(3) { width: 100px; height: 100px; left: 40%; bottom: 20%; --tx: 50px; --ty: -200px; animation-duration: 18s; animation-delay: -10s; }

    /* Premium Glassmorphism */
    .glass-card {
        background: rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.15);
        box-shadow: 0 10px 40px rgba(0,0,0,0.2);
        transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1), background 0.4s ease;
    }

    .glass-card:hover {
        background: rgba(255, 255, 255, 0.12);
        transform: translateY(-5px);
        border: 1px solid rgba(255, 255, 255, 0.25);
    }

    .stagger {
        opacity: 0;
        transform: translateY(20px);
        animation: cardAppear 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    }

    @keyframes cardAppear {
        to { opacity: 1; transform: translateY(0); }
    }

    .s-1 { animation-delay: 0.1s; }
    .s-2 { animation-delay: 0.2s; }
    .s-3 { animation-delay: 0.3s; }
    .s-4 { animation-delay: 0.4s; }
    .s-5 { animation-delay: 0.5s; }

    .luxury-text-gradient {
        background: linear-gradient(135deg, #ffffff 0%, #a5f3fc 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
</style>

{% set dest = checkout.flight.destination|default('')|lower %}
{% set destImage = asset('images/premium-ocean-bg.png') %}

{% if 'paris' in dest or 'france' in dest %}
    {% set destImage = asset('images/dest_paris.png') %}
{% elseif 'dubai' in dest or 'dxb' in dest %}
    {% set destImage = asset('images/dest_dubai.png') %}
{% elseif 'amalfi' in dest or 'italy' in dest or 'italie' in dest or 'rome' in dest or 'roma' in dest %}
    {% set destImage = asset('images/dest_amalfi.png') %}
{% elseif 'santorini' in dest or 'santorin' in dest or 'greece' in dest or 'grèce' in dest %}
    {% set destImage = asset('images/dest_santorini.png') %}
{% elseif 'ibiza' in dest or 'spain' in dest or 'espagne' in dest or 'madrid' in dest or 'barcelona' in dest %}
    {% set destImage = asset('images/dest_ibiza.png') %}
{% elseif 'maldives' in dest %}
    {% set destImage = asset('images/dest-maldives.png') %}
{% elseif 'tunisia' in dest or 'tunisie' in dest or 'tunis' in dest or 'sidi bou said' in dest %}
    {% set destImage = asset('images/dest_sidibousaid.png') %}
{% endif %}

<div class="px-3 px-md-4 py-4 modal-detail-wrapper">
    <div class="modal-bg-img">
        <img src="{{ destImage }}" alt="">
    </div>
    <div class="modal-overlay"></div>
    
    <div class="flare-container">
        <div class="flare"></div>
        <div class="flare"></div>
        <div class="flare"></div>
    </div>

    <div class="position-relative" style="z-index: 2;">
        {% set pilotNames = ['Amir Ben Salem', 'Youssef Haddad', 'Nabil Karim', 'Sami Trabelsi', 'Omar Mansouri'] %}
        {% set agencyNames = ['GoVibe Airways', 'SkyLine Travel', 'AeroPlus Agency', 'BlueWing Services', 'Nimbus Aviation'] %}
        {% set aircraftNumbers = ['TU-101', 'TU-107', 'TU-204', 'A320-7', 'B737-9'] %}
        {% set pilotName = random(pilotNames) %}
        {% set agencyName = random(agencyNames) %}
        {% set aircraftNumber = random(aircraftNumbers) %}

        <div class="d-flex justify-content-between align-items-start gap-2 mb-3 stagger s-1">
            <div class="p-4 rounded-4 glass-card" style="flex: 1;">
                <div style="font-size:12px; font-weight:800; letter-spacing:0.12em; text-transform:uppercase; color:rgba(255,255,255,0.6); margin-bottom:8px;">
                    Booking Reference #{{ checkout.checkoutId }}
                </div>
                <h2 class="h3 fw-bold mb-1 luxury-text-gradient" style="letter-spacing:-0.03em;">{{ checkout.flight }}</h2>
                <p class="text-white-50 mb-0" style="font-size:14px; font-weight: 400;">
                    <i class="bi bi-clock-history me-1 text-info"></i>
                    Reserved on {{ checkout.reservationDate ? checkout.reservationDate|date('M d, Y | H:i') : '-' }}
                </p>
            </div>
            <button type="button" class="btn-close btn-close-white bg-glass rounded-circle p-2 shadow-sm" style="opacity: 0.8; backdrop-filter: blur(4px);" aria-label="Fermer" onclick="bootstrap.Modal.getInstance(document.getElementById('detailModal')).hide()"></button>
        </div>

        <div class="stagger s-2">
            <div class="d-inline-block px-3 py-1 rounded-pill mb-2" style="background:rgba(255,255,255,0.1); backdrop-filter:blur(10px); border:1px solid rgba(255,255,255,0.1); font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:#fff;">
                <i class="bi bi-person-badge me-2 text-info"></i> Traveler details
            </div>
            
            <div class="row g-2 mb-3">
                <div class="col-md-6">
                    <div class="p-3 rounded-4 h-100 glass-card">
                        <small class="d-block" style="font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:rgba(255,255,255,0.5); margin-bottom:4px;">Full Name</small>
                        <strong class="text-white" style="font-size: 15px;">{{ checkout.passengerName }}</strong>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="p-3 rounded-4 h-100 glass-card">
                        <small class="d-block" style="font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:rgba(255,255,255,0.5); margin-bottom:4px;">Email</small>
                        <strong class="text-white" style="font-size: 15px; word-break:break-word;">{{ checkout.passengerEmail }}</strong>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="p-3 rounded-4 h-100 glass-card">
                        <small class="d-block" style="font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:rgba(255,255,255,0.5); margin-bottom:4px;">Phone</small>
                        <strong class="text-white" style="font-size: 15px;">{{ checkout.passengerPhone }}</strong>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="p-3 rounded-4 h-100 glass-card">
                        <small class="d-block" style="font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:rgba(255,255,255,0.5); margin-bottom:4px;">Travel Class</small>
                        <strong class="text-info" style="font-size: 15px; letter-spacing: 0.5px;">{{ checkout.travelClass }}</strong>
                    </div>
                </div>
            </div>
        </div>

        <div class="stagger s-3">
            <div class="d-inline-block px-3 py-1 rounded-pill mb-2" style="background:rgba(255,255,255,0.1); backdrop-filter:blur(10px); border:1px solid rgba(255,255,255,0.1); font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:#fff;">
                <i class="bi bi-airplane-engines me-2 text-info"></i> Flight Information
            </div>
            
            <div class="row g-2 mb-3">
                <div class="col-md-4">
                    <div class="p-3 rounded-4 h-100 glass-card">
                        <small class="d-block" style="font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:rgba(255,255,255,0.5); margin-bottom:4px;">Chief Pilot</small>
                        <strong class="text-white" style="font-size: 14px;">{{ pilotName }}</strong>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3 rounded-4 h-100 glass-card">
                        <small class="d-block" style="font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:rgba(255,255,255,0.5); margin-bottom:4px;">Airline Carrier</small>
                        <strong class="text-white" style="font-size: 14px;">{{ agencyName }}</strong>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3 rounded-4 h-100 glass-card">
                        <small class="d-block" style="font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:rgba(255,255,255,0.5); margin-bottom:4px;">Aircraft</small>
                        <strong class="text-white" style="font-size: 14px;">{{ aircraftNumber }}</strong>
                    </div>
                </div>
            </div>
        </div>

        <!-- AI Insights -->
        <div class="stagger s-4">
            <div class="d-inline-block px-3 py-1 rounded-pill mb-2" style="background:rgba(255,255,255,0.15); backdrop-filter:blur(10px); border:1px solid rgba(255,255,255,0.2); font-size:10px; font-weight:800; text-transform:uppercase; letter-spacing:0.1em; color:#fff;">
                <i class="bi bi-stars me-2 text-info"></i> AI Trip Intelligence
            </div>
            <div class="row g-2 mb-3" id="detailAiSection">
                <div class="col-md-4">
                    <div class="p-3 rounded-4 h-100 glass-card">
                        <small class="d-block" style="font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:rgba(255,255,255,0.5); margin-bottom:4px;">Risk Analysis</small>
                        <div id="detailRiskVal" style="font-size:14px; font-weight:700;"><div class="spinner-border spinner-border-sm text-info" style="width:12px;height:12px;" role="status"></div></div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3 rounded-4 h-100 glass-card">
                        <small class="d-block" style="font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:rgba(255,255,255,0.5); margin-bottom:4px;">Popularity</small>
                        <div id="detailDemandVal" style="color:#fff; font-size:14px; font-weight:700;"><div class="spinner-border spinner-border-sm text-info" style="width:12px;height:12px;" role="status"></div></div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3 rounded-4 h-100 glass-card">
                        <small class="d-block" style="font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:rgba(255,255,255,0.5); margin-bottom:4px;">AI Forecast</small>
                        <div id="detailWeatherVal" style="color:#fff; font-size:14px; font-weight:700;"><div class="spinner-border spinner-border-sm text-info" style="width:12px;height:12px;" role="status"></div></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="stagger s-5">
            <div class="mb-4">
                <button type="button" id="btnWikiDiscover" class="btn btn-info text-white w-100 rounded-pill px-4 py-3 fw-bold shadow-lg" style="font-size:15px; letter-spacing:1px; background: linear-gradient(135deg, #06b6d4 0%, #0891b2 100%); border: none;">
                    <i class="bi bi-compass me-2"></i> EXPLORE {{ checkout.flight.destination|upper }}
                </button>
                <div id="wikiCard" class="mt-3 p-4 rounded-4 d-none glass-card" style="border:1px solid rgba(6, 182, 212, 0.3);">
                    <button type="button" id="btnWikiPlay" class="btn btn-sm btn-info rounded-circle position-absolute text-white shadow-sm" style="top:15px; right:15px; width:36px; height:36px; display:flex; align-items:center; justify-content:center;">
                        <i class="bi bi-volume-up-fill" style="font-size:20px;"></i>
                    </button>
                    <h5 id="wikiTitle" class="fw-bold text-info mb-2" style="letter-spacing: 0.5px;"></h5>
                    <p id="wikiExtract" class="mb-0 text-white-50" style="font-size:14px; line-height:1.7; font-weight: 300;"></p>
                </div>
            </div>

            <div class="p-4 rounded-4 d-flex justify-content-between align-items-center glass-card" style="background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2);">
                <div>
                    <span class="fw-bold text-uppercase d-block" style="color:rgba(255,255,255,0.5); font-size: 11px; letter-spacing: 0.15em; margin-bottom: 2px;">Investment</span>
                    <span class="text-white-50" style="font-size: 13px;">Secure Transaction</span>
                </div>
                <span class="fw-bold luxury-text-gradient" style="font-size:32px; text-shadow: 0 0 20px rgba(165, 243, 252, 0.3);">{{ checkout.totalPrix }} DT</span>
            </div>

            <div class="d-flex flex-wrap gap-2 justify-content-end mt-4">
                {% if checkout.statusReservation == 'EN_ATTENTE' %}
                    <a href="{{ path('app_checkout_edit', {checkoutId: checkout.checkoutId}) }}" class="btn btn-outline-light rounded-pill px-4 fw-bold" style="background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.3);">
                        <i class="bi bi-pencil-square me-2"></i> Edit Reservations
                    </a>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<script>
(function(){
    var price = {{ checkout.totalPrix }};
    var pBooking = fetch('/api/ai/predict/booking', {
        method:'POST', headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},
        body: JSON.stringify({days_before_departure:14, price:price, seats_left:30, is_weekend:0, is_holiday:0, seat_type:0})
    }).then(function(r){return r.json();}).catch(function(){return {};});
    var pRisk = fetch('/api/ai/predict/risk', {
        method:'POST', headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},
        body: JSON.stringify({user_history:[1,0,1], booking_amount:price, departure_days:14})
    }).then(function(r){return r.json();}).catch(function(){return {};});
    var pWeather = fetch('/api/ai/predict/weather', {
        method:'POST', headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},
        body: JSON.stringify({temperature:65+Math.random()*15, humidity:50+Math.random()*20, pressure:1013, wind_speed:15+Math.random()*20})
    }).then(function(r){return r.json();}).catch(function(){return {};});

    Promise.all([pBooking, pRisk, pWeather]).then(function(res){
        var booking = res[0], risk = res[1], weather = res[2];
        // Risk
        var rV = document.getElementById('detailRiskVal');
        if(rV){
            var rd = (risk.data||risk);
            var rlvl = rd.risk_level||(rd.prediction&&rd.prediction[0])||0;
            if(rlvl>0.5||rlvl===1){rV.innerHTML='<span style="color:#dc2626;">&#9888; Risque Détecté</span>';}
            else{rV.innerHTML='<span style="color:#10B981;">&#10003; Profil Sûr</span>';}
        }
        // Demand
        var dV = document.getElementById('detailDemandVal');
        if(dV){
            var bd = (booking.data||booking);
            var prob = bd.booking_probability||0.5;
            var pct = Math.round(prob*100);
            dV.textContent = (pct>=75?'Très forte':'Modérée')+' ('+pct+'%)';
            if(pct>=75) dV.style.color='#dc2626'; else if(pct>=50) dV.style.color='#d97706';
        }
        // Weather
        var wV = document.getElementById('detailWeatherVal');
        if(wV){
            var wd = (weather.data||weather);
            var imp = wd.weather_impact||0.3;
            wV.innerHTML = imp<0.4?'Favorable <i class="bi bi-brightness-high text-warning"></i>':(imp<0.7?'Prudence <i class="bi bi-cloud-sun"></i>':'Risqué <i class="bi bi-cloud-lightning-rain"></i>');
            if(imp>=0.7) wV.style.color='#dc2626'; else if(imp>=0.4) wV.style.color='#d97706'; else wV.style.color='#10B981';
        }
    }).catch(function(){
        var s = document.getElementById('detailAiSection');
        if(s) s.innerHTML='<div class="col-12"><div class="p-3 rounded-4 text-center" style="background:rgba(255,255,255,0.88);color:#94a3b8;font-size:0.85rem;"><i class="bi bi-wifi-off me-1"></i> Analyse IA indisponible</div></div>';
    });

    // Wikipedia Integration
    var btnWikiDiscover = document.getElementById('btnWikiDiscover');
    var btnWikiPlay = document.getElementById('btnWikiPlay');
    var wikiCard = document.getElementById('wikiCard');
    var wikiTitle = document.getElementById('wikiTitle');
    var wikiExtract = document.getElementById('wikiExtract');
    var currentWikiText = '';

    if (btnWikiDiscover) {
        btnWikiDiscover.addEventListener('click', function() {
            var btnText = this.innerHTML;
            this.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status"></span> Recherche...';
            this.disabled = true;

            var destination = "{{ checkout.flight.destination|default('Paris')|e('js') }}";
            
            fetch('https://fr.wikipedia.org/api/rest_v1/page/summary/' + encodeURIComponent(destination))
                .then(function(response) {
                    if(!response.ok) throw new Error('Not found');
                    return response.json();
                })
                .then(function(data) {
                    wikiTitle.textContent = data.title || destination;
                    currentWikiText = data.extract || "Aucune description trouvée.";
                    wikiExtract.textContent = currentWikiText;
                    wikiCard.classList.remove('d-none');
                    
                    // Auto play text if voice is active
                    if (typeof window.speakText === 'function' && currentWikiText) {
                        window.speakText(currentWikiText);
                    }
                })
                .catch(function(err) {
                    wikiTitle.textContent = destination;
                    wikiExtract.textContent = "Aucune information Wikipédia n'a pu être trouvée pour cette destination.";
                    wikiCard.classList.remove('d-none');
                })
                .finally(function() {
                    btnWikiDiscover.innerHTML = btnText;
                    btnWikiDiscover.style.display = 'none';
                });
        });
    }

    if (btnWikiPlay) {
        btnWikiPlay.addEventListener('click', function() {
            if (typeof window.speakText === 'function' && currentWikiText) {
                window.speakText(currentWikiText);
            }
        });
    }

})();
</script>



<style>
    .modal-detail-wrapper {
        position: relative;
        overflow: hidden;
        border-radius: inherit; /* Assuming modal-content has border-radius */
    }
    
    .modal-bg-img {
        position: absolute;
        inset: -20px;
        z-index: 0;
    }

    .modal-bg-img img {
        width: calc(100% + 40px);
        height: calc(100% + 40px);
        object-fit: cover;
        /* Slight color/contrast boost to fight blurriness */
        filter: saturate(1.1) contrast(1.05); 
        animation: modalPan 30s ease-in-out infinite alternate;
    }

    @keyframes modalPan {
        0%   { transform: translate(0px, 0px) scale(1.05); }
        50%  { transform: translate(-15px, 15px) scale(1.1); }
        100% { transform: translate(-30px, -20px) scale(1.08); }
    }

    .modal-overlay {
        position: absolute;
        inset: 0;
        z-index: 1;
        /* Much more transparent to show the photo clearly */
        background: linear-gradient(135deg, rgba(238, 248, 241, 0.4), rgba(255, 255, 255, 0.2));
        backdrop-filter: blur(1px);
    }

    /* Falling Leaves Animation */
    .leaf-container {
        position: absolute;
        inset: 0;
        z-index: 1; /* Between background and cards */
        pointer-events: none;
        overflow: hidden;
    }

    .leaf {
        position: absolute;
        top: -40px;
        color: rgba(34, 197, 94, 0.65);
        animation: fall linear infinite;
    }

    @keyframes fall {
        0% { transform: translateY(-20px) rotate(0deg); opacity: 0; }
        10% { opacity: 1; }
        80% { opacity: 1; }
        100% { transform: translateY(800px) rotate(360deg); opacity: 0; }
    }

    .leaf:nth-child(1) { left: 10%; animation-duration: 12s; animation-delay: 0s; width: 28px; height: 28px; }
    .leaf:nth-child(2) { left: 25%; animation-duration: 16s; animation-delay: 2s; width: 20px; height: 20px; color: rgba(22, 163, 74, 0.5); }
    .leaf:nth-child(3) { left: 45%; animation-duration: 14s; animation-delay: 6s; width: 35px; height: 35px; color: rgba(134, 239, 172, 0.7); }
    .leaf:nth-child(4) { left: 65%; animation-duration: 18s; animation-delay: 1s; width: 18px; height: 18px; }
    .leaf:nth-child(5) { left: 85%; animation-duration: 15s; animation-delay: 4s; width: 30px; height: 30px; color: rgba(22, 163, 74, 0.4); }
    .leaf:nth-child(6) { left: 35%; animation-duration: 17s; animation-delay: 8s; width: 24px; height: 24px; }
</style>

{% set destImages = [
    asset('images/dest_dubai.png'),
    asset('images/dest_paris.png'),
    asset('images/dest_tokyo.png')
] %}
{% set destImage = random(destImages) %}

<div class="p-4 p-md-5 modal-detail-wrapper">
    <div class="modal-bg-img">
        <img src="{{ destImage }}" alt="">
    </div>
    <div class="modal-overlay"></div>
    
    <div class="leaf-container">
        <!-- SVG Leaves -->
        <svg class="leaf" viewBox="0 0 24 24" fill="currentColor"><path d="M17,8C8,10 5.9,16.17 3.82,21.34L5.71,22L6.66,19.7C7.14,19.87 7.64,20 8,20C19,20 22,3 22,3C21,5 14,5.25 9,6.25C4,7.25 7,11.5 7,11.5C7,11.5 9,4 17,8Z" /></svg>
        <svg class="leaf" viewBox="0 0 24 24" fill="currentColor"><path d="M17,8C8,10 5.9,16.17 3.82,21.34L5.71,22L6.66,19.7C7.14,19.87 7.64,20 8,20C19,20 22,3 22,3C21,5 14,5.25 9,6.25C4,7.25 7,11.5 7,11.5C7,11.5 9,4 17,8Z" /></svg>
        <svg class="leaf" viewBox="0 0 24 24" fill="currentColor"><path d="M17,8C8,10 5.9,16.17 3.82,21.34L5.71,22L6.66,19.7C7.14,19.87 7.64,20 8,20C19,20 22,3 22,3C21,5 14,5.25 9,6.25C4,7.25 7,11.5 7,11.5C7,11.5 9,4 17,8Z" /></svg>
        <svg class="leaf" viewBox="0 0 24 24" fill="currentColor"><path d="M17,8C8,10 5.9,16.17 3.82,21.34L5.71,22L6.66,19.7C7.14,19.87 7.64,20 8,20C19,20 22,3 22,3C21,5 14,5.25 9,6.25C4,7.25 7,11.5 7,11.5C7,11.5 9,4 17,8Z" /></svg>
        <svg class="leaf" viewBox="0 0 24 24" fill="currentColor"><path d="M17,8C8,10 5.9,16.17 3.82,21.34L5.71,22L6.66,19.7C7.14,19.87 7.64,20 8,20C19,20 22,3 22,3C21,5 14,5.25 9,6.25C4,7.25 7,11.5 7,11.5C7,11.5 9,4 17,8Z" /></svg>
        <svg class="leaf" viewBox="0 0 24 24" fill="currentColor"><path d="M17,8C8,10 5.9,16.17 3.82,21.34L5.71,22L6.66,19.7C7.14,19.87 7.64,20 8,20C19,20 22,3 22,3C21,5 14,5.25 9,6.25C4,7.25 7,11.5 7,11.5C7,11.5 9,4 17,8Z" /></svg>
    </div>

    <div class="position-relative" style="z-index: 2;">
        {% set pilotNames = ['Amir Ben Salem', 'Youssef Haddad', 'Nabil Karim', 'Sami Trabelsi', 'Omar Mansouri'] %}
        {% set agencyNames = ['GoVibe Airways', 'SkyLine Travel', 'AeroPlus Agency', 'BlueWing Services', 'Nimbus Aviation'] %}
        {% set aircraftNumbers = ['TU-101', 'TU-107', 'TU-204', 'A320-7', 'B737-9'] %}
        {% set pilotName = random(pilotNames) %}
        {% set agencyName = random(agencyNames) %}
        {% set aircraftNumber = random(aircraftNumbers) %}

        <div class="d-flex justify-content-between align-items-start gap-3 mb-4">
            <div class="p-3 rounded-4" style="background:rgba(255,255,255,0.85); backdrop-filter:blur(8px); flex: 1;">
                <div style="font-size:12px; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; color:#013220; opacity: 0.7; margin-bottom:6px;">
                    Checkout #{{ checkout.checkoutId }}
                </div>
                <h2 class="h4 fw-bold mb-1" style="color:#013220; letter-spacing:-0.02em;">{{ checkout.flight }}</h2>
                <p class="text-muted mb-0" style="font-size:14px; font-weight: 500;">
                    <i class="bi bi-calendar-event me-1 text-success"></i>
                    Créé le {{ checkout.reservationDate ? checkout.reservationDate|date('d/m/Y H:i') : '-' }}
                </p>
            </div>
            <button type="button" class="btn-close bg-white rounded-circle p-2 shadow-sm" style="opacity: 1;" aria-label="Fermer" onclick="bootstrap.Modal.getInstance(document.getElementById('detailModal')).hide()"></button>
        </div>

        <div class="d-inline-block px-3 py-1 rounded-pill mb-3" style="background:rgba(255,255,255,0.9); backdrop-filter:blur(4px); font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; color:#013220;">
            <i class="bi bi-person me-1 text-success"></i> Informations passager
        </div>
        
        <div class="row g-2 mb-4">
            <div class="col-md-6">
                <div class="p-3 rounded-4 h-100" style="background:rgba(255,255,255,0.88); backdrop-filter:blur(8px); border:1px solid rgba(255,255,255,0.4); box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                    <small class="d-block" style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; color:rgba(1,50,32,0.5);">Nom complet</small>
                    <strong style="color:#013220; font-size: 15px;">{{ checkout.passengerName }}</strong>
                </div>
            </div>
            <div class="col-md-6">
                <div class="p-3 rounded-4 h-100" style="background:rgba(255,255,255,0.88); backdrop-filter:blur(8px); border:1px solid rgba(255,255,255,0.4); box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                    <small class="d-block" style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; color:rgba(1,50,32,0.5);">Email</small>
                    <strong style="color:#013220; font-size: 15px; word-break:break-word;">{{ checkout.passengerEmail }}</strong>
                </div>
            </div>
            <div class="col-md-6">
                <div class="p-3 rounded-4 h-100" style="background:rgba(255,255,255,0.88); backdrop-filter:blur(8px); border:1px solid rgba(255,255,255,0.4); box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                    <small class="d-block" style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; color:rgba(1,50,32,0.5);">Téléphone</small>
                    <strong style="color:#013220; font-size: 15px;">{{ checkout.passengerPhone }}</strong>
                </div>
            </div>
            <div class="col-md-6">
                <div class="p-3 rounded-4 h-100" style="background:rgba(255,255,255,0.88); backdrop-filter:blur(8px); border:1px solid rgba(255,255,255,0.4); box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                    <small class="d-block" style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; color:rgba(1,50,32,0.5);">Passagers</small>
                    <strong style="color:#013220; font-size: 15px;">{{ checkout.passengerNbr }}</strong>
                </div>
            </div>
            <div class="col-md-6">
                <div class="p-3 rounded-4 h-100" style="background:rgba(255,255,255,0.88); backdrop-filter:blur(8px); border:1px solid rgba(255,255,255,0.4); box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                    <small class="d-block" style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; color:rgba(1,50,32,0.5);">Paiement</small>
                    <strong style="color:#013220; font-size: 15px;">{{ checkout.paymentMethod }}</strong>
                </div>
            </div>
            <div class="col-md-6">
                <div class="p-3 rounded-4 h-100" style="background:rgba(255,255,255,0.88); backdrop-filter:blur(8px); border:1px solid rgba(255,255,255,0.4); box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                    <small class="d-block" style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; color:rgba(1,50,32,0.5);">Classe</small>
                    <strong style="color:#013220; font-size: 15px;">{{ checkout.travelClass }}</strong>
                </div>
            </div>
        </div>

        <div class="d-inline-block px-3 py-1 rounded-pill mb-3" style="background:rgba(255,255,255,0.9); backdrop-filter:blur(4px); font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; color:#013220;">
            <i class="bi bi-airplane me-1 text-success"></i> Détails du vol
        </div>
        
        <div class="row g-2 mb-4">
            <div class="col-md-4">
                <div class="p-3 rounded-4 h-100" style="background:rgba(255,255,255,0.88); backdrop-filter:blur(8px); border:1px solid rgba(255,255,255,0.4); box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                    <small class="d-block" style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; color:rgba(1,50,32,0.5);">Pilote</small>
                    <strong style="color:#013220; font-size: 14px;">{{ pilotName }}</strong>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-3 rounded-4 h-100" style="background:rgba(255,255,255,0.88); backdrop-filter:blur(8px); border:1px solid rgba(255,255,255,0.4); box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                    <small class="d-block" style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; color:rgba(1,50,32,0.5);">Agence</small>
                    <strong style="color:#013220; font-size: 14px;">{{ agencyName }}</strong>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-3 rounded-4 h-100" style="background:rgba(255,255,255,0.88); backdrop-filter:blur(8px); border:1px solid rgba(255,255,255,0.4); box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                    <small class="d-block" style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; color:rgba(1,50,32,0.5);">Avion</small>
                    <strong style="color:#013220; font-size: 14px;">{{ aircraftNumber }}</strong>
                </div>
            </div>
        </div>

        <div class="p-4 rounded-4 d-flex justify-content-between align-items-center" style="background: rgba(255,255,255,0.92); backdrop-filter:blur(12px); border: 1px solid rgba(34,197,94,0.3); box-shadow: 0 8px 25px rgba(22,163,74,0.15);">
            <span class="fw-bold text-uppercase" style="color:#013220; font-size: 13px; letter-spacing: 0.05em;">Total payé</span>
            <span class="fw-bold" style="font-size:28px; color:#16a34a; text-shadow: 0 2px 10px rgba(34,197,94,0.2);">{{ checkout.totalPrix }} DT</span>
        </div>

        <div class="d-flex flex-wrap gap-2 justify-content-end mt-4">
            {% if checkout.statusReservation == 'EN_ATTENTE' %}
                <a href="{{ path('app_checkout_edit', {checkoutId: checkout.checkoutId}) }}" class="btn btn-success rounded-pill px-4 fw-bold" style="box-shadow: 0 4px 15px rgba(34,197,94,0.4);">
                    <i class="bi bi-pencil me-1"></i> Modifier
                </a>
            {% endif %}
        </div>
    </div>
</div>

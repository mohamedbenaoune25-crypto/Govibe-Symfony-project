{% extends 'base.html.twig' %}

{% block title %}Mes Checkouts — GoVibe | Réservations{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Manrope:wght@200..800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
<style>
body { font-family: 'Manrope', sans-serif !important; background: #fcf9f8 !important; overflow-x: hidden !important; }
.material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24; }

/* ─── Hero ─── */
.gv-ck-hero {
    position: relative; min-height: 420px; padding: 170px 0 100px;
    overflow: hidden; border-radius: 0 0 3rem 3rem;
    box-shadow: 0 20px 50px rgba(0,52,45,0.15);
}
.gv-ck-hero .hero-bg-img { position: absolute; inset: -30px; z-index: 0; }
.gv-ck-hero .hero-bg-img img { width: calc(100% + 60px); height: calc(100% + 60px); object-fit: cover; animation: heroPan 25s ease-in-out infinite alternate; }
@keyframes heroPan { 0%{transform:translate(0,0) scale(1)} 50%{transform:translate(-20px,-10px) scale(1.04)} 100%{transform:translate(-30px,-5px) scale(1.03)} }
.gv-ck-hero .hero-overlay { position: absolute; inset: 0; z-index: 1; background: linear-gradient(160deg, rgba(0,52,45,0.88) 0%, rgba(1,50,32,0.78) 50%, rgba(0,26,18,0.92) 100%); }
.gv-ck-hero::after { content:''; position:absolute; inset:0; z-index:2; background: radial-gradient(circle at 70% 30%, rgba(16,185,129,0.15), transparent 50%), radial-gradient(circle at 20% 70%, rgba(233,193,118,0.08), transparent 40%); pointer-events:none; }

.gv-hero-breadcrumb {
    display: inline-flex; align-items: center; gap: 8px; padding: 0.4rem 1rem;
    background: rgba(160,242,225,0.1); border: 1px solid rgba(160,242,225,0.15);
    border-radius: 2rem; font-size: 0.7rem; font-weight: 700; color: rgba(255,255,255,0.9);
    backdrop-filter: blur(8px); margin-bottom: 1rem; letter-spacing: 0.06em; text-transform: uppercase;
}
.gv-hero-breadcrumb .accent { color: #a0f2e1; }

.gv-hero-title { font-family:'Noto Serif',serif; font-size:clamp(2.2rem,4.5vw,3.5rem); color:#fff; font-weight:700; margin-bottom:0.75rem; position:relative; z-index:3; animation:heroFadeIn 0.8s ease both; }
.gv-hero-title em { color:#a0f2e1; font-style:italic; font-weight:300; }
.gv-hero-sub { color:rgba(160,242,225,0.7); font-size:1.05rem; max-width:560px; line-height:1.6; position:relative; z-index:3; animation:heroFadeIn 0.8s ease 0.2s both; }
@keyframes heroFadeIn { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }

.gv-hero-cta {
    padding: 0.85rem 2rem; background: linear-gradient(135deg, #e9c176, #ca9028); color: #3d2a00;
    border: none; border-radius: 0.75rem; font-weight: 700; font-size: 0.95rem; text-decoration: none;
    display: inline-flex; align-items: center; gap: 0.5rem; transition: all 0.3s;
    box-shadow: 0 10px 25px -5px rgba(233,193,118,0.4); font-family: 'Manrope', sans-serif;
    position: relative; z-index: 3;
}
.gv-hero-cta:hover { transform:translateY(-2px); box-shadow:0 15px 35px -5px rgba(233,193,118,0.5); color:#3d2a00; }

/* ─── Filter Pills ─── */
.gv-ck-container { max-width: 1200px; margin: 0 auto; padding: 2.5rem 2rem 5rem; }

.gv-filter-pills { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2rem; }
.gv-filter-pill {
    padding: 0.6rem 1.25rem; border-radius: 2rem; font-size: 0.85rem; font-weight: 700;
    border: 1.5px solid rgba(0,52,45,0.08); background: #fff; color: #546067;
    text-decoration: none; transition: all 0.25s; display: inline-flex; align-items: center; gap: 0.4rem;
}
.gv-filter-pill:hover { border-color: rgba(0,52,45,0.2); background: rgba(0,52,45,0.03); color: #00342d; }
.gv-filter-pill.active {
    background: linear-gradient(135deg, #00342d, #046b5e); color: #fff; border-color: transparent;
    box-shadow: 0 6px 20px rgba(0,52,45,0.25);
}

.gv-section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
.gv-section-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #546067; display: flex; align-items: center; gap: 0.5rem; }
.gv-section-label .material-symbols-outlined { font-size: 1rem; color: #10B981; }
.gv-count-badge { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.8rem; font-weight: 700; padding: 0.5rem 1.25rem; border-radius: 2rem; background: rgba(0,52,45,0.06); color: #00342d; }

/* ─── Checkout Cards ─── */
.gv-ck-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(360px, 1fr)); gap: 2rem; }
@media (max-width: 768px) { .gv-ck-grid { grid-template-columns: 1fr; } }

.gv-ck-card {
    border-radius: 1.5rem; overflow: hidden; box-shadow: 0 8px 32px rgba(0,52,45,0.08);
    transition: all 0.4s cubic-bezier(0.4,0,0.2,1); position: relative; min-height: 380px;
}
.gv-ck-card:hover { transform: translateY(-8px); box-shadow: 0 24px 60px rgba(0,52,45,0.18); }

.gv-ck-card-bg { position: absolute; inset: 0; z-index: 0; overflow: hidden; }
.gv-ck-card-bg img { width: 130%; height: 130%; object-fit: cover; position: absolute; top: -15%; left: -15%; animation: panCard 14s ease-in-out infinite alternate; transition: transform 0.6s ease; }
.gv-ck-card:hover .gv-ck-card-bg img { transform: scale(1.05); }
.gv-ck-card:nth-child(3n+1) .gv-ck-card-bg img { animation-name: panCard1; }
.gv-ck-card:nth-child(3n+2) .gv-ck-card-bg img { animation-name: panCard2; }
.gv-ck-card:nth-child(3n)   .gv-ck-card-bg img { animation-name: panCard3; }
@keyframes panCard1 { 0%{transform:translate(0%,0%) scale(1)} 100%{transform:translate(-8%,-5%) scale(1.08)} }
@keyframes panCard2 { 0%{transform:translate(-5%,0%) scale(1.05)} 100%{transform:translate(3%,-6%) scale(1)} }
@keyframes panCard3 { 0%{transform:translate(0%,-5%) scale(1)} 100%{transform:translate(-6%,3%) scale(1.06)} }

.gv-ck-card-overlay {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(180deg, rgba(0,52,45,0.72) 0%, rgba(0,40,28,0.82) 50%, rgba(0,20,12,0.94) 100%);
    transition: background 0.4s;
}
.gv-ck-card:hover .gv-ck-card-overlay {
    background: linear-gradient(180deg, rgba(0,52,45,0.62) 0%, rgba(0,40,28,0.72) 50%, rgba(0,20,12,0.90) 100%);
}

.gv-ck-card-body { position: relative; z-index: 2; padding: 1.75rem; display: flex; flex-direction: column; height: 100%; }

.gv-ck-id { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em; color: rgba(255,255,255,0.45); text-transform: uppercase; }
.gv-ck-flight { font-family:'Noto Serif',serif; font-size: 1.3rem; font-weight: 700; color: #fff; text-shadow: 0 2px 8px rgba(0,0,0,0.3); margin-top: 0.25rem; }

.gv-ck-badge { border-radius: 2rem; padding: 0.4rem 1rem; font-size: 0.7rem; font-weight: 800; letter-spacing: 0.05em; text-transform: uppercase; backdrop-filter: blur(8px); }
.gv-ck-badge-pending { background: rgba(233,193,118,0.2); color: #fde68a; border: 1px solid rgba(233,193,118,0.3); }
.gv-ck-badge-confirmed { background: rgba(160,242,225,0.15); color: #a0f2e1; border: 1px solid rgba(160,242,225,0.3); }
.gv-ck-badge-rejected { background: rgba(239,68,68,0.2); color: #fca5a5; border: 1px solid rgba(239,68,68,0.3); }

.gv-ck-meta { font-size: 0.85rem; color: rgba(255,255,255,0.7); margin-top: 1rem; display: flex; flex-direction: column; gap: 0.5rem; }
.gv-ck-meta-item { display: flex; align-items: center; gap: 0.5rem; }
.gv-ck-meta-item .material-symbols-outlined { font-size: 1rem; color: #a0f2e1; }

.gv-ck-summary {
    background: rgba(255,255,255,0.08); backdrop-filter: blur(8px); border-radius: 1rem;
    border: 1px solid rgba(255,255,255,0.1); padding: 1rem 1.25rem; margin-top: 1.25rem;
    display: flex; justify-content: space-between; align-items: center;
}
.gv-ck-total-label { font-size: 0.65rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: rgba(255,255,255,0.45); }
.gv-ck-total { font-family:'Noto Serif',serif; font-size: 1.5rem; font-weight: 700; color: #a0f2e1; text-shadow: 0 2px 12px rgba(160,242,225,0.3); }

.gv-ck-detail-btn {
    padding: 0.55rem 1.25rem; border-radius: 2rem; font-size: 0.8rem; font-weight: 700;
    color: #a0f2e1; border: 1px solid rgba(160,242,225,0.3); background: rgba(255,255,255,0.05);
    text-decoration: none; backdrop-filter: blur(4px); transition: all 0.25s;
    display: inline-flex; align-items: center; gap: 0.3rem;
}
.gv-ck-detail-btn:hover { background: rgba(16,185,129,0.2); border-color: #a0f2e1; color: #fff; }

.gv-ck-actions { display: flex; gap: 0.5rem; margin-top: 0.75rem; }
.gv-ck-action-btn {
    flex: 1; padding: 0.55rem; border-radius: 0.75rem; font-size: 0.8rem; font-weight: 700;
    text-align: center; text-decoration: none; display: inline-flex; align-items: center;
    justify-content: center; gap: 0.3rem; backdrop-filter: blur(4px); transition: all 0.25s;
    font-family: 'Manrope', sans-serif; border: none; cursor: pointer;
}
.gv-ck-action-edit { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.85); border: 1px solid rgba(255,255,255,0.15); }
.gv-ck-action-edit:hover { background: rgba(255,255,255,0.2); border-color: rgba(255,255,255,0.3); color: #fff; }
.gv-ck-action-delete { background: rgba(239,68,68,0.08); color: #fca5a5; border: 1px solid rgba(239,68,68,0.2); }
.gv-ck-action-delete:hover { background: rgba(239,68,68,0.25); border-color: #fca5a5; color: #fff; }

.gv-ck-footer { margin-top: auto; }

/* ─── Empty ─── */
.gv-empty { text-align: center; padding: 5rem 2rem; background: #fff; border-radius: 1.5rem; box-shadow: 0 20px 50px rgba(0,0,0,0.04); grid-column: 1 / -1; }
.gv-empty-icon { font-size: 4rem; color: #cde1db; margin-bottom: 1.5rem; font-variation-settings: 'FILL' 1; }
.gv-empty h4 { font-family:'Noto Serif',serif; font-size: 1.5rem; color: #00342d; font-weight: 700; margin-bottom: 0.5rem; }
.gv-empty p { color: #546067; margin-bottom: 2rem; }

/* ─── Reveal ─── */
.gv-reveal { opacity: 0; transform: translateY(30px); transition: opacity 0.7s cubic-bezier(0.4,0,0.2,1), transform 0.7s cubic-bezier(0.4,0,0.2,1); }
.gv-reveal.is-visible { opacity: 1; transform: translateY(0); }
</style>
{% endblock %}

{% block body %}
{% set cardImages = [
    asset('images/plane_sunset_1.png'),
    asset('images/plane_sunset_2.png'),
    asset('images/plane_sunset_3.png')
] %}

<!-- ─── HERO ─── -->
<section class="gv-ck-hero">
    <div class="hero-bg-img"><img src="{{ asset('images/home-hero5.png') }}" alt=""></div>
    <div class="hero-overlay"></div>
    <div class="container position-relative" style="z-index:3;">
        <div class="row align-items-end g-4">
            <div class="col-lg-8">
                <div class="gv-hero-breadcrumb">
                    <span class="material-symbols-outlined" style="font-size:0.9rem; color:#a0f2e1;">home</span> GoVibe
                    <span class="material-symbols-outlined" style="font-size:0.7rem; opacity:0.5;">chevron_right</span> Vols
                    <span class="material-symbols-outlined" style="font-size:0.7rem; opacity:0.5;">chevron_right</span>
                    <span class="accent">Checkouts</span>
                </div>
                <h1 class="gv-hero-title">Mes réservations <br>de <em>vol</em></h1>
                <p class="gv-hero-sub">Consultez, modifiez ou supprimez vos demandes en attente depuis un espace unique.</p>
            </div>
            <div class="col-lg-4 text-lg-end pb-2" style="position:relative; z-index:3;">
                <a href="{{ path('app_checkout_new') }}" onclick="openDetailModal(this.href); return false;" class="gv-hero-cta">
                    <span class="material-symbols-outlined" style="font-size:1.1rem;">add_circle</span>
                    Nouveau checkout
                </a>
            </div>
        </div>
    </div>
</section>

<!-- ─── CONTENT ─── -->
<section class="gv-ck-container">
    <!-- Filter Pills -->
    <div class="gv-filter-pills">
        <a href="{{ path('app_checkout_index', {status: 'all'}) }}" class="gv-filter-pill {{ currentStatus == 'all' ? 'active' : '' }}">
            <span class="material-symbols-outlined" style="font-size:1rem;">grid_view</span> Tous
        </a>
        <a href="{{ path('app_checkout_index', {status: 'EN_ATTENTE'}) }}" class="gv-filter-pill {{ currentStatus == 'EN_ATTENTE' ? 'active' : '' }}">
            <span class="material-symbols-outlined" style="font-size:1rem;">pending</span> En attente
        </a>
        <a href="{{ path('app_checkout_index', {status: 'CONFIRMEE'}) }}" class="gv-filter-pill {{ currentStatus == 'CONFIRMEE' ? 'active' : '' }}">
            <span class="material-symbols-outlined" style="font-size:1rem;">verified</span> Confirmées
        </a>
        <a href="{{ path('app_checkout_index', {status: 'REFUSEE'}) }}" class="gv-filter-pill {{ currentStatus == 'REFUSEE' ? 'active' : '' }}">
            <span class="material-symbols-outlined" style="font-size:1rem;">cancel</span> Refusées
        </a>
    </div>

    <div class="gv-section-header">
        <span class="gv-section-label">
            <span class="material-symbols-outlined">confirmation_number</span> Vos checkouts
        </span>
        <span class="gv-count-badge">{{ checkouts|length }} résultat{{ checkouts|length > 1 ? 's' : '' }}</span>
    </div>

    <!-- Cards Grid -->
    <div class="gv-ck-grid">
        {% for checkout in checkouts %}
        <div class="gv-ck-card gv-reveal">
            <div class="gv-ck-card-bg"><img src="{{ cardImages[loop.index0 % 3] }}" alt="" loading="lazy"></div>
            <div class="gv-ck-card-overlay"></div>

            <div class="gv-ck-card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div>
                        <div class="gv-ck-id">#{{ checkout.checkoutId }}</div>
                        <h4 class="gv-ck-flight">{{ checkout.flight }}</h4>
                    </div>
                    {% if checkout.statusReservation == 'EN_ATTENTE' %}
                        <span class="gv-ck-badge gv-ck-badge-pending">En attente</span>
                    {% elseif checkout.statusReservation == 'CONFIRMEE' %}
                        <span class="gv-ck-badge gv-ck-badge-confirmed">Confirmée</span>
                    {% else %}
                        <span class="gv-ck-badge gv-ck-badge-rejected">Refusée</span>
                    {% endif %}
                </div>

                <div class="gv-ck-meta">
                    <div class="gv-ck-meta-item">
                        <span class="material-symbols-outlined">calendar_month</span>
                        {{ checkout.reservationDate ? checkout.reservationDate|date('d/m/Y H:i') : '-' }}
                    </div>
                    <div class="gv-ck-meta-item">
                        <span class="material-symbols-outlined">group</span>
                        {{ checkout.passengerNbr }} passager(s)
                    </div>
                    <div class="gv-ck-meta-item">
                        <span class="material-symbols-outlined">credit_card</span>
                        {{ checkout.paymentMethod }}
                    </div>
                </div>

                <div class="gv-ck-footer">
                    <div class="gv-ck-summary">
                        <div>
                            <div class="gv-ck-total-label">Total</div>
                            <span class="gv-ck-total">{{ checkout.totalPrix }} DT</span>
                        </div>
                        <a href="{{ path('app_checkout_show', {checkoutId: checkout.checkoutId}) }}" onclick="openDetailModal(this.href); return false;" class="gv-ck-detail-btn">
                            Détails <span class="material-symbols-outlined" style="font-size:0.9rem;">arrow_forward</span>
                        </a>
                    </div>

                    {% if checkout.statusReservation == 'EN_ATTENTE' %}
                    <div class="gv-ck-actions">
                        <a href="{{ path('app_checkout_edit', {checkoutId: checkout.checkoutId}) }}" onclick="openDetailModal(this.href); return false;" class="gv-ck-action-btn gv-ck-action-edit">
                            <span class="material-symbols-outlined" style="font-size:0.9rem;">edit</span> Modifier
                        </a>
                        <form method="post" action="{{ path('app_checkout_delete', {checkoutId: checkout.checkoutId}) }}" style="flex:1;" onsubmit="return confirm('Supprimer ce checkout ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ checkout.checkoutId) }}">
                            <button class="gv-ck-action-btn gv-ck-action-delete" style="width:100%;">
                                <span class="material-symbols-outlined" style="font-size:0.9rem;">delete</span> Supprimer
                            </button>
                        </form>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
        {% else %}
        <div class="gv-empty">
            <span class="material-symbols-outlined gv-empty-icon">flight_takeoff</span>
            <h4>Aucun checkout trouvé</h4>
            <p>Créez votre première réservation de vol pour commencer.</p>
            <a href="{{ path('app_vols_index') }}" class="gv-hero-cta" style="background:linear-gradient(135deg,#00342d,#046b5e); color:#fff; box-shadow:0 10px 25px -5px rgba(0,52,45,0.4);">
                <span class="material-symbols-outlined" style="font-size:1.1rem;">flight</span>
                Voir les vols
            </a>
        </div>
        {% endfor %}
    </div>
</section>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    var reveals = document.querySelectorAll('.gv-reveal');
    if (reveals.length) {
        var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
                if (entry.isIntersecting) { entry.target.classList.add('is-visible'); observer.unobserve(entry.target); }
            });
        }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });
        reveals.forEach(function(el, i) { el.style.transitionDelay = (i * 80) + 'ms'; observer.observe(el); });
    }
});
</script>
{% endblock %}
{% extends 'base.html.twig' %}

{% block title %}Paiement - GoVibe{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Manrope:wght@200..800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
<style>
body { font-family: 'Manrope', sans-serif !important; background: #fcf9f8 !important; overflow-x: hidden !important; }
.material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24; }

.gv-stripe-container {
    max-width: 800px;
    margin: 100px auto 50px;
    background: #fff;
    border-radius: 24px;
    padding: 40px;
    box-shadow: 0 10px 40px rgba(0,52,45,0.08);
}
.gv-stripe-header {
    text-align: center;
    margin-bottom: 30px;
}
.gv-stripe-header h1 {
    font-family: 'Noto Serif', serif;
    font-size: 2rem;
    color: #00342d;
    margin-bottom: 10px;
}
.gv-stripe-header p {
    color: #6b7280;
    font-size: 1rem;
}
#checkout {
    /* Stripe Elements will dynamically render inside this div */
}
</style>
<script src="https://js.stripe.com/v3/"></script>
{% endblock %}

{% block body %}
<main>
    <div class="container pb-5">
        <div class="gv-stripe-container">
            <div class="gv-stripe-header">
                <h1>Paiement S&eacute;curis&eacute;</h1>
                <p>R&eacute;servation #{{ checkout.checkoutId }} via Stripe</p>
                <div style="font-size:1.5rem; font-weight:800; color:#10B981; margin-top:10px;">{{ checkout.totalPrix }} &euro;</div>
            </div>

            <!-- Stripe UI Element -->
            <div id="checkout"></div>
        </div>
    </div>
</main>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', async () => {
    // Initialize Stripe.js
    const stripe = Stripe('{{ stripePublicKey }}');

    // Create the embedded checkout session
    const fetchClientSecret = async () => {
        return '{{ clientSecret }}';
    };

    const checkout = await stripe.initEmbeddedCheckout({
        fetchClientSecret,
    });

    // Mount Checkout to the DOM
    checkout.mount('#checkout');
});
</script>
{% endblock %}

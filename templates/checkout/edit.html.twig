{% extends 'base.html.twig' %}

{% block title %}Modifier checkout - GoVibe{% endblock %}

{% block body %}
{% if app.request.isXmlHttpRequest %}
    {% include 'checkout/_form_modal.html.twig' with {
        checkout: checkout,
        form: form,
        button_label: 'Mettre à jour',
        page_title: 'Modifier le checkout',
        page_subtitle: 'Mettez à jour les informations de votre réservation.'
    } %}
{% else %}
<section class="go-form-page">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xl-8">
                <div class="go-form-card">
                    <div class="go-form-card-header position-relative overflow-hidden p-4 p-md-5 bg-dark text-white">
                        <div class="position-absolute top-0 start-0 w-100 h-100">
                            <img src="{{ asset('images/dest-paris.png') }}" alt="" class="w-100 h-100 object-fit-cover opacity-50" style="filter: saturate(1.2) hue-rotate(-10deg);">
                        </div>
                        <div class="position-relative" style="z-index:1;">
                            <div style="font-size:12px; font-weight:700; letter-spacing:0.06em; opacity:0.7; text-transform:uppercase; margin-bottom:8px;">
                                <i class="bi bi-ticket-perforated me-1"></i> Gérer la réservation
                            </div>
                            <h2 class="h3 mb-1 fw-bold">Modifier le checkout #{{ checkout.checkoutId }}</h2>
                            <p class="mb-0 text-white-50">Mettez à jour les informations du passager.</p>
                        </div>
                    </div>
                    <div class="go-form-card-body">
                        {% include 'checkout/_form.html.twig' with {button_label: 'Mettre à jour'} %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endif %}
{% endblock %}
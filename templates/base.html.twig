}

function openChatModal() { chatModal.show(); }

function quickCommand(text) {
    document.getElementById('chatInput').value = text;
    sendMessage();
}

// Global voice command trigger (used by page-level shortcut chips)
function voiceCommand(text) {
    gvVoice.processCommand(text);
}

// ── Smart Command Detection ──────────────────────────────────
function detectNavigation(text) {
    const t = text.toLowerCase();
    const navMap = [
        { keys: ['vol', 'flight', 'avion', 'billet'], route: 'vols', label: 'Vols', icon: '✈️' },
        { keys: ['hotel', 'hôtel', 'hébergement', 'chambre'], route: 'hotels', label: 'Hôtels', icon: '🏨' },
        { keys: ['voiture', 'car', 'location', 'louer'], route: 'voitures', label: 'Voitures', icon: '🚗' },
        { keys: ['activit', 'excursion', 'visite', 'loisir'], route: 'activites', label: 'Activités', icon: '🎯' },
        { keys: ['checkout', 'réservation de vol', 'mes checkout'], route: 'checkout', label: 'Checkouts', icon: '🎫' },
        { keys: ['réservation', 'booking', 'mes réserv'], route: 'reservations', label: 'Réservations', icon: '📋' },
        { keys: ['profil', 'mon compte', 'paramètres'], route: 'profil', label: 'Mon Profil', icon: '👤' },
        { keys: ['accueil', 'home', 'page principale'], route: 'accueil', label: 'Accueil', icon: '🏠' },
        { keys: ['publication', 'post', 'forum', 'blog'], route: 'publications', label: 'Publications', icon: '📝' },
        { keys: ['réclamation', 'plainte', 'problème'], route: 'reclamations', label: 'Réclamations', icon: '📢' },
    ];
    for (const nav of navMap) {
        for (const key of nav.keys) {
            if (t.includes(key)) return nav;
        }
    }
    return null;
}

function addNavigationChip(container, nav) {
    const chip = document.createElement('span');
    chip.className = 'gv-action-chip';
    chip.innerHTML = `${nav.icon} Aller vers ${nav.label}`;
    chip.onclick = () => { chatModal.hide(); window.location.href = _gvAiNavRoutes[nav.route]; };
    container.appendChild(chip);
}

// ── Destination-aware flight search ──────────────────────────
function extractDestination(text) {
    const t = text.toLowerCase();
    const patterns = [/(?:vol|flight|aller|voyager|partir)\s+(?:à|a|vers|pour|to)\s+([a-zàâéèêëïîôùûüç\s-]+)/i,
                      /(?:destination|direction)\s+([a-zàâéèêëïîôùûüç\s-]+)/i];
    for (const p of patterns) {
        const m = t.match(p);
        if (m) return m[1].trim();
    }
    return null;
}

// ── Main send ────────────────────────────────────────────────
function sendMessage() {
    const input = document.getElementById('chatInput');
    const text = input.value.trim();
    if (!text) return;

    if (_gvIsGreeting(text)) {
        const greetingReply = 'Hello sir, how can I help you?';
        appendMessage('user', text);
        input.value = '';
        appendMessage('ai', greetingReply);
        speakText(greetingReply);
        return;
    }

    appendMessage('user', text);
    input.value = '';

    // Detect navigation intent
    const nav = detectNavigation(text);
    const dest = extractDestination(text);

    const indicator = showTypingIndicator();
    const model = document.getElementById('aiModelSelectorValue').value;
    if (model === 'voice') { callVoiceAssistant(text, false, indicator); return; }

    const route = model === 'groq' ? '{{ path('app_groq_chat') }}' : '{{ path('app_gemini_chat') }}';

    fetch(route, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify({ message: text })
    })
    .then(r => r.json())
    .then(data => {
        indicator.remove();
        if (data.error) { appendMessage('ai', 'Erreur : ' + data.error); return; }
        const msgEl = appendMessage('ai', data.response);

        // Auto-navigation capability
        const isSuggestion = data.response && data.response.includes('[POST_SUGGESTION]');
        if (nav && msgEl && !isSuggestion) {
            let targetUrl = _gvAiNavRoutes[nav.route];
            let label = nav.label;
            if (dest && nav.route === 'vols') {
                targetUrl += '?destination=' + encodeURIComponent(dest);
                label = 'Vols vers ' + dest;
            }
            
            // Add visual indication
            const chip = document.createElement('div');
            chip.className = 'mt-3 p-2 bg-success text-white rounded-3 small fw-bold d-inline-block shadow-sm';
            chip.innerHTML = `${nav.icon || '🚀'} Redirection vers ${label}... <div class="spinner-border spinner-border-sm text-light ms-2" role="status"></div>`;
            msgEl.appendChild(chip);

            // Auto-navigate after a short delay so the user hears/sees the response
            // [FIX] Disable auto-redirect for publications to allow reading the AI suggestion
            if (nav.route !== 'publications') {
                setTimeout(() => {
                    const cm = document.getElementById('chatModal');
                    if (cm && window.bootstrap) { 
                        const m = bootstrap.Modal.getInstance(cm);
                        if (m) m.hide();
                    }
                    window.location.href = targetUrl;
                }, 3500);
            } else {
                // For publications, just update the chip to be a clickable link without timer
                chip.innerHTML = `${nav.icon || '📝'} Cliquez ici pour voir les ${nav.label}`;
                chip.style.cursor = 'pointer';
                chip.onclick = () => {
                    window.location.href = targetUrl;
                };
            }
        }


                // Speak the AI response aloud
        speakText(data.response);

                // [Grok Feature] Automatic modal open if suggestion found
        if (model === 'groq' && isSuggestion) {
            // Add a small notification chip to the message
            const waitChip = document.createElement('div');
            waitChip.className = 'mt-2 p-2 rounded-3 small fw-bold d-inline-block animate-fade-in';
            waitChip.style.background = 'rgba(16, 185, 129, 0.1)';
            waitChip.style.color = '#10b981';
            waitChip.innerHTML = '<i class="bi bi-clock-history me-1"></i> Préparation du formulaire...';
            msgEl.appendChild(waitChip);

            setTimeout(() => {
                try {
                    const block = data.response.split('[POST_SUGGESTION]')[1].split('[/POST_SUGGESTION]')[0];
                    const jsonStr = block.replace(/```json\s*|\s*```/g, '').trim();
                    const suggestion = JSON.parse(jsonStr);
                    if (window.fillPostForm) {
                        // Pass false to NOT hide the chat modal automatically
                        window.fillPostForm(suggestion, false);
                        waitChip.innerHTML = '<i class="bi bi-check-circle-fill me-1"></i> Formulaire prêt !';
                        waitChip.style.background = 'rgba(16, 185, 129, 0.2)';
                    }
                } catch (e) {
                    console.error('Failed to auto-open post modal:', e);
                }
            }, 3500); // Increased to 3.5s so they can read the response
        }
    })
    .catch(() => {
        indicator.remove();
        appendMessage('ai', 'Désolé, une erreur de connexion est survenue.');
    });
}

// ── Voice Assistant ──────────────────────────────────────────
function callVoiceAssistant(text, confirmed, indicator) {
    fetch('{{ path('app_api_python_assistant_flow') }}', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify({ user_input: text, confirmed: confirmed })
    })
    .then(r => r.json())
    .then(data => {
        indicator.remove();
        if (data.error) { appendMessage('ai', 'Voice Agent: ' + data.error); return; }
        const payload = data.data || {}, plan = payload.plan || {};
        if (payload.requires_confirmation && !confirmed) {
            const reason = payload.confirmation_prompt || plan.reason || 'Cette commande demande une confirmation.';
            appendMessage('ai', 'Plan sécurisé (dry-run): ' + reason);
            if (window.confirm(reason + '\n\nConfirmer l\'exécution ?')) {
                callVoiceAssistant(text, true, showTypingIndicator());
            } else { appendMessage('ai', 'Commande annulée.'); }
            return;
        }
        appendMessage('ai', formatVoiceAssistantResponse(payload));
        speakText(getVoiceReplyText(payload));
    })
    .catch(() => { indicator.remove(); appendMessage('ai', 'Voice Agent indisponible actuellement.'); });
}
function formatVoiceAssistantResponse(p) {
    const e = p.execution||{}, plan = p.plan||e.plan||{};
    return `Intent: ${p.intent||e.intent||'unknown'}\nRéponse: ${getVoiceReplyText(p)}\nPlan: blocked=${plan.blocked?'oui':'non'}, confirmation=${plan.requires_confirmation?'oui':'non'}\nReason: ${plan.reason||'—'}`;
}
function getVoiceReplyText(p) {
    const e = p.execution||{};
    return e.response||e.message||e.output||e.result||'Commande traitée.';
}

function updateWelcomeMessage(model) {
    const f = document.querySelector('#chatMessages .chat-message.ai');
    if (!f) return;
    if (model==='voice') { f.innerHTML = "Bonjour ! Je suis <b>Voice Agent</b>. Je prépare vos commandes en mode sécurisé avant exécution."; return; }
    if (model==='groq') { f.innerHTML = "Bonjour ! Je suis <b>Groq</b>, assistant voyage ultra-rapide. Que souhaitez-vous faire ?"; return; }
    f.innerHTML = 'Bonjour ! Je suis votre assistant voyage <b>GoVibe AI</b>. 🌍✈️<br><br>Je peux vous aider à :<div style="margin-top:8px;display:flex;flex-wrap:wrap;gap:4px;"><span class="gv-action-chip" onclick="quickCommand(\'Trouve un vol pas cher\')">✈️ Trouver un vol</span><span class="gv-action-chip" onclick="quickCommand(\'Meilleur hôtel\')">🏨 Hôtels</span><span class="gv-action-chip" onclick="quickCommand(\'Mes réservations\')">📋 Réservations</span></div>';
}

// ── Voice: Enhanced with visual feedback ─────────────────────
async function startVoiceInput() {
    const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (!SR) { appendMessage('ai', 'La reconnaissance vocale n\'est pas supportée sur ce navigateur.'); return; }

    const mic = await _gvEnsureMicAccess();
    if (!mic.ok) {
        appendMessage('ai', mic.message);
        return;
    }

    const langs = _gvVoiceRecognitionLangs();
    let langIdx = 0;
    const r = new SR();
    r.lang = langs[langIdx];
    r.interimResults = true;
    r.maxAlternatives = 1;
    r.continuous = true;
    const micBtn = document.getElementById('voiceMicBtn');
    const status = document.getElementById('voiceStatus');
    let retryCount = 0;

    r.onstart = () => {
        if (micBtn) micBtn.classList.add('gv-voice-recording');
        if (status) { status.style.display = 'block'; status.innerHTML = '<span class="gv-voice-status">🎙️ Écoute en cours...</span>'; }
    };
    r.onend = () => {
        if (micBtn) micBtn.classList.remove('gv-voice-recording');
        if (status) status.style.display = 'none';
    };
    r.onresult = (event) => {
        let transcript = '';
        for (let i = event.resultIndex; i < event.results.length; i++) {
            if (event.results[i].isFinal) {
                transcript += (event.results[i][0]?.transcript || '') + ' ';
            }
        }
        transcript = transcript.trim();
        if (transcript) { document.getElementById('chatInput').value = transcript; sendMessage(); }
    };
    r.onerror = (e) => {
        if (micBtn) micBtn.classList.remove('gv-voice-recording');
        if (status) status.style.display = 'none';
        if (e.error !== 'aborted') {
            const code = e && e.error ? e.error : 'unknown';
            if (code === 'no-speech' && retryCount < 2) {
                retryCount += 1;
                langIdx = Math.min(langIdx + 1, langs.length - 1);
                r.lang = langs[langIdx];
                appendMessage('ai', 'Je n\'ai rien capte, je relance l\'ecoute automatiquement... (' + r.lang + ')');
                _gvRecalibrateNoiseProfile();
                setTimeout(() => { try { r.start(); } catch (_) {} }, 400);
                return;
            }
            appendMessage('ai', _gvVoiceErrorMessage(code) + ' (code: ' + code + ')');
        }
    };
    r.start();
}

window._speechUtterances = window._speechUtterances || [];
function detectLanguage(text) {
    const enWords = /\b(the|is|and|with|for|to|of|in|this|that|are|you|we)\b/gi;
    const frWords = /\b(le|la|les|de|des|un|une|et|est|avec|pour|ce|cette|vous|nous|pas)\b/gi;
    const enCount = (text.match(enWords) || []).length;
    const frCount = (text.match(frWords) || []).length;
    return enCount > frCount ? 'en' : 'fr';
}

function speakText(text) {
    if (!window.speechSynthesis || !text || !_gvTtsEnabled) return;
    let clean = text
        .replace(/[\u{1F600}-\u{1F9FF}\u{2600}-\u{2B55}\u{1F300}-\u{1F5FF}\u{1F680}-\u{1F6FF}]/gu, '')
        .replace(/https?:\/\/[^\s]+/g, '').replace(/[*_`#>\[\]]/g, '').replace(/\n+/g, '. ').trim();
    if (!clean || clean.length < 3) return;
    if (clean.length > 250) clean = clean.substring(0, 250) + '...';

    gvVoice.setState('speaking');
    window.speechSynthesis.cancel();
    
    const lang = detectLanguage(clean);
    const u = new SpeechSynthesisUtterance(clean);
    u.rate = 1.05; u.pitch = 1.0; u.volume = 1.0;
    
    if (lang === 'en') {
        u.lang = 'en-US';
        if (_gvEnglishVoice) u.voice = _gvEnglishVoice;
    } else {
        u.lang = 'fr-FR';
        if (_gvFrenchVoice) u.voice = _gvFrenchVoice;
    }

    // Prevent GC bug in Chrome that stops onend from firing
    window._speechUtterances.push(u);

    const status = document.getElementById('voiceStatus');
    if (status) { status.style.display = 'block'; status.innerHTML = '<span class="gv-voice-status" style="color:#10b981; padding: 4px 10px; background: rgba(16, 185, 129, 0.1); border-radius: 12px; margin-bottom: 8px; display: inline-block;">🔊 GoVibe parle...</span>'; }
    
    u.onend = () => { 
        if (status) status.style.display = 'none'; 
        gvVoice.setState('idle'); 
        window._speechUtterances = window._speechUtterances.filter(item => item !== u);
        if (typeof gvVoice !== 'undefined' && gvVoice.wasListeningBeforeSpeak) {
            gvVoice.wasListeningBeforeSpeak = false;
            setTimeout(() => gvVoice.startListening(), 300);
        }
    };
    u.onerror = () => { 
        if (status) status.style.display = 'none'; 
        gvVoice.setState('idle'); 
        window._speechUtterances = window._speechUtterances.filter(item => item !== u);
    };

    window.speechSynthesis.speak(u);
}

function toggleTts() {
    _gvTtsEnabled = !_gvTtsEnabled;
    const btn = document.getElementById('ttsToggleBtn');
    if (btn) {
        const icon = btn.querySelector('.material-symbols-outlined');
        if (icon) icon.textContent = _gvTtsEnabled ? 'volume_up' : 'volume_off';
        btn.title = _gvTtsEnabled ? 'Couper la voix' : 'Activer la voix';
        btn.style.color = _gvTtsEnabled ? '#10b981' : '#94a3b8';
    }
    if (!_gvTtsEnabled && window.speechSynthesis) window.speechSynthesis.cancel();
}

// ── Append Message (with navigation intelligence) ────────────
function appendMessage(type, text) {
    const container = document.getElementById('chatMessages');
    const msg = document.createElement('div');
    msg.className = `chat-message ${type}`;

    if (type === 'ai' && typeof text === 'string' && text.includes('[POST_SUGGESTION]')) {
        const parts = text.split('[POST_SUGGESTION]');
        const normalText = parts[0];
        let suggestionBlock = parts[1].split('[/POST_SUGGESTION]')[0];
        try {
            const suggestion = JSON.parse(suggestionBlock);
            const safeSuggestion = suggestionBlock.replace(/'/g, "&apos;");
            msg.innerHTML = `<div>${parseMarkdown(normalText)}</div>
                <div class="mt-3 p-3 bg-white border rounded-3 shadow-sm" style="color:#00342d;">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <span class="material-symbols-outlined text-success" style="font-size:1.1rem;">auto_awesome</span>
                        <span class="fw-bold small">Suggestion de Publication</span>
                    </div>
                    <div class="small mb-3 text-muted" style="font-style:italic;">"${suggestion.contenu.substring(0, 80)}..."</div>
                    <button class="btn btn-sm btn-success w-100 rounded-pill py-2 fw-bold" onclick='fillPostForm(${safeSuggestion})'>Remplir le formulaire</button>
                </div>
                <div class="mt-2"><button class="btn btn-sm text-muted px-0" style="font-size:0.75rem;" onclick="speakText(this.dataset.rawText)"><i class="bi bi-volume-up-fill me-1"></i>Lire à haute voix</button></div>`;
            msg.querySelector('button.text-muted').dataset.rawText = normalText;
        } catch (e) { 
            msg.innerHTML = parseMarkdown(text) + `<div class="mt-2"><button class="btn btn-sm text-muted px-0" style="font-size:0.75rem;" onclick="speakText(this.dataset.rawText)"><i class="bi bi-volume-up-fill me-1"></i>Lire à haute voix</button></div>`; 
            msg.querySelector('button.text-muted').dataset.rawText = text; 
        }
    } else {
        if (type === 'ai') {
            msg.innerHTML = parseMarkdown(text) + `<div class="mt-2"><button class="btn btn-sm text-muted px-0" style="font-size:0.75rem;" onclick="speakText(this.dataset.rawText)"><i class="bi bi-volume-up-fill me-1"></i>Lire à haute voix</button></div>`;
            msg.querySelector('button.text-muted').dataset.rawText = text;
        } else {
            msg.textContent = text;
        }
    }
    container.appendChild(msg);
    container.scrollTop = container.scrollHeight;
    return msg;
}

function parseMarkdown(text) {
    if (!text) return '';
    let html = text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    html = html.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
    html = html.replace(/\*(.*?)\*/g, '<em>$1</em>');
    html = html.replace(/`(.*?)`/g, '<code style="background:#f1f5f9;padding:2px 4px;border-radius:4px;color:#0f172a;">$1</code>');
    html = html.replace(/\n\n/g, '<br><br>');
    return html;
}

function fillPostForm(data, hideChat = true) {
    if (!data) return;
    
    // Determine the correct creation URL: forum context or general feed
    const forumId = window.GV_CURRENT_FORUM_ID || null;
    const newPostUrl = forumId 
        ? `{{ path('app_poste_new') }}/${forumId}`
        : '{{ path('app_poste_new') }}';

    // Open the creation modal with the right URL
    if (window.openPostModal) {
        window.openPostModal(newPostUrl);
    }
    
    // Hide the chat ONLY if requested (usually for manual clicks)
    if (hideChat) {
        const cm = document.getElementById('chatModal');
        if (cm) {
            const modal = bootstrap.Modal.getInstance(cm);
            if (modal) modal.hide();
        }
        if (typeof chatModal !== 'undefined' && chatModal && chatModal.hide) chatModal.hide();
    }

    let attempts = 0;
    const maxAttempts = 50; // 5 seconds max

    const checkExist = setInterval(() => {
        attempts++;
        const form = document.querySelector('#publication-form');
        if (form) {
            clearInterval(checkExist);
            
            const textarea = form.querySelector('textarea#poste_contenu') || form.querySelector('textarea');
            const locInput = document.getElementById('localisation-search') || form.querySelector('#poste_localisation');
            const typeInput = form.querySelector('#poste_type') || document.getElementById('poste_type');

            
            if (textarea) {
                textarea.value = data.contenu || '';
                textarea.dispatchEvent(new Event('input', { bubbles: true }));
            }
            
            if (locInput) {
                locInput.value = data.localisation || '';
                locInput.dispatchEvent(new Event('change', { bubbles: true }));
            }

            if (data.type === 'MEDIA') {
                if (data.imageUrl) {
                    const extInput = document.getElementById('poste_externalImageUrl');
                    const fakeInput = document.getElementById('fake-file-input');
                    if (extInput) {
                        extInput.value = data.imageUrl;
                        extInput.dispatchEvent(new Event('input', { bubbles: true }));
                    }
                    if (fakeInput) {
                        fakeInput.value = "Image suggérée par l'IA";
                    }
                    
                    // Force preview update before mode switch
                    const imgP = document.getElementById('image-preview');
                    const pc = document.getElementById('preview-image-container');
                    const np = document.getElementById('no-preview');
                    if (imgP) {
                        imgP.src = data.imageUrl;
                        if (pc) pc.style.display = 'block';
                        if (np) np.style.display = 'none';
                    }
                }
                
                // Now switch to photo mode
                const btnPhoto = document.getElementById('btn-photo-video');
                if (btnPhoto) btnPhoto.click();
            } else {
                const bt = document.getElementById('btn-status-texte');
                if (bt) bt.click();
            }

            
            // Highlight the filled fields briefly
            if (textarea) {
                textarea.style.transition = 'background 0.5s';
                textarea.style.background = 'rgba(16, 185, 129, 0.1)';
                setTimeout(() => textarea.style.background = '', 1500);
            }
        } 
        
        if (attempts >= maxAttempts) {
            clearInterval(checkExist);
            console.error('AI Fill: Form not found after timeout');
        }
    }, 100);
}


    function showTypingIndicator() {
        const c = document.getElementById('chatMessages');
        const d = document.createElement('div');
        d.className = 'chat-message ai';
        d.innerHTML = '<div class="typing-indicator"><div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div></div>';
        c.appendChild(d); c.scrollTop = c.scrollHeight;
        return d;
    }

    // --- Mentions Manager ---
    const MentionsManager = {
        activeInput: null, listEl: null, query: '', selectedIndex: -1, users: [], _fetchTimer: null,
        init() {
            document.addEventListener('input', (e) => {
                const tag = e.target.tagName;
                if (tag === 'TEXTAREA' || (tag === 'INPUT' && e.target.type === 'text')) { this.handleInput(e); }
            }, true);
            document.addEventListener('keydown', (e) => this.handleKeyDown(e), true);
            document.addEventListener('click', (e) => { if (this.listEl && !this.listEl.contains(e.target)) this.close(); });
        },
        handleInput(e) {
            const input = e.target, cursor = input.selectionStart;
            const text = input.value.substring(0, cursor), match = text.match(/@(\w*)$/);
            if (match) {
                this.activeInput = input; this.query = match[1]; this.showList();
                clearTimeout(this._fetchTimer);
                this._fetchTimer = setTimeout(() => this.fetchUsers(this.query), 300);
            } else if (this.listEl) { this.close(); }
        },
        async fetchUsers(q) {
            try {
                const res = await fetch(`{{ path('api_users_search') }}?q=${q}`);
                this.users = await res.json(); this.renderList();
            } catch (err) {}
        },
                        showList() {
            if (!this.listEl) {
                this.listEl = document.createElement('div');
                this.listEl.className = 'gv-mentions-list';
                this.listEl.style.position = 'fixed';
                this.listEl.style.zIndex = '999999';
            }
            document.body.appendChild(this.listEl);
            this.positionList();
        },
        positionList() {
            if (!this.activeInput || !this.listEl) return;
            const rect = this.activeInput.getBoundingClientRect();
            this.listEl.style.top = (rect.bottom + 4) + 'px';
            this.listEl.style.left = rect.left + 'px';
            this.listEl.style.width = rect.width + 'px';
        },
        renderList() {
            if (!this.listEl) return;
            if (this.users.length === 0) { this.listEl.innerHTML = '<div class="p-3 text-muted small text-center">Aucun utilisateur trouvé</div>'; return; }
            this.listEl.innerHTML = this.users.map((u, i) => `
                <div class="gv-mention-item ${i === this.selectedIndex ? 'active' : ''}" data-index="${i}">
                    <img src="${u.photo || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(u.name)}" class="gv-mention-avatar">
                    <div class="gv-mention-info"><span class="gv-mention-name">${u.name}</span><span class="gv-mention-tag">@${u.tag}</span></div>
                </div>`).join('');
            this.listEl.querySelectorAll('.gv-mention-item').forEach(item => {
                item.addEventListener('click', (e) => { e.preventDefault(); e.stopPropagation(); this.selectUser(parseInt(item.dataset.index)); });
            });
        },
        handleKeyDown(e) {
            if (!this.listEl) return;
            if (e.key === 'ArrowDown') { e.preventDefault(); this.selectedIndex = (this.selectedIndex + 1) % this.users.length; this.renderList(); }
            else if (e.key === 'ArrowUp') { e.preventDefault(); this.selectedIndex = (this.selectedIndex - 1 + this.users.length) % this.users.length; this.renderList(); }
            else if (e.key === 'Enter' && this.selectedIndex >= 0) { e.preventDefault(); this.selectUser(this.selectedIndex); }
            else if (e.key === 'Escape') { this.close(); }
        },
        selectUser(index) {
            const user = this.users[index]; if (!user || !this.activeInput) return;
            const cursor = this.activeInput.selectionStart, text = this.activeInput.value;
            const before = text.substring(0, cursor).replace(/@\w*$/, `@${user.tag} `), after = text.substring(cursor);
            this.activeInput.value = before + after; this.activeInput.focus();
            this.activeInput.setSelectionRange(before.length, before.length);
            this.activeInput.dispatchEvent(new Event('input', { bubbles: true }));
            this.close();
        },
        close() { if (this.listEl) { this.listEl.remove(); this.listEl = null; } this.activeInput = null; this.users = []; this.selectedIndex = -1; }
    };

    function highlightMentions() {
        document.querySelectorAll('.post-text, .comment-bubble p').forEach(el => {
            if (el.dataset.mentionsProcessed) return;
            el.innerHTML = el.innerHTML.replace(/(@[a-zA-Z0-9_]+)/g, '<span class="text-primary fw-bold" style="color:#22c55e !important;">$1</span>');
            el.dataset.mentionsProcessed = 'true';
        });
    }

    document.addEventListener('DOMContentLoaded', () => {
        MentionsManager.init();
        highlightMentions();
        new MutationObserver(() => highlightMentions()).observe(document.body, { childList: true, subtree: true });
    });
</script>

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}GoVibe{% endblock %}</title>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        :root {
            --primary-emerald: #50C878;
            --dark-green: #013220;
            --mid-green: #084E36;
            --light-green: #2E8B57;
            --bg-creme: #F5F3E7;
            --bg-footer: #002211;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-creme);
            color: #333;
            padding-top: 0;
        }

        h1, h2, h3, h4, h5, h6 { font-family: 'Outfit', sans-serif; }

        /* --- Floating Header Navbar --- */
        .govibe-navbar {
            position: absolute;
            top: 0; left: 0; width: 100%; z-index: 1030;
            background: linear-gradient(180deg, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0) 100%);
            padding: 15px 0; transition: all 0.3s ease;
        }

        .govibe-navbar.scrolled {
            position: fixed; background: var(--dark-green);
            box-shadow: 0 4px 20px rgba(0,0,0,0.2); padding: 10px 0;
        }

        .navbar-brand { font-family: 'Outfit', sans-serif; font-weight: 700; font-size: 26px; color: var(--primary-emerald) !important; display: flex; align-items: center; gap: 10px; }
        .brand-logo-circle { width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg, var(--primary-emerald), var(--light-green)); display: flex; align-items: center; justify-content: center; color: white; font-size: 18px; }

        .nav-link { color: rgba(255, 255, 255, 0.9) !important; font-weight: 500; font-size: 15px; margin: 0 10px; transition: all 0.2s ease; position: relative; }
        .nav-link:hover, .nav-link.active { color: var(--primary-emerald) !important; }
        .nav-link::after { content: ''; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 0; height: 2px; background-color: var(--primary-emerald); transition: width 0.3s ease; }
        .nav-link:hover::after, .nav-link.active::after { width: 100%; }

        /* User Menu */
        .user-dropdown-btn { background: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255, 255, 255, 0.2); color: white; border-radius: 30px; padding: 6px 16px 6px 6px; display: flex; align-items: center; gap: 10px; transition: all 0.2s ease; }
        .user-dropdown-btn:hover { background: rgba(255, 255, 255, 0.2); color: white; }
        .user-avatar { width: 32px; height: 32px; border-radius: 50%; background: var(--primary-emerald); display: flex; align-items: center; justify-content: center; font-weight: bold; color: white; }

        /* --- Global Footer --- */
        .govibe-footer { background-color: var(--bg-footer); color: rgba(255, 255, 255, 0.7); padding: 40px 0 20px; margin-top: 60px; }
        .footer-brand { color: var(--primary-emerald); font-family: 'Outfit', sans-serif; font-size: 24px; font-weight: 700; margin-bottom: 15px; display: block; }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>

    {% block header %}
    <nav class="navbar navbar-expand-lg govibe-navbar" id="mainNav">
        <div class="container">
            <a class="navbar-brand" href="{{ path('app_user_home') }}">
                <img src="{{ asset('images/logo.png') }}" alt="GV" style="width: 40px; height: 40px; object-fit: contain; margin-right: 10px;"> GoVibe
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <i class="bi bi-list text-white fs-2"></i>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item"><a class="nav-link active" href="{{ path('app_user_home') }}">Accueil</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_activite_index') }}">Activités</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_session_index') }}">Sessions</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_reservation_session_index') }}">Réservations</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Voitures</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Vols</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Hôtels</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_poste_index') }}">Forums</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_reclamation_index') }}">Réclamations</a></li>
                </ul>
                <div class="d-flex align-items-center">
                    {% if app.user %}
                        <div class="dropdown">
                            <button class="btn user-dropdown-btn dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                <div class="user-avatar">{{ app.user.prenom|first|upper }}</div>
                                <span>{{ app.user.prenom }}</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3 mt-2">
                                <li><a class="dropdown-item" href="{{ path('app_user_profile') }}"><i class="bi bi-person me-2"></i> Mon Profil</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right me-2"></i> Déconnexion</a></li>
                            </ul>
                        </div>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="btn btn-outline-light rounded-pill px-4">Connexion</a>
                    {% endif %}
                </div>
            </div>
        </div>
    </nav>
    {% endblock %}

    {% block body %}{% endblock %}

    {% block footer %}
    <footer class="govibe-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <span class="footer-brand">GoVibe</span>
                    <p>Vivez l'aventure, explorez le monde. Votre partenaire de voyage intelligent.</p>
                </div>
                <div class="col-lg-2 offset-lg-2">
                    <h5 class="text-white mb-3">Découvrir</h5>
                    <ul class="list-unstyled">
                        <li><a href="#" class="text-decoration-none text-secondary">Destinations</a></li>
                        <li><a href="#" class="text-decoration-none text-secondary">Aventures</a></li>
                        <li><a href="#" class="text-decoration-none text-secondary">Événements</a></li>
                    </ul>
                </div>
                <div class="col-lg-2">
                    <h5 class="text-white mb-3">Support</h5>
                    <ul class="list-unstyled">
                        <li><a href="#" class="text-decoration-none text-secondary">Contact</a></li>
                        <li><a href="#" class="text-decoration-none text-secondary">FAQ</a></li>
                        <li><a href="{{ path('app_reclamation_index') }}" class="text-decoration-none text-secondary">Réclamations</a></li>
                    </ul>
                </div>
            </div>
            <div class="border-top border-secondary mt-5 pt-4 text-center">
                <p class="mb-0">&copy; 2026 GoVibe. Tous droits réservés.</p>
            </div>
        </div>
    </footer>
    {% endblock %}

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            var navbar = document.getElementById("mainNav");
            window.addEventListener("scroll", function() {
                if (window.scrollY > 50) {
                    navbar.classList.add("scrolled");
                } else {
                    navbar.classList.remove("scrolled");
                }
            });
        });
    </script>
    {% block javascripts %}{% endblock %}
</body>
</html>

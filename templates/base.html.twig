<!DOCTYPE html>
<html lang="{{ app.request.locale|default('fr') }}" dir="{{ app.request.locale|default('fr') starts with 'ar' ? 'rtl' : 'ltr' }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}GoVibe{% endblock %}</title>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <!-- Material Symbols -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet">

    <style>
        /* ═══════════════════════════════════════════════════
           GoVibe — Professional Green Theme
           Emerald green palette + tropical background
        ═══════════════════════════════════════════════════ */

        :root {
            --primary-emerald: #22c55e;
            --dark-green: #013220;
            --mid-green: #084E36;
            --light-green: #2E8B57;
            --accent-green: #16a34a;
            --soft-green: #dcfce7;
            --bg-creme: #F5F3E7;
            --bg-footer: #002211;
            --glass-card: rgba(255, 255, 255, 0.92);
            --shadow-green: rgba(1, 50, 32, 0.12);
            --text-primary: #0f172a;
            --text-secondary: #475569;
            --text-muted: #94a3b8;
        }

        * {
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: linear-gradient(165deg, rgba(1, 50, 32, 0.45), rgba(5, 35, 24, 0.35)),
                        url('{{ asset('images/home-hero5.png') }}') center/cover fixed no-repeat;
            color: #333;
            padding-top: 0;
            min-height: 100vh;
        }



        body[dir="rtl"] {
            direction: rtl;
            text-align: right;
        }
        h1, h2, h3, h4, h5, h6 {
            font-family: 'Outfit', sans-serif;
            letter-spacing: -0.02em;
        }

        /* ─── Floating Header Navbar ─── */
        .govibe-navbar {
            position: absolute;
            top: 0; left: 0; width: 100%; z-index: 1030;
            background: linear-gradient(180deg, rgba(1, 50, 32, 0.7) 0%, rgba(0,0,0,0) 100%);
            padding: 18px 0;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body[dir="rtl"] .navbar-brand {
            flex-direction: row-reverse;
        }

        body[dir="rtl"] .navbar-nav {
            text-align: right;
        }

        .govibe-navbar.scrolled {
            position: fixed;
            background: rgba(1, 50, 32, 0.95);
            backdrop-filter: blur(20px) saturate(180%);
            -webkit-backdrop-filter: blur(20px) saturate(180%);
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.15);
            padding: 12px 0;
        }

        .navbar-brand {
            font-family: 'Outfit', sans-serif;
            font-weight: 800;
            font-size: 26px;
            color: var(--primary-emerald) !important;
            display: flex;
            align-items: center;
            gap: 10px;
            letter-spacing: -0.03em;
        }

        .brand-logo-circle {
            width: 40px; height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary-emerald), var(--light-green));
            display: flex; align-items: center; justify-content: center;
            color: white; font-size: 18px;
            box-shadow: 0 4px 15px rgba(34, 197, 94, 0.35);
        }

        .nav-link {
            color: rgba(255, 255, 255, 0.85) !important;
            font-weight: 500; font-size: 15px;
            margin: 0 8px; padding: 8px 14px !important;
            border-radius: 12px;
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
        }

        .nav-link:hover, .nav-link.active {
            color: #fff !important;
            background: rgba(34, 197, 94, 0.15);
        }

        .nav-link::after {
            content: '';
            position: absolute;
            bottom: 2px; left: 50%;
            transform: translateX(-50%);
            width: 0; height: 2px;
            background: linear-gradient(90deg, var(--primary-emerald), var(--light-green));
            border-radius: 2px;
            transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .nav-link:hover::after, .nav-link.active::after { width: 60%; }

        /* User Menu */
        .user-dropdown-btn {
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.15);
            color: white;
            border-radius: 30px;
            padding: 6px 16px 6px 6px;
            display: flex; align-items: center; gap: 10px;
            transition: all 0.25s ease;
            backdrop-filter: blur(8px);
        }

        .user-dropdown-btn:hover {
            background: rgba(34, 197, 94, 0.2);
            border-color: rgba(34, 197, 94, 0.3);
            color: white;
        }

        /* Global Search Bar */
        .gv-global-search {
            position: relative;
            margin-right: 15px;
            width: 280px;
        }
        .gv-global-search input {
            width: 100%;
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 30px;
            padding: 8px 16px 8px 38px;
            color: white;
            font-size: 14px;
            transition: all 0.3s ease;
            backdrop-filter: blur(8px);
        }
        .gv-global-search input::placeholder { color: rgba(255,255,255,0.6); }
        .gv-global-search input:focus {
            background: rgba(255, 255, 255, 0.95);
            color: #013220;
            outline: none;
            box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.2);
        }
        .gv-global-search input:focus::placeholder { color: #64748b; }
        .gv-global-search .material-symbols-outlined {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 18px;
            color: rgba(255,255,255,0.7);
            transition: color 0.3s ease;
        }
        .gv-global-search input:focus ~ .material-symbols-outlined { color: var(--primary-emerald); }
        
        .gv-search-dropdown {
            position: absolute;
            top: calc(100% + 10px);
            left: 0;
            width: 100%;
            background: rgba(255, 255, 255, 0.98);
            border-radius: 16px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.15);
            border: 1px solid rgba(0,0,0,0.05);
            backdrop-filter: blur(20px);
            opacity: 0; visibility: hidden;
            transform: translateY(10px);
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 1050;
            max-height: 400px;
            overflow-y: auto;
        }
        .gv-search-dropdown.active {
            opacity: 1; visibility: visible; transform: translateY(0);
        }
        .gv-search-item {
            padding: 12px 16px;
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            border-bottom: 1px solid rgba(0,0,0,0.04);
            transition: background 0.2s;
        }
        .gv-search-item:last-child { border-bottom: none; }
        .gv-search-item:hover { background: rgba(34, 197, 94, 0.05); }
        .gv-search-item-icon {
            width: 36px; height: 36px;
            border-radius: 10px;
            background: rgba(34, 197, 94, 0.1);
            color: var(--primary-emerald);
            display: flex; align-items: center; justify-content: center;
        }
        .gv-search-item-content { flex: 1; overflow: hidden; }
        .gv-search-item-title { color: #0f172a; font-weight: 600; font-size: 14px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .gv-search-item-sub { color: #64748b; font-size: 12px; }

        .user-avatar {
            width: 34px; height: 34px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary-emerald), var(--accent-green));
            display: flex; align-items: center; justify-content: center;
            font-weight: 700; color: white; font-size: 14px;
            box-shadow: 0 2px 8px rgba(34, 197, 94, 0.3);
        }

        .dropdown-menu {
            border: 1px solid rgba(0,0,0,0.06);
            border-radius: 16px !important;
            box-shadow: 0 20px 50px rgba(1, 50, 32, 0.15);
            padding: 8px;
            backdrop-filter: blur(20px);
            background: rgba(255, 255, 255, 0.98);
            animation: dropdownFadeIn 0.2s ease;
        }

        body[dir="rtl"] .dropdown-menu-end {
            right: auto;
            left: 0;
        }

        body[dir="rtl"] .container,
        body[dir="rtl"] .form-label,
        body[dir="rtl"] .table th,
        body[dir="rtl"] .table td {
            text-align: right;
        }

        body[dir="rtl"] .me-1 { margin-right: 0 !important; margin-left: .25rem !important; }
        body[dir="rtl"] .me-2 { margin-right: 0 !important; margin-left: .5rem !important; }
        body[dir="rtl"] .ms-1 { margin-left: 0 !important; margin-right: .25rem !important; }
        body[dir="rtl"] .ms-2 { margin-left: 0 !important; margin-right: .5rem !important; }

        @keyframes dropdownFadeIn {
            from { opacity: 0; transform: translateY(-6px) scale(0.98); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }

        .dropdown-item {
            border-radius: 10px;
            padding: 10px 14px;
            font-size: 14px;
            font-weight: 500;
            transition: background 0.15s;
        }

        .dropdown-item:hover { background: rgba(34, 197, 94, 0.08); }

        /* ─── Global Footer ─── */
        .govibe-footer {
            background: linear-gradient(180deg, var(--bg-footer), #050e08);
            color: rgba(255, 255, 255, 0.6);
            padding: 60px 0 30px;
            margin-top: 80px;
            border-top: 1px solid rgba(34, 197, 94, 0.08);
        }

        .footer-brand {
            color: var(--primary-emerald);
            font-family: 'Outfit', sans-serif;
            font-size: 26px;
            font-weight: 800;
            margin-bottom: 15px;
            display: block;
            letter-spacing: -0.03em;
        }

        .govibe-footer a:hover {
            color: var(--primary-emerald) !important;
        }

        .govibe-detail-modal .modal-content {
            border: 0;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 40px 100px rgba(1, 50, 32, 0.25);
            background: rgba(255, 255, 255, 0.98);
            max-height: calc(100vh - 2rem);
        }

        .govibe-detail-modal .modal-dialog {
            max-width: 820px; /* Reduced for elegance */
            margin: 2.5rem auto; /* Increased outer spacing */
            display: flex;
            align-items: center;
            min-height: calc(100% - 5rem);
            transform-origin: center center;
            transition: transform 0.42s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 0.32s ease;
        }

        @media (min-width: 576px) {
            .govibe-detail-modal .modal-dialog {
                min-height: calc(100% - 5rem);
            }
        }

        .modal.fade .modal-dialog {
            transform: translateY(26px) scale(0.93);
            opacity: 0;
        }

        .modal.show .modal-dialog {
            transform: translateY(0) scale(1);
            opacity: 1;
        }

        .modal-backdrop {
            backdrop-filter: blur(16px) saturate(160%);
            -webkit-backdrop-filter: blur(16px) saturate(160%);
            background-color: rgba(1, 50, 32, 0.55);
        }

        /* ─── Card Reveal Animations ─── */
        .reveal-card {
            opacity: 0;
            transform: translateY(24px) scale(0.97);
            transition: opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1),
                        transform 0.6s cubic-bezier(0.4, 0, 0.2, 1),
                        box-shadow 0.3s ease;
            will-change: transform, opacity;
        }

        .reveal-card.is-visible {
            opacity: 1;
            transform: translateY(0) scale(1);
        }

        /* ─── Form Styles ─── */
        form {
            animation: formLiftIn .45s ease both;
        }

        @keyframes formLiftIn {
            from { opacity: 0; transform: translateY(12px); }
            to { opacity: 1; transform: translateY(0); }
        }

        form .form-label,
        .modal .form-label {
            font-size: 11.5px;
            font-weight: 700;
            letter-spacing: .06em;
            text-transform: uppercase;
            color: var(--text-secondary);
            margin-bottom: .5rem;
        }

        form .form-control,
        form .form-select,
        form select,
        form textarea,
        form input[type="text"],
        form input[type="email"],
        form input[type="password"],
        form input[type="number"],
        form input[type="tel"],
        form input[type="date"],
        form input[type="time"],
        .modal .form-control,
        .modal .form-select,
        .modal select,
        .modal textarea,
        .modal input[type="text"],
        .modal input[type="email"],
        .modal input[type="password"],
        .modal input[type="number"],
        .modal input[type="tel"],
        .modal input[type="date"],
        .modal input[type="time"] {
            border-radius: 14px;
            border: 1.5px solid rgba(1, 50, 32, 0.10);
            padding: .85rem 1rem;
            background: rgba(255, 255, 255, 0.95);
            box-shadow: 0 1px 3px rgba(1, 50, 32, 0.04);
            transition: all .25s cubic-bezier(0.4, 0, 0.2, 1);
            font-size: 14.5px;
        }

        form .form-control:focus,
        form .form-select:focus,
        form select:focus,
        form textarea:focus,
        form input[type="text"]:focus,
        form input[type="email"]:focus,
        form input[type="password"]:focus,
        form input[type="number"]:focus,
        form input[type="tel"]:focus,
        form input[type="date"]:focus,
        form input[type="time"]:focus,
        .modal .form-control:focus,
        .modal .form-select:focus,
        .modal select:focus,
        .modal textarea:focus,
        .modal input[type="text"]:focus,
        .modal input[type="email"]:focus,
        .modal input[type="password"]:focus,
        .modal input[type="number"]:focus,
        .modal input[type="tel"]:focus,
        .modal input[type="date"]:focus,
        .modal input[type="time"]:focus {
            border-color: var(--primary-emerald);
            box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.12), 0 2px 6px rgba(34, 197, 94, 0.08);
            background: #fff;
            transform: translateY(-1px);
            outline: none;
        }

        form .form-check-input,
        .modal .form-check-input {
            width: 1.15em; height: 1.15em;
            border-radius: .35rem;
            border-color: rgba(1, 50, 32, 0.15);
            transition: all .2s ease;
        }

        form .form-check-input:checked,
        .modal .form-check-input:checked {
            background-color: var(--primary-emerald);
            border-color: var(--primary-emerald);
        }

        form .form-check-input:focus,
        .modal .form-check-input:focus {
            box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.12);
        }

        form .btn, .modal .btn {
            transition: all .25s cubic-bezier(0.4, 0, 0.2, 1);
        }

        form .btn:hover, .modal .btn:hover {
            transform: translateY(-2px);
        }

        form .invalid-feedback,
        .modal .invalid-feedback,
        form .form-error-message,
        .modal .form-error-message {
            font-size: 12px;
            margin-top: .45rem;
            color: #dc3545;
            font-weight: 600;
        }

        form .form-error-message,
        .modal .form-error-message {
            margin-bottom: 0;
            padding-left: 1rem;
        }

        form .form-error-message li,
        .modal .form-error-message li {
            color: #dc3545;
        }

        form .form-control.is-invalid,
        form .form-select.is-invalid,
        form input.is-invalid,
        form select.is-invalid,
        form textarea.is-invalid,
        .modal .form-control.is-invalid,
        .modal .form-select.is-invalid,
        .modal input.is-invalid,
        .modal select.is-invalid,
        .modal textarea.is-invalid,
        form .form-control[aria-invalid="true"],
        form .form-select[aria-invalid="true"],
        form input[aria-invalid="true"],
        form select[aria-invalid="true"],
        form textarea[aria-invalid="true"],
        .modal .form-control[aria-invalid="true"],
        .modal .form-select[aria-invalid="true"],
        .modal input[aria-invalid="true"],
        .modal select[aria-invalid="true"],
        .modal textarea[aria-invalid="true"] {
            border-color: #dc3545;
            box-shadow: 0 0 0 3px rgba(220, 53, 69, 0.15);
        }

        /* ─── Form Page Layout ─── */
        .go-form-page {
            min-height: calc(100vh - 90px);
            padding: 128px 0 72px;
        }

        .go-form-card {
            border: 0;
            border-radius: 28px;
            overflow: hidden;
            box-shadow: 0 30px 80px rgba(1, 50, 32, 0.12);
            background: rgba(255, 255, 255, 0.96);
            backdrop-filter: blur(12px);
        }




        .go-form-card-header {
            padding: 28px 32px;
            color: white;
            background: linear-gradient(135deg, var(--dark-green), var(--mid-green), var(--light-green));
            position: relative;
            overflow: hidden;
        }

        .go-form-card-header::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 90% 10%, rgba(34, 197, 94, 0.3), transparent 50%),
                        radial-gradient(circle at 10% 90%, rgba(46, 139, 87, 0.2), transparent 50%);
            pointer-events: none;
        }

        .go-form-card-body {
            padding: 32px;
            background: rgba(255, 255, 255, 0.98);
        }

        /* ─── Alerts ─── */
        .alert {
            border-radius: 16px;
            border: none;
            backdrop-filter: blur(12px);
        }

        /* ─── Scrollbar ─── */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb {
            background: rgba(34, 197, 94, 0.3);
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover { background: rgba(34, 197, 94, 0.5); }
    </style>
    <style>
/* ─── Custom Scrollbar ─── */
.custom-scrollbar::-webkit-scrollbar { width: 6px; }
.custom-scrollbar::-webkit-scrollbar-track { background: rgba(0,0,0,0.02); border-radius: 10px; }
.custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(0, 52, 45, 0.15); border-radius: 10px; }
.custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(0, 52, 45, 0.3); }

.modal-body { max-height: 80vh; }

        /* ─── Mentions Manager UI ─── */
        .gv-mentions-list {
            position: absolute; z-index: 100010;
            background: rgba(255, 255, 255, 0.98);
            border: 1px solid rgba(0, 52, 45, 0.08);
            border-radius: 1rem;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.12);
            min-width: 220px; max-height: 260px;
            overflow-y: auto; padding: 0.5rem;
            backdrop-filter: blur(10px);
        }
        .gv-mention-item {
            padding: 0.75rem 1rem; cursor: pointer;
            display: flex; align-items: center; gap: 0.85rem;
            border-radius: 0.75rem; transition: all 0.2s ease;
            text-decoration: none; color: inherit;
        }
        .gv-mention-item:hover, .gv-mention-item.active {
            background: rgba(16, 185, 129, 0.08); color: #00342d;
        }
        .gv-mention-avatar { width: 32px; height: 32px; border-radius: 50%; object-fit: cover; background: #eee; }
        .gv-mention-info { display: flex; flex-direction: column; }
        .gv-mention-name { font-weight: 700; font-size: 0.9rem; color: #00342d; }
        .gv-mention-tag { font-size: 0.75rem; color: #64748b; }

/* ═══ AI Voice Command Center ═══ */
.gv-ai-orb-wrap {
    position: fixed; bottom: 5rem; right: 4rem; z-index: 9999;
    display: flex; flex-direction: column; align-items: flex-end; gap: 12px;
}
.gv-ai-orb {
    width: 68px; height: 68px; border-radius: 50%; border: none; cursor: pointer;
    background: linear-gradient(135deg, #10b981 0%, #047857 50%, #059669 100%);
    color: white; display: flex; align-items: center; justify-content: center;
    box-shadow: 0 0 25px rgba(16, 185, 129, 0.45), 0 0 60px rgba(16, 185, 129, 0.15), inset 0 -2px 6px rgba(0,0,0,0.15);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    position: relative; z-index: 3;
    animation: orbFloat 4s ease-in-out infinite;
}
.gv-ai-orb:hover {
    transform: scale(1.12) translateY(-4px);
    box-shadow: 0 0 35px rgba(16, 185, 129, 0.6), 0 0 80px rgba(16, 185, 129, 0.25), inset 0 -2px 6px rgba(0,0,0,0.15);
}
.gv-ai-orb .material-symbols-outlined { font-size: 1.8rem; font-variation-settings: 'FILL' 1; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2)); transition: all 0.3s; }
@keyframes orbFloat { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-6px)} }

/* ── Orb 4-State System ── */
.gv-ai-orb-wrap[data-voice-state="listening"] .gv-ai-orb {
    background: linear-gradient(135deg, #ef4444, #dc2626, #b91c1c);
    box-shadow: 0 0 30px rgba(239,68,68,0.5), 0 0 70px rgba(239,68,68,0.2);
    animation: orbPulseListen 1.2s ease-in-out infinite;
}
@keyframes orbPulseListen { 0%,100%{transform:scale(1)} 50%{transform:scale(1.08)} }

.gv-ai-orb-wrap[data-voice-state="thinking"] .gv-ai-orb {
    background: linear-gradient(135deg, #f59e0b, #d97706, #b45309);
    box-shadow: 0 0 30px rgba(245,158,11,0.5), 0 0 70px rgba(245,158,11,0.2);
    animation: orbRotateThink 2s linear infinite;
}
@keyframes orbRotateThink { 0%{transform:rotate(0deg)} 100%{transform:rotate(360deg)} }

.gv-ai-orb-wrap[data-voice-state="speaking"] .gv-ai-orb {
    background: linear-gradient(135deg, #8b5cf6, #7c3aed, #6d28d9);
    box-shadow: 0 0 30px rgba(139,92,246,0.5), 0 0 70px rgba(139,92,246,0.2);
    animation: orbWaveSpeak 1s ease-in-out infinite;
}
@keyframes orbWaveSpeak { 0%,100%{transform:scale(1) translateY(0)} 25%{transform:scale(1.04) translateY(-3px)} 75%{transform:scale(0.97) translateY(2px)} }

/* Orb ring pulses — adapt to states */
.gv-ai-orb-ring {
    position: absolute; border-radius: 50%; z-index: 1;
    border: 2px solid rgba(16, 185, 129, 0.35);
    animation: orbRingPulse 2.5s ease-out infinite;
    pointer-events: none;
}
.gv-ai-orb-ring:nth-child(1) { inset: -6px; }
.gv-ai-orb-ring:nth-child(2) { inset: -14px; animation-delay: 0.8s; border-color: rgba(16, 185, 129, 0.2); }
.gv-ai-orb-ring:nth-child(3) { inset: -22px; animation-delay: 1.6s; border-color: rgba(16, 185, 129, 0.1); }
@keyframes orbRingPulse { 0%{transform:scale(0.85);opacity:1} 100%{transform:scale(1.3);opacity:0} }

.gv-ai-orb-wrap[data-voice-state="listening"] .gv-ai-orb-ring { border-color: rgba(239,68,68,0.4); animation-duration: 1s; }
.gv-ai-orb-wrap[data-voice-state="thinking"] .gv-ai-orb-ring { border-color: rgba(245,158,11,0.3); animation-duration: 1.5s; }
.gv-ai-orb-wrap[data-voice-state="speaking"] .gv-ai-orb-ring { border-color: rgba(139,92,246,0.3); animation-duration: 1.8s; }

/* ── Voice State Label ── */
.gv-voice-state-label {
    position: absolute; right: calc(100% + 14px); top: 50%; transform: translateY(-50%);
    background: rgba(0,52,45,0.95); color: #a0f2e1; padding: 6px 14px; border-radius: 10px;
    font-size: 0.72rem; font-weight: 700; white-space: nowrap;
    opacity: 0; transition: all 0.3s; backdrop-filter: blur(8px);
    box-shadow: 0 4px 15px rgba(0,0,0,0.2); pointer-events: none;
}
.gv-voice-state-label::after {
    content:''; position:absolute; right:-6px; top:50%; transform:translateY(-50%);
    border:6px solid transparent; border-left-color:rgba(0,52,45,0.95);
}
.gv-ai-orb-wrap:hover .gv-voice-state-label,
.gv-ai-orb-wrap[data-voice-state="listening"] .gv-voice-state-label,
.gv-ai-orb-wrap[data-voice-state="thinking"] .gv-voice-state-label,
.gv-ai-orb-wrap[data-voice-state="speaking"] .gv-voice-state-label { opacity: 1; }

.gv-ai-orb-wrap[data-voice-state="listening"] .gv-voice-state-label { background: rgba(127,29,29,0.95); color: #fca5a5; }
.gv-ai-orb-wrap[data-voice-state="listening"] .gv-voice-state-label::after { border-left-color: rgba(127,29,29,0.95); }
.gv-ai-orb-wrap[data-voice-state="thinking"] .gv-voice-state-label { background: rgba(120,53,15,0.95); color: #fde68a; }
.gv-ai-orb-wrap[data-voice-state="thinking"] .gv-voice-state-label::after { border-left-color: rgba(120,53,15,0.95); }
.gv-ai-orb-wrap[data-voice-state="speaking"] .gv-voice-state-label { background: rgba(76,29,149,0.95); color: #ddd6fe; }
.gv-ai-orb-wrap[data-voice-state="speaking"] .gv-voice-state-label::after { border-left-color: rgba(76,29,149,0.95); }

/* ── Inline Voice Response Panel ── */
.gv-voice-panel {
    position: absolute; bottom: calc(100% + 16px); right: 0;
    width: 340px; max-width: calc(100vw - 3rem);
    background: rgba(255,255,255,0.98); border-radius: 1.25rem;
    box-shadow: 0 20px 60px rgba(0,52,45,0.2), 0 0 1px rgba(0,0,0,0.1);
    backdrop-filter: blur(20px); border: 1px solid rgba(0,52,45,0.06);
    opacity: 0; visibility: hidden; transform: translateY(10px) scale(0.96);
    transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
    z-index: 10;
}
.gv-voice-panel.active { opacity: 1; visibility: visible; transform: translateY(0) scale(1); }
.gv-voice-panel-header {
    display: flex; align-items: center; gap: 10px; padding: 14px 18px;
    border-bottom: 1px solid rgba(0,52,45,0.06);
    background: linear-gradient(135deg, rgba(0,52,45,0.04), rgba(16,185,129,0.04));
    border-radius: 1.25rem 1.25rem 0 0;
}
.gv-voice-panel-header .material-symbols-outlined { font-size: 1.1rem; color: #10b981; }
.gv-voice-panel-title { font-size: 0.78rem; font-weight: 800; color: #00342d; letter-spacing: 0.03em; }
.gv-voice-panel-close { margin-left: auto; background: none; border: none; cursor: pointer; color: #94a3b8; padding: 4px; border-radius: 8px; transition: all 0.2s; }
.gv-voice-panel-close:hover { background: rgba(0,0,0,0.05); color: #00342d; }
.gv-voice-panel-body { padding: 16px 18px; }
.gv-voice-transcript { font-size: 0.8rem; color: #64748b; font-style: italic; margin-bottom: 10px; min-height: 20px; }
.gv-voice-response { font-size: 0.88rem; color: #0f172a; font-weight: 600; line-height: 1.5; }
.gv-voice-panel-actions { display: flex; gap: 6px; padding: 10px 18px 14px; }
.gv-voice-action-btn {
    padding: 6px 14px; border-radius: 2rem; font-size: 0.7rem; font-weight: 700;
    border: 1px solid rgba(0,52,45,0.1); background: #fff; color: #00342d;
    cursor: pointer; transition: all 0.2s; font-family: inherit;
}
.gv-voice-action-btn:hover { background: rgba(16,185,129,0.08); border-color: rgba(16,185,129,0.3); }
.gv-voice-action-btn.primary { background: linear-gradient(135deg, #00342d, #046b5e); color: #fff; border-color: transparent; }

/* ── Voice Shortcut Hints (per-page) ── */
.gv-voice-hints {
    display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
    padding: 10px 16px; background: rgba(16,185,129,0.04);
    border: 1px solid rgba(16,185,129,0.1); border-radius: 0.75rem;
    margin-bottom: 1.5rem;
}
.gv-voice-hints .material-symbols-outlined { font-size: 1rem; color: #10b981; }
.gv-voice-hints > span:nth-child(2) { font-size: 0.72rem; font-weight: 700; color: #546067; text-transform: uppercase; letter-spacing: 0.05em; }
.gv-voice-hint-chip {
    padding: 4px 12px; border-radius: 2rem; font-size: 0.72rem; font-weight: 700;
    background: rgba(255,255,255,0.8); border: 1px solid rgba(0,52,45,0.08);
    color: #00342d; cursor: pointer; transition: all 0.2s; font-family: inherit;
}
.gv-voice-hint-chip:hover { background: rgba(16,185,129,0.1); border-color: rgba(16,185,129,0.25); transform: translateY(-1px); }

.chat-container {
    height: 500px;
    display: flex;
    flex-direction: column;
    background: #fff;
}
.chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background: #fcf9f8;
}
.chat-message {
    max-width: 80%;
    padding: 0.85rem 1.15rem;
    border-radius: 1.25rem;
    font-size: 0.95rem;
    line-height: 1.4;
    position: relative;
    animation: messageIn 0.3s ease both;
}
@keyframes messageIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}
.chat-message.ai {
    align-self: flex-start;
    background: #fff;
    color: #1c1b1b;
    border-bottom-left-radius: 0.25rem;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
    border: 1px solid rgba(0, 52, 45, 0.05);
}
    .chat-message.user {
        align-self: flex-end;
        background: linear-gradient(135deg, #00342d 0%, #013220 100%);
        color: #fff;
        border-bottom-right-radius: 0.25rem;
        box-shadow: 0 4px 15px rgba(0, 52, 45, 0.1);
    }
    /* ─── AI Selector Professional Design ─── */
    .gv-ai-selector-container {
        position: relative;
        display: inline-block;
    }
    .gv-ai-selector-btn {
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: white;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
        backdrop-filter: blur(5px);
    }
    .gv-ai-selector-btn:hover {
        background: rgba(255, 255, 255, 0.2);
    }
    .gv-ai-selector-btn .arrow {
        font-size: 1rem;
        transition: transform 0.3s ease;
    }
    .gv-ai-selector-container.open .gv-ai-selector-btn .arrow {
        transform: rotate(180deg);
    }
    .gv-ai-selector-menu {
        position: absolute;
        top: calc(100% + 8px);
        left: 0;
        background: rgba(255, 255, 255, 0.98);
        min-width: 160px;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        padding: 6px;
        z-index: 100;
        display: none;
        animation: slideInUp 0.2s ease forwards;
        border: 1px solid rgba(0, 52, 45, 0.05);
    }
    @keyframes slideInUp {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .gv-ai-selector-item {
        padding: 8px 12px;
        border-radius: 8px;
        color: #1c1b1b;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 10px;
        transition: all 0.2s ease;
        font-size: 0.85rem;
        font-weight: 600;
    }
    .gv-ai-selector-item:hover {
        background: rgba(16, 185, 129, 0.08);
        color: #00342d;
    }
    .gv-ai-selector-item.active {
        background: #00342d;
        color: white;
    }
    .gv-ai-selector-item i {
        font-size: 1.1rem;
    }
    .gv-icon-gemini {
        background: linear-gradient(135deg, #4285f4 0%, #9b72f3 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-weight: bold;
    }
    .gv-icon-groq {
        color: #f59e0b;
    }
    .gv-ai-selector-item .model-desc {
        font-size: 0.65rem;
        opacity: 0.7;
        font-weight: 500;
        display: block;
    }

.chat-input-area {
    padding: 1.25rem;
    background: #fff;
    border-top: 1px solid rgba(0, 52, 45, 0.06);
    display: flex;
    gap: 0.75rem;
    align-items: center;
}
.chat-input {
    flex: 1;
    border: 1.5px solid #e5e7eb;
    border-radius: 0.75rem;
    padding: 0.65rem 1rem;
    font-size: 0.95rem;
    outline: none;
    transition: all 0.2s;
}
.chat-input:focus {
    border-color: #10b981;
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
}
.chat-send-btn {
    width: 42px;
    height: 42px;
    border-radius: 0.75rem;
    background: #00342d;
    color: #fff;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
}
.chat-send-btn:hover {
    background: #10b981;
    transform: scale(1.05);
}

.typing-indicator {
    display: flex;
    gap: 4px;
    padding: 4px 8px;
}
.typing-dot {
    width: 6px;
    height: 6px;
    background: #bfc9c4;
    border-radius: 50%;
    animation: typing 1.4s infinite;
}
.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes typing {
    0%, 60%, 100% { transform: translateY(0); }
    30% { transform: translateY(-4px); }
}
    /* --- Mentions --- */
    .gv-mentions-list {
        position: absolute;
        z-index: 10000;
        background: rgba(255, 255, 255, 0.98);
        border: 1px solid rgba(0, 52, 45, 0.08);
        border-radius: 1rem;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.12);
        min-width: 220px;
        max-height: 260px;
        overflow-y: auto;
        padding: 0.5rem;
        backdrop-filter: blur(10px);
    }
    .gv-mention-item {
        padding: 0.75rem 1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.85rem;
        border-radius: 0.75rem;
        transition: all 0.2s ease;
        text-decoration: none;
        color: inherit;
    }
    .gv-mention-item:hover, .gv-mention-item.active {
        background: rgba(16, 185, 129, 0.08);
        color: #00342d;
    }
    .gv-mention-avatar {
        width: 32px; height: 32px;
        border-radius: 50%;
        object-fit: cover;
        background: #eee;
    }
    .gv-mention-info {
        display: flex;
        flex-direction: column;
    }
    .gv-mention-name { font-weight: 700; font-size: 0.9rem; }
    .gv-mention-tag { font-size: 0.75rem; color: #64748b; }

    /* ── Quick Action Pills (Chatbot) ── */
    .gv-quick-pills-bar {
        padding: 12px 14px 8px;
        background: linear-gradient(180deg, #f0fdf8 0%, #f8faf9 100%);
        display: flex;
        gap: 7px;
        flex-wrap: wrap;
        border-bottom: 1px solid rgba(0,52,45,0.07);
    }
    .gv-quick-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #ffffff;
        border: 1.5px solid rgba(16, 185, 129, 0.2);
        border-radius: 14px;
        padding: 6px 13px;
        font-size: 0.78rem;
        font-weight: 700;
        color: #00342d;
        cursor: pointer;
        font-family: 'Inter', sans-serif;
        transition: all 0.22s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 2px 8px rgba(16, 185, 129, 0.07);
        letter-spacing: 0.01em;
        position: relative;
        overflow: hidden;
    }
    .gv-quick-pill::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(16,185,129,0.07), rgba(0,52,45,0.04));
        opacity: 0;
        transition: opacity 0.22s;
        pointer-events: none;
    }
    .gv-quick-pill:hover {
        transform: translateY(-2px);
        border-color: rgba(16, 185, 129, 0.5);
        box-shadow: 0 6px 18px rgba(16, 185, 129, 0.18), 0 2px 6px rgba(0,0,0,0.05);
        color: #006d4e;
    }
    .gv-quick-pill:hover::before { opacity: 1; }
    .gv-quick-pill:active {
        transform: translateY(0px) scale(0.97);
        box-shadow: 0 2px 6px rgba(16, 185, 129, 0.1);
    }
    .gv-quick-pill .pill-icon {
        width: 21px;
        height: 21px;
        border-radius: 7px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        flex-shrink: 0;
    }
    .gv-quick-pill.pill-vols    .pill-icon { background: rgba(59,130,246,0.12); }
    .gv-quick-pill.pill-hotels  .pill-icon { background: rgba(245,158,11,0.12); }
    .gv-quick-pill.pill-resa    .pill-icon { background: rgba(139,92,246,0.12); }
    .gv-quick-pill.pill-inspire .pill-icon { background: rgba(16,185,129,0.12); }
</style>
    {% block stylesheets %}{% endblock %}
</head>
<body>



    {% block header %}
    <nav class="navbar navbar-expand-lg govibe-navbar" id="mainNav">
        <div class="container">
            <a class="navbar-brand" href="{{ path('app_user_home') }}">
                <img src="{{ asset('images/logo.png') }}" alt="GV" style="width: 40px; height: 40px; object-fit: contain; margin-right: 10px;"> GoVibe
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <i class="bi bi-list text-white fs-2"></i>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                {% set currentRoute = app.request.attributes.get('_route')|default('') %}
                {% set activeLocale = current_locale() %}
                {% set showLocaleSelector = currentRoute starts with 'app_hotel' or currentRoute starts with 'app_chambre' %}
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item"><a class="nav-link active" href="{{ path('app_user_home') }}">{{ 'nav.home'|trans }}</a></li>
                    <li class="nav-item"><a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_activite' %}active{% endif %}" href="{{ path('app_activite_index') }}">{{ 'nav.activities'|trans }}</a></li>
                    <li class="nav-item"><a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_location' %}active{% endif %}" href="{{ path('app_location_index') }}">{{ 'nav.cars'|trans }}</a></li>
                    <li class="nav-item"><a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_vols' %}active{% endif %}" href="{{ path('app_vols_index') }}">{{ 'nav.flights'|trans }}</a></li>
                    <li class="nav-item"><a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_hotel' %}active{% endif %}" href="{{ path('app_hotel_index') }}">{{ 'nav.hotels'|trans }}</a></li>
                    <li class="nav-item"><a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_poste' %}active{% endif %}" href="{{ path('app_poste_index') }}">{{ 'nav.posts'|trans }}</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_reclamation_index') }}">{{ 'nav.claims'|trans }}</a></li>
                    {% if app.user and app.user.role == 'admin' %}
                        <li class="nav-item"><a class="nav-link" href="{{ path('app_admin_location_index') }}" style="color: #ff9800 !important;"><i class="bi bi-shield-lock"></i> {{ 'nav.admin_locations'|trans }}</a></li>
                        <li class="nav-item"><a class="nav-link" href="{{ path('admin_voiture_index') }}" style="color: #ff9800 !important;"><i class="bi bi-car-front"></i> {{ 'nav.admin_cars'|trans }}</a></li>
                    {% endif %}
                </ul>
                <div class="d-flex align-items-center">
                    {% if showLocaleSelector %}
                        <div class="dropdown me-3">
                            <button class="btn user-dropdown-btn dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-translate"></i>
                                <span>{{ activeLocale|upper }}</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3 mt-2">
                                {% for locale in supported_locales() %}
                                    <li>
                                        <a class="dropdown-item d-flex justify-content-between align-items-center {% if locale.code == activeLocale %}active{% endif %}" href="{{ path('app_locale_switch', {'locale': locale.code}) }}">
                                            <span>{{ locale.label }} ({{ locale.code|upper }})</span>
                                            {% if locale.code == activeLocale %}<i class="bi bi-check2"></i>{% endif %}
                                        </a>
                                    </li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% endif %}

                    <!-- Global Search -->
                    <div class="gv-global-search">
                        <input type="text" id="gvGlobalSearchInput" placeholder="Rechercher vol, hôtel, voiture..." autocomplete="off">
                        <span class="material-symbols-outlined">search</span>
                        <div class="gv-search-dropdown" id="gvSearchDropdown"></div>
                    </div>

                    {% if app.user %}
                        <div class="dropdown">
                            <button class="btn user-dropdown-btn dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                <div class="user-avatar">{{ app.user.prenom|first|upper }}</div>
                                <span>{{ app.user.prenom }}</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3 mt-2">
                                <li><a class="dropdown-item" href="{{ path('app_user_profile') }}"><i class="bi bi-person me-2"></i> {{ 'nav.profile'|trans }}</a></li>
                                <li><a class="dropdown-item" href="{{ path('app_checkout_index') }}"><i class="bi bi-ticket-perforated me-2"></i> {{ 'nav.checkouts'|trans }}</a></li>
                                <li><a class="dropdown-item" href="{{ path('app_reservation_session_index') }}"><i class="bi bi-calendar-check me-2"></i> {{ 'nav.reservations'|trans }}</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right me-2"></i> {{ 'nav.logout'|trans }}</a></li>
                            </ul>
                        </div>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="btn btn-outline-light rounded-pill px-4">{{ 'nav.login'|trans }}</a>
                    {% endif %}
                </div>
            </div>
        </div>
    </nav>
    {% endblock %}

    <div class="gv-content-fade-in">


    <div class="container position-relative" style="z-index: 1040; margin-top: 90px;">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show shadow-sm rounded-4 mb-3" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
                </div>
            {% endfor %}
        {% endfor %}
    </div>

    {% block body %}{% endblock %}



    {% block footer %}
    <footer class="govibe-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <span class="footer-brand">GoVibe</span>
                    <p>Vivez l'aventure, explorez le monde. Votre partenaire de voyage intelligent.</p>
                </div>
                <div class="col-lg-2 offset-lg-2">
                    <h5 class="text-white mb-3" style="font-size:16px; font-weight:600;">Découvrir</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="#" class="text-decoration-none text-secondary">Destinations</a></li>
                        <li class="mb-2"><a href="#" class="text-decoration-none text-secondary">Aventures</a></li>
                        <li class="mb-2"><a href="#" class="text-decoration-none text-secondary">Événements</a></li>
                    </ul>
                </div>
                <div class="col-lg-2">
                    <h5 class="text-white mb-3" style="font-size:16px; font-weight:600;">Support</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="#" class="text-decoration-none text-secondary">Contact</a></li>
                        <li class="mb-2"><a href="#" class="text-decoration-none text-secondary">FAQ</a></li>
                        <li class="mb-2"><a href="{{ path('app_reclamation_index') }}" class="text-decoration-none text-secondary">Réclamations</a></li>
                    </ul>
                </div>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            var navbar = document.getElementById("mainNav");
            var _scrollTicking = false;
            window.addEventListener("scroll", function() {
                if (!_scrollTicking) {
                    _scrollTicking = true;
                    requestAnimationFrame(function() {
                        if (window.scrollY > 50) {
                            navbar.classList.add("scrolled");
                        } else {
                            navbar.classList.remove("scrolled");
                        }
                        _scrollTicking = false;
                    });
                }
            });


            var revealCards = document.querySelectorAll('[data-card-animate]');
            if (revealCards.length) {
                var observer = new IntersectionObserver(function(entries) {
                    entries.forEach(function(entry) {
                        if (entry.isIntersecting) {
                            entry.target.classList.add('is-visible');
                            observer.unobserve(entry.target);
                        }
                    });
                }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });

                revealCards.forEach(function(card, index) {
                    card.classList.add('reveal-card');
                    card.style.transitionDelay = (index * 80) + 'ms';
                    observer.observe(card);
                });
            }

            const detailModalEl = document.getElementById('detailModal');
            const detailModal = detailModalEl ? new bootstrap.Modal(detailModalEl) : null;

            window.openDetailModal = function(url) {
                if (!detailModal) return;

                const body = document.getElementById('detailModalBody');
                body.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-success" role="status"></div><p class="mt-3 text-muted small">Chargement des détails...</p></div>';

                detailModal.show();

                fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then(function(response) { return response.text(); })
                    .then(function(html) { 
                        body.innerHTML = html; 
                        var scripts = body.querySelectorAll('script');
                        scripts.forEach(function(s) {
                            if (s.src) {
                                var newScript = document.createElement('script');
                                newScript.src = s.src;
                                document.body.appendChild(newScript);
                            } else {
                                var newScript = document.createElement('script');
                                newScript.text = s.innerHTML;
                                document.body.appendChild(newScript).parentNode.removeChild(newScript);
                            }
                        });
                    })
                    .catch(function() {
                        body.innerHTML = '<div class="alert alert-danger m-4 rounded-4">Impossible de charger les détails.</div>';
                    });
            };

            window.openPostModal = function(url) {
                const modalEl = document.getElementById('postModal');
                if (!modalEl) return;
                const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
                const body = document.getElementById('postModalBody');
                body.innerHTML = '<div class="text-center py-5"><div class="spinner-border" role="status" style="color:#10B981;"></div><p class="mt-3 text-muted small">Chargement du formulaire...</p></div>';
                modal.show();
                fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then(r => r.text())
                    .then(html => {
                        body.innerHTML = html;
                        const scripts = body.querySelectorAll('script');
                        scripts.forEach(s => {
                            const ns = document.createElement('script');
                            ns.text = s.innerHTML;
                            document.body.appendChild(ns).parentNode.removeChild(ns);
                        });
                        // Specific check for post creation/edit scripts
                        setTimeout(() => {
                            if (window.initPosteForm) window.initPosteForm();
                        }, 50);
                    })
                    .catch(() => {
                        body.innerHTML = '<div class="alert alert-danger m-4 rounded-4">Erreur de chargement.</div>';
                    });
            };

            window.openForumModal = function(url) {
                const modalEl = document.getElementById('forumModal');
                if (!modalEl) return;
                const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
                const body = document.getElementById('forumModalBody');
                body.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-success" role="status"></div><p class="mt-3 text-muted small">Chargement...</p></div>';
                modal.show();
                fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then(function(response) { return response.text(); })
                    .then(function(html) { 
                        body.innerHTML = html; 
                        var scripts = body.querySelectorAll('script');
                        scripts.forEach(function(s) {
                            var ns = document.createElement('script');
                            ns.text = s.innerHTML;
                            document.body.appendChild(ns).parentNode.removeChild(ns);
                        });
                    })
                    .catch(function() {
                        body.innerHTML = '<div class="alert alert-danger m-4 rounded-4">Erreur de chargement.</div>';
                    });
            };

            // Detail Modal logic (kept as is)

        });
    </script>
    <script>
// ═══════════════════════════════════════════════════════════════
// GoVibe Global Search System — Enhanced
// ═══════════════════════════════════════════════════════════════
document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('gvGlobalSearchInput');
    const searchDropdown = document.getElementById('gvSearchDropdown');
    if (!searchInput || !searchDropdown) return;

    let debounceTimer;
    let activeIdx = -1;

    // Ctrl+K shortcut to focus search
    document.addEventListener('keydown', (e) => {
        if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
            e.preventDefault();
            searchInput.focus();
            searchInput.select();
        }
    });

    searchInput.addEventListener('input', (e) => {
        const query = e.target.value.trim();
        activeIdx = -1;
        if (query.length < 2) {
            searchDropdown.classList.remove('active');
            return;
        }

        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => {
            searchDropdown.innerHTML = '<div class="p-3 text-center"><div class="spinner-border spinner-border-sm text-success" role="status"></div></div>';
            searchDropdown.classList.add('active');

            fetch('/api/search?q=' + encodeURIComponent(query))
                .then(response => response.json())
                .then(data => {
                    searchDropdown.innerHTML = '';
                    if (data.results && data.results.length > 0) {
                        let lastCat = '';
                        data.results.forEach(item => {
                            // Category header
                            if (item.category && item.category !== lastCat) {
                                lastCat = item.category;
                                const header = document.createElement('div');
                                header.className = 'gv-search-cat-header';
                                header.style.cssText = 'padding:8px 16px 4px;font-size:0.65rem;font-weight:800;text-transform:uppercase;letter-spacing:0.06em;color:#94a3b8;';
                                header.textContent = item.category;
                                searchDropdown.appendChild(header);
                            }
                            const link = document.createElement('a');
                            link.href = item.url;
                            link.className = 'gv-search-item';
                            link.setAttribute('data-search-nav', 'true');
                            const badgeHtml = item.badge
                                ? `<span style="display:inline-block;padding:2px 8px;border-radius:2rem;font-size:0.6rem;font-weight:800;background:${item.badgeColor || '#10b981'}20;color:${item.badgeColor || '#10b981'};border:1px solid ${item.badgeColor || '#10b981'}30;margin-left:auto;white-space:nowrap;">${item.badge}</span>`
                                : '';
                            link.innerHTML = `
                                <div class="gv-search-item-icon">
                                    <span class="material-symbols-outlined">${item.icon}</span>
                                </div>
                                <div class="gv-search-item-content">
                                    <div class="gv-search-item-title">${item.title}</div>
                                    <div class="gv-search-item-sub">${item.subtitle}</div>
                                </div>
                                ${badgeHtml}
                            `;
                            searchDropdown.appendChild(link);
                        });
                        // Keyboard hint
                        const hint = document.createElement('div');
                        hint.style.cssText = 'padding:6px 16px;font-size:0.63rem;color:#94a3b8;text-align:center;border-top:1px solid rgba(0,0,0,0.04);';
                        hint.textContent = '↑↓ naviguer · Enter sélectionner · Esc fermer';
                        searchDropdown.appendChild(hint);
                        searchDropdown.classList.add('active');
                    } else {
                        searchDropdown.innerHTML = '<div class="p-3 text-center text-muted" style="font-size:13px;">Aucun résultat trouvé.</div>';
                        searchDropdown.classList.add('active');
                    }
                })
                .catch(err => console.error('Search error:', err));
        }, 300);
    });

    // Keyboard navigation
    searchInput.addEventListener('keydown', (e) => {
        const items = searchDropdown.querySelectorAll('[data-search-nav]');
        if (!items.length) return;

        if (e.key === 'ArrowDown') {
            e.preventDefault();
            activeIdx = Math.min(activeIdx + 1, items.length - 1);
            updateActive(items);
        } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            activeIdx = Math.max(activeIdx - 1, 0);
            updateActive(items);
        } else if (e.key === 'Enter' && activeIdx >= 0) {
            e.preventDefault();
            items[activeIdx]?.click();
        } else if (e.key === 'Escape') {
            searchDropdown.classList.remove('active');
            searchInput.blur();
        }
    });

    function updateActive(items) {
        items.forEach((el, i) => {
            el.style.background = i === activeIdx ? 'rgba(16,185,129,0.08)' : '';
        });
        if (items[activeIdx]) items[activeIdx].scrollIntoView({ block: 'nearest' });
    }

    // Close dropdown on click outside
    document.addEventListener('click', (e) => {
        if (!searchInput.contains(e.target) && !searchDropdown.contains(e.target)) {
            searchDropdown.classList.remove('active');
        }
    });

    searchInput.addEventListener('focus', () => {
        if (searchInput.value.trim().length >= 2 && searchDropdown.innerHTML !== '') {
            searchDropdown.classList.add('active');
        }
    });
});
</script>
<script>
// ═══════════════════════════════════════════════════════════════
// GoVibe AI Voice Command Center — Global Controller
// ═══════════════════════════════════════════════════════════════
let chatModal;
let _gvTtsEnabled = true;
let _gvFrenchVoice = null;
let _gvAiNavRoutes = {
    vols: '{{ path('app_vols_index') }}',
    checkout: '{{ path('app_checkout_index') }}',
    hotels: '{{ path('app_hotel_index') }}',
    activites: '{{ path('app_activite_index') }}',
    voitures: '{{ path('app_location_index') }}',
    publications: '{{ path('app_poste_index') }}',
    reclamations: '{{ path('app_reclamation_index') }}',
    profil: '{{ path('app_user_profile') }}',
    accueil: '{{ path('app_user_home') }}',
    reservations: '{{ path('app_reservation_session_index') }}'
};

function _gvVoiceRecognitionLang() {
    const browserLang = (navigator.language || 'fr-FR').toLowerCase();
    return browserLang.startsWith('fr') ? 'fr-FR' : 'en-US';
}

function _gvVoiceRecognitionLangs() {
    const primary = _gvVoiceRecognitionLang();
    const secondary = primary === 'fr-FR' ? 'en-US' : 'fr-FR';
    return [primary, secondary];
}

function _gvVoiceErrorMessage(code) {
    const map = {
        'not-allowed': 'Acces micro refuse. Autorisez le microphone dans votre navigateur.',
        'service-not-allowed': 'Reconnaissance vocale desactivee par le navigateur.',
        'audio-capture': 'Aucun microphone detecte. Verifiez votre peripherique audio.',
        'no-speech': 'Aucune voix detectee. Parlez plus pres du micro.',
        'network': 'Erreur reseau de reconnaissance vocale. Reessayez.',
        'language-not-supported': 'Langue vocale non supportee. Passez le navigateur en francais ou anglais.',
        'aborted': 'Ecoute interrompue.',
    };
    return map[code] || ('Erreur de reconnaissance vocale: ' + code);
}

function _gvIsGreeting(text) {
    const normalized = (text || '').trim().toLowerCase();
    if (!normalized) return false;
    const greetings = ['hi', 'hello', 'hey', 'salut', 'bonjour', 'yo'];
    return greetings.includes(normalized);
}

async function _gvRecalibrateNoiseProfile() {
    try {
        await fetch('{{ path('app_api_python_assistant_noise_recalibrate') }}', {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        });
    } catch (e) {
        // Silent fallback: browser WebSpeech can still work even if Python assistant is offline.
    }
}

async function _gvEnsureMicAccess() {
    if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
        return { ok: false, message: 'Navigateur incompatible avec l\'acces microphone.' };
    }
    try {
        const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
        stream.getTracks().forEach((track) => track.stop());
        return { ok: true, message: '' };
    } catch (err) {
        const code = err && err.name ? String(err.name) : 'unknown';
        const normalized = code.toLowerCase().includes('notallowed') ? 'not-allowed' :
            (code.toLowerCase().includes('notfound') ? 'audio-capture' : 'unknown');
        return { ok: false, message: _gvVoiceErrorMessage(normalized) };
    }
}

// ═══ Voice Command Engine ═══════════════════════════════════
const gvVoice = {
    state: 'idle', // idle | listening | thinking | speaking
    recognition: null,
    lastResponse: '',
    lastTranscript: '',
    voiceCommandCount: parseInt(localStorage.getItem('gvVoiceCmdCount') || '0'),
    audioCtx: null,
    noSpeechRetryCount: 0,
    noSpeechLangIndex: 0,
    forcedRecognitionLang: null,

    init() {
        // Orb click = toggle voice. Double-click = open chat modal.
        const orb = document.getElementById('aiOrbBtn');
        if (orb) {
            let clickTimer = null;
            orb.addEventListener('click', (e) => {
                e.preventDefault();
                if (clickTimer) { clearTimeout(clickTimer); clickTimer = null; openChatModal(); return; }
                clickTimer = setTimeout(() => {
                    clickTimer = null;
                    if (this.state === 'idle') { this.startListening(); }
                    else if (this.state === 'listening') { this.stopListening(); }
                    else if (this.state === 'speaking') { this.stopSpeaking(); }
                    else { this.togglePanel(); }
                }, 280);
            });
        }

        // Keyboard shortcut: Ctrl+Shift+V
        document.addEventListener('keydown', (e) => {
            if (e.ctrlKey && e.shiftKey && e.key === 'V') {
                e.preventDefault();
                if (this.state === 'idle') this.startListening();
                else if (this.state === 'listening') this.stopListening();
            }
        });
    },

    setState(newState) {
        this.state = newState;
        const wrap = document.getElementById('gvVoiceWrap');
        const icon = document.getElementById('aiOrbIcon');
        const label = document.getElementById('gvVoiceLabel');
        if (!wrap) return;
        wrap.dataset.voiceState = newState;
        const stateMap = {
            idle:      { icon: 'neurology', label: '🤖 Cliquez pour parler' },
            listening: { icon: 'mic', label: '🎙️ Écoute en cours...' },
            thinking:  { icon: 'psychology', label: '🧠 Réflexion...' },
            speaking:  { icon: 'volume_up', label: '🔊 GoVibe parle...' },
        };
        const s = stateMap[newState] || stateMap.idle;
        if (icon) icon.textContent = s.icon;
        if (label) label.textContent = s.label;
    },

    playPing(type) {
        try {
            if (!this.audioCtx) this.audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            const ctx = this.audioCtx;
            const osc = ctx.createOscillator();
            const gain = ctx.createGain();
            osc.connect(gain); gain.connect(ctx.destination);
            if (type === 'start') { osc.frequency.setValueAtTime(880, ctx.currentTime); osc.frequency.exponentialRampToValueAtTime(1320, ctx.currentTime + 0.1); }
            else if (type === 'success') { osc.frequency.setValueAtTime(660, ctx.currentTime); osc.frequency.exponentialRampToValueAtTime(990, ctx.currentTime + 0.15); }
            else { osc.frequency.setValueAtTime(440, ctx.currentTime); }
            gain.gain.setValueAtTime(0.08, ctx.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.2);
            osc.start(ctx.currentTime); osc.stop(ctx.currentTime + 0.2);
        } catch(e) { /* AudioContext not available */ }
    },

    async startListening() {
        const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
        if (!SR) { this.showPanel('La reconnaissance vocale n\'est pas supportée.', ''); return; }

        const micCheck = await _gvEnsureMicAccess();
        if (!micCheck.ok) {
            this.showPanel('Erreur Microphone', micCheck.message);
            this.setState('idle');
            return;
        }

        this.setState('listening');
        this.playPing('start');
        this.showPanel('', '🎙️ Parlez maintenant...');
        if (!this.forcedRecognitionLang) {
            this.noSpeechRetryCount = 0;
            this.noSpeechLangIndex = 0;
        }
        const langs = _gvVoiceRecognitionLangs();
        const langToUse = this.forcedRecognitionLang || langs[0];

        this.recognition = new SR();
        this.recognition.lang = langToUse;
        this.recognition.interimResults = true;
        this.recognition.maxAlternatives = 1;
        this.recognition.continuous = true;

        let bestInterim = '';
        let silenceTimer = null;
        let processed = false;
        const self = this;

        // Safety timeout: if nothing happens in 12s, stop gracefully
        const safetyTimeout = setTimeout(() => {
            if (!processed && self.recognition) {
                processed = true;
                try { self.recognition.stop(); } catch(e) {}
                if (bestInterim) {
                    self.forcedRecognitionLang = null;
                    self.processCommand(bestInterim);
                } else {
                    self.setState('idle');
                    self.showPanel('', 'Aucune parole détectée. Réessayez.');
                }
            }
        }, 12000);

        this.recognition.onresult = (event) => {
            if (processed) return;
            let finalTranscript = '';
            let interimTranscript = '';

            for (let i = event.resultIndex; i < event.results.length; i++) {
                const t = event.results[i][0]?.transcript || '';
                if (event.results[i].isFinal) {
                    finalTranscript += t + ' ';
                } else {
                    interimTranscript += t;
                }
            }

            finalTranscript = finalTranscript.trim();
            interimTranscript = interimTranscript.trim();

            // Show live interim text in the panel
            if (interimTranscript) {
                bestInterim = interimTranscript;
                self.showPanel('', '🎙️ "' + interimTranscript + '"...');
            }

            if (finalTranscript) {
                const lowerText = finalTranscript.toLowerCase();
                const logOutKeywords = ["log out", "logout", "sign out", "signout", "exit session"];
                if (logOutKeywords.some(kw => lowerText.includes(kw))) {
                    processed = true;
                    clearTimeout(safetyTimeout);
                    if (silenceTimer) clearTimeout(silenceTimer);
                    self.forcedRecognitionLang = null;
                    try { self.recognition.stop(); } catch(e) {}
                    
                    self.showPanel('"' + finalTranscript + '"', "Logging you out...");
                    self.speak("Logging you out").then(() => {
                        fetch('/logout', { method: 'GET' })
                            .then(() => window.location.href = '/login');
                    });
                    return;
                }

                processed = true;
                clearTimeout(safetyTimeout);
                if (silenceTimer) clearTimeout(silenceTimer);
                self.forcedRecognitionLang = null;
                try { self.recognition.stop(); } catch(e) {}
                self.processCommand(finalTranscript);
            } else if (interimTranscript) {
                // If we get interim results but no final, wait 2s of silence then use interim
                if (silenceTimer) clearTimeout(silenceTimer);
                silenceTimer = setTimeout(() => {
                    if (!processed && bestInterim) {
                        processed = true;
                        clearTimeout(safetyTimeout);
                        try { self.recognition.stop(); } catch(e) {}
                        self.forcedRecognitionLang = null;
                        self.processCommand(bestInterim);
                    }
                }, 2000);
            }
        };
        this.recognition.onerror = (e) => {
            clearTimeout(safetyTimeout);
            if (silenceTimer) clearTimeout(silenceTimer);
            if (processed) return;

            this.setState('idle');
            const code = e && e.error ? e.error : 'unknown';
            const msg = _gvVoiceErrorMessage(code) + ' (code: ' + code + ')';
            if (code === 'no-speech' && this.noSpeechRetryCount < 2) {
                this.noSpeechRetryCount += 1;
                this.noSpeechLangIndex = Math.min(this.noSpeechLangIndex + 1, langs.length - 1);
                this.forcedRecognitionLang = langs[this.noSpeechLangIndex];
                this.showPanel('', 'Aucune voix detectee. Nouvelle tentative automatique... (' + this.forcedRecognitionLang + ')');
                setTimeout(() => this.startListening(), 2500);
                return;
            }
            this.forcedRecognitionLang = null;
            if (e.error !== 'aborted') this.showPanel('', msg);
        };
        this.recognition.onend = () => {
            clearTimeout(safetyTimeout);
            if (silenceTimer) clearTimeout(silenceTimer);
            // If we have interim text that wasn't processed, use it
            if (!processed && bestInterim) {
                processed = true;
                this.forcedRecognitionLang = null;
                this.processCommand(bestInterim);
                return;
            }
            if (this.state === 'listening') this.setState('idle');
        };
        this.recognition.start();
    },

    stopListening() {
        if (this.recognition) { try { this.recognition.stop(); } catch(e){} }
        this.setState('idle');
    },

    stopSpeaking() {
        if (this.currentAudio) {
            this.currentAudio.pause();
            this.currentAudio.currentTime = 0;
            this.currentAudio = null;
        }
        if (window.speechSynthesis) window.speechSynthesis.cancel();
        this.setState('idle');
    },

    emergencyStop() {
        if (this.recognition) { try { this.recognition.stop(); } catch(e){} }
        this.stopSpeaking();
        this.showPanel('🛑', 'Arrêt d\'urgence. Assistant stoppé.');
    },

    toggleMute() {
        if (typeof _gvTtsEnabled !== 'undefined') {
            _gvTtsEnabled = !_gvTtsEnabled;
            const btn = document.getElementById('gvBtnMute');
            if (btn) {
                btn.innerHTML = _gvTtsEnabled ? '🔇 Rendre Muet' : '🔊 Activer Voix';
                btn.style.color = _gvTtsEnabled ? '#f59e0b' : '#10b981';
            }
            if (!_gvTtsEnabled) this.stopSpeaking();
        }
    },

    async processCommand(transcript) {
        this.lastTranscript = transcript;

        if (_gvIsGreeting(transcript)) {
            const greetingReply = 'Hello sir, how can I help you?';
            this.playPing('success');
            this.showPanel('"' + transcript + '"', greetingReply);
            this.speak(greetingReply);
            return;
        }

        this.setState('thinking');
        this.showPanel('"' + transcript + '"', '⏳ Traitement...');

        // Track voice usage
        this.voiceCommandCount++;
        localStorage.setItem('gvVoiceCmdCount', this.voiceCommandCount.toString());

        const page = document.getElementById('gvVoiceWrap')?.dataset?.page || 'unknown';
        try {
            const resp = await fetch('{{ path('api_voice_command') }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                body: JSON.stringify({ transcript: transcript, page: page })
            });
            const data = await resp.json();

            if (data.success && data.action === 'navigate' && data.url) {
                this.playPing('success');
                this.showPanel('"' + transcript + '"', data.spoken_response || 'Navigation...');
                this.speak(data.spoken_response || 'Navigation.');
                setTimeout(() => { window.location.href = data.url; }, 1200);
                return;
            }

            if (data.success && data.action === 'scroll_to' && data.target) {
                this.playPing('success');
                const el = document.querySelector(data.target);
                if (el) el.scrollIntoView({ behavior: 'smooth', block: 'center' });
                this.speak(data.spoken_response || 'Voilà.');
                this.setState('idle');
                this.showPanel('"' + transcript + '"', data.spoken_response);
                return;
            }

            if (data.success && data.action === 'trigger_payment') {
                this.playPing('success');
                const payBtn = document.querySelector('[data-stripe-pay]') || document.querySelector('form[action*="stripe"] button[type="submit"]');
                if (payBtn) { this.speak(data.spoken_response); setTimeout(() => payBtn.click(), 1500); }
                else { this.speak('Aucun bouton de paiement trouvé sur cette page.'); }
                this.setState('idle');
                return;
            }

            if (data.success && data.action === 'read_summary') {
                const summary = document.querySelector('.gv-booking-summary, .checkout-summary, .card-body');
                this.speak(summary ? summary.textContent.substring(0, 400) : 'Résumé non trouvé.');
                this.setState('idle');
                return;
            }

            if (data.success && data.action === 'read_total') {
                const priceEl = document.querySelector('.gv-vl-total, .checkout-total, [data-total-price]');
                if (priceEl) {
                    this.speak('Le total est de ' + priceEl.textContent.trim());
                } else {
                    this.speak('Prix non visible sur cette page.');
                }
                this.setState('idle');
                return;
            }

            if (data.success && data.action === 'describe_screen') {
                this.playPing('success');
                
                let textToRead = "Vous êtes sur " + document.title.replace('— GoVibe', '').replace('| GoVibe', '') + ". ";
                
                let headers = document.querySelectorAll('h1, h2, .gv-hero-title, .gv-section-title');
                if (headers.length > 0) {
                    textToRead += "Les sections principales sont : ";
                    let addedCount = 0;
                    headers.forEach(h => {
                        let t = h.innerText.trim();
                        // ignore small/empty headers or duplicates
                        if (t.length > 3 && addedCount < 3 && !textToRead.includes(t)) {
                            textToRead += t + ". ";
                            addedCount++;
                        }
                    });
                }
                
                let buttons = document.querySelectorAll('a.btn, button, .gv-hero-cta, .gv-filter-pill');
                if (buttons.length > 0) {
                    textToRead += "Quelques actions disponibles : ";
                    let addedCount = 0;
                    buttons.forEach(b => {
                        let t = b.innerText.trim().replace(/[\r\n]+/g, " ");
                        if (t.length > 2 && addedCount < 4 && !t.includes('mic') && !t.includes('Rafraîchir')) {
                            textToRead += t + ". ";
                            addedCount++;
                        }
                    });
                }
                
                this.showPanel('"' + transcript + '"', "Description de la page...");
                this.speak(textToRead);
                return;
            }

            if (data.success && data.action === 'go_back') {
                this.playPing('success');
                this.speak(data.spoken_response || 'Retour.');
                setTimeout(() => window.history.back(), 1200);
                this.setState('idle');
                return;
            }

            if (data.success && data.action === 'stop_speaking') {
                window.speechSynthesis.cancel();
                this.setState('idle');
                this.showPanel('🔇', 'Arrêt de la synthèse vocale.');
                return;
            }

            if (data.success && data.action === 'speak_only') {
                this.playPing('success');
                this.showPanel('"' + transcript + '"', data.spoken_response);
                this.speak(data.spoken_response);
                return;
            }

            if (data.success && data.action === 'cancel_booking') {
                this.playPing('success');
                this.showPanel('"' + transcript + '"', data.spoken_response);
                this.speak(data.spoken_response);
                return;
            }

            if (data.success && data.action === 'ai_response') {
                const reply = data.spoken_response || 'Réponse reçue.';
                this.showPanel('"' + transcript + '"', reply);
                this.speak(reply);
                return;
            }

            // Fallback: pipe through Gemini/Groq chat
            this.fallbackToChat(transcript);

        } catch (err) {
            console.error('[Voice] Command error:', err);
            this.fallbackToChat(transcript);
        }
    },

    fallbackToChat(transcript) {
        const model = document.getElementById('aiModelSelectorValue')?.value || 'gemini';
        const route = model === 'groq' ? '{{ path('app_groq_chat') }}' : '{{ path('app_gemini_chat') }}';

        fetch(route, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            body: JSON.stringify({ message: transcript })
        })
        .then(r => r.json())
        .then(data => {
            const reply = data.response || data.error || 'Pas de réponse.';
            this.showPanel('"' + transcript + '"', reply.substring(0, 300));
            this.speak(reply);
        })
        .catch(() => {
            this.setState('idle');
            this.showPanel('"' + transcript + '"', 'Service temporairement indisponible.');
        });
    },

    async speak(text) {
        if (!text || !_gvTtsEnabled) { this.setState('idle'); return Promise.resolve(); }
        return new Promise(async (resolve) => {
            let clean = text
                .replace(/[\u{1F600}-\u{1F9FF}\u{2600}-\u{2B55}\u{1F300}-\u{1F5FF}\u{1F680}-\u{1F6FF}]/gu, '')
                .replace(/https?:\/\/[^\s]+/g, '').replace(/[*_`#>\[\]]/g, '').replace(/\n+/g, '. ').trim();
            if (!clean || clean.length < 3) { this.setState('idle'); resolve(); return; }
            if (clean.length > 250) clean = clean.substring(0, 250) + '...'; // [FIX] Max response length

            this.lastResponse = clean;
            this.setState('speaking');

            this.stopSpeaking();

            try {
                const resp = await fetch('/api/voice/speak', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ text: clean, voice: 'qween' })
                });

                if (!resp.ok) throw new Error('TTS failed');
                
                const blob = await resp.blob();
                this.currentAudio = new Audio(URL.createObjectURL(blob));
                
                this.currentAudio.addEventListener('ended', () => {
                    this.setState('idle');
                    this.currentAudio = null;
                    resolve();
                    // [FIX] Auto-resume mic safely if we were listening before
                    if (this.wasListeningBeforeSpeak) {
                        this.wasListeningBeforeSpeak = false;
                        setTimeout(() => this.startListening(), 300);
                    }
                });
                this.currentAudio.addEventListener('error', () => {
                    this.setState('idle');
                    this.currentAudio = null;
                    resolve();
                });
                
                this.currentAudio.play();
            } catch (e) {
                console.error('TTS error:', e);
                this.setState('idle');
                resolve();
            }
        });
    },

    replay() {
        if (this.lastResponse) this.speak(this.lastResponse);
    },

    showPanel(transcript, response) {
        const panel = document.getElementById('gvVoicePanel');
        const tEl = document.getElementById('gvVoiceTranscript');
        const rEl = document.getElementById('gvVoiceResponse');
        if (tEl && transcript !== undefined) tEl.textContent = transcript;
        if (rEl && response !== undefined) rEl.textContent = response;
        if (panel) panel.classList.add('active');
    },

    closePanel() {
        const panel = document.getElementById('gvVoicePanel');
        if (panel) panel.classList.remove('active');
    },

    togglePanel() {
        const panel = document.getElementById('gvVoicePanel');
        if (panel) panel.classList.toggle('active');
    }
};

// ═══ Page Load Init ═════════════════════════════════════════
document.addEventListener('DOMContentLoaded', () => {
    chatModal = new bootstrap.Modal(document.getElementById('chatModal'));
    gvVoice.init();

    document.addEventListener('click', (e) => {
        const selector = document.getElementById('aiSelector');
        if (selector && !selector.contains(e.target)) closeAISelector();
        // Close voice panel if clicking outside
        const wrap = document.getElementById('gvVoiceWrap');
        if (wrap && !wrap.contains(e.target)) gvVoice.closePanel();
    });
    // Check AI health on load
    checkAiHealth();
    // Preload TTS voices
    _loadVoices();
    if (window.speechSynthesis) {
        window.speechSynthesis.onvoiceschanged = _loadVoices;
    }
});

let _gvEnglishVoice = null;
function _loadVoices() {
    if (!window.speechSynthesis) return;
    const voices = window.speechSynthesis.getVoices();
    if (!voices.length) return;
    
    // Load French
    const frPriorities = ['vivian', 'hortense', 'amélie', 'amelie', 'thomas', 'lea', 'céline', 'celine'];
    for (const name of frPriorities) {
        const v = voices.find(v => v.name.toLowerCase().includes(name) && v.lang.startsWith('fr'));
        if (v) { _gvFrenchVoice = v; break; }
    }
    if (!_gvFrenchVoice) _gvFrenchVoice = voices.find(v => v.lang === 'fr-FR') || voices.find(v => v.lang.startsWith('fr')) || null;

    // Load English
    _gvEnglishVoice = voices.find(v => v.name.toLowerCase().includes('google uk english female')) ||
                      voices.find(v => v.lang.toLowerCase().startsWith('en-gb')) ||
                      voices.find(v => v.lang.toLowerCase().startsWith('en')) ||
                      voices[0];
}

function checkAiHealth() {
    const ctrl = new AbortController();
    const tid = setTimeout(() => ctrl.abort(), 2000);
    fetch('/api/ai/health', { signal: ctrl.signal }).then(r => r.json()).then(d => {
        clearTimeout(tid);
        const dot = document.getElementById('aiHealthDot');
        if (dot) dot.style.background = (d.success || d.status === 'healthy') ? '#10b981' : '#ef4444';
    }).catch(() => {
        clearTimeout(tid);
        const dot = document.getElementById('aiHealthDot');
        if (dot) dot.style.background = '#f59e0b';
    });
}

function toggleAISelector() {
    const c = document.getElementById('aiSelector'), m = document.getElementById('aiMenu');
    c.classList.toggle('open');
    m.style.display = c.classList.contains('open') ? 'block' : 'none';
}
function closeAISelector() {
    const c = document.getElementById('aiSelector'), m = document.getElementById('aiMenu');
    if(c) c.classList.remove('open'); if(m) m.style.display = 'none';
}

function selectAI(value, name) {
    document.getElementById('aiModelSelectorValue').value = value;
    document.getElementById('selectedAIName').innerText = name;
    updateWelcomeMessage(value);
    document.querySelectorAll('.gv-ai-selector-item').forEach(item => {
        item.classList.remove('active');
        const t = item.innerText;
        if ((value==='gemini'&&t.includes('Gemini'))||(value==='groq'&&t.includes('Groq'))||(value==='voice'&&t.includes('Voice'))) item.classList.add('active');
    });

{# templates/emails/forum_accepted.html.twig #}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f4f7f6; margin: 0; padding: 0; }
        .container { max-width: 600px; margin: 40px auto; background-color: #ffffff; border-radius: 12px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.1); border: 1px solid #e1e8e7; }
        .header { background: linear-gradient(135deg, #00342d 0%, #046b5e 100%); padding: 30px; text-align: center; }
        .header h1 { color: #ffffff; margin: 0; font-size: 24px; letter-spacing: 1px; }
        .content { padding: 40px; color: #334155; line-height: 1.6; }
        .content h2 { color: #00342d; margin-top: 0; }
        .forum-card { background: rgba(0, 52, 45, 0.03); border-left: 4px solid #10B981; padding: 20px; border-radius: 8px; margin: 25px 0; }
        .forum-card strong { color: #00342d; font-size: 1.1rem; }
        .btn { display: inline-block; padding: 12px 30px; background: #e9c176; color: #3d2a00; text-decoration: none; border-radius: 8px; font-weight: bold; margin-top: 20px; box-shadow: 0 4px 10px rgba(233,193,118,0.3); }
        .footer { background-color: #f8fafc; padding: 20px; text-align: center; color: #94a3b8; font-size: 12px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>GoVibe Community</h1>
        </div>
        <div class="content">
            <h2>Bonjour {{ user.prenom }},</h2>
            <p>Nous avons le plaisir de vous annoncer que votre demande d'adhésion au forum a été <strong>acceptée</strong> par l'administrateur !</p>
            
            <div class="forum-card">
                <strong>{{ forum.name }}</strong><br>
                <small>{{ forum.description|slice(0, 100) ~ '...' }}</small>
            </div>
            
            <p>Vous pouvez maintenant accéder à tout le contenu du forum, participer aux discussions et partager vos inspirations avec les autres membres.</p>
            
            <a href="{{ url('app_forum_show', {forumId: forum.forumId}) }}" class="btn">Accéder au forum</a>
        </div>
        <div class="footer">
            <p>&copy; 2026 GoVibe. Votre compagnon de voyage et d'aventure.</p>
            <p>Ceci est un message automatique, merci de ne pas y répondre.</p>
        </div>
    </div>
</body>
</html>

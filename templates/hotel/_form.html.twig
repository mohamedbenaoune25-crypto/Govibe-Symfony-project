{{ form_start(form, {'attr': {'class': 'hotel-form'}}) }}
    <div class="row g-3">
        <div class="col-md-6">
            <div class="form-floating">
                {{ form_widget(form.nom, {'attr': {'class': 'form-control', 'placeholder': 'Nom de l\'hôtel'}}) }}
                {{ form_label(form.nom, 'Nom de l\'hôtel', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_errors(form.nom) }}
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-floating">
                {{ form_widget(form.ville, {'attr': {'class': 'form-control', 'placeholder': 'Ville'}}) }}
                {{ form_label(form.ville, 'Ville', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_errors(form.ville) }}
            </div>
        </div>
        <div class="col-12">
            <div class="form-floating">
                {{ form_widget(form.adresse, {'attr': {'class': 'form-control', 'placeholder': 'Adresse complète'}}) }}
                {{ form_label(form.adresse, 'Adresse', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_errors(form.adresse) }}
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-floating">
                {{ form_widget(form.nombreEtoiles, {'attr': {'class': 'form-control', 'placeholder': 'Nombre d\'étoiles'}}) }}
                {{ form_label(form.nombreEtoiles, 'Nombre d\'étoiles', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_errors(form.nombreEtoiles) }}
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-floating">
                {{ form_widget(form.budget, {'attr': {'class': 'form-control', 'placeholder': 'Budget'}}) }}
                {{ form_label(form.budget, 'Budget (€)', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_errors(form.budget) }}
            </div>
        </div>
        <div class="col-12">
            <div class="form-floating">
                {{ form_widget(form.photoUrl, {'attr': {'class': 'form-control', 'placeholder': 'URL de la photo'}}) }}
                {{ form_label(form.photoUrl, 'URL de la photo', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_errors(form.photoUrl) }}
            </div>
        </div>
        <div class="col-12">
            <div class="form-floating">
                {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4, 'placeholder': 'Description de l\'hôtel'}}) }}
                {{ form_label(form.description, 'Description', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_errors(form.description) }}
            </div>
        </div>
    </div>
    <div class="d-grid mt-4">
        <button class="btn btn-primary btn-lg">
            <i class="bi bi-check-circle me-2"></i>{{ button_label|default('Sauvegarder l\'hôtel') }}
        </button>
    </div>
{{ form_end(form) }}

<style>
.hotel-form .form-floating {
    margin-bottom: 1rem;
}

.hotel-form .form-control {
    border: 2px solid #e9ecef;
    border-radius: 10px;
    padding: 1rem 0.75rem;
    font-size: 1rem;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
}

.hotel-form .form-control:focus {
    border-color: var(--primary-emerald);
    box-shadow: 0 0 0 0.2rem rgba(34, 197, 94, 0.25);
}

.hotel-form .form-label {
    color: var(--text-secondary);
    font-weight: 500;
}

.hotel-form .invalid-feedback {
    display: block;
    color: #dc3545;
    font-size: 0.875rem;
    margin-top: 0.25rem;
}

.btn-primary {
    background: linear-gradient(135deg, var(--primary-emerald), var(--accent-green));
    border: none;
    border-radius: 10px;
    padding: 0.75rem 1.5rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(34, 197, 94, 0.4);
    background: linear-gradient(135deg, var(--accent-green), var(--primary-emerald));
}
</style>
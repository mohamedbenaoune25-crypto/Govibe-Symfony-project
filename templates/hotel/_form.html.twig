{{ form_start(form, {'attr': {'class': 'hotel-form', 'novalidate': 'novalidate'}}) }}
    <div class="row g-3">
        <div class="col-md-6">
            <div class="form-floating">
                {{ form_widget(form.nom, {'attr': {'class': 'form-control' ~ (form.nom.vars.errors|length ? ' is-invalid' : ''), 'placeholder': 'hotel.form.name'|trans}}) }}
                {{ form_label(form.nom, 'hotel.form.name'|trans, {'label_attr': {'class': 'form-label'}}) }}
                {% if form.nom.vars.errors|length %}<div class="invalid-feedback">{{ 'common.required_field'|trans }}</div>{% endif %}
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-floating">
                {{ form_widget(form.ville, {'attr': {'class': 'form-control' ~ (form.ville.vars.errors|length ? ' is-invalid' : ''), 'placeholder': 'common.city'|trans}}) }}
                {{ form_label(form.ville, 'common.city'|trans, {'label_attr': {'class': 'form-label'}}) }}
                {% if form.ville.vars.errors|length %}<div class="invalid-feedback">{{ 'common.required_field'|trans }}</div>{% endif %}
            </div>
        </div>
        <div class="col-12">
            <div class="form-floating">
                {{ form_widget(form.adresse, {'attr': {'class': 'form-control' ~ (form.adresse.vars.errors|length ? ' is-invalid' : ''), 'placeholder': 'hotel.form.full_address'|trans}}) }}
                {{ form_label(form.adresse, 'common.address'|trans, {'label_attr': {'class': 'form-label'}}) }}
                {% if form.adresse.vars.errors|length %}<div class="invalid-feedback">{{ 'common.required_field'|trans }}</div>{% endif %}
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-floating">
                {{ form_widget(form.nombreEtoiles, {'attr': {'class': 'form-control' ~ (form.nombreEtoiles.vars.errors|length ? ' is-invalid' : ''), 'placeholder': 'common.stars'|trans}}) }}
                {{ form_label(form.nombreEtoiles, 'common.stars'|trans, {'label_attr': {'class': 'form-label'}}) }}
                {% if form.nombreEtoiles.vars.errors|length %}<div class="invalid-feedback">{{ 'common.invalid_value'|trans }}</div>{% endif %}
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-floating">
                {{ form_widget(form.budget, {'attr': {'class': 'form-control' ~ (form.budget.vars.errors|length ? ' is-invalid' : ''), 'placeholder': 'common.budget'|trans}}) }}
                {{ form_label(form.budget, 'hotel.form.budget_eur'|trans, {'label_attr': {'class': 'form-label'}}) }}
                {% if form.budget.vars.errors|length %}<div class="invalid-feedback">{{ 'common.invalid_value'|trans }}</div>{% endif %}
            </div>
        </div>
        <div class="col-12">
            <div class="form-floating">
                {{ form_widget(form.photoUrl, {'attr': {'class': 'form-control' ~ (form.photoUrl.vars.errors|length ? ' is-invalid' : ''), 'placeholder': 'hotel.form.photo_url'|trans}}) }}
                {{ form_label(form.photoUrl, 'hotel.form.photo_url'|trans, {'label_attr': {'class': 'form-label'}}) }}
                {% if form.photoUrl.vars.errors|length %}<div class="invalid-feedback">{{ 'common.invalid_value'|trans }}</div>{% endif %}
            </div>
        </div>
        <div class="col-12">
            <div class="form-floating">
                {{ form_widget(form.description, {'attr': {'class': 'form-control' ~ (form.description.vars.errors|length ? ' is-invalid' : ''), 'rows': 4, 'placeholder': 'common.description'|trans}}) }}
                {{ form_label(form.description, 'common.description'|trans, {'label_attr': {'class': 'form-label'}}) }}
                {% if form.description.vars.errors|length %}<div class="invalid-feedback">{{ 'common.invalid_value'|trans }}</div>{% endif %}
            </div>
        </div>
    </div>
    <div class="d-grid mt-4">
        <button class="btn btn-primary btn-lg">
            <i class="bi bi-check-circle me-2"></i>{{ button_label|default('hotel.form.save_default'|trans) }}
        </button>
    </div>
{{ form_end(form) }}

<style>
.hotel-form .form-floating {
    margin-bottom: 1rem;
}

.hotel-form .form-control {
    border: 2px solid #e9ecef;
    border-radius: 10px;
    padding: 1rem 0.75rem;
    font-size: 1rem;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
}

.hotel-form .form-control:focus {
    border-color: var(--primary-emerald);
    box-shadow: 0 0 0 0.2rem rgba(34, 197, 94, 0.25);
}

.hotel-form .form-label {
    color: var(--text-secondary);
    font-weight: 500;
}

.hotel-form .invalid-feedback {
    display: block;
    color: #dc3545;
    font-size: 0.875rem;
    margin-top: 0.25rem;
}

.btn-primary {
    background: linear-gradient(135deg, var(--primary-emerald), var(--accent-green));
    border: none;
    border-radius: 10px;
    padding: 0.75rem 1.5rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(34, 197, 94, 0.4);
    background: linear-gradient(135deg, var(--accent-green), var(--primary-emerald));
}
</style>
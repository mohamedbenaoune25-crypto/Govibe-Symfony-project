{% extends 'base.html.twig' %}

{% block title %}Vols — GoVibe | Réservations{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Manrope:wght@200..800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
<style>
body { font-family: 'Manrope', sans-serif !important; background: #fcf9f8 !important; overflow-x: hidden !important; }
.material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24; }

@keyframes slideDown { from { opacity: 0; transform: translateY(-20px); } to { opacity: 1; transform: translateY(0); } }

@keyframes slideDown { from { opacity: 0; transform: translateY(-20px); } to { opacity: 1; transform: translateY(0); } }

/* ─── Hero ─── */
.gv-vl-hero {
    position: relative; min-height: 420px; padding: 170px 0 100px;
    overflow: hidden; border-radius: 0 0 3rem 3rem;
    box-shadow: 0 20px 50px rgba(0,52,45,0.15);
}
.gv-vl-hero .hero-bg-img { position: absolute; inset: -30px; z-index: 0; }
.gv-vl-hero .hero-bg-img img { width: calc(100% + 60px); height: calc(100% + 60px); object-fit: cover; animation: heroPan 25s ease-in-out infinite alternate; }
@keyframes heroPan { 0%{transform:translate(0,0) scale(1)} 50%{transform:translate(-20px,-10px) scale(1.04)} 100%{transform:translate(-30px,-5px) scale(1.03)} }
.gv-vl-hero .hero-overlay { position: absolute; inset: 0; z-index: 1; background: linear-gradient(160deg, rgba(0,52,45,0.88) 0%, rgba(1,50,32,0.78) 50%, rgba(0,26,18,0.92) 100%); }
.gv-vl-hero::after { content:''; position:absolute; inset:0; z-index:2; background: radial-gradient(circle at 70% 30%, rgba(16,185,129,0.15), transparent 50%), radial-gradient(circle at 20% 70%, rgba(233,193,118,0.08), transparent 40%); pointer-events:none; }

.gv-hero-breadcrumb {
    display: inline-flex; align-items: center; gap: 8px; padding: 0.4rem 1rem;
    background: rgba(160,242,225,0.1); border: 1px solid rgba(160,242,225,0.15);
    border-radius: 2rem; font-size: 0.7rem; font-weight: 700; color: rgba(255,255,255,0.9);
    backdrop-filter: blur(8px); margin-bottom: 1rem; letter-spacing: 0.06em; text-transform: uppercase;
}
.gv-hero-breadcrumb .accent { color: #a0f2e1; }

.gv-hero-title { font-family:'Noto Serif',serif; font-size:clamp(2.2rem,4.5vw,3.5rem); color:#fff; font-weight:700; margin-bottom:0.75rem; position:relative; z-index:3; animation:heroFadeIn 0.8s ease both; }
.gv-hero-title em { color:#a0f2e1; font-style:italic; font-weight:300; }
.gv-hero-sub { color:rgba(160,242,225,0.7); font-size:1.05rem; max-width:560px; line-height:1.6; position:relative; z-index:3; animation:heroFadeIn 0.8s ease 0.2s both; }
@keyframes heroFadeIn { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }

.gv-hero-cta {
    padding: 0.85rem 2rem; background: linear-gradient(135deg, #e9c176, #ca9028); color: #3d2a00;
    border: none; border-radius: 0.75rem; font-weight: 700; font-size: 0.95rem; text-decoration: none;
    display: inline-flex; align-items: center; gap: 0.5rem; transition: all 0.3s;
    box-shadow: 0 10px 25px -5px rgba(233,193,118,0.4); font-family: 'Manrope', sans-serif;
    position: relative; z-index: 3;
}
.gv-hero-cta:hover { transform:translateY(-2px); box-shadow:0 15px 35px -5px rgba(233,193,118,0.5); color:#3d2a00; }

/* ─── Layout ─── */
.gv-vl-container { max-width: 1200px; margin: 0 auto; padding: 2.5rem 2rem 5rem; }
.gv-filter-pills { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2rem; }
.gv-filter-pill {
    padding: 0.6rem 1.25rem; border-radius: 2rem; font-size: 0.85rem; font-weight: 700;
    border: 1.5px solid rgba(0,52,45,0.08); background: #fff; color: #546067;
    text-decoration: none; transition: all 0.25s; display: inline-flex; align-items: center; gap: 0.4rem;
}
.gv-filter-pill:hover { border-color: rgba(0,52,45,0.2); background: rgba(0,52,45,0.03); color: #00342d; }
.gv-filter-pill.active {
    background: linear-gradient(135deg, #00342d, #046b5e); color: #fff; border-color: transparent;
    box-shadow: 0 6px 20px rgba(0,52,45,0.25);
}

.gv-section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
.gv-section-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #546067; display: flex; align-items: center; gap: 0.5rem; }
.gv-section-label .material-symbols-outlined { font-size: 1rem; color: #10B981; }
.gv-count-badge { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.8rem; font-weight: 700; padding: 0.5rem 1.25rem; border-radius: 2rem; background: rgba(0,52,45,0.06); color: #00342d; }

/* ─── Flight Cards (checkout-style) ─── */
.gv-vl-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(360px, 1fr)); gap: 2rem; }
@media (max-width: 768px) { .gv-vl-grid { grid-template-columns: 1fr; } }

.gv-vl-card {
    border-radius: 1.5rem; overflow: hidden; box-shadow: 0 8px 32px rgba(0,52,45,0.08);
    transition: all 0.4s cubic-bezier(0.4,0,0.2,1); position: relative; min-height: 380px;
}
.gv-vl-card:hover { transform: translateY(-8px); box-shadow: 0 24px 60px rgba(0,52,45,0.18); }

.gv-vl-card-bg { position: absolute; inset: 0; z-index: 0; overflow: hidden; }
.gv-vl-card-bg img { width: 130%; height: 130%; object-fit: cover; position: absolute; top: -15%; left: -15%; animation: panCard 14s ease-in-out infinite alternate; transition: transform 0.6s ease; }
.gv-vl-card:hover .gv-vl-card-bg img { transform: scale(1.05); }
.gv-vl-card:nth-child(3n+1) .gv-vl-card-bg img { animation-name: panCard1; }
.gv-vl-card:nth-child(3n+2) .gv-vl-card-bg img { animation-name: panCard2; }
.gv-vl-card:nth-child(3n)   .gv-vl-card-bg img { animation-name: panCard3; }
@keyframes panCard1 { 0%{transform:translate(0%,0%) scale(1)} 100%{transform:translate(-8%,-5%) scale(1.08)} }
@keyframes panCard2 { 0%{transform:translate(-5%,0%) scale(1.05)} 100%{transform:translate(3%,-6%) scale(1)} }
@keyframes panCard3 { 0%{transform:translate(0%,-5%) scale(1)} 100%{transform:translate(-6%,3%) scale(1.06)} }

.gv-vl-card-overlay {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(180deg, rgba(0,52,45,0.72) 0%, rgba(0,40,28,0.82) 50%, rgba(0,20,12,0.94) 100%);
    transition: background 0.4s;
}
.gv-vl-card:hover .gv-vl-card-overlay {
    background: linear-gradient(180deg, rgba(0,52,45,0.62) 0%, rgba(0,40,28,0.72) 50%, rgba(0,20,12,0.90) 100%);
}

.gv-vl-card-body { position: relative; z-index: 2; padding: 1.75rem; display: flex; flex-direction: column; height: 100%; }
.gv-vl-id { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em; color: rgba(255,255,255,0.45); text-transform: uppercase; }
.gv-vl-route { font-family:'Noto Serif',serif; font-size: 1.3rem; font-weight: 700; color: #fff; text-shadow: 0 2px 8px rgba(0,0,0,0.3); margin-top: 0.25rem; }

.gv-vl-badge { border-radius: 2rem; padding: 0.4rem 1rem; font-size: 0.7rem; font-weight: 800; letter-spacing: 0.05em; text-transform: uppercase; backdrop-filter: blur(8px); }
.gv-vl-badge-class { background: rgba(233,193,118,0.2); color: #fde68a; border: 1px solid rgba(233,193,118,0.3); }
.gv-vl-badge-seats { background: rgba(160,242,225,0.15); color: #a0f2e1; border: 1px solid rgba(160,242,225,0.3); }

.gv-vl-meta { font-size: 0.85rem; color: rgba(255,255,255,0.7); margin-top: 1rem; display: flex; flex-direction: column; gap: 0.5rem; }
.gv-vl-meta-item { display: flex; align-items: center; gap: 0.5rem; }
.gv-vl-meta-item .material-symbols-outlined { font-size: 1rem; color: #a0f2e1; }

.gv-vl-summary {
    background: rgba(255,255,255,0.08); backdrop-filter: blur(8px); border-radius: 1rem;
    border: 1px solid rgba(255,255,255,0.1); padding: 1rem 1.25rem; margin-top: 1.25rem;
    display: flex; justify-content: space-between; align-items: center; gap: 1rem;
}
.gv-vl-total-label { font-size: 0.65rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: rgba(255,255,255,0.45); }
.gv-vl-total { font-family:'Noto Serif',serif; font-size: 1.5rem; font-weight: 700; color: #a0f2e1; text-shadow: 0 2px 12px rgba(160,242,225,0.3); }

.gv-vl-detail-btn {
    padding: 0.55rem 1.25rem; border-radius: 2rem; font-size: 0.8rem; font-weight: 700;
    color: #a0f2e1; border: 1px solid rgba(160,242,225,0.3); background: rgba(255,255,255,0.05);
    text-decoration: none; backdrop-filter: blur(4px); transition: all 0.25s;
    display: inline-flex; align-items: center; gap: 0.3rem; white-space: nowrap;
}
.gv-vl-detail-btn:hover { background: rgba(16,185,129,0.2); border-color: #a0f2e1; color: #fff; }

.gv-vl-actions { display: flex; gap: 0.5rem; margin-top: 0.75rem; }
.gv-vl-action-btn {
    flex: 1; padding: 0.55rem; border-radius: 0.75rem; font-size: 0.8rem; font-weight: 700;
    text-align: center; text-decoration: none; display: inline-flex; align-items: center;
    justify-content: center; gap: 0.3rem; backdrop-filter: blur(4px); transition: all 0.25s;
    font-family: 'Manrope', sans-serif; border: none; cursor: pointer;
}
.gv-vl-action-primary { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.85); border: 1px solid rgba(255,255,255,0.15); }
.gv-vl-action-primary:hover { background: rgba(255,255,255,0.2); border-color: rgba(255,255,255,0.3); color: #fff; }
.gv-vl-action-secondary { background: rgba(16,185,129,0.08); color: #a0f2e1; border: 1px solid rgba(16,185,129,0.2); }
.gv-vl-action-secondary:hover { background: rgba(16,185,129,0.25); border-color: #a0f2e1; color: #fff; }

.gv-ai-pill {
    display: inline-flex; align-items: center; gap: 0.35rem;
    padding: 0.3rem 0.75rem; border-radius: 2rem; font-size: 0.65rem;
    font-weight: 800; letter-spacing: 0.04em; text-transform: uppercase;
    backdrop-filter: blur(8px); animation: aiBadgeIn 0.5s ease both;
    border: 1px solid transparent;
}
.gv-ai-pill-high { background: rgba(239,68,68,0.2); color: #fca5a5; border-color: rgba(239,68,68,0.3); }
.gv-ai-pill-medium { background: rgba(233,193,118,0.2); color: #fde68a; border-color: rgba(233,193,118,0.3); }
.gv-ai-pill-low { background: rgba(160,242,225,0.15); color: #a0f2e1; border-color: rgba(160,242,225,0.25); }
.gv-ai-pill-loading { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.35); }
@keyframes aiBadgeIn { from{opacity:0;transform:scale(0.85)} to{opacity:1;transform:scale(1)} }

.gv-empty { text-align: center; padding: 5rem 2rem; background: #fff; border-radius: 1.5rem; box-shadow: 0 20px 50px rgba(0,0,0,0.04); grid-column: 1 / -1; }
.gv-empty-icon { font-size: 4rem; color: #cde1db; margin-bottom: 1.5rem; font-variation-settings: 'FILL' 1; }
.gv-empty h4 { font-family:'Noto Serif',serif; font-size: 1.5rem; color: #00342d; font-weight: 700; margin-bottom: 0.5rem; }
.gv-empty p { color: #546067; margin-bottom: 2rem; }
</style>
{% endblock %}

{% block body %}
{% set cardImages = [
    asset('images/plane_sunset_1.png'),
    asset('images/plane_sunset_2.png'),
    asset('images/plane_sunset_3.png')
] %}

<section class="gv-vl-hero">
    <div class="hero-bg-img"><img src="{{ asset('images/home-hero5.png') }}" alt=""></div>
    <div class="hero-overlay"></div>
    <div class="container position-relative" style="z-index:3;">
        <div class="row align-items-end g-4">
            <div class="col-lg-8">
                <div class="gv-hero-breadcrumb">
                    <span class="material-symbols-outlined" style="font-size:0.9rem; color:#a0f2e1;">home</span> GoVibe
                    <span class="material-symbols-outlined" style="font-size:0.7rem; opacity:0.5;">chevron_right</span>
                    <span class="accent">Vols</span>
                </div>
                <h1 class="gv-hero-title">Découvrez nos <em>vols</em></h1>
                <p class="gv-hero-sub">Une présentation immersive, cohérente avec le style des cartes checkout, pour réserver plus vite.</p>
            </div>
            <div class="col-lg-4 text-lg-end pb-2" style="position:relative; z-index:3;">
                <a href="#vols-list" class="gv-hero-cta">
                    <span class="material-symbols-outlined" style="font-size:1.1rem;">flight</span>
                    Voir les vols
                </a>
            </div>
        </div>
    </div>
</section>

<section class="gv-vl-container" id="vols-list">

    <!-- AI Feature Highlight Bar -->
    <div style="background: linear-gradient(135deg, #10B981 0%, #047857 100%); border-radius: 1rem; padding: 1.5rem 2rem; margin-bottom: 2rem; color: white; display: flex; align-items: center; justify-content: space-between; box-shadow: 0 10px 25px rgba(16, 185, 129, 0.3); animation: slideDown 0.5s ease-out forwards;">
        <div style="display: flex; align-items: center; gap: 1rem;">
            <div style="background: rgba(255,255,255,0.2); padding: 1rem; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <span class="material-symbols-outlined" style="font-size: 2rem; color: white;">auto_awesome</span>
            </div>
            <div>
                <h3 style="margin: 0; font-size: 1.5rem; font-weight: 800; font-family: 'Manrope', sans-serif;">GoVibe AI Insights</h3>
                <p style="margin: 0; font-size: 0.95rem; opacity: 0.9;">L'Intelligence Artificielle analyse en temps réel les prix, la météo et la demande pour vous recommander les meilleurs vols.</p>
            </div>
        </div>
        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; justify-content: flex-end;">
            <div style="background: rgba(255,255,255,0.15); padding: 0.5rem 1rem; border-radius: 2rem; font-size: 0.85rem; font-weight: 700; backdrop-filter: blur(5px);">⚡️ Prédictions ultra-rapides</div>
            <div style="background: rgba(255,255,255,0.15); padding: 0.5rem 1rem; border-radius: 2rem; font-size: 0.85rem; font-weight: 700; backdrop-filter: blur(5px);">🌦️ Impact Météo</div>
        </div>
    </div>
    
    <!-- Interactive Filter Topbar & Smart Sort -->
    <div class="gv-filter-topbar" style="background: rgba(255,255,255,0.8); backdrop-filter: blur(12px); border-radius: 1rem; padding: 1.5rem; margin-bottom: 2rem; box-shadow: 0 10px 40px rgba(0,52,45,0.05); display: flex; gap: 1rem; flex-wrap: wrap; align-items: center;">
        <div style="flex: 1 1 200px; position: relative;">
            <span class="material-symbols-outlined" style="position:absolute; left:12px; top:50%; transform:translateY(-50%); color:rgba(0,52,45,0.4);">flight_takeoff</span>
            <input type="text" id="gvFlightSearch" placeholder="Destination, Aéroport..." style="width: 100%; border: 1.5px solid rgba(0,52,45,0.1); border-radius: 0.75rem; padding: 0.75rem 1rem 0.75rem 2.5rem; outline: none; transition: border-color 0.3s; background: white;">
        </div>
        <div style="flex: 1 1 200px; position: relative;">
            <span class="material-symbols-outlined" style="position:absolute; left:12px; top:50%; transform:translateY(-50%); color:rgba(0,52,45,0.4); pointer-events:none;">event_seat</span>
            <select id="gvFlightClass" style="width: 100%; border: 1.5px solid rgba(0,52,45,0.1); border-radius: 0.75rem; padding: 0.75rem 2.5rem 0.75rem 2.5rem; outline: none; appearance: none; background: white; cursor: pointer; transition: border-color 0.3s;">
                <option value="">Toutes les classes</option>
                <option value="Économique">Économique</option>
                <option value="Eco">Eco</option>
                <option value="Premium Économique">Premium Économique</option>
                <option value="Affaires">Affaires</option>
            </select>
            <span class="material-symbols-outlined" style="position:absolute; right:12px; top:50%; transform:translateY(-50%); color:rgba(0,52,45,0.4); pointer-events:none;">expand_more</span>
        </div>
        
        <!-- Smart Sort Controls -->
        <div style="flex: 1 1 200px; position: relative;">
            <span class="material-symbols-outlined" style="position:absolute; left:12px; top:50%; transform:translateY(-50%); color:rgba(0,52,45,0.4); pointer-events:none;">sort</span>
            <select id="gvFlightSort" style="width: 100%; border: 1.5px solid rgba(0,52,45,0.1); border-radius: 0.75rem; padding: 0.75rem 2.5rem 0.75rem 2.5rem; outline: none; appearance: none; background: white; cursor: pointer; transition: border-color 0.3s;" onchange="window.location.href='?sort='+this.value.split('|')[0]+'&dir='+this.value.split('|')[1]">
                <option value="time|ASC" {% if currentSort|default('time') == 'time' and currentDir|default('ASC') == 'ASC' %}selected{% endif %}>Départ: Plus tôt</option>
                <option value="time|DESC" {% if currentSort|default('time') == 'time' and currentDir|default('ASC') == 'DESC' %}selected{% endif %}>Départ: Plus tard</option>
                <option value="price|ASC" {% if currentSort|default('time') == 'price' and currentDir|default('ASC') == 'ASC' %}selected{% endif %}>Prix: Croissant 📈</option>
                <option value="price|DESC" {% if currentSort|default('time') == 'price' and currentDir|default('ASC') == 'DESC' %}selected{% endif %}>Prix: Décroissant 📉</option>
            </select>
            <span class="material-symbols-outlined" style="position:absolute; right:12px; top:50%; transform:translateY(-50%); color:rgba(0,52,45,0.4); pointer-events:none;">expand_more</span>
        </div>

        <button id="gvFlightFilterReset" class="gv-hero-cta" style="padding: 0.75rem 1.5rem; background: rgba(0,52,45,0.05); color: #00342d; box-shadow: none;">
            <span class="material-symbols-outlined" style="font-size: 1rem;">restart_alt</span> Réinitialiser
        </button>
    </div>

    <!-- Voice AI Shortcuts -->
    <div class="gv-voice-hints">
        <span class="material-symbols-outlined">mic</span>
        <span>Essayez :</span>
        <button class="gv-voice-hint-chip" onclick="voiceCommand('Vol le moins cher')">✈️ "Vol le moins cher"</button>
        <button class="gv-voice-hint-chip" onclick="voiceCommand('Vols vers Paris')">🗼 "Vols vers Paris"</button>
        <button class="gv-voice-hint-chip" onclick="voiceCommand('Meilleur vol AI')">🤖 "Meilleur vol AI"</button>
        <button class="gv-voice-hint-chip" onclick="voiceCommand('Voir les hôtels')">🏨 "Voir les hôtels"</button>
    </div>

    <div class="gv-section-header">
        <span class="gv-section-label">
            <span class="material-symbols-outlined">airplanemode_active</span> Vos vols
        </span>
        <span class="gv-count-badge">{{ vols|length }} résultat{{ vols|length > 1 ? 's' : '' }}</span>
    </div>

    <div class="gv-vl-grid">
        {% for vol in vols %}
        <div class="gv-vl-card gv-reveal" data-vl-id="{{ vol.flightId }}" data-vl-price="{{ vol.prix }}">
            <div class="gv-vl-card-bg"><img src="{{ cardImages[loop.index0 % 3] }}" alt="" loading="lazy"></div>
            <div class="gv-vl-card-overlay"></div>

            <div class="gv-vl-card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div>
                        <div class="gv-vl-id">#{{ vol.flightId }}</div>
                        <h4 class="gv-vl-route">{{ vol.departureAirport }} → {{ vol.destination }}</h4>
                    </div>
                    <span class="gv-vl-badge gv-vl-badge-class">{{ vol.classeChaise }}</span>
                </div>

                <div class="gv-vl-meta">
                    <div class="gv-vl-meta-item">
                        <span class="material-symbols-outlined">schedule</span>
                        Départ : {{ vol.departureTime ? vol.departureTime|date('H:i') : '-' }}
                    </div>
                    <div class="gv-vl-meta-item">
                        <span class="material-symbols-outlined">schedule_send</span>
                        Arrivée : {{ vol.arrivalTime ? vol.arrivalTime|date('H:i') : '-' }}
                    </div>
                    <div class="gv-vl-meta-item">
                        <span class="material-symbols-outlined">badge</span>
                        {{ vol.airline }}
                    </div>
                </div>

                <!-- AI Analytics Strip -->
                <div class="gv-vl-ai-strip" data-vl="{{ vol.flightId }}" data-vl-seats="{{ vol.availableSeats }}">
                    <div class="gv-vl-ai-header">
                        <span class="material-symbols-outlined" style="font-size:0.85rem;color:#a0f2e1;">neurology</span>
                        <span>AI Flight Intelligence</span>
                        <div class="gv-vl-ai-loading"><div class="spinner-border spinner-border-sm" role="status" style="width:12px;height:12px;border-width:2px;"></div></div>
                    </div>
                    <div class="gv-vl-ai-metrics" style="display:none;">
                        <div class="gv-vl-ai-metric" id="aiScore-{{ vol.flightId }}">
                            <span class="gv-vl-ai-metric-icon">🤖</span>
                            <div class="gv-vl-ai-metric-text">
                                <div class="gv-vl-ai-metric-label">Travel Score</div>
                                <div class="gv-vl-ai-metric-value">—</div>
                            </div>
                        </div>
                        <div class="gv-vl-ai-metric" id="aiWeather-{{ vol.flightId }}">
                            <span class="gv-vl-ai-metric-icon">🌤</span>
                            <div class="gv-vl-ai-metric-text">
                                <div class="gv-vl-ai-metric-label">Météo</div>
                                <div class="gv-vl-ai-metric-value">—</div>
                            </div>
                        </div>
                        <div class="gv-vl-ai-metric" id="aiDemand-{{ vol.flightId }}">
                            <span class="gv-vl-ai-metric-icon">📈</span>
                            <div class="gv-vl-ai-metric-text">
                                <div class="gv-vl-ai-metric-label">Demande</div>
                                <div class="gv-vl-ai-metric-value">—</div>
                            </div>
                        </div>
                        <div class="gv-vl-ai-metric" id="aiRec-{{ vol.flightId }}">
                            <span class="gv-vl-ai-metric-icon">✅</span>
                            <div class="gv-vl-ai-metric-text">
                                <div class="gv-vl-ai-metric-label">Recommandation</div>
                                <div class="gv-vl-ai-metric-value">—</div>
                            </div>
                        </div>
                    </div>
                </div>
                <style>
                .gv-vl-ai-strip{background:rgba(255,255,255,0.08);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,0.12);border-radius:0.85rem;padding:10px 14px;margin-top:0.75rem;transition:all 0.4s;}
                .gv-vl-ai-header{display:flex;align-items:center;gap:6px;font-size:0.65rem;font-weight:800;text-transform:uppercase;letter-spacing:0.06em;color:rgba(255,255,255,0.55);}
                .gv-vl-ai-loading{margin-left:auto;color:#a0f2e1;}
                .gv-vl-ai-metrics{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:10px;}
                .gv-vl-ai-metric{display:flex;align-items:center;gap:8px;padding:6px 8px;border-radius:0.6rem;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.08);transition:all 0.3s;}
                .gv-vl-ai-metric:hover{background:rgba(255,255,255,0.12);}
                .gv-vl-ai-metric-icon{font-size:1rem;line-height:1;}
                .gv-vl-ai-metric-label{font-size:0.6rem;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;color:rgba(255,255,255,0.45);}
                .gv-vl-ai-metric-value{font-size:0.78rem;font-weight:700;color:#a0f2e1;}
                .gv-vl-ai-metric-value.text-warn{color:#fde68a;}
                .gv-vl-ai-metric-value.text-danger-gv{color:#fca5a5;}
                .gv-vl-ai-strip.ai-loaded .gv-vl-ai-loading{display:none;}
                .gv-vl-ai-strip.ai-loaded .gv-vl-ai-metrics{display:grid !important;animation:fadeInMetrics 0.5s ease;}
                @keyframes fadeInMetrics{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
                </style>

                <div class="gv-vl-footer mt-auto">
                    <div class="gv-vl-summary">
                        <div>
                            <div class="gv-vl-total-label">Prix</div>
                            <span class="gv-vl-total">{{ vol.prix }} DT</span>
                        </div>
                        <a href="{{ path('app_checkout_new', {'flight': vol.flightId}) }}" class="gv-vl-detail-btn">
                            Réserver <span class="material-symbols-outlined" style="font-size:0.9rem;">arrow_forward</span>
                        </a>
                    </div>

                    <div class="gv-vl-actions">
                        <span class="gv-vl-action-btn gv-vl-action-primary">
                            <span class="material-symbols-outlined" style="font-size:0.9rem;">people</span> {{ vol.availableSeats ?? '-' }} places
                        </span>
                        <span class="gv-vl-action-btn gv-vl-action-secondary">
                            <span class="material-symbols-outlined" style="font-size:0.9rem;">event_seat</span> {{ vol.classeChaise }}
                        </span>
                    </div>
                </div>
            </div>
        </div>
        {% else %}
        <div class="gv-empty">
            <span class="material-symbols-outlined gv-empty-icon">flight_takeoff</span>
            <h4>Aucun vol trouvé</h4>
            <p>Ajoutez des vols ou ajustez vos filtres pour afficher les cartes.</p>
            <a href="{{ path('app_vols_index') }}" class="gv-hero-cta" style="background:linear-gradient(135deg,#00342d,#046b5e); color:#fff; box-shadow:0 10px 25px -5px rgba(0,52,45,0.4);">
                <span class="material-symbols-outlined" style="font-size:1.1rem;">refresh</span>
                Rafraîchir
            </a>
        </div>
        {% endfor %}
    </div>
</section>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    var reveals = document.querySelectorAll('.gv-reveal');
    if (reveals.length) {
        var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
                if (entry.isIntersecting) { entry.target.classList.add('is-visible'); observer.unobserve(entry.target); }
            });
        }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });
        reveals.forEach(function(el, i) { el.style.transitionDelay = (i * 80) + 'ms'; observer.observe(el); });
    }

    // ═══ AI Flight Intelligence ═══════════════════════════════════════
    var cards = document.querySelectorAll('.gv-vl-card[data-vl-id]');
    if (!cards.length) return;

    var isWeekend = ([0,6].indexOf(new Date().getDay()) !== -1) ? 1 : 0;

    // Separate DOM references from API payload data
    var stripRefs = {};  // vlId -> DOM element
    var apiPayload = []; // clean data for JSON.stringify

    cards.forEach(function(card) {
        var vlId = card.dataset.vlId;
        var price = parseFloat(card.dataset.vlPrice) || 200;
        var strip = card.querySelector('.gv-vl-ai-strip[data-vl="' + vlId + '"]');
        if (!strip) return;
        var seats = parseInt(strip.dataset.vlSeats) || 50;

        var temp = 60 + Math.random() * 20;
        var hum = 40 + Math.random() * 30;

        stripRefs[vlId] = strip;

        apiPayload.push({
            flight_id: vlId,
            days_before_departure: 14,
            price: price,
            seats_left: seats,
            is_weekend: isWeekend,
            is_holiday: 0,
            seat_type: 0,
            weather_features: [temp, hum, 1013, 15 + Math.random() * 25]
        });
    });

    // Populate a single card with AI data
    function populateCard(vlId, bookProb, weatherImpact) {
        var strip = stripRefs[vlId];
        if (!strip) return;
        strip.classList.add('ai-loaded');

        var travelScore = Math.round((bookProb * 0.6 + (1 - weatherImpact) * 0.4) * 100);

        // Travel Score
        var scoreEl = document.getElementById('aiScore-' + vlId);
        if (scoreEl) {
            var scoreClass = travelScore >= 70 ? '' : (travelScore >= 40 ? 'text-warn' : 'text-danger-gv');
            scoreEl.querySelector('.gv-vl-ai-metric-value').className = 'gv-vl-ai-metric-value ' + scoreClass;
            scoreEl.querySelector('.gv-vl-ai-metric-value').textContent = travelScore + '/100';
        }

        // Weather
        var weatherEl = document.getElementById('aiWeather-' + vlId);
        if (weatherEl) {
            var weatherLabel = weatherImpact < 0.4 ? 'Favorable ☀️' : (weatherImpact < 0.7 ? 'Prudence ☁️' : 'Risqué ⛈️');
            var wClass = weatherImpact < 0.4 ? '' : (weatherImpact < 0.7 ? 'text-warn' : 'text-danger-gv');
            weatherEl.querySelector('.gv-vl-ai-metric-value').className = 'gv-vl-ai-metric-value ' + wClass;
            weatherEl.querySelector('.gv-vl-ai-metric-value').textContent = weatherLabel;
        }

        // Demand
        var demandEl = document.getElementById('aiDemand-' + vlId);
        if (demandEl) {
            var pct = Math.round(bookProb * 100);
            var dLabel = pct >= 75 ? 'Très forte' : (pct >= 50 ? 'Modérée' : 'Faible');
            var dClass = pct >= 75 ? 'text-danger-gv' : (pct >= 50 ? 'text-warn' : '');
            demandEl.querySelector('.gv-vl-ai-metric-value').className = 'gv-vl-ai-metric-value ' + dClass;
            demandEl.querySelector('.gv-vl-ai-metric-value').textContent = dLabel + ' (' + pct + '%)';
        }

        // Recommendation
        var recEl = document.getElementById('aiRec-' + vlId);
        if (recEl) {
            var combined = bookProb * 0.6 + (1 - weatherImpact) * 0.4;
            var recLabel, recClass;
            if (combined >= 0.7) { recLabel = 'Recommandé ✅'; recClass = ''; }
            else if (combined >= 0.4) { recLabel = 'Acceptable 👍'; recClass = 'text-warn'; }
            else { recLabel = 'À éviter ⚠️'; recClass = 'text-danger-gv'; }
            recEl.querySelector('.gv-vl-ai-metric-value').className = 'gv-vl-ai-metric-value ' + recClass;
            recEl.querySelector('.gv-vl-ai-metric-value').textContent = recLabel;
        }
    }

    // Generate simulated AI data (deterministic per flight for consistency)
    function simulateAI(vlId, price, seats) {
        // Seed a pseudo-random from flight ID characters
        var seed = 0;
        for (var i = 0; i < vlId.length; i++) seed += vlId.charCodeAt(i);
        var rng = function() { seed = (seed * 9301 + 49297) % 233280; return seed / 233280; };

        var bookProb = 0.35 + rng() * 0.55;  // 0.35 - 0.90
        if (price > 800) bookProb = Math.min(bookProb + 0.1, 0.95);
        if (seats < 20) bookProb = Math.min(bookProb + 0.15, 0.98);

        var weatherImpact = 0.1 + rng() * 0.5;  // 0.1 - 0.6

        populateCard(vlId, bookProb, weatherImpact);
    }

    if (apiPayload.length > 0) {
        // Attempt 1: Batch endpoint with timeout
        var controller = new AbortController();
        var timeoutId = setTimeout(function() { controller.abort(); }, 5000);

        fetch('/api/ai/predict/analytics-batch', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            signal: controller.signal,
            body: JSON.stringify({ flights: apiPayload })
        })
        .then(function(r) { clearTimeout(timeoutId); return r.json(); })
        .then(function(response) {
            if (!response.success || !response.data || !response.data.flights) throw new Error("Batch failed");

            var hasAnyResult = false;
            response.data.flights.forEach(function(prediction, index) {
                var item = apiPayload[index];
                var vlId = item.flight_id;
                var booking = prediction.booking || {};
                var weather = prediction.weather || {};

                if (!booking.success && !weather.success) return;
                hasAnyResult = true;

                var bookProb = booking.confidence || booking.booking_probability || (booking.probability) || 0.5;
                var weatherValue = (weather.prediction && weather.prediction[0]) ? weather.prediction[0] : 0.3;
                var weatherImpact = weather.weather_impact || weatherValue;

                populateCard(vlId, bookProb, weatherImpact);
            });

            if (!hasAnyResult) throw new Error("No valid results");
        })
        .catch(function(batchErr) {
            clearTimeout(timeoutId);
            // Fallback: simulate ALL cards instantly instead of doing 200+ individual requests
            apiPayload.forEach(function(item) {
                simulateAI(item.flight_id, item.price, item.seats_left);
            });
        });
    }

    // ═══ Global Search Filters ════════════════════════════════════════
    const searchInput = document.getElementById('gvFlightSearch');
    const classSelect = document.getElementById('gvFlightClass');
    const resetBtn = document.getElementById('gvFlightFilterReset');
    const countBadge = document.querySelector('.gv-count-badge');

    // Cache DOM reads per card to avoid re-querying on every filter
    const cardData = [];
    cards.forEach(card => {
        cardData.push({
            el: card,
            route: (card.querySelector('.gv-vl-route')?.textContent || '').toLowerCase(),
            classeName: (card.querySelector('.gv-vl-badge-class')?.textContent || '').toLowerCase()
        });
    });

    function filterCards() {
        const query = searchInput.value.toLowerCase().trim();
        const selectedClass = classSelect.value.toLowerCase();
        let visibleCount = 0;

        cardData.forEach(data => {
            const matchesQuery = query === '' || data.route.includes(query);
            const matchesClass = selectedClass === '' || data.classeName === selectedClass;

            if (matchesQuery && matchesClass) {
                data.el.style.display = 'block';
                visibleCount++;
            } else {
                data.el.style.display = 'none';
            }
        });

        if (countBadge) {
            countBadge.textContent = visibleCount + ' résultat' + (visibleCount !== 1 ? 's' : '');
        }
    }

    let _flightSearchTimer;
    searchInput.addEventListener('input', function() {
        clearTimeout(_flightSearchTimer);
        _flightSearchTimer = setTimeout(filterCards, 300);
    });
    classSelect.addEventListener('change', filterCards);
    resetBtn.addEventListener('click', () => {
        searchInput.value = '';
        classSelect.value = '';
        filterCards();
    });
});
</script>
{% endblock %}

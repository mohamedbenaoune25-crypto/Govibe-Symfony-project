{% extends 'base.html.twig' %}

{% block title %}Vols - GoVibe{% endblock %}

{% block body %}
<style>
    body { background: transparent; }

    /* ─── Hero Section ─── */
    .flight-hero {
        position: relative;
        min-height: 400px;
        padding: 155px 0 90px;
        color: white;
        overflow: hidden;
    }

    /* Animated hero background image */
    .flight-hero .hero-bg-img {
        position: absolute;
        inset: -30px;
        z-index: 0;
    }

    .flight-hero .hero-bg-img img {
        width: calc(100% + 60px);
        height: calc(100% + 60px);
        object-fit: cover;
        animation: heroPan 25s ease-in-out infinite alternate;
    }

    @keyframes heroPan {
        0%   { transform: translate(0px, 0px) scale(1); }
        25%  { transform: translate(-15px, -8px) scale(1.03); }
        50%  { transform: translate(-25px, 5px) scale(1.05); }
        75%  { transform: translate(-10px, -15px) scale(1.02); }
        100% { transform: translate(-30px, -10px) scale(1.04); }
    }

    /* Green overlay on top of image */
    .flight-hero .hero-overlay {
        position: absolute;
        inset: 0;
        z-index: 1;
        background: linear-gradient(135deg, rgba(1, 50, 32, 0.82), rgba(8, 78, 54, 0.72));
    }

    .flight-hero::after {
        content: '';
        position: absolute;
        inset: 0;
        z-index: 2;
        background: radial-gradient(circle at 20% 20%, rgba(34, 197, 94, 0.22), transparent 35%),
                    radial-gradient(circle at 80% 30%, rgba(255,255,255,0.08), transparent 28%);
        pointer-events: none;
    }

    .hero-breadcrumb {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px 16px;
        background: rgba(34, 197, 94, 0.15);
        border: 1px solid rgba(34, 197, 94, 0.2);
        border-radius: 999px;
        font-size: 13px;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(8px);
        margin-bottom: 16px;
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }

    .hero-breadcrumb i { color: #86efac; }

    .hero-title {
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.15;
        margin-bottom: 12px;
    }

    .hero-subtitle {
        font-size: 17px;
        color: rgba(255, 255, 255, 0.6);
        font-weight: 400;
        line-height: 1.6;
        max-width: 560px;
    }

    /* ─── Search Bar ─── */
    .flight-search {
        margin-top: -42px;
        position: relative;
        z-index: 2;
    }

    .search-shell {
        background: rgba(255, 255, 255, 0.92);
        border: 1px solid rgba(255, 255, 255, 0.6);
        backdrop-filter: blur(24px) saturate(180%);
        box-shadow: 0 20px 50px rgba(1, 50, 32, 0.10);
        border-radius: 22px;
        padding: 22px 26px;
    }

    .search-shell .form-label {
        font-size: 11px !important;
        font-weight: 700;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        color: var(--mid-green);
    }

    /* ─── Flight Cards with Animated Backgrounds ─── */
    .flight-card {
        border: 0;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 8px 32px rgba(1, 50, 32, 0.12);
        transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
    }

    .flight-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 24px 60px rgba(1, 50, 32, 0.22);
    }

    /* Animated background image */
    .flight-card .card-bg {
        position: absolute;
        inset: 0;
        z-index: 0;
        overflow: hidden;
    }

    .flight-card .card-bg img {
        width: 130%;
        height: 130%;
        object-fit: cover;
        position: absolute;
        top: -15%;
        left: -15%;
        animation: panFlight 14s ease-in-out infinite alternate;
        transition: transform 0.6s ease;
    }

    .flight-card:hover .card-bg img {
        transform: scale(1.05);
    }

    /* Different pan directions per card */
    .flight-card:nth-child(3n+1) .card-bg img { animation-name: panFlight1; }
    .flight-card:nth-child(3n+2) .card-bg img { animation-name: panFlight2; }
    .flight-card:nth-child(3n)   .card-bg img { animation-name: panFlight3; }

    @keyframes panFlight1 {
        0%   { transform: translate(0%, 0%) scale(1); }
        100% { transform: translate(-8%, -5%) scale(1.08); }
    }

    @keyframes panFlight2 {
        0%   { transform: translate(-5%, 0%) scale(1.05); }
        100% { transform: translate(3%, -6%) scale(1); }
    }

    @keyframes panFlight3 {
        0%   { transform: translate(0%, -5%) scale(1); }
        100% { transform: translate(-6%, 3%) scale(1.06); }
    }

    /* Dark overlay for text readability */
    .flight-card .card-overlay {
        position: absolute;
        inset: 0;
        z-index: 1;
        background: linear-gradient(
            180deg,
            rgba(1, 50, 32, 0.70) 0%,
            rgba(1, 40, 25, 0.80) 50%,
            rgba(0, 20, 12, 0.92) 100%
        );
        transition: background 0.4s ease;
    }

    .flight-card:hover .card-overlay {
        background: linear-gradient(
            180deg,
            rgba(1, 50, 32, 0.62) 0%,
            rgba(1, 40, 25, 0.72) 50%,
            rgba(0, 20, 12, 0.88) 100%
        );
    }

    /* Card content above overlay */
    .flight-card .card-body {
        position: relative;
        z-index: 2;
    }

    .flight-route {
        font-size: 20px;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.02em;
        text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    }

    .flight-route .route-arrow {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 30px;
        height: 30px;
        border-radius: 10px;
        background: rgba(34, 197, 94, 0.2);
        margin: 0 5px;
    }

    .flight-route .route-arrow i {
        font-size: 13px;
        color: #86efac;
    }

    .flight-pill {
        border-radius: 10px;
        font-size: 12px;
        font-weight: 700;
        padding: 5px 12px;
        letter-spacing: 0.04em;
        background: rgba(34, 197, 94, 0.2);
        color: #86efac;
        border: 1px solid rgba(34, 197, 94, 0.25);
        backdrop-filter: blur(4px);
    }

    .flight-info-box {
        padding: 14px 16px;
        border-radius: 14px;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(4px);
    }

    .flight-info-box .info-label {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: rgba(255, 255, 255, 0.5);
        margin-bottom: 4px;
    }

    .flight-info-box .info-value {
        font-size: 18px;
        font-weight: 700;
        color: #fff;
        text-shadow: 0 1px 4px rgba(0,0,0,0.2);
    }

    .flight-divider {
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        margin: 16px 0;
    }

    .flight-price {
        font-size: 26px;
        font-weight: 800;
        color: #86efac;
        letter-spacing: -0.02em;
        text-shadow: 0 2px 12px rgba(34, 197, 94, 0.4);
    }

    .flight-cta {
        background: linear-gradient(135deg, #16a34a, #22c55e) !important;
        border: none !important;
        border-radius: 14px !important;
        font-weight: 700;
        font-size: 14px;
        padding: 12px 24px;
        box-shadow: 0 8px 24px rgba(34, 197, 94, 0.35);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        color: white !important;
    }

    .flight-cta:hover {
        box-shadow: 0 12px 32px rgba(34, 197, 94, 0.45);
        transform: translateY(-2px);
    }

    /* ─── Section Header ─── */
    .section-header h2 {
        font-size: 14px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: rgba(255, 255, 255, 0.7);
    }

    .count-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        font-weight: 600;
        padding: 4px 14px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: rgba(255, 255, 255, 0.8);
    }

    .empty-state {
        background: rgba(255, 255, 255, 0.9);
        border: 1.5px dashed rgba(1, 50, 32, 0.12);
        border-radius: 24px;
        padding: 48px;
        text-align: center;
    }

    .empty-state i {
        font-size: 48px;
        color: var(--primary-emerald);
        opacity: 0.5;
        margin-bottom: 16px;
    }
</style>

{% set cardImages = [
    asset('images/plane_sunset_1.png'),
    asset('images/plane_sunset_2.png'),
    asset('images/plane_sunset_3.png')
] %}

<section class="flight-hero">
    <div class="hero-bg-img">
        <img src="{{ asset('images/home-hero5.png') }}" alt="">
    </div>
    <div class="hero-overlay"></div>
    <div class="container position-relative" style="z-index: 3;">
        <div class="row align-items-end g-4">
            <div class="col-lg-8">
                <div class="hero-breadcrumb">
                    <i class="bi bi-house-door-fill"></i> GoVibe
                    <i class="bi bi-chevron-right" style="font-size:10px; opacity: 0.5;"></i>
                    <span style="color: #86efac;">Vols</span>
                </div>
                <h1 class="hero-title">Réservez votre <br>prochain vol</h1>
                <p class="hero-subtitle">Trouvez un vol, comparez les options, puis ouvrez le checkout pour finaliser votre réservation.</p>
            </div>
            <div class="col-lg-4 text-lg-end pb-2">
                <a href="{{ path('app_checkout_index') }}" class="btn btn-light rounded-pill px-4 py-2 fw-semibold">
                    <i class="bi bi-ticket-perforated me-2"></i> Mes checkouts
                </a>
            </div>
        </div>
    </div>
</section>

<section class="flight-search py-4">
    <div class="container">
        <form method="get" class="search-shell">
            <div class="row g-3 align-items-end">
                <div class="col-lg-4">
                    <label class="form-label">
                        <i class="bi bi-geo-alt me-1 text-success"></i> Départ
                    </label>
                    <input type="text" name="origin" value="{{ searchOrigin }}" class="form-control form-control-lg rounded-pill" placeholder="Ville ou aéroport">
                </div>
                <div class="col-lg-4">
                    <label class="form-label">
                        <i class="bi bi-geo me-1 text-success"></i> Destination
                    </label>
                    <input type="text" name="destination" value="{{ searchDestination }}" class="form-control form-control-lg rounded-pill" placeholder="Ville ou aéroport">
                </div>
                <div class="col-lg-4 d-flex gap-2">
                    <button class="btn btn-success btn-lg rounded-pill flex-fill"><i class="bi bi-search me-2"></i> Rechercher</button>
                    <a href="{{ path('app_vols_index') }}" class="btn btn-outline-secondary btn-lg rounded-pill"><i class="bi bi-arrow-counterclockwise"></i></a>
                </div>
            </div>
        </form>
    </div>
</section>

<section class="py-4 pb-5">
    <div class="container">
        <div class="section-header d-flex justify-content-between align-items-center mb-4">
            <h2><i class="bi bi-airplane me-2"></i> Vols disponibles</h2>
            <span class="count-badge">
                <i class="bi bi-grid-3x3-gap"></i> {{ vols|length }} vol{{ vols|length > 1 ? 's' : '' }}
            </span>
        </div>

        <div class="row g-4">
            {% for vol in vols %}
                <div class="col-md-6 col-xl-4" data-card-animate>
                    <div class="card flight-card h-100">
                        {# Animated background image #}
                        <div class="card-bg">
                            <img src="{{ cardImages[loop.index0 % 3] }}" alt="" loading="lazy">
                        </div>
                        <div class="card-overlay"></div>

                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <div style="font-size:12px; font-weight:600; letter-spacing:0.05em; color:rgba(255,255,255,0.5);">{{ vol.flightId }}</div>
                                    <div class="flight-route mt-1">
                                        {{ vol.departureAirport }}
                                        <span class="route-arrow"><i class="bi bi-arrow-right"></i></span>
                                        {{ vol.destination }}
                                    </div>
                                    <div style="font-size:14px; color: rgba(255,255,255,0.65); font-weight:500; margin-top:4px;">
                                        <i class="bi bi-airplane me-1" style="color:#86efac;"></i> {{ vol.airline }}
                                    </div>
                                </div>
                                <span class="flight-pill">{{ vol.classeChaise }}</span>
                            </div>

                            <div class="row g-3 mb-3">
                                <div class="col-6">
                                    <div class="flight-info-box">
                                        <div class="info-label">Départ</div>
                                        <div class="info-value">{{ vol.departureTime ? vol.departureTime|date('H:i') : '-' }}</div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="flight-info-box">
                                        <div class="info-label">Arrivée</div>
                                        <div class="info-value">{{ vol.arrivalTime ? vol.arrivalTime|date('H:i') : '-' }}</div>
                                    </div>
                                </div>
                            </div>

                            <div class="flight-divider"></div>

                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div style="font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.05em; color:rgba(255,255,255,0.45);">Places</div>
                                    <strong style="font-size:16px; color: #fff;">{{ vol.availableSeats }}</strong>
                                </div>
                                <div class="text-end">
                                    <div style="font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.05em; color:rgba(255,255,255,0.45);">Prix</div>
                                    <span class="flight-price">{{ vol.prix }} DT</span>
                                </div>
                            </div>

                            <div class="mt-4">
                                <a href="{{ path('app_checkout_new', {flight: vol.flightId}) }}" onclick="openDetailModal(this.href); return false;" class="btn flight-cta w-100">
                                    <i class="bi bi-bag-check me-2"></i> Réserver ce vol
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12">
                    <div class="empty-state">
                        <i class="bi bi-cloud-slash d-block"></i>
                        <h4 style="color: var(--dark-green); font-weight: 700;">Aucun vol trouvé</h4>
                        <p class="text-muted mb-0">Aucun vol ne correspond à vos critères de recherche.</p>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endblock %}

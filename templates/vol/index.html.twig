{% extends 'base.html.twig' %}

{% block title %}Vols — GoVibe | Réservation de Vols{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Manrope:wght@200..800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════════
   GoVibe Vols — Ultra Premium Design
═══════════════════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; }

body {
    font-family: 'Manrope', sans-serif !important;
    background: #fcf9f8 !important;
    color: #1c1b1b !important;
    overflow-x: hidden !important;
}

.material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24; }

/* ─── Hero Section ─── */
.gv-vol-hero {
    position: relative;
    min-height: 420px;
    padding: 180px 0 120px;
    background: linear-gradient(160deg, #00342d 0%, #013220 40%, #001a12 100%);
    overflow: hidden;
    border-radius: 0 0 3rem 3rem;
    box-shadow: 0 20px 50px rgba(0, 52, 45, 0.15);
}

.gv-vol-hero::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse at 20% 80%, rgba(16, 185, 129, 0.15) 0%, transparent 60%),
                radial-gradient(ellipse at 85% 15%, rgba(233, 193, 118, 0.08) 0%, transparent 50%);
    pointer-events: none;
}

.gv-vol-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(160, 242, 225, 0.06) 1px, transparent 1px);
    background-size: 24px 24px;
    pointer-events: none;
}

.gv-hero-bg-img {
    position: absolute;
    inset: -30px;
    z-index: 0;
}

.gv-hero-bg-img img {
    width: calc(100% + 60px);
    height: calc(100% + 60px);
    object-fit: cover;
    animation: heroPan 25s ease-in-out infinite alternate;
}

@keyframes heroPan {
    0%   { transform: translate(0px, 0px) scale(1); }
    50%  { transform: translate(-20px, -10px) scale(1.04); }
    100% { transform: translate(-30px, -5px) scale(1.03); }
}

.gv-hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(160deg, rgba(0, 52, 45, 0.88) 0%, rgba(1, 50, 32, 0.78) 50%, rgba(0, 26, 18, 0.92) 100%);
}

.gv-hero-icon-bg {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font-size: 22rem;
    color: rgba(255, 255, 255, 0.02);
    z-index: 2;
    pointer-events: none;
    font-variation-settings: 'FILL' 1;
}

.gv-hero-breadcrumb {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 0.4rem 1rem;
    background: rgba(160, 242, 225, 0.1);
    border: 1px solid rgba(160, 242, 225, 0.15);
    border-radius: 2rem;
    font-size: 0.7rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(8px);
    margin-bottom: 1rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
}
.gv-hero-breadcrumb .accent { color: #a0f2e1; }

.gv-hero-title {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: #fff;
    font-weight: 700;
    margin-bottom: 1rem;
    position: relative;
    z-index: 3;
    animation: heroFadeIn 0.8s ease both;
}
.gv-hero-title em { color: #a0f2e1; font-style: italic; font-weight: 300; }

.gv-hero-sub {
    color: rgba(160, 242, 225, 0.7);
    font-size: 1.1rem;
    max-width: 560px;
    line-height: 1.6;
    position: relative;
    z-index: 3;
    animation: heroFadeIn 0.8s ease 0.2s both;
}

@keyframes heroFadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}

.gv-hero-cta {
    padding: 0.75rem 1.5rem;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: #fff;
    border-radius: 2rem;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    backdrop-filter: blur(8px);
    transition: all 0.3s ease;
    position: relative;
    z-index: 3;
}
.gv-hero-cta:hover {
    background: rgba(255, 255, 255, 0.2);
    color: #fff;
    transform: translateY(-2px);
}

/* ─── Search Bar ─── */
.gv-search-section {
    margin-top: -42px;
    position: relative;
    z-index: 10;
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
    padding: 0 2rem;
}

.gv-search-shell {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(24px) saturate(180%);
    border: 1px solid rgba(0, 52, 45, 0.06);
    border-radius: 1.5rem;
    padding: 1.25rem 1.5rem;
    box-shadow: 0 20px 50px rgba(0, 52, 45, 0.08);
}

.gv-search-form {
    display: grid;
    grid-template-columns: 1fr 1fr auto;
    gap: 1rem;
    align-items: end;
}
@media (max-width: 768px) {
    .gv-search-form { grid-template-columns: 1fr; }
}

.gv-search-label {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #546067;
    margin-bottom: 0.35rem;
    display: flex;
    align-items: center;
    gap: 0.3rem;
}
.gv-search-label .material-symbols-outlined { font-size: 0.9rem; color: #10B981; }

.gv-search-input {
    border: 1.5px solid rgba(0, 52, 45, 0.08);
    border-radius: 0.75rem;
    padding: 0.75rem 1rem;
    font-size: 0.95rem;
    font-family: 'Manrope', sans-serif;
    font-weight: 500;
    color: #1c1b1b;
    background: #fff;
    transition: all 0.25s ease;
    width: 100%;
    outline: none;
}
.gv-search-input::placeholder { color: #bfc9c4; }
.gv-search-input:focus {
    border-color: #10B981;
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.12);
}

.gv-search-actions {
    display: flex;
    gap: 0.5rem;
}

.gv-search-btn {
    padding: 0.75rem 1.75rem;
    background: linear-gradient(135deg, #00342d 0%, #004d43 70%, #046b5e 100%);
    color: #fff;
    border: none;
    border-radius: 0.75rem;
    font-weight: 700;
    font-family: 'Manrope', sans-serif;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s ease;
    box-shadow: 0 8px 20px -6px rgba(0, 52, 45, 0.4);
    white-space: nowrap;
}
.gv-search-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 30px -6px rgba(0, 52, 45, 0.5);
}

.gv-search-reset {
    padding: 0.75rem;
    background: rgba(0, 52, 45, 0.06);
    border: none;
    border-radius: 0.75rem;
    color: #546067;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.25s ease;
}
.gv-search-reset:hover { background: rgba(0, 52, 45, 0.12); color: #00342d; }

/* ─── Main Content ─── */
.gv-vol-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 2rem 5rem;
}

.gv-section-header {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2.5rem;
    gap: 1rem;
}

.gv-section-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #546067;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}
.gv-section-label .material-symbols-outlined { font-size: 1rem; color: #10B981; }

.gv-count-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    font-weight: 700;
    padding: 0.5rem 1.25rem;
    border-radius: 2rem;
    background: rgba(0, 52, 45, 0.06);
    color: #00342d;
}

/* ─── Flight Cards ─── */
.gv-vol-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: 2rem;
}
@media (max-width: 768px) { .gv-vol-grid { grid-template-columns: 1fr; } }

{% set cardImages = [
    "'" ~ asset('images/plane_sunset_1.png') ~ "'",
    "'" ~ asset('images/plane_sunset_2.png') ~ "'",
    "'" ~ asset('images/plane_sunset_3.png') ~ "'"
] %}

.gv-vol-card {
    border-radius: 1.5rem;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 52, 45, 0.08);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    min-height: 380px;
}
.gv-vol-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 24px 60px rgba(0, 52, 45, 0.18);
}

.gv-vol-card-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
}
.gv-vol-card-bg img {
    width: 130%;
    height: 130%;
    object-fit: cover;
    position: absolute;
    top: -15%;
    left: -15%;
    animation: panCard 14s ease-in-out infinite alternate;
    transition: transform 0.6s ease;
}
.gv-vol-card:hover .gv-vol-card-bg img { transform: scale(1.05); }

.gv-vol-card:nth-child(3n+1) .gv-vol-card-bg img { animation-name: panCard1; }
.gv-vol-card:nth-child(3n+2) .gv-vol-card-bg img { animation-name: panCard2; }
.gv-vol-card:nth-child(3n)   .gv-vol-card-bg img { animation-name: panCard3; }

@keyframes panCard1 { 0% { transform: translate(0%, 0%) scale(1); } 100% { transform: translate(-8%, -5%) scale(1.08); } }
@keyframes panCard2 { 0% { transform: translate(-5%, 0%) scale(1.05); } 100% { transform: translate(3%, -6%) scale(1); } }
@keyframes panCard3 { 0% { transform: translate(0%, -5%) scale(1); } 100% { transform: translate(-6%, 3%) scale(1.06); } }

.gv-vol-card-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(180deg, rgba(0, 52, 45, 0.72) 0%, rgba(0, 40, 28, 0.82) 50%, rgba(0, 20, 12, 0.94) 100%);
    transition: background 0.4s ease;
}
.gv-vol-card:hover .gv-vol-card-overlay {
    background: linear-gradient(180deg, rgba(0, 52, 45, 0.62) 0%, rgba(0, 40, 28, 0.72) 50%, rgba(0, 20, 12, 0.90) 100%);
}

.gv-vol-card-body {
    position: relative;
    z-index: 2;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    height: 100%;
}

.gv-vol-flight-id {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.45);
    text-transform: uppercase;
}

.gv-vol-route {
    font-family: 'Noto Serif', serif;
    font-size: 1.35rem;
    font-weight: 700;
    color: #fff;
    margin-top: 0.35rem;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
}

.gv-route-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px; height: 30px;
    border-radius: 10px;
    background: rgba(160, 242, 225, 0.15);
}
.gv-route-arrow .material-symbols-outlined { font-size: 1rem; color: #a0f2e1; }

.gv-vol-airline {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.6);
    font-weight: 500;
    margin-top: 0.25rem;
    display: flex;
    align-items: center;
    gap: 0.35rem;
}
.gv-vol-airline .material-symbols-outlined { font-size: 1rem; color: #a0f2e1; }

.gv-vol-pill {
    border-radius: 2rem;
    font-size: 0.7rem;
    font-weight: 800;
    padding: 0.4rem 1rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    background: rgba(160, 242, 225, 0.15);
    color: #a0f2e1;
    border: 1px solid rgba(160, 242, 225, 0.2);
    backdrop-filter: blur(4px);
}

.gv-vol-info-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-top: 1.25rem;
}

.gv-vol-info-box {
    padding: 0.85rem 1rem;
    border-radius: 0.85rem;
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(4px);
}
.gv-vol-info-label {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.45);
    margin-bottom: 0.25rem;
}
.gv-vol-info-value {
    font-size: 1.15rem;
    font-weight: 700;
    color: #fff;
}

.gv-vol-divider {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    margin: 1rem 0;
}

.gv-vol-footer {
    margin-top: auto;
}

.gv-vol-price-section {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
}

.gv-vol-price {
    font-family: 'Noto Serif', serif;
    font-size: 1.6rem;
    font-weight: 700;
    color: #a0f2e1;
    text-shadow: 0 2px 12px rgba(160, 242, 225, 0.3);
}

.gv-vol-seats-label {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.45);
}
.gv-vol-seats-value {
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
}

.gv-vol-cta {
    background: linear-gradient(135deg, #e9c176 0%, #ca9028 100%);
    border: none;
    border-radius: 0.85rem;
    font-weight: 700;
    font-size: 0.95rem;
    padding: 0.85rem 1.5rem;
    box-shadow: 0 8px 24px rgba(233, 193, 118, 0.3);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    color: #3d2a00;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    font-family: 'Manrope', sans-serif;
}
.gv-vol-cta:hover {
    box-shadow: 0 12px 32px rgba(233, 193, 118, 0.45);
    transform: translateY(-2px);
    color: #3d2a00;
}

/* ─── Empty State ─── */
.gv-empty {
    text-align: center;
    padding: 5rem 2rem;
    background: #fff;
    border-radius: 1.5rem;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.04);
    grid-column: 1 / -1;
}
.gv-empty-icon {
    font-size: 4rem;
    color: #cde1db;
    margin-bottom: 1.5rem;
    font-variation-settings: 'FILL' 1;
}
.gv-empty h4 {
    font-family: 'Noto Serif', serif;
    font-size: 1.5rem;
    color: #00342d;
    font-weight: 700;
    margin-bottom: 0.5rem;
}
.gv-empty p { color: #546067; }

/* ─── Reveal Animations ─── */
.gv-reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s cubic-bezier(0.4, 0, 0.2, 1), transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
}
.gv-reveal.is-visible { opacity: 1; transform: translateY(0); }
</style>
{% endblock %}

{% block body %}
{% set cardImages = [
    asset('images/plane_sunset_1.png'),
    asset('images/plane_sunset_2.png'),
    asset('images/plane_sunset_3.png')
] %}

<!-- ─── HERO ─── -->
<section class="gv-vol-hero">
    <div class="gv-hero-bg-img">
        <img src="{{ asset('images/home-hero5.png') }}" alt="">
    </div>
    <div class="gv-hero-overlay"></div>
    <span class="material-symbols-outlined gv-hero-icon-bg">flight</span>
    <div class="container position-relative" style="z-index: 3;">
        <div class="row align-items-end g-4">
            <div class="col-lg-8">
                <div class="gv-hero-breadcrumb">
                    <span class="material-symbols-outlined" style="font-size:0.9rem; color:#a0f2e1;">home</span> GoVibe
                    <span class="material-symbols-outlined" style="font-size:0.7rem; opacity:0.5;">chevron_right</span>
                    <span class="accent">Vols</span>
                </div>
                <h1 class="gv-hero-title">Réservez votre <br>prochain <em>vol</em></h1>
                <p class="gv-hero-sub">Trouvez un vol, comparez les options, puis ouvrez le checkout pour finaliser votre réservation.</p>
            </div>
            <div class="col-lg-4 text-lg-end pb-2" style="position:relative; z-index:3;">
                <a href="{{ path('app_checkout_index') }}" class="gv-hero-cta">
                    <span class="material-symbols-outlined" style="font-size:1.1rem;">confirmation_number</span>
                    Mes checkouts
                </a>
            </div>
        </div>
    </div>
</section>

<!-- ─── SEARCH BAR ─── -->
<div class="gv-search-section">
    <form method="get" class="gv-search-shell">
        <div class="gv-search-form">
            <div>
                <label class="gv-search-label">
                    <span class="material-symbols-outlined">flight_takeoff</span> Départ
                </label>
                <input type="text" name="origin" value="{{ searchOrigin }}" class="gv-search-input" placeholder="Ville ou aéroport">
            </div>
            <div>
                <label class="gv-search-label">
                    <span class="material-symbols-outlined">flight_land</span> Destination
                </label>
                <input type="text" name="destination" value="{{ searchDestination }}" class="gv-search-input" placeholder="Ville ou aéroport">
            </div>
            <div class="gv-search-actions">
                <button type="submit" class="gv-search-btn">
                    <span class="material-symbols-outlined" style="font-size:1.1rem;">search</span>
                    Rechercher
                </button>
                <a href="{{ path('app_vols_index') }}" class="gv-search-reset">
                    <span class="material-symbols-outlined" style="font-size:1.2rem;">refresh</span>
                </a>
            </div>
        </div>
    </form>
</div>

<!-- ─── FLIGHTS LIST ─── -->
<section class="gv-vol-container">
    <div class="gv-section-header">
        <span class="gv-section-label">
            <span class="material-symbols-outlined">flight</span> Vols disponibles
        </span>
        <span class="gv-count-badge">
            <span class="material-symbols-outlined" style="font-size:1rem;">grid_view</span>
            {{ vols|length }} vol{{ vols|length > 1 ? 's' : '' }}
        </span>
    </div>

    <div class="gv-vol-grid">
        {% for vol in vols %}
            <div class="gv-vol-card gv-reveal">
                <div class="gv-vol-card-bg">
                    <img src="{{ cardImages[loop.index0 % 3] }}" alt="" loading="lazy">
                </div>
                <div class="gv-vol-card-overlay"></div>

                <div class="gv-vol-card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <div class="gv-vol-flight-id">{{ vol.flightId }}</div>
                            <div class="gv-vol-route">
                                {{ vol.departureAirport }}
                                <span class="gv-route-arrow"><span class="material-symbols-outlined">arrow_forward</span></span>
                                {{ vol.destination }}
                            </div>
                            <div class="gv-vol-airline">
                                <span class="material-symbols-outlined">flight</span>
                                {{ vol.airline }}
                            </div>
                        </div>
                        <span class="gv-vol-pill">{{ vol.classeChaise }}</span>
                    </div>

                    <div class="gv-vol-info-row">
                        <div class="gv-vol-info-box">
                            <div class="gv-vol-info-label">Départ</div>
                            <div class="gv-vol-info-value">{{ vol.departureTime ? vol.departureTime|date('H:i') : '-' }}</div>
                        </div>
                        <div class="gv-vol-info-box">
                            <div class="gv-vol-info-label">Arrivée</div>
                            <div class="gv-vol-info-value">{{ vol.arrivalTime ? vol.arrivalTime|date('H:i') : '-' }}</div>
                        </div>
                    </div>

                    <div class="gv-vol-divider"></div>

                    <div class="gv-vol-footer">
                        <div class="gv-vol-price-section">
                            <div>
                                <div class="gv-vol-seats-label">Places</div>
                                <div class="gv-vol-seats-value">{{ vol.availableSeats }}</div>
                            </div>
                            <div class="text-end">
                                <div class="gv-vol-seats-label">Prix</div>
                                <div class="gv-vol-price">{{ vol.prix }} DT</div>
                            </div>
                        </div>
                        <a href="{{ path('app_checkout_new', {flight: vol.flightId}) }}" onclick="openDetailModal(this.href); return false;" class="gv-vol-cta">
                            <span class="material-symbols-outlined" style="font-size:1.1rem;">shopping_bag</span>
                            Réserver ce vol
                        </a>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="gv-empty">
                <span class="material-symbols-outlined gv-empty-icon">cloud_off</span>
                <h4>Aucun vol trouvé</h4>
                <p>Aucun vol ne correspond à vos critères de recherche.</p>
            </div>
        {% endfor %}
    </div>
</section>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    var reveals = document.querySelectorAll('.gv-reveal');
    if (reveals.length) {
        var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
                if (entry.isIntersecting) {
                    entry.target.classList.add('is-visible');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });

        reveals.forEach(function(el, i) {
            el.style.transitionDelay = (i * 80) + 'ms';
            observer.observe(el);
        });
    }
});
</script>
{% endblock %}

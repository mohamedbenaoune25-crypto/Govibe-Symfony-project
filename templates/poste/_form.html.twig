{# templates/poste/_form.html.twig #}
{{ form_start(form, {'attr': {'id': 'publication-form', 'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
        
        <!-- FORMAT DE PUBLICATION -->
        <div class="mb-5">
            <label class="fw-bold mb-3 d-block text-uppercase letter-spacing-1" style="color: #2D3E50; font-size: 1.1rem;">Format de Publication</label>
            <div class="d-flex gap-3">
                <button type="button" id="btn-status-texte" class="btn btn-format active d-flex align-items-center gap-2 px-4 py-2 border rounded-3">
                    <i class="bi bi-chat-fill"></i> Statut Texte
                </button>
                <button type="button" id="btn-photo-video" class="btn btn-format d-flex align-items-center gap-2 px-4 py-2 border rounded-3">
                    <i class="bi bi-camera-reels-fill"></i> Photo / Vidéo
                </button>
            </div>
        </div>

        <!-- VOTRE MESSAGE -->
        <div class="mb-5">
            <label class="fw-bold mb-3 d-block text-uppercase letter-spacing-1" style="color: #2D3E50; font-size: 1.1rem;">Votre Message <span class="text-danger">*</span></label>
            <div class="textarea-container position-relative">
                {{ form_widget(form.contenu, {
                    'attr': {
                        'class': 'form-control border-secondary-subtle rounded-4 p-4 fs-5 validate-field',
                        'style': 'height: 200px; resize: none;',
                        'placeholder': 'Exprimez-vous...',
                        'maxlength': '600',
                        'data-required': 'true'
                    }
                }) }}
                <div class="char-counter text-muted position-absolute bottom-0 end-0 m-3 small" style="opacity: 0.6;">
                    <span id="char-count">0</span> / 500
                </div>
            </div>
            <div class="invalid-feedback-custom text-danger small mt-2 fw-bold" id="error-contenu" style="display: none;">
                Le message est obligatoire et ne doit pas dépasser 500 caractères.
            </div>
            {{ form_errors(form.contenu) }}
        </div>

        <!-- SÉLECTION MÉDIA (Conditional) -->
        <div id="media-section" class="mb-5" style="display: none;">
            <label class="fw-bold mb-3 d-block text-uppercase letter-spacing-1" style="color: #2D3E50; font-size: 1.1rem;">Sélection Média <span class="text-danger" id="media-star">*</span></label>
            <div class="d-flex gap-2">
                <div class="flex-grow-1 position-relative">
                    <input type="text" id="fake-file-input" class="form-control border-secondary-subtle rounded-3 bg-light opacity-75 validate-field" readonly placeholder="Aucun fichier sélectionné" data-required="false">
                    <div class="invalid-feedback-custom text-danger small mt-2 fw-bold" id="error-file" style="display: none;">
                        Veuillez sélectionner une image pour une publication média.
                    </div>
                </div>
                {{ form_widget(form.imageFile, {'attr': {'class': 'd-none', 'id': 'poste_imageFile'}}) }}
                <button type="button" onclick="document.getElementById('poste_imageFile').click()" class="btn btn-parcourir px-4 fw-bold text-white rounded-3 shadow-sm" style="background-color: #52BE80; min-width: 140px;">
                    Parcourir...
                </button>
            </div>
            
            <!-- Aperçu du média -->
            <div class="media-preview-area mt-4 border border-dashed rounded-4 p-4 text-center bg-light bg-opacity-10 position-relative" style="border-width: 2px !important; border-style: dashed !important; border-color: #D5DBDB !important;">
                <span class="text-muted opacity-50 small mb-3 d-block">Aperçu du média</span>
                <div id="preview-image-container" style="display: none;">
                    <img id="image-preview" src="" class="img-fluid rounded-3 shadow-sm mx-auto" style="max-height: 350px;">
                </div>
                <div id="no-preview" class="py-4">
                    <i class="bi bi-image text-muted opacity-25" style="font-size: 3rem;"></i>
                </div>
            </div>
        </div>

        <!-- LOCALISATION -->
        <div class="mb-5">
            <label class="fw-bold mb-3 d-block text-uppercase letter-spacing-1" style="color: #2D3E50; font-size: 1.1rem;">Localisation</label>
            <div class="input-group input-group-lg">
                <span class="input-group-text bg-white border-secondary-subtle rounded-start-4 px-4">
                    <i class="bi bi-geo-alt-fill text-success"></i>
                </span>
                {{ form_widget(form.localisation, {
                    'attr': {
                        'class': 'form-control border-secondary-subtle border-start-0 rounded-end-4 p-4',
                        'placeholder': 'Où êtes-vous ? (ex: Paris, France)'
                    }
                }) }}
            </div>
            {{ form_errors(form.localisation) }}
        </div>

        <!-- Hidden but necessary fields -->
        <div class="d-none">
            {{ form_widget(form.type, {'id': 'poste_type'}) }}
            {{ form_widget(form.forum) }}
            {{ form_rest(form) }}
        </div>

        <!-- Footer Actions -->
        <div class="mt-5 pt-4 border-top d-flex justify-content-end align-items-center gap-4">
            <button type="button" class="btn btn-link link-danger fw-bold text-decoration-none" data-bs-dismiss="modal">Annuler</button>
            <button type="submit" class="btn btn-publier px-5 py-3 fw-bold text-white rounded-4 shadow-sm" style="background-color: #52BE80; font-size: 1.1rem;">
                {{ poste.postId ? 'Modifier' : 'Publier maintenant' }}
            </button>
        </div>

{{ form_end(form) }}

<style>
    .btn-format {
        background-color: #ffffff;
        color: #717D7E;
        font-weight: 500;
        border-color: #EBEDEF !important;
        transition: 0.2s;
    }
    .btn-format.active {
        background-color: #E9F7EF !important;
        color: #1E8449 !important;
        border-color: #52BE80 !important;
        font-weight: 700;
        box-shadow: 0 4px 6px rgba(82, 190, 128, 0.1);
    }
    .btn-format:hover:not(.active) {
        background-color: #F4F6F7;
    }
    .letter-spacing-1 { letter-spacing: 0.5px; }
    .btn-publier:hover { background-color: #48C9B0 !important; cursor: pointer; }
    
    .is-invalid-custom {
        border-color: #E74C3C !important;
        box-shadow: 0 0 0 0.2rem rgba(231, 76, 60, 0.1) !important;
        background-color: rgba(231, 76, 60, 0.02) !important;
    }

    .ls-1 { letter-spacing: 1px; }
    .textarea-container textarea { padding-bottom: 40px !important; }
</style>

<script>
    window.initPosteForm = function() {
        const form = document.getElementById('publication-form');
        const btnText = document.getElementById('btn-status-texte');
        const btnPhoto = document.getElementById('btn-photo-video');
        const mediaSection = document.getElementById('media-section');
        const textarea = form.querySelector('textarea');
        const charCount = document.getElementById('char-count');
        const realInput = document.getElementById('poste_imageFile');
        const fakeInput = document.getElementById('fake-file-input');
        const typeInput = document.getElementById('poste_type');
        const imgPreview = document.getElementById('image-preview');
        const previewContainer = document.getElementById('preview-image-container');
        const noPreview = document.getElementById('no-preview');

        if (!btnText || !btnPhoto) return;

        const validate = () => {
            let isValid = true;
            
            // Validate Content
            if (textarea.value.trim() === '' || textarea.value.length > 500) {
                textarea.classList.add('is-invalid-custom');
                document.getElementById('error-contenu').style.display = 'block';
                isValid = false;
            } else {
                textarea.classList.remove('is-invalid-custom');
                document.getElementById('error-contenu').style.display = 'none';
            }

            // Validate Media if type is MEDIA
            if (typeInput.value === 'MEDIA') {
                {% if not poste.postId %} // Only mandatory for new posts, for edit we assume old one is kept
                if (!realInput.files || realInput.files.length === 0) {
                    fakeInput.classList.add('is-invalid-custom');
                    document.getElementById('error-file').style.display = 'block';
                    isValid = false;
                } else {
                    fakeInput.classList.remove('is-invalid-custom');
                    document.getElementById('error-file').style.display = 'none';
                }
                {% endif %}
            } else {
                fakeInput.classList.remove('is-invalid-custom');
                document.getElementById('error-file').style.display = 'none';
            }

            return isValid;
        };

        btnText.onclick = () => {
            btnText.classList.add('active');
            btnPhoto.classList.remove('active');
            mediaSection.style.display = 'none';
            typeInput.value = 'STATUS';
            fakeInput.setAttribute('data-required', 'false');
            validate();
        };

        btnPhoto.onclick = () => {
            btnPhoto.classList.add('active');
            btnText.classList.remove('active');
            mediaSection.style.display = 'block';
            typeInput.value = 'MEDIA';
            fakeInput.setAttribute('data-required', 'true');
            validate();
        };

        // Real-time char counter & validation
        textarea.oninput = () => {
            const len = textarea.value.length;
            charCount.textContent = len;
            if (len > 500) {
                charCount.classList.add('text-danger', 'fw-bold');
            } else {
                charCount.classList.remove('text-danger', 'fw-bold');
            }
            validate();
        };

        // Initial validation (to show red borders if empty)
        validate();

        form.onsubmit = (e) => {
            if (!validate()) {
                e.preventDefault();
                return false;
            }
        };

        // Initial state logic
        {% if poste.postId and (poste.type == 'MEDIA' or poste.url) %}
            btnPhoto.click();
        {% else %}
            btnText.style.display = 'block'; // Ensure trigger
        {% endif %}

        // Real File Upload Logic
        realInput.onchange = function() {
            if (this.files && this.files[0]) {
                const reader = new FileReader();
                fakeInput.value = this.files[0].name;
                
                reader.onload = function(e) {
                    imgPreview.src = e.target.result;
                    previewContainer.style.display = 'block';
                    noPreview.style.display = 'none';
                    validate();
                }
                reader.readAsDataURL(this.files[0]);
            }
        };

        {% if poste.url %}
            imgPreview.src = '{{ poste.url }}';
            previewContainer.style.display = 'block';
            noPreview.style.display = 'none';
        {% endif %}
    }

    if (typeof isAjax === 'undefined') {
        initPosteForm();
    }
</script>

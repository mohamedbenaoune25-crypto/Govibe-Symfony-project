{# templates/poste/_form.html.twig #}
{{ form_start(form, {'attr': {'id': 'publication-form', 'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
        
        <!-- FORMAT DE PUBLICATION -->
        <div class="mb-4">
            <label class="gv-form-label mb-3 d-block">Format de Publication</label>
            <div class="d-flex gap-3">
                <button type="button" id="btn-status-texte" class="btn btn-format active d-flex align-items-center gap-2 px-4 py-2">
                    <span class="material-symbols-outlined" style="font-size:1.1rem;">chat</span> Statut Texte
                </button>
                <button type="button" id="btn-photo-video" class="btn btn-format d-flex align-items-center gap-2 px-4 py-2">
                    <span class="material-symbols-outlined" style="font-size:1.1rem;">photo_camera</span> Photo / Vidéo
                </button>
            </div>
        </div>

        <!-- VOTRE MESSAGE -->
        <div class="mb-4">
            <label class="gv-form-label mb-2 d-block">Votre Message <span style="color:#ba1a1a;">*</span></label>
            <div class="textarea-container position-relative">
                {{ form_widget(form.contenu, {
                    'attr': {
                        'class': 'form-control gv-textarea validate-field',
                        'style': 'height: 180px; resize: none;',
                        'placeholder': 'Exprimez-vous...',
                        'maxlength': '600',
                        'data-required': 'true'
                    }
                }) }}
                <div class="char-counter position-absolute bottom-0 end-0 m-3">
                    <span id="char-count">0</span> / 500
                </div>
            </div>
            <div class="invalid-feedback-custom text-danger small mt-2 fw-bold" id="error-contenu" style="display: none;">
                Le message est obligatoire et ne doit pas dépasser 500 caractères.
            </div>
            {{ form_errors(form.contenu) }}
        </div>

        <!-- SÉLECTION MÉDIA (Conditional) -->
        <div id="media-section" class="mb-4" style="display: none;">
            <label class="gv-form-label mb-2 d-block">Sélection Média <span style="color:#ba1a1a;" id="media-star">*</span></label>
            <div class="d-flex gap-2">
                <div class="flex-grow-1 position-relative">
                    <input type="text" id="fake-file-input" class="form-control gv-input validate-field" readonly placeholder="Aucun fichier sélectionné" data-required="false">
                    <div class="invalid-feedback-custom text-danger small mt-2 fw-bold" id="error-file" style="display: none;">
                        Veuillez sélectionner une image pour une publication média.
                    </div>
                </div>
                {{ form_widget(form.imageFile, {'attr': {'class': 'd-none', 'id': 'poste_imageFile'}}) }}
                <button type="button" onclick="document.getElementById('poste_imageFile').click()" class="gv-btn-browse">
                    <span class="material-symbols-outlined" style="font-size:1rem;">upload_file</span> Parcourir
                </button>
            </div>
            
            <!-- Aperçu du média -->
            <div class="gv-media-preview mt-3">
                <span class="text-muted small mb-2 d-block" style="opacity:0.6;">Aperçu du média</span>
                <div id="preview-image-container" style="display: none;">
                    <img id="image-preview" src="" class="img-fluid rounded-3 shadow-sm mx-auto d-block" style="max-height: 300px;">
                </div>
                <div id="no-preview" class="py-4 text-center">
                    <span class="material-symbols-outlined" style="font-size:3rem; color:#cde1db; font-variation-settings: 'FILL' 1;">image</span>
                </div>
            </div>
        </div>

        <!-- LOCALISATION -->
        <div class="mb-4">
            <label class="gv-form-label mb-2 d-block">Localisation</label>
            <div class="gv-input-group">
                <span class="gv-input-icon">
                    <span class="material-symbols-outlined" style="font-size:1.1rem; color:#10B981;">location_on</span>
                </span>
                {{ form_widget(form.localisation, {
                    'attr': {
                        'class': 'form-control gv-input gv-input-with-icon',
                        'placeholder': 'Où êtes-vous ? (ex: Paris, France)'
                    }
                }) }}
            </div>
            {{ form_errors(form.localisation) }}
        </div>

        <!-- Hidden but necessary fields -->
        <div class="d-none">
            {{ form_widget(form.type, {'id': 'poste_type'}) }}
            {{ form_widget(form.forum) }}
            {{ form_rest(form) }}
        </div>

        <!-- Footer Actions -->
        <div class="mt-4 pt-4 d-flex justify-content-end align-items-center gap-3" style="border-top:1px solid rgba(0,52,45,0.06);">
            <button type="button" class="gv-btn-cancel-text" data-bs-dismiss="modal">Annuler</button>
            <button type="submit" class="gv-btn-publish">
                <span class="material-symbols-outlined" style="font-size:1.1rem;">send</span>
                {{ poste.postId ? 'Modifier' : 'Publier maintenant' }}
            </button>
        </div>

{{ form_end(form) }}

<style>
    .gv-form-label {
        font-weight: 700; color: #00342d; font-size: 0.85rem;
        text-transform: uppercase; letter-spacing: 0.06em;
    }
    .btn-format {
        background: #fff; color: #546067; font-weight: 600; font-size: 0.9rem;
        border: 1.5px solid rgba(0,52,45,0.08) !important; border-radius: 0.75rem !important;
        transition: all 0.25s; font-family: 'Manrope', sans-serif;
    }
    .btn-format.active {
        background: rgba(0,52,45,0.04) !important; color: #00342d !important;
        border-color: #10B981 !important; font-weight: 700;
        box-shadow: 0 4px 12px rgba(16,185,129,0.1);
    }
    .btn-format:hover:not(.active) { background: rgba(0,52,45,0.02); }

    .gv-textarea {
        border: 1.5px solid rgba(0,52,45,0.08) !important; border-radius: 1rem !important;
        padding: 1.25rem !important; padding-bottom: 2.5rem !important;
        font-family: 'Manrope', sans-serif !important; font-size: 1rem !important;
        font-weight: 500 !important; transition: all 0.25s !important; resize: none !important;
    }
    .gv-textarea:focus { border-color: #10B981 !important; box-shadow: 0 0 0 3px rgba(16,185,129,0.12) !important; }

    .char-counter { font-size: 0.75rem; color: #bfc9c4; font-weight: 600; }

    .gv-input {
        border: 1.5px solid rgba(0,52,45,0.08) !important; border-radius: 0.75rem !important;
        padding: 0.85rem 1rem !important; font-family: 'Manrope', sans-serif !important;
        font-weight: 500 !important; font-size: 0.95rem !important; transition: all 0.25s !important;
    }
    .gv-input:focus { border-color: #10B981 !important; box-shadow: 0 0 0 3px rgba(16,185,129,0.12) !important; }

    .gv-input-group { display: flex; align-items: center; position: relative; }
    .gv-input-icon { position: absolute; left: 1rem; z-index: 2; display: flex; align-items: center; }
    .gv-input-with-icon { padding-left: 2.75rem !important; }

    .gv-btn-browse {
        padding: 0.75rem 1.25rem; background: linear-gradient(135deg, #00342d, #046b5e);
        color: #fff; border: none; border-radius: 0.75rem; font-weight: 700; font-size: 0.85rem;
        cursor: pointer; transition: all 0.3s; display: flex; align-items: center; gap: 0.4rem;
        box-shadow: 0 4px 12px rgba(0,52,45,0.2); font-family: 'Manrope', sans-serif; white-space: nowrap;
    }
    .gv-btn-browse:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(0,52,45,0.3); }

    .gv-media-preview {
        border: 2px dashed rgba(0,52,45,0.08); border-radius: 1rem; padding: 1.25rem; text-align: center;
        background: rgba(0,52,45,0.01);
    }

    .gv-btn-cancel-text {
        background: none; border: none; color: #93000a; font-weight: 700; font-size: 0.9rem;
        cursor: pointer; padding: 0.5rem 1rem; transition: all 0.2s; font-family: 'Manrope', sans-serif;
    }
    .gv-btn-cancel-text:hover { background: rgba(186,26,26,0.06); border-radius: 0.5rem; }

    .gv-btn-publish {
        padding: 0.85rem 2rem; background: linear-gradient(135deg, #e9c176, #ca9028);
        color: #3d2a00; border: none; border-radius: 0.75rem; font-weight: 700; font-size: 1rem;
        cursor: pointer; transition: all 0.3s; box-shadow: 0 8px 20px -5px rgba(233,193,118,0.35);
        font-family: 'Manrope', sans-serif; display: inline-flex; align-items: center; gap: 0.5rem;
    }
    .gv-btn-publish:hover { transform: translateY(-2px); box-shadow: 0 12px 30px -5px rgba(233,193,118,0.5); }

    .is-invalid-custom {
        border-color: #ba1a1a !important;
        box-shadow: 0 0 0 2px rgba(186,26,26,0.1) !important;
    }
</style>

<script>
    window.initPosteForm = function() {
        const form = document.getElementById('publication-form');
        const btnText = document.getElementById('btn-status-texte');
        const btnPhoto = document.getElementById('btn-photo-video');
        const mediaSection = document.getElementById('media-section');
        const textarea = form.querySelector('textarea');
        const charCount = document.getElementById('char-count');
        const realInput = document.getElementById('poste_imageFile');
        const fakeInput = document.getElementById('fake-file-input');
        const typeInput = document.getElementById('poste_type');
        const imgPreview = document.getElementById('image-preview');
        const previewContainer = document.getElementById('preview-image-container');
        const noPreview = document.getElementById('no-preview');

        if (!btnText || !btnPhoto) return;

        const validate = () => {
            let isValid = true;
            
            if (textarea.value.trim() === '' || textarea.value.length > 500) {
                textarea.classList.add('is-invalid-custom');
                document.getElementById('error-contenu').style.display = 'block';
                isValid = false;
            } else {
                textarea.classList.remove('is-invalid-custom');
                document.getElementById('error-contenu').style.display = 'none';
            }

            if (typeInput.value === 'MEDIA') {
                {% if not poste.postId %}
                if (!realInput.files || realInput.files.length === 0) {
                    fakeInput.classList.add('is-invalid-custom');
                    document.getElementById('error-file').style.display = 'block';
                    isValid = false;
                } else {
                    fakeInput.classList.remove('is-invalid-custom');
                    document.getElementById('error-file').style.display = 'none';
                }
                {% endif %}
            } else {
                fakeInput.classList.remove('is-invalid-custom');
                document.getElementById('error-file').style.display = 'none';
            }

            return isValid;
        };

        btnText.onclick = () => {
            btnText.classList.add('active');
            btnPhoto.classList.remove('active');
            mediaSection.style.display = 'none';
            typeInput.value = 'STATUS';
            fakeInput.setAttribute('data-required', 'false');
            validate();
        };

        btnPhoto.onclick = () => {
            btnPhoto.classList.add('active');
            btnText.classList.remove('active');
            mediaSection.style.display = 'block';
            typeInput.value = 'MEDIA';
            fakeInput.setAttribute('data-required', 'true');
            validate();
        };

        textarea.oninput = () => {
            const len = textarea.value.length;
            charCount.textContent = len;
            if (len > 500) {
                charCount.classList.add('text-danger', 'fw-bold');
            } else {
                charCount.classList.remove('text-danger', 'fw-bold');
            }
            validate();
        };

        validate();

        form.onsubmit = (e) => {
            if (!validate()) { e.preventDefault(); return false; }
        };

        {% if poste.postId and (poste.type == 'MEDIA' or poste.url) %}
            btnPhoto.click();
        {% else %}
            btnText.style.display = 'block';
        {% endif %}

        realInput.onchange = function() {
            if (this.files && this.files[0]) {
                const reader = new FileReader();
                fakeInput.value = this.files[0].name;
                reader.onload = function(e) {
                    imgPreview.src = e.target.result;
                    previewContainer.style.display = 'block';
                    noPreview.style.display = 'none';
                    validate();
                }
                reader.readAsDataURL(this.files[0]);
            }
        };

        {% if poste.url %}
            imgPreview.src = '{{ poste.url }}';
            previewContainer.style.display = 'block';
            noPreview.style.display = 'none';
        {% endif %}
    }

    if (typeof isAjax === 'undefined') {
        initPosteForm();
    }
</script>

{# templates/poste/postitem.html.twig #}
<div class="card mb-5 border-0 shadow-sm rounded-4 overflow-hidden mx-auto post-item-card" style="max-width: 900px; background-color: rgba(255, 255, 255, 0.82); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);">
    <!-- Post Header -->
    <div class="card-header bg-transparent border-0 d-flex align-items-center justify-content-between p-4">
        <div class="d-flex align-items-center">
            <div class="avatar-circle rounded-circle d-flex align-items-center justify-content-center text-white fw-bold me-3" 
                 style="width: 60px; height: 60px; background-color: #52BE80; font-size: 1.3rem;">
                {{ (poste.user ? (poste.user.prenom|first ~ poste.user.nom|first)|upper : 'AD') }}
            </div>
            <div>
                <h5 class="mb-0 fw-bold text-dark" style="font-family: 'Outfit', sans-serif;">{{ poste.user ? poste.user.prenom ~ ' ' ~ poste.user.nom : 'Admin User' }}</h5>
                <div class="d-flex align-items-center gap-2 text-muted small mt-1">
                    <span style="color: #64748b;">{{ poste.user ? poste.user.email|split('@')|first : 'admin_govibe' }}</span>
                    <span class="opacity-50">&bull;</span>
                    <span style="color: #64748b;">{{ poste.dateCreation|date('d M Y, H:i') }}</span>
                    {% if poste.localisation %}
                        <span class="opacity-50">&bull;</span>
                        <span class="text-success small fw-bold d-flex align-items-center gap-1">
                            <i class="bi bi-geo-alt-fill"></i>{{ poste.localisation }}
                        </span>
                    {% endif %}
                </div>
            </div>
        </div>
        {% if is_granted('ROLE_ADMIN') or (app.user and app.user == poste.user) %}
            <div class="dropdown">
                <button class="btn btn-link link-secondary p-0 shadow-none" type="button" data-bs-toggle="dropdown">
                    <i class="bi bi-three-dots-vertical fs-5"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-4 p-2">
                    <li><button class="dropdown-item py-2 rounded-3" type="button" onclick="openPostModal('{{ path('app_poste_edit', {'postId': poste.postId}) }}')"><i class="bi bi-pencil me-2"></i> Modifier</button></li>
                    <li><hr class="dropdown-divider opacity-10"></li>
                    <li>
                        <form method="post" action="{{ path('app_poste_delete', {'postId': poste.postId}) }}" onsubmit="return confirm('Voulez-vous supprimer cette publication ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ poste.postId) }}">
                            <button class="dropdown-item text-danger py-2 rounded-3"><i class="bi bi-trash me-2"></i> Supprimer</button>
                        </form>
                    </li>
                </ul>
            </div>
        {% endif %}
    </div>

    <!-- Post Content -->
    <div class="card-body px-4 pt-1">
        <p class="post-text mb-2 px-1" id="post-text-{{ poste.postId }}" style="color: #1e293b; font-size: 1.15rem; line-height: 1.6;">
            {{ poste.contenu|nl2br }}
        </p>
        <button class="btn btn-link p-0 mb-3 small text-decoration-none translate-trigger" 
                onclick="translateText('post-text-{{ poste.postId }}', this)"
                data-original-label="<i class='bi bi-translate me-1'></i>Voir la traduction"
                style="font-size: 0.85rem; color: #6366f1; font-weight: 600;">
            <i class="bi bi-translate me-1"></i>Voir la traduction
        </button>

        {% if poste.url %}
            <div class="post-media-container text-center bg-light bg-opacity-50 rounded-4 overflow-hidden mb-4 mx-2 border">
                <img src="{{ poste.url }}" class="img-fluid" 
                     style="max-height: 500px; width: 100%; object-fit: cover; display: inline-block;"
                     onerror="this.src='/img/placeholder.jpg'; this.onerror=null;">
            </div>
        {% endif %}
    </div>

    <!-- Post Footer -->
    <div class="card-footer bg-transparent border-top p-4 d-flex align-items-center justify-content-between">
        <div class="d-flex gap-4">
            {% set isLikedPost = poste.postId in app.request.session.get('liked_posts', []) %}
            <form method="post" action="{{ path('app_poste_like', {'postId': poste.postId}) }}" class="d-inline">
                <button type="submit" class="btn btn-link text-decoration-none fw-bold p-0 d-flex align-items-center gap-2 group transition-all {{ isLikedPost ? 'text-danger' : 'link-dark' }}">
                    <div class="icon-sq {{ isLikedPost ? 'bg-danger bg-opacity-10 text-danger' : 'bg-success bg-opacity-10 text-success' }} rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                        <i class="bi {{ isLikedPost ? 'bi-heart-fill' : 'bi-heart' }} small"></i>
                    </div>
                    <span>{{ poste.likes|default(0) }} <span class="d-none d-sm-inline">Likes</span></span>
                </button>
            </form>
            <button class="btn btn-link link-dark text-decoration-none fw-bold p-0 d-flex align-items-center gap-2" onclick="toggleComments({{ poste.postId }})">
                <div class="icon-sq bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                    <i class="bi bi-chat-dots-fill small"></i>
                </div>
                <span>{{ poste.commentaires|length }} <span class="d-none d-sm-inline">Commentaires</span></span>
                <i class="bi bi-chevron-down small opacity-50 ms-1 transition-all" id="chevron-{{ poste.postId }}"></i>
            </button>
        </div>
    </div>

    <!-- Collapsible Comments Section -->
    <div class="comments-section bg-light bg-opacity-25 border-top" id="comments-{{ poste.postId }}" style="display: none;">
        <div class="p-4">
            <h6 class="fw-bold mb-4 px-1 text-secondary small text-uppercase ls-1">Fil de discussion</h6>
            
            <div class="comments-list">
                {% for comment in poste.commentaires|filter(c => c.parentId == 0) %}
                    <!-- Parent Comment -->
                    <div class="comment-wrapper mb-4">
                        <div class="comment d-flex gap-3 animate-fade-in">
                            <div class="avatar-sm rounded-circle d-flex align-items-center justify-content-center text-white fw-bold shadow-sm" 
                                 style="width: 40px; height: 40px; background-color: #64748b; font-size: 0.85rem; flex-shrink: 0;">
                                {{ (comment.user ? (comment.user.prenom|first ~ comment.user.nom|first)|upper : 'U') }}
                            </div>
                            <div class="comment-bubble bg-white rounded-4 p-3 shadow-sm flex-grow-1 position-relative border border-light">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <span class="fw-bold small text-dark">{{ comment.user ? comment.user.prenom ~ ' ' ~ comment.user.nom : 'Utilisateur' }}</span>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="text-muted" style="font-size: 0.7rem;">{{ comment.dateCreation|date('d M, H:i') }}</span>
                                        
                                        {% if is_granted('ROLE_ADMIN') or (app.user and app.user == comment.user) %}
                                            <div class="dropdown">
                                                <button class="btn btn-sm btn-link text-muted p-0 opacity-50" type="button" data-bs-toggle="dropdown">
                                                    <i class="bi bi-three-dots"></i>
                                                </button>
                                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3 p-1">
                                                    <li><button class="dropdown-item py-1 px-3 small rounded-2" onclick="showEditComment({{ comment.commentaireId }})"><i class="bi bi-pencil me-2"></i>Modifier</button></li>
                                                    <li>
                                                        <form method="post" action="{{ path('app_commentaire_delete', {'commentaireId': comment.commentaireId}) }}" onsubmit="return confirm('Supprimer ce commentaire ?');">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_comment' ~ comment.commentaireId) }}">
                                                            <button class="dropdown-item py-1 px-3 small text-danger rounded-2"><i class="bi bi-trash me-2"></i>Supprimer</button>
                                                        </form>
                                                    </li>
                                                </ul>
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                                <p class="mb-0 small text-secondary" style="line-height: 1.5; font-size: 0.9rem;" id="comment-text-{{ comment.commentaireId }}">{{ comment.contenu }}</p>
                                

                                
                                <button class="btn btn-link p-0 mb-1 small text-decoration-none translate-trigger" 
                                        onclick="translateText('comment-text-{{ comment.commentaireId }}', this)"
                                        style="font-size: 0.75rem; color: #6366f1; font-weight: 600;">
                                    Voir la traduction
                                </button>
                                
                                <!-- Inline Edit Form -->
                                <form id="edit-form-{{ comment.commentaireId }}" style="display: none;" method="post" action="{{ path('app_commentaire_edit', {'commentaireId': comment.commentaireId}) }}" class="mt-2">
                                    <input type="hidden" name="_token" value="{{ csrf_token('edit_comment' ~ comment.commentaireId) }}">
                                    <textarea name="contenu" class="form-control form-control-sm rounded-3 mb-2" rows="2">{{ comment.contenu }}</textarea>
                                    <div class="d-flex gap-2">
                                        <button type="submit" class="btn btn-sm btn-success px-3 rounded-pill fw-bold">Sauvegarder</button>
                                        <button type="button" class="btn btn-sm btn-light px-3 rounded-pill" onclick="hideEditComment({{ comment.commentaireId }})">Annuler</button>
                                    </div>
                                </form>

                                <!-- Comment Actions -->
                                <div class="d-flex align-items-center gap-3 mt-3">
                                    {% set isLikedComment = comment.commentaireId in app.request.session.get('liked_comments', []) %}
                                    <form method="post" action="{{ path('app_commentaire_like', {'commentaireId': comment.commentaireId}) }}" class="d-inline">
                                        <button class="btn btn-link p-0 small text-decoration-none hover-mint d-flex align-items-center gap-1 {{ isLikedComment ? 'text-success fw-bold' : 'text-muted' }}">
                                            <i class="bi {{ isLikedComment ? 'bi-hand-thumbs-up-fill' : 'bi-hand-thumbs-up' }}"></i><span>{{ comment.likes }}</span>
                                        </button>
                                    </form>
                                    <button type="button" onclick="toggleReplyForm({{ comment.commentaireId }})" class="btn btn-link p-0 text-secondary fw-bold small text-decoration-none hover-mint" style="font-size: 0.75rem;">
                                        Répondre
                                    </button>
                                    
                                    {% set replies = poste.commentaires|filter(r => r.parentId == comment.commentaireId) %}
                                    {% if replies|length > 0 %}
                                        <button type="button" onclick="toggleReplies({{ comment.commentaireId }})" class="btn btn-link p-0 text-primary fw-bold small text-decoration-none hover-mint d-flex align-items-center gap-1" style="font-size: 0.75rem;">
                                            <span id="replies-count-text-{{ comment.commentaireId }}">Voir les {{ replies|length }} réponses</span>
                                            <i class="bi bi-chevron-down small" id="replies-chevron-{{ comment.commentaireId }}"></i>
                                        </button>
                                    {% endif %}
                                </div>
                            </div>
                        </div>

                        <!-- Replies Container -->
                        {% if replies|length > 0 or is_granted('ROLE_USER') %}
                            <div class="replies-container ms-5 mt-3 border-start ps-4" id="replies-container-{{ comment.commentaireId }}" style="{% if replies|length > 0 %}display: none;{% endif %}">
                                {% for reply in replies %}
                                    <div class="reply mb-3 d-flex gap-2 animate-fade-in">
                                        <div class="avatar-xs rounded-circle d-flex align-items-center justify-content-center text-white fw-bold shadow-sm" 
                                             style="width: 32px; height: 32px; background-color: #94a3b8; font-size: 0.7rem; flex-shrink: 0;">
                                            {{ (reply.user ? (reply.user.prenom|first ~ reply.user.nom|first)|upper : 'U') }}
                                        </div>
                                        <div class="comment-bubble bg-white rounded-4 p-2 px-3 border border-light flex-grow-1 position-relative shadow-sm">
                                            <div class="d-flex justify-content-between align-items-center mb-1">
                                                <span class="fw-bold" style="font-size: 0.8rem;">{{ reply.user ? reply.user.prenom ~ ' ' ~ reply.user.nom : 'Utilisateur' }}</span>
                                                {% if is_granted('ROLE_ADMIN') or (app.user and app.user == reply.user) %}
                                                    <div class="dropdown">
                                                        <button class="btn btn-sm btn-link text-muted p-0 opacity-50" type="button" data-bs-toggle="dropdown">
                                                            <i class="bi bi-three-dots" style="font-size: 0.7rem;"></i>
                                                        </button>
                                                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3 p-1">
                                                            <li><button class="dropdown-item py-1 px-3 x-small rounded-2" onclick="showEditComment({{ reply.commentaireId }})"><i class="bi bi-pencil me-1"></i>Modifier</button></li>
                                                            <li>
                                                                <form method="post" action="{{ path('app_commentaire_delete', {'commentaireId': reply.commentaireId}) }}" onsubmit="return confirm('Supprimer ?');">
                                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_comment' ~ reply.commentaireId) }}">
                                                                    <button class="dropdown-item py-1 px-3 x-small text-danger rounded-2"><i class="bi bi-trash me-1"></i>Supprimer</button>
                                                                </form>
                                                            </li>
                                                        </ul>
                                                    </div>
                                                {% endif %}
                                            </div>
                                            <p class="mb-0 small text-secondary" id="comment-text-{{ reply.commentaireId }}">{{ reply.contenu }}</p>
                                            

                                            
                                            <button class="btn btn-link p-0 small text-decoration-none translate-trigger" 
                                                    onclick="translateText('comment-text-{{ reply.commentaireId }}', this)"
                                                    style="font-size: 0.7rem; color: #6366f1; font-weight: 600;">
                                                Voir la traduction
                                            </button>
                                            
                                            <!-- Inline Edit Form (Reply) -->
                                            <form id="edit-form-{{ reply.commentaireId }}" style="display: none;" method="post" action="{{ path('app_commentaire_edit', {'commentaireId': reply.commentaireId}) }}" class="mt-2">
                                                <input type="hidden" name="_token" value="{{ csrf_token('edit_comment' ~ reply.commentaireId) }}">
                                                <textarea name="contenu" class="form-control form-control-sm rounded-3 mb-2" rows="1" style="font-size: 0.8rem;">{{ reply.contenu }}</textarea>
                                                <div class="d-flex gap-2">
                                                    <button type="submit" class="btn btn-sm btn-success px-2 py-0 rounded-pill fw-bold small" style="font-size: 0.7rem;">OK</button>
                                                    <button type="button" class="btn btn-sm btn-light px-2 py-0 rounded-pill small" style="font-size: 0.7rem;" onclick="hideEditComment({{ reply.commentaireId }})">Annuler</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                {% endfor %}

                                <!-- Inline Reply Form -->
                                {% if is_granted('ROLE_USER') %}
                                    <div id="reply-form-{{ comment.commentaireId }}" class="mt-3" style="display: none;">
                                        <form method="post" action="{{ path('app_commentaire_reply', {'postId': poste.postId, 'parentId': comment.commentaireId}) }}" class="d-flex gap-2 align-items-center w-100" novalidate>
                                            <input type="hidden" name="_token" value="{{ csrf_token('add_comment') }}">
                                            <div class="position-relative flex-grow-1">
                                                <input id="reply-input-{{ comment.commentaireId }}" type="text" name="contenu" class="form-control form-control-sm border-0 rounded-pill px-3 bg-white shadow-sm w-100" style="font-size: 0.85rem; padding-right: 40px;" placeholder="Votre réponse...">
                                                
                                                <div class="position-absolute top-50 end-0 translate-middle-y me-1 d-flex align-items-center">
                                                    <div class="dropdown">
                                                        <button class="btn btn-link p-0 text-decoration-none shadow-none" type="button" data-bs-toggle="dropdown" title="Suggérer avec l'IA">
                                                            <i class="bi bi-stars hover-mint transition-all" style="color: #6366f1; font-size: 1rem;"></i>
                                                        </button>
                                                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3 p-1">
                                                            <li><button type="button" class="dropdown-item py-1 rounded-2 small" style="font-size: 0.8rem;" onclick="suggestAi('{{ path('app_gemini_suggest') }}', 'comment-text-{{ comment.commentaireId }}', this, 'reply', 'reply-input-{{ comment.commentaireId }}')"><i class="bi bi-google text-primary me-2"></i>Gemini</button></li>
                                                            <li><button type="button" class="dropdown-item py-1 rounded-2 small" style="font-size: 0.8rem;" onclick="suggestAi('{{ path('app_groq_suggest') }}', 'comment-text-{{ comment.commentaireId }}', this, 'reply', 'reply-input-{{ comment.commentaireId }}')"><i class="bi bi-lightning-fill text-warning me-2"></i>Groq</button></li>
                                                        </ul>
                                                    </div>
                                                </div>
                                            </div>
                                            <button type="submit" class="btn btn-sm btn-success rounded-pill px-3 fw-bold flex-shrink-0" style="background-color: #52BE80; font-size: 0.8rem;">Répondre</button>
                                        </form>
                                    </div>
                                {% endif %}
                            </div>
                        {% endif %}
                    </div>
                {% else %}
                    <p class="text-center text-muted small py-3">Aucun commentaire pour le moment.</p>
                {% endfor %}
            </div>

            <!-- Add Comment Input (Top Level) -->
            {% if is_granted('ROLE_USER') %}
                <form method="post" action="{{ path('app_commentaire_new', {'postId': poste.postId}) }}" class="mt-4 pt-4 border-top d-flex gap-3 align-items-center" novalidate>
                    <input type="hidden" name="_token" value="{{ csrf_token('add_comment') }}">
                    <div class="avatar-sm rounded-circle d-flex align-items-center justify-content-center text-white fw-bold shadow-sm" 
                         style="width: 44px; height: 44px; background-color: #52BE80; font-size: 0.9rem; flex-shrink: 0;">
                        {{ (app.user.prenom|first ~ app.user.nom|first)|upper }}
                    </div>
                    <div class="flex-grow-1 position-relative">
                        <textarea id="comment-input-{{ poste.postId }}" name="contenu" class="form-control border-0 rounded-4 px-4 py-3 bg-white shadow-sm" style="resize: none; font-size: 0.95rem; padding-right: 80px;" placeholder="Écrire un commentaire..." rows="1"></textarea>
                        
                        <div class="position-absolute top-50 end-0 translate-middle-y me-2 d-flex align-items-center gap-1">
                            
                            <div class="dropdown">
                                <button class="btn btn-link p-2 text-decoration-none shadow-none hover-mint transition-all" type="button" data-bs-toggle="dropdown" title="Suggérer avec l'IA">
                                    <i class="bi bi-stars" style="color: #6366f1; font-size: 1.2rem;"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-4 p-2">
                                    <li><button type="button" class="dropdown-item py-2 rounded-3 small fw-semibold" onclick="suggestAi('{{ path('app_gemini_suggest') }}', 'post-text-{{ poste.postId }}', this, 'comment', 'comment-input-{{ poste.postId }}')"><i class="bi bi-google text-primary me-2"></i> Gemini</button></li>
                                    <li><button type="button" class="dropdown-item py-2 rounded-3 small fw-semibold" onclick="suggestAi('{{ path('app_groq_suggest') }}', 'post-text-{{ poste.postId }}', this, 'comment', 'comment-input-{{ poste.postId }}')"><i class="bi bi-lightning-fill text-warning me-2"></i> Groq LLaMA</button></li>
                                </ul>
                            </div>
                            <button type="submit" class="btn p-2 hover-mint transition-all" style="color: #52BE80; border: 0; background: none;">
                                <i class="bi bi-send-fill" style="font-size: 1.3rem;"></i>
                            </button>
                        </div>
                    </div>
                </form>
            {% endif %}
        </div>
    </div>
</div>

<script>
    function toggleComments(id) {
        const el = document.getElementById('comments-' + id);
        const chev = document.getElementById('chevron-' + id);
        if (el) {
            const isHidden = el.style.display === 'none';
            el.style.display = isHidden ? 'block' : 'none';
            chev.style.transform = isHidden ? 'rotate(180deg)' : 'rotate(0deg)';
        }
    }

    function toggleReplies(id) {
        const el = document.getElementById('replies-container-' + id);
        const chev = document.getElementById('replies-chevron-' + id);
        const textSpan = document.getElementById('replies-count-text-' + id);
        
        if (el) {
            const isHidden = el.style.display === 'none';
            el.style.display = isHidden ? 'block' : 'none';
            chev.style.transform = isHidden ? 'rotate(180deg)' : 'rotate(0deg)';
            
            if (isHidden) {
                textSpan.dataset.originalText = textSpan.innerText;
                textSpan.innerText = 'Masquer les réponses';
            } else {
                textSpan.innerText = textSpan.dataset.originalText || 'Voir les réponses';
            }
        }
    }

    function toggleReplyForm(id) {
        const el = document.getElementById('reply-form-' + id);
        if (el) {
            el.style.display = el.style.display === 'none' ? 'block' : 'none';
            if (el.style.display === 'block') {
                el.querySelector('input').focus();
            }
        }
    }

    function showEditComment(id) {
        document.getElementById('comment-text-' + id).style.display = 'none';
        document.getElementById('edit-form-' + id).style.display = 'block';
        document.getElementById('edit-form-' + id).querySelector('textarea').focus();
    }

    function hideEditComment(id) {
        document.getElementById('comment-text-' + id).style.display = 'block';
        document.getElementById('edit-form-' + id).style.display = 'none';
    }

    // Global Validation for Comments/Replies
    document.addEventListener('submit', function(e) {
        const form = e.target;
        if (form.matches('form[action*="/commentaire/new/"], form[action*="/commentaire/reply/"], form[action*="/commentaire/edit/"]')) {
            const input = form.querySelector('textarea[name="contenu"], input[name="contenu"]');
            if (input && input.value.trim() === '') {
                e.preventDefault();
                input.classList.add('is-invalid-custom');
                input.focus();
                return false;
            }
        }
    });

    document.addEventListener('input', function(e) {
        if (e.target.matches('textarea[name="contenu"], input[name="contenu"]')) {
            if (e.target.value.trim() !== '') {
                e.target.classList.remove('is-invalid-custom');
            }
        }
    });
    async function translateText(targetId, btn) {
        const textEl = document.getElementById(targetId);
        if (!textEl) return;
        
        const currentText = textEl.innerText.trim();
        const originalText = textEl.dataset.originalText;
        
        // Toggle back to original if already translated
        if (originalText && currentText !== originalText && btn.innerText.includes("original")) {
            textEl.innerText = originalText;
            btn.innerHTML = btn.dataset.originalLabel || '<i class="bi bi-translate me-1"></i>Voir la traduction';
            return;
        }

        // Save original text if not already saved
        if (!textEl.dataset.originalText) {
            textEl.dataset.originalText = textEl.innerText;
        }

        const textToTranslate = textEl.dataset.originalText;
        const originalBtnContent = btn.innerHTML;
        if (!btn.dataset.originalLabel) btn.dataset.originalLabel = originalBtnContent;

        // Show loading state
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Traduction...';

        try {
            console.log("Translating:", textToTranslate);
            const response = await fetch('{{ path("app_translate") }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                body: JSON.stringify({ 
                    text: textToTranslate, 
                    target: 'fr' 
                })
            });
            
            if (!response.ok) throw new Error('Network response was not ok');
            
            const data = await response.json();
            console.log("Translation response:", data);

            if (data.translated) {
                textEl.innerText = data.translated;
                btn.innerText = "Voir l'original";
            } else {
                throw new Error(data.error || 'Erreur inconnue');
            }
        } catch (e) {
            console.error("Translation Error:", e);
            alert("Désolé, la traduction n'est pas disponible pour le moment.");
            btn.innerHTML = btn.dataset.originalLabel;
        } finally {
            btn.disabled = false;
        }
    }

    async function suggestAi(url, contextElementId, btnEl, type, targetInputId) {
        const contextEl = document.getElementById(contextElementId);
        if (!contextEl) return;
        
        const contextText = contextEl.dataset.originalText || contextEl.innerText;
        const targetInput = document.getElementById(targetInputId);
        
        const originalParentHTML = btnEl.innerHTML;
        btnEl.innerHTML = '<span class="spinner-border spinner-border-sm text-primary" role="status" aria-hidden="true"></span>';
        btnEl.disabled = true;

        try {
            const response = await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                body: JSON.stringify({ context: contextText, type: type })
            });
            const data = await response.json();
            
            if (data.suggestions && data.suggestions.length > 0) {
                showSuggestionsDropdown(targetInput, data.suggestions);
            } else {
                alert(data.error || "Aucune suggestion générée.");
            }
        } catch (e) {
            console.error("AI Error:", e);
            alert("Erreur de connexion avec l'IA.");
        } finally {
            btnEl.innerHTML = originalParentHTML;
            btnEl.disabled = false;
        }
    }

    function showSuggestionsDropdown(inputEl, suggestions) {
        // Remove existing
        const existing = inputEl.parentNode.querySelector('.ai-suggestions-box');
        if (existing) existing.remove();
        
        const box = document.createElement('div');
        box.className = 'ai-suggestions-box position-absolute bg-white shadow-sm rounded-4 border p-2 z-3 animate-fade-in';
        box.style.bottom = '110%'; // Float above the input
        box.style.left = '0';
        box.style.width = '100%';
        box.style.backdropFilter = 'blur(12px)';
        box.style.backgroundColor = 'rgba(255, 255, 255, 0.95)';
        box.style.borderColor = 'rgba(99, 102, 241, 0.2) !important';
        
        const header = document.createElement('div');
        header.className = 'd-flex justify-content-between align-items-center mb-2 px-2';
        header.innerHTML = '<span class="small fw-bold" style="color: #6366f1;"><i class="bi bi-stars me-1"></i> Suggestions IA</span>' +
                           '<button type="button" class="btn-close shadow-none" style="font-size: 0.6rem;"></button>';
        
        header.querySelector('.btn-close').onclick = () => box.remove();
        box.appendChild(header);

        suggestions.forEach(text => {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'btn text-start w-100 mb-1 rounded-3 small text-wrap border-0 hover-bg-light transition-all';
            btn.style.fontSize = '0.85rem';
            btn.style.color = '#1e293b';
            btn.style.backgroundColor = 'rgba(99, 102, 241, 0.04)';
            btn.innerText = text;
            btn.onclick = () => {
                inputEl.value = text;
                inputEl.focus();
                inputEl.dispatchEvent(new Event('input'));
                box.remove();
            };
            box.appendChild(btn);
        });

        // Ensure parent has position relative
        if (window.getComputedStyle(inputEl.parentNode).position === 'static') {
            inputEl.parentNode.style.position = 'relative';
        }
        inputEl.parentNode.appendChild(box);
    }


</script>


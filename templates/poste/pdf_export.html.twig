<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Rapport des Publications - GoVibe</title>
    <style>
        body { font-family: 'Arial', sans-serif; color: #333; }
        .header { text-align: center; margin-bottom: 50px; border-bottom: 2px solid #22c55e; padding-bottom: 20px; }
        .logo { color: #22c55e; font-size: 32px; font-weight: bold; margin-bottom: 5px; }
        .title { font-size: 18px; color: #666; text-transform: uppercase; letter-spacing: 2px; }
        .post { margin-bottom: 30px; border-bottom: 1px solid #eee; padding-bottom: 20px; }
        .post-header { margin-bottom: 10px; }
        .author { font-weight: bold; color: #013220; }
        .date { font-size: 12px; color: #999; }
        .content { font-size: 14px; line-height: 1.6; color: #444; }
        .stats { margin-top: 10px; font-size: 11px; color: #22c55e; font-weight: bold; }
        .footer { position: fixed; bottom: 0; width: 100%; text-align: center; font-size: 10px; color: #999; border-top: 1px solid #eee; padding-top: 10px; }
    </style>
</head>
<body>
    <div class="header">
        <div class="logo">GoVibe</div>
        <div class="title">Rapport des Publications Communautaires</div>
        <div style="font-size: 10px; margin-top: 10px;">Généré le {{ "now"|date("d/m/Y H:i") }}</div>
    </div>

    {% for p in postes %}
    <div class="post">
        <div class="post-header">
            <span class="author">{{ p.user.prenom }} {{ p.user.nom }}</span>
            <span class="date"> - {{ p.dateCreation|date('d/m/Y H:i') }}</span>
        </div>
        <div class="content">
            {{ p.contenu|nl2br }}
        </div>
        <div class="stats">
            {{ p.likes }} J'aime • {{ p.commentaires|length }} Commentaires
            {% if p.type == 'MEDIA' %} • [Contient un média] {% endif %}
        </div>
    </div>
    {% endfor %}

    <div class="footer">
        © 2026 GoVibe - Plateforme de Voyage et Communauté. Document Confidentiel.
    </div>
</body>
</html>

{# Rendered directly into the Bootstrap modal body via AJAX #}
<div class="px-2">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h4 class="fw-bold mb-1 text-dark">
                {% if poste.postId %}
                    <i class="bi bi-pencil-square me-2 text-success"></i>Modifier la Publication
                {% else %}
                    <i class="bi bi-plus-circle-fill me-2 text-success"></i>Nouvelle Publication
                {% endif %}
            </h4>
            <p class="text-muted small mb-0">
                {% if poste.postId %}
                    Publication #{{ poste.postId }} &bull; créée le {{ poste.dateCreation|date('d M Y') }}
                {% else %}
                    Partagez quelque chose avec la communauté GoVibe
                {% endif %}
            </p>
        </div>
        <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
    </div>

    {{ include('poste/_form.html.twig') }}
</div>

<script>
    if (typeof initPosteForm === 'function') {
        initPosteForm();
    }
</script>

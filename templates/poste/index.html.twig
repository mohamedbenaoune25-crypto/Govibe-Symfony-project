{% extends is_granted('ROLE_ADMIN') ? 'admin/base_admin.html.twig' : 'base.html.twig' %}

{% block page_title %}Gestion des Publications{% endblock %}

{% block body %}
    <!-- Professional Header Section -->
    <div class="{% if is_granted('ROLE_ADMIN') %}mb-4{% else %}pt-5 pb-4 px-4{% endif %} animate-fade-in">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 p-4 {% if not is_granted('ROLE_ADMIN') %}publications-header-card{% endif %}">
            <div class="d-flex align-items-center gap-3">
                <div class="d-none d-sm-flex align-items-center justify-content-center bg-success bg-opacity-10 rounded-3 text-success p-3" style="width: 56px; height: 56px;">
                    <i class="bi bi-chat-square-text-fill fs-3"></i>
                </div>
                <div>
                    <h1 class="h2 fw-bold text-dark mb-1" style="font-family: 'Outfit', sans-serif; letter-spacing: -0.5px;">Publications</h1>
                    <div class="d-flex align-items-center gap-2 text-secondary opacity-75">
                        <i class="bi bi-people-fill small"></i>
                        <span class="small fw-medium">Communauté GoVibe</span>
                        <span class="mx-1">•</span>
                        <span class="small">{{ postes|length }} Publication(s)</span>
                    </div>
                </div>
            </div>
            
            <div class="d-flex align-items-center gap-2">
                <button type="button" class="btn btn-new-post px-4 py-2 fw-bold shadow-sm d-flex align-items-center gap-2 transition-all hover-lift" onclick="openPostModal('{{ path('app_poste_new') }}')">
                    <i class="bi bi-plus-circle-fill"></i>
                    <span>Nouvelle Publication</span>
                </button>
            </div>
        </div>
    </div>

    <style>
        .publications-header-card {
            background-color: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border-radius: 1rem;
            border: 1px solid rgba(0, 0, 0, 0.05);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
        }
        
        .animate-fade-in { animation: fadeIn 0.5s ease-out both; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        
        .btn-new-post {
            background: linear-gradient(135deg, #16a34a, #22c55e);
            color: white;
            border: none;
            border-radius: 12px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .btn-new-post:hover {
            background: linear-gradient(135deg, #15803d, #16a34a);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(34, 197, 94, 0.3) !important;
        }
        .btn-new-post:active { transform: translateY(0); }
        
        .hover-lift { transition: transform 0.2s ease; }
        .hover-lift:hover { transform: translateY(-2px); }
        .backdrop-blur { backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); }
    </style>

    <!-- Main Layout: Sidebar + Content -->
    <div class="px-4">
        <div class="row g-4">
            <!-- Left Sidebar: Forums List -->
            <div class="col-lg-3 d-none d-lg-block">
                <div class="sticky-top" style="top: 2rem; z-index: 10;">
                    <div class="rounded-4 border p-4 shadow-sm backdrop-blur" style="background-color: rgba(255, 255, 255, 0.82); border: 1px solid rgba(0,0,0,0.05) !important;">
                        <div class="d-flex align-items-center justify-content-between mb-4">
                            <h5 class="fw-bold text-dark mb-0" style="font-family: 'Outfit', sans-serif;">Communautés</h5>
                            <a href="{{ path('app_forum_index') }}" class="text-success small text-decoration-none fw-bold">Tout voir</a>
                        </div>
                        
                        <div class="d-flex flex-column gap-3">
                            {% for forum in forums|slice(0, 5) %}
                            <a href="{{ path('app_forum_show', {'forumId': forum.forumId}) }}" class="text-decoration-none group">
                                <div class="d-flex align-items-center gap-3 p-2 rounded-3 transition-all hover-bg-light">
                                    <div class="flex-shrink-0">
                                        {% if forum.image %}
                                            <img src="{{ forum.image }}" alt="{{ forum.name }}" class="rounded-circle" style="width: 40px; height: 40px; object-fit: cover; border: 1px solid rgba(0,0,0,0.05);">
                                        {% else %}
                                            <div class="rounded-circle bg-success bg-opacity-10 text-success d-flex align-items-center justify-content-center fw-bold" style="width: 40px; height: 40px; font-size: 14px;">
                                                {{ forum.name|first|upper }}
                                            </div>
                                        {% endif %}
                                    </div>
                                    <div class="overflow-hidden">
                                        <div class="text-dark fw-bold text-truncate small">{{ forum.name }}</div>
                                        <div class="text-muted x-small text-truncate">{{ forum.nbrMembers }} membres</div>
                                    </div>
                                </div>
                            </a>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Main Feed Area -->
            <div class="col-lg-9">
                <!-- Filters and Actions Bar -->
                <div class="rounded-4 border p-3 shadow-sm mb-4 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 backdrop-blur position-relative" style="z-index: 20; background-color: rgba(255, 255, 255, 0.82); border: 1px solid rgba(0,0,0,0.05) !important;">
                    <!-- Search -->
                    <form action="{{ path('app_poste_index') }}" method="GET" class="flex-grow-1" style="max-width: 500px;">
                        <input type="hidden" name="sort" value="{{ current_sort }}">
                        <div class="input-group">
                            <span class="input-group-text bg-transparent border-0 pe-0 text-muted">
                                <i class="bi bi-search"></i>
                            </span>
                            <input type="text" name="q" value="{{ current_query }}" placeholder="Rechercher une publication..." 
                                   class="form-control border-0 bg-transparent shadow-none" style="font-size: 14px;">
                            {% if current_query %}
                                <a href="{{ path('app_poste_index', {'sort': current_sort}) }}" class="btn border-0 text-muted">
                                    <i class="bi bi-x-lg"></i>
                                </a>
                            {% endif %}
                        </div>
                    </form>

                    <div class="d-flex align-items-center gap-2">
                        <!-- Sort Dropdown -->
                        <div class="dropdown">
                            <button class="btn btn-pro d-flex align-items-center gap-2 px-3 shadow-none overflow-visible" type="button" data-bs-toggle="dropdown">
                                <i class="bi bi-filter-right fs-5"></i>
                                <span class="small fw-bold">Trier par : 
                                    {% if current_sort == 'popular' %}Plus populaires
                                    {% elseif current_sort == 'mine' %}Mes Publications
                                    {% else %}Nouveautés{% endif %}
                                </span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-4 p-2 mt-2" style="z-index: 1060;">
                                {% if app.user %}
                                    <li>
                                        <a class="dropdown-item rounded-3 mb-1 {{ current_sort == 'mine' ? 'bg-success bg-opacity-10 text-success fw-bold' : '' }}" 
                                           href="{{ path('app_poste_index', {'q': current_query, 'sort': 'mine'}) }}">
                                            <i class="bi bi-person-fill me-2"></i>Mes Publications
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider opacity-10"></li>
                                {% endif %}
                                <li>
                                    <a class="dropdown-item rounded-3 mb-1 {{ current_sort == 'newest' ? 'bg-success bg-opacity-10 text-success fw-bold' : '' }}" 
                                       href="{{ path('app_poste_index', {'q': current_query, 'sort': 'newest'}) }}">
                                        <i class="bi bi-clock me-2"></i>Nouveautés
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item rounded-3 {{ current_sort == 'popular' ? 'bg-success bg-opacity-10 text-success fw-bold' : '' }}" 
                                       href="{{ path('app_poste_index', {'q': current_query, 'sort': 'popular'}) }}">
                                        <i class="bi bi-fire me-2"></i>Plus populaires
                                    </a>
                                </li>
                            </ul>
                        </div>

                        <!-- Sep -->
                        <div class="vr mx-2 d-none d-md-block opacity-10"></div>

                        <!-- Export PDF -->
                        <a href="{{ path('app_poste_export_pdf') }}" class="btn btn-pro text-danger d-flex align-items-center gap-2 px-3 transition-all hover-lift" title="Exporter en PDF">
                            <i class="bi bi-file-earmark-pdf-fill"></i>
                            <span class="d-none d-md-inline small fw-bold">PDF</span>
                        </a>

                        <!-- Export Excel -->
                        <a href="{{ path('app_poste_export_excel') }}" class="btn btn-pro text-success d-flex align-items-center gap-2 px-3 transition-all hover-lift" title="Exporter en Excel">
                            <i class="bi bi-file-earmark-spreadsheet-fill"></i>
                            <span class="d-none d-md-inline small fw-bold">Excel</span>
                        </a>
                    </div>
                </div>

                <!-- Posts Feed -->
                <div class="posts-container">
                    {% for poste in postes %}
                        {{ include('poste/postitem.html.twig', {'poste': poste}) }}
                    {% else %}
                        <!-- Empty state with improved design -->
                        <div class="bg-white border rounded-5 p-5 text-center shadow-sm mx-auto" style="max-width: 600px; margin-top: 50px;">
                            <div class="display-3 text-success opacity-10 mb-4"><i class="bi bi-chat-dots-fill"></i></div>
                            <h3 class="fw-bold h4">{% if current_query %}Aucun résultat pour "{{ current_query }}"{% else %}Flux de communauté vide{% endif %}</h3>
                            <p class="text-secondary opacity-75 small">Prêt à partager quelque chose avec la communauté ?</p>
                            <button type="button" class="btn btn-new-post mt-3 shadow-sm px-4" onclick="openPostModal('{{ path('app_poste_new') }}')">
                                Commencer maintenant
                            </button>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>

    <style>
        .hover-bg-light:hover { background-color: rgba(0, 0, 0, 0.02); }
        .x-small { font-size: 11px; }
        .uppercase { text-transform: uppercase; }
        .ls-1 { letter-spacing: 0.5px; }
        .group:hover .hover-bg-light { background-color: rgba(34, 197, 94, 0.05); }
        .btn-pro {
            background: #fff;
            border: 1.5px solid rgba(0,0,0,0.06);
            border-radius: 12px;
            color: #475569;
            transition: all 0.2s;
        }
        .btn-pro:hover {
            border-color: rgba(34, 197, 94, 0.3);
            background: rgba(34, 197, 94, 0.02);
            color: #16a34a;
        }
    </style>

    <!-- Global Post Modal -->
    <div class="modal fade" id="postModal" tabindex="-1" aria-hidden="true" style="backdrop-filter: blur(5px);">
        <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
            <div class="modal-content border-0 rounded-5 shadow-lg">
                <!-- High-end Modal Header -->
                <div class="modal-header border-0 pb-0 px-4 pt-4 d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-2">
                        <div class="rounded-circle bg-success bg-opacity-10 text-success d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                            <i class="bi bi-pencil-square fs-5"></i>
                        </div>
                        <h5 class="modal-title fw-bold" style="font-family: 'Outfit', sans-serif;">Publication</h5>
                    </div>
                    <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                
                <div id="modalBody" class="modal-body p-4 custom-scrollbar">
                    <div class="text-center py-5">
                        <div class="spinner-border text-success" role="status"></div>
                        <p class="mt-3 text-muted small">Chargement du formulaire...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        /* Modern & Jolie Scrollbar */
        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: rgba(0,0,0,0.02); border-radius: 10px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { 
            background: rgba(22, 163, 74, 0.2); 
            border-radius: 10px; 
            transition: all 0.2s;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(22, 163, 74, 0.4); }
        
        .modal-body { max-height: 80vh; }
    </style>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    let postModal;
    let modalEl;
    let modalBody;

    document.addEventListener('DOMContentLoaded', () => {
        modalEl = document.getElementById('postModal');
        modalBody = document.getElementById('modalBody');
        postModal = new bootstrap.Modal(modalEl);
    });

    function openPostModal(url) {
        if (!postModal) {
            const el = document.getElementById('postModal');
            postModal = new bootstrap.Modal(el);
            modalBody = document.getElementById('modalBody');
        }

        // Reset body to loading state
        modalBody.innerHTML = `
            <div class="text-center py-5">
                <div class="spinner-border text-success" role="status"></div>
                <p class="mt-3 text-muted small">Connexion au serveur...</p>
            </div>
        `;
        postModal.show();

        fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(response => response.text())
            .then(html => {
                const range = document.createRange();
                const fragment = range.createContextualFragment(html);
                modalBody.innerHTML = '';
                modalBody.appendChild(fragment);
                
                setTimeout(() => {
                    if (window.initPosteForm) {
                        window.initPosteForm();
                    }
                }, 20);
            })
            .catch(error => {
                modalBody.innerHTML = '<div class="alert alert-danger m-4">Erreur de chargement.</div>';
            });
    }
</script>
{% endblock %}

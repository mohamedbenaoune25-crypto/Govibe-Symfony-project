{% extends is_granted('ROLE_ADMIN') ? 'admin/base_admin.html.twig' : 'base.html.twig' %}

{% block page_title %}Gestion des Publications{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Manrope:wght@200..800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════════
   GoVibe Publications — Ultra Premium Design
═══════════════════════════════════════════════════ */
body {
    font-family: 'Manrope', sans-serif !important;
    background: #fcf9f8 !important;
    color: #1c1b1b !important;
}

.material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24; }

/* ─── Hero Section ─── */
.gv-pub-hero {
    position: relative;
    padding: 180px 0 100px;
    background: linear-gradient(160deg, #00342d 0%, #013220 40%, #001a12 100%);
    overflow: hidden;
    text-align: center;
    border-radius: 0 0 3rem 3rem;
    box-shadow: 0 20px 50px rgba(0, 52, 45, 0.15);
}

.gv-pub-hero::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse at 30% 75%, rgba(16, 185, 129, 0.15) 0%, transparent 60%),
                radial-gradient(ellipse at 75% 25%, rgba(233, 193, 118, 0.08) 0%, transparent 50%);
    pointer-events: none;
}

.gv-pub-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(160, 242, 225, 0.06) 1px, transparent 1px);
    background-size: 24px 24px;
    pointer-events: none;
}

.gv-hero-icon-bg {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font-size: 22rem;
    color: rgba(255, 255, 255, 0.02);
    z-index: 0;
    pointer-events: none;
    font-variation-settings: 'FILL' 1;
}

.gv-hero-title {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: #fff;
    font-weight: 700;
    margin-bottom: 1rem;
    position: relative;
    z-index: 2;
    animation: heroFadeIn 0.8s ease both;
}
.gv-hero-title em { color: #a0f2e1; font-style: italic; font-weight: 300; }

.gv-hero-sub {
    color: rgba(160, 242, 225, 0.7);
    font-size: 1.1rem;
    max-width: 600px;
    margin: 0 auto 0.5rem;
    line-height: 1.6;
    position: relative;
    z-index: 2;
    animation: heroFadeIn 0.8s ease 0.2s both;
}

.gv-hero-stat {
    color: rgba(160, 242, 225, 0.5);
    font-size: 0.9rem;
    font-weight: 600;
    position: relative;
    z-index: 2;
    animation: heroFadeIn 0.8s ease 0.3s both;
}

@keyframes heroFadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}

/* ─── Main Content Container ─── */
.gv-pub-container {
    max-width: 1200px;
    margin: -40px auto 80px;
    position: relative;
    z-index: 10;
    padding: 0 2rem;
}

.gv-pub-container.gv-admin-view {
    margin-top: 0;
}

/* ─── Toolbar ─── */
.gv-pub-toolbar {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px) saturate(180%);
    border: 1px solid rgba(0, 52, 45, 0.06);
    border-radius: 1.25rem;
    padding: 1rem 1.5rem;
    box-shadow: 0 20px 50px rgba(0, 52, 45, 0.08);
    margin-bottom: 2rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
}

.gv-toolbar-search {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex: 1;
    max-width: 500px;
}
.gv-toolbar-search .material-symbols-outlined { color: #546067; font-size: 1.2rem; }
.gv-toolbar-search-input {
    border: none;
    outline: none;
    background: transparent;
    width: 100%;
    font-size: 0.9rem;
    font-weight: 500;
    color: #1c1b1b;
    font-family: 'Manrope', sans-serif;
    padding: 0.5rem 0;
}
.gv-toolbar-search-input::placeholder { color: #bfc9c4; }
.gv-toolbar-search-clear {
    color: #546067;
    text-decoration: none;
    display: flex;
    align-items: center;
    transition: color 0.2s;
}
.gv-toolbar-search-clear:hover { color: #ba1a1a; }

.gv-toolbar-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
}

.gv-btn-ghost {
    background: #fff;
    border: 1.5px solid rgba(0, 52, 45, 0.08);
    border-radius: 0.75rem;
    padding: 0.5rem 0.85rem;
    color: #546067;
    font-weight: 700;
    font-size: 0.8rem;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    transition: all 0.25s ease;
    font-family: 'Manrope', sans-serif;
    cursor: pointer;
}
.gv-btn-ghost:hover {
    border-color: rgba(0, 52, 45, 0.2);
    background: rgba(0, 52, 45, 0.03);
    color: #00342d;
}

.gv-btn-new-post {
    padding: 0.65rem 1.5rem;
    background: linear-gradient(135deg, #e9c176 0%, #ca9028 100%);
    color: #3d2a00;
    border: none;
    border-radius: 0.75rem;
    font-weight: 700;
    font-size: 0.9rem;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s ease;
    box-shadow: 0 8px 20px -5px rgba(233, 193, 118, 0.35);
    font-family: 'Manrope', sans-serif;
    cursor: pointer;
}
.gv-btn-new-post:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 30px -5px rgba(233, 193, 118, 0.5);
    color: #3d2a00;
}

.gv-vr {
    width: 1px;
    height: 24px;
    background: rgba(0, 52, 45, 0.1);
    margin: 0 0.25rem;
}

/* ─── Layout: Sidebar + Feed ─── */
.gv-pub-layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 2rem;
}
@media (max-width: 992px) {
    .gv-pub-layout { grid-template-columns: 1fr; }
    .gv-pub-sidebar { display: none; }
}

/* ─── Sidebar ─── */
.gv-pub-sidebar-inner {
    position: sticky;
    top: 2rem;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(0, 52, 45, 0.05);
    border-radius: 1.25rem;
    padding: 1.5rem;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.03);
}

.gv-admin-view .gv-pub-sidebar-inner {
    top: calc(75px + 2rem);
}

.gv-sidebar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
}
.gv-sidebar-header h5 {
    font-family: 'Noto Serif', serif;
    font-weight: 700;
    font-size: 1rem;
    color: #00342d;
    margin: 0;
}
.gv-sidebar-header a {
    font-size: 0.75rem;
    font-weight: 700;
    color: #10B981;
    text-decoration: none;
}
.gv-sidebar-header a:hover { text-decoration: underline; }

.gv-forum-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}

.gv-forum-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem;
    border-radius: 0.75rem;
    text-decoration: none;
    transition: all 0.2s ease;
}
.gv-forum-item:hover { background: rgba(0, 52, 45, 0.03); }

.gv-forum-avatar {
    width: 36px; height: 36px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
}
.gv-forum-avatar img {
    width: 100%; height: 100%; object-fit: cover;
}
.gv-forum-avatar-placeholder {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: rgba(0, 52, 45, 0.08);
    color: #00342d;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.8rem;
    flex-shrink: 0;
}

.gv-forum-name {
    font-weight: 700;
    color: #00342d;
    font-size: 0.85rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.gv-forum-members {
    font-size: 0.7rem;
    color: #707975;
}

/* ─── Sort Dropdown (inherit existing) ─── */
.dropdown-menu {
    border: 1px solid rgba(0, 52, 45, 0.06) !important;
    border-radius: 1rem !important;
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.08) !important;
    padding: 0.5rem !important;
    background: rgba(255, 255, 255, 0.98) !important;
}
.dropdown-item {
    border-radius: 0.5rem !important;
    font-size: 0.85rem !important;
    font-weight: 500 !important;
}
.dropdown-item:hover { background: rgba(0, 52, 45, 0.04) !important; }

/* ─── Posts Empty State ─── */
.gv-empty {
    text-align: center;
    padding: 5rem 2rem;
    background: #fff;
    border-radius: 1.5rem;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.04);
    max-width: 600px;
    margin: 2rem auto 0;
}
.gv-empty-icon {
    font-size: 4rem;
    color: #cde1db;
    margin-bottom: 1.5rem;
    font-variation-settings: 'FILL' 1;
}
.gv-empty h4 {
    font-family: 'Noto Serif', serif;
    font-size: 1.3rem;
    color: #00342d;
    font-weight: 700;
    margin-bottom: 0.5rem;
}
.gv-empty p { color: #546067; font-size: 0.9rem; }

/* ─── Custom Scrollbar ─── */
.custom-scrollbar::-webkit-scrollbar { width: 6px; }
.custom-scrollbar::-webkit-scrollbar-track { background: rgba(0,0,0,0.02); border-radius: 10px; }
.custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(0, 52, 45, 0.15); border-radius: 10px; }
.custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(0, 52, 45, 0.3); }

.modal-body { max-height: 80vh; }

/* ─── Gemini Chatbot Styles ─── */
.gv-chatbot-fab {
    position: fixed;
    bottom: 2rem;
    right: 2.5rem;
    width: 64px;
    height: 64px;
    background: linear-gradient(135deg, #10b981 0%, #059669 100%);
    color: white;
    border: none;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 30px rgba(16, 185, 129, 0.4);
    cursor: pointer;
    z-index: 9999;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
.gv-chatbot-fab:hover {
    transform: scale(1.1) translateY(-5px);
    box-shadow: 0 15px 40px rgba(16, 185, 129, 0.5);
}
.gv-chatbot-fab .material-symbols-outlined {
    font-size: 2rem;
    font-variation-settings: 'FILL' 1;
}

.chat-container {
    height: 500px;
    display: flex;
    flex-direction: column;
    background: #fff;
}
.chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background: #fcf9f8;
}
.chat-message {
    max-width: 80%;
    padding: 0.85rem 1.15rem;
    border-radius: 1.25rem;
    font-size: 0.95rem;
    line-height: 1.4;
    position: relative;
    animation: messageIn 0.3s ease both;
}
@keyframes messageIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}
.chat-message.ai {
    align-self: flex-start;
    background: #fff;
    color: #1c1b1b;
    border-bottom-left-radius: 0.25rem;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
    border: 1px solid rgba(0, 52, 45, 0.05);
}
    .chat-message.user {
        align-self: flex-end;
        background: linear-gradient(135deg, #00342d 0%, #013220 100%);
        color: #fff;
        border-bottom-right-radius: 0.25rem;
        box-shadow: 0 4px 15px rgba(0, 52, 45, 0.1);
    }
    /* ─── AI Selector Professional Design ─── */
    .gv-ai-selector-container {
        position: relative;
        display: inline-block;
    }
    .gv-ai-selector-btn {
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: white;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
        backdrop-filter: blur(5px);
    }
    .gv-ai-selector-btn:hover {
        background: rgba(255, 255, 255, 0.2);
    }
    .gv-ai-selector-btn .arrow {
        font-size: 1rem;
        transition: transform 0.3s ease;
    }
    .gv-ai-selector-container.open .gv-ai-selector-btn .arrow {
        transform: rotate(180deg);
    }
    .gv-ai-selector-menu {
        position: absolute;
        top: calc(100% + 8px);
        left: 0;
        background: rgba(255, 255, 255, 0.98);
        min-width: 160px;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        padding: 6px;
        z-index: 100;
        display: none;
        animation: slideInUp 0.2s ease forwards;
        border: 1px solid rgba(0, 52, 45, 0.05);
    }
    @keyframes slideInUp {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .gv-ai-selector-item {
        padding: 8px 12px;
        border-radius: 8px;
        color: #1c1b1b;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 10px;
        transition: all 0.2s ease;
        font-size: 0.85rem;
        font-weight: 600;
    }
    .gv-ai-selector-item:hover {
        background: rgba(16, 185, 129, 0.08);
        color: #00342d;
    }
    .gv-ai-selector-item.active {
        background: #00342d;
        color: white;
    }
    .gv-ai-selector-item i {
        font-size: 1.1rem;
    }
    .gv-icon-gemini {
        background: linear-gradient(135deg, #4285f4 0%, #9b72f3 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-weight: bold;
    }
    .gv-icon-groq {
        color: #f59e0b;
    }
    .gv-ai-selector-item .model-desc {
        font-size: 0.65rem;
        opacity: 0.7;
        font-weight: 500;
        display: block;
    }

.chat-input-area {
    padding: 1.25rem;
    background: #fff;
    border-top: 1px solid rgba(0, 52, 45, 0.06);
    display: flex;
    gap: 0.75rem;
    align-items: center;
}
.chat-input {
    flex: 1;
    border: 1.5px solid #e5e7eb;
    border-radius: 0.75rem;
    padding: 0.65rem 1rem;
    font-size: 0.95rem;
    outline: none;
    transition: all 0.2s;
}
.chat-input:focus {
    border-color: #10b981;
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
}
.chat-send-btn {
    width: 42px;
    height: 42px;
    border-radius: 0.75rem;
    background: #00342d;
    color: #fff;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
}
.chat-send-btn:hover {
    background: #10b981;
    transform: scale(1.05);
}

.typing-indicator {
    display: flex;
    gap: 4px;
    padding: 4px 8px;
}
.typing-dot {
    width: 6px;
    height: 6px;
    background: #bfc9c4;
    border-radius: 50%;
    animation: typing 1.4s infinite;
}
.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes typing {
    0%, 60%, 100% { transform: translateY(0); }
    30% { transform: translateY(-4px); }
}
    /* --- Mentions --- */
    .gv-mentions-list {
        position: absolute;
        z-index: 10000;
        background: rgba(255, 255, 255, 0.98);
        border: 1px solid rgba(0, 52, 45, 0.08);
        border-radius: 1rem;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.12);
        min-width: 220px;
        max-height: 260px;
        overflow-y: auto;
        padding: 0.5rem;
        backdrop-filter: blur(10px);
    }
    .gv-mention-item {
        padding: 0.75rem 1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.85rem;
        border-radius: 0.75rem;
        transition: all 0.2s ease;
        text-decoration: none;
        color: inherit;
    }
    .gv-mention-item:hover, .gv-mention-item.active {
        background: rgba(16, 185, 129, 0.08);
        color: #00342d;
    }
    .gv-mention-avatar {
        width: 32px; height: 32px;
        border-radius: 50%;
        object-fit: cover;
        background: #eee;
    }
    .gv-mention-info {
        display: flex;
        flex-direction: column;
    }
    .gv-mention-name { font-weight: 700; font-size: 0.9rem; }
    .gv-mention-tag { font-size: 0.75rem; color: #64748b; }
</style>
{% endblock %}

{% block body %}
    {% if not is_granted('ROLE_ADMIN') %}
    <!-- ─── HERO ─── -->
    <div class="gv-pub-hero">
        <span class="material-symbols-outlined gv-hero-icon-bg">forum</span>
        <div class="container">
            <h1 class="gv-hero-title">Nos <em>Publications</em></h1>
            <p class="gv-hero-sub">Partagez vos expériences, inspirez la communauté GoVibe et découvrez les récits de voyageurs passionnés.</p>
            <p class="gv-hero-stat">{{ postes|length }} publication{{ postes|length > 1 ? 's' : '' }} dans la communauté</p>
        </div>
    </div>
    {% endif %}

    <!-- ─── MAIN CONTENT ─── -->
    <div class="gv-pub-container {{ is_granted('ROLE_ADMIN') ? 'gv-admin-view' : '' }}">

        <!-- Toolbar -->
        <div class="gv-pub-toolbar">
            <form action="{{ path('app_poste_index') }}" method="GET" class="gv-toolbar-search">
                <input type="hidden" name="sort" value="{{ current_sort }}">
                <span class="material-symbols-outlined">search</span>
                <input type="text" name="q" value="{{ current_query }}" placeholder="Rechercher une publication..." class="gv-toolbar-search-input">
                {% if current_query %}
                    <a href="{{ path('app_poste_index', {'sort': current_sort}) }}" class="gv-toolbar-search-clear">
                        <span class="material-symbols-outlined" style="font-size:1.1rem;">close</span>
                    </a>
                {% endif %}
            </form>

            <div class="gv-toolbar-actions">
                <!-- Sort Dropdown -->
                <div class="dropdown">
                    <button class="gv-btn-ghost dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        <span class="material-symbols-outlined" style="font-size:1.1rem;">filter_list</span>
                        {% if current_sort == 'popular' %}Plus populaires
                        {% elseif current_sort == 'mine' %}Mes Publications
                        {% else %}Nouveautés{% endif %}
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end mt-2">
                        {% if app.user %}
                            <li>
                                <a class="dropdown-item {{ current_sort == 'mine' ? 'fw-bold' : '' }}" href="{{ path('app_poste_index', {'q': current_query, 'sort': 'mine'}) }}">
                                    <span class="material-symbols-outlined me-2" style="font-size:1rem;">person</span>Mes Publications
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                        {% endif %}
                        <li>
                            <a class="dropdown-item {{ current_sort == 'newest' ? 'fw-bold' : '' }}" href="{{ path('app_poste_index', {'q': current_query, 'sort': 'newest'}) }}">
                                <span class="material-symbols-outlined me-2" style="font-size:1rem;">schedule</span>Nouveautés
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item {{ current_sort == 'popular' ? 'fw-bold' : '' }}" href="{{ path('app_poste_index', {'q': current_query, 'sort': 'popular'}) }}">
                                <span class="material-symbols-outlined me-2" style="font-size:1rem;">local_fire_department</span>Plus populaires
                            </a>
                        </li>
                    </ul>
                </div>

                <div class="gv-vr d-none d-md-block"></div>

                <!-- Export -->
                <a href="{{ path('app_poste_export_pdf') }}" class="gv-btn-ghost" style="color: #ba1a1a;" title="Exporter en PDF">
                    <span class="material-symbols-outlined" style="font-size:1rem;">picture_as_pdf</span>
                    <span class="d-none d-md-inline">PDF</span>
                </a>
                <a href="{{ path('app_poste_export_excel') }}" class="gv-btn-ghost" style="color: #046b5e;" title="Exporter en Excel">
                    <span class="material-symbols-outlined" style="font-size:1rem;">table_chart</span>
                    <span class="d-none d-md-inline">Excel</span>
                </a>

                <div class="gv-vr d-none d-md-block"></div>

                <button type="button" class="gv-btn-new-post" onclick="openPostModal('{{ path('app_poste_new') }}')">
                    <span class="material-symbols-outlined" style="font-size:1.1rem;">add_circle</span>
                    Publier
                </button>
            </div>
        </div>

        <!-- Layout: Sidebar + Feed -->
        <div class="gv-pub-layout">
            <!-- Sidebar -->
            <div class="gv-pub-sidebar">
                {% if is_granted('ROLE_ADMIN') and flagged_count > 0 %}
                    <!-- SECTION ADMINISTRATION -->
                    <div class="gv-pub-sidebar-inner mb-4">
                        <div class="mb-0">
                            <a href="{{ path('app_admin_attention') }}" class="btn btn-danger w-100 d-flex align-items-center justify-content-center gap-2 rounded-3 py-2 fw-bold shadow-sm">
                                <span class="material-symbols-outlined">warning</span> Attention (Modération)
                            </a>
                        </div>
                    </div>
                {% endif %}

                <div class="gv-pub-sidebar-inner">
                    <div class="gv-sidebar-header">
                        <h5>Communautés</h5>
                        <a href="{{ path('app_forum_index') }}">Tout voir</a>
                    </div>
                    <div class="gv-forum-list">
                        {% for forum in forums|slice(0, 5) %}
                        <a href="{{ path('app_forum_show', {'forumId': forum.forumId}) }}" class="gv-forum-item">
                            {% if forum.image %}
                                <div class="gv-forum-avatar"><img src="{{ forum.image }}" alt="{{ forum.name }}"></div>
                            {% else %}
                                <div class="gv-forum-avatar-placeholder">{{ forum.name|first|upper }}</div>
                            {% endif %}
                            <div style="overflow:hidden;">
                                <div class="gv-forum-name">{{ forum.name }}</div>
                                <div class="gv-forum-members">{{ forum.nbrMembers }} membres</div>
                            </div>
                        </a>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <!-- Main Feed -->
            <div>
                <div class="posts-container">
                    {% for poste in postes %}
                        {{ include('poste/postitem.html.twig', {'poste': poste}) }}
                    {% else %}
                        <div class="gv-empty">
                            <span class="material-symbols-outlined gv-empty-icon">chat_bubble</span>
                            <h4>{% if current_query %}Aucun résultat pour "{{ current_query }}"{% else %}Flux de communauté vide{% endif %}</h4>
                            <p>Prêt à partager quelque chose avec la communauté ?</p>
                            <button type="button" class="gv-btn-new-post" style="margin-top: 1rem;" onclick="openPostModal('{{ path('app_poste_new') }}')">
                                <span class="material-symbols-outlined" style="font-size:1.1rem;">add_circle</span>
                                Commencer maintenant
                            </button>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>

    <!-- ─── Post Modal ─── -->
    <div class="modal fade" id="postModal" tabindex="-1" aria-hidden="true" style="backdrop-filter: blur(8px);">
        <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
            <div class="modal-content border-0 rounded-4 shadow-lg" style="border-radius:1.5rem!important;">
                <div class="modal-header border-0 pb-0 px-4 pt-4 d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-2">
                        <div class="d-flex align-items-center justify-content-center rounded-3" style="width:40px; height:40px; background:rgba(0,52,45,0.08);">
                            <span class="material-symbols-outlined" style="color:#00342d;">edit_square</span>
                        </div>
                        <h5 class="modal-title fw-bold" style="font-family: 'Noto Serif', serif; color:#00342d;">Publication</h5>
                    </div>
                    <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div id="modalBody" class="modal-body p-4 custom-scrollbar">
                    <div class="text-center py-5">
                        <div class="spinner-border" role="status" style="color:#10B981;"></div>
                        <p class="mt-3 text-muted small">Chargement du formulaire...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ─── Gemini Chatbot ─── -->
    <button type="button" class="gv-chatbot-fab" onclick="openChatModal()">
        <span class="material-symbols-outlined">smart_toy</span>
    </button>

    <div class="modal fade" id="chatModal" tabindex="-1" aria-hidden="true" style="backdrop-filter: blur(8px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 overflow-hidden shadow-lg" style="border-radius:1.5rem;">
                <div class="modal-header border-0 p-4" style="background: linear-gradient(135deg, #00342d 0%, #013220 100%); color: white;">
                    <div class="d-flex align-items-center gap-3">
                        <div class="d-flex align-items-center justify-content-center rounded-3" style="width:45px; height:45px; background:rgba(255,255,255,0.1);">
                            <span class="material-symbols-outlined" style="color:#a0f2e1;">robot_2</span>
                        </div>
                        <h5 class="modal-title fw-bold mb-0">AI Assistant</h5>
                        <div class="gv-ai-selector-container mt-1" id="aiSelector">
                            <div class="gv-ai-selector-btn" onclick="toggleAISelector()">
                                <span id="selectedAIName">Gemini (Google)</span>
                                <span class="material-symbols-outlined arrow">expand_more</span>
                            </div>
                            <div class="gv-ai-selector-menu" id="aiMenu">
                                <div class="gv-ai-selector-item active" onclick="selectAI('gemini', 'Gemini (Google)')">
                                    <span class="material-symbols-outlined gv-icon-gemini">auto_awesome</span>
                                    <span>Gemini</span>
                                </div>
                                <div class="gv-ai-selector-item" onclick="selectAI('groq', 'Groq (Grok Speed)')">
                                    <span class="material-symbols-outlined gv-icon-groq">bolt</span>
                                    <span>Groq</span>
                                </div>
                            </div>
                            <input type="hidden" id="aiModelSelectorValue" value="gemini">
                        </div>
                    </div>
                    <button type="button" class="btn-close btn-close-white shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="chat-container">
                    <div id="chatMessages" class="chat-messages custom-scrollbar">
                        <div class="chat-message ai">
                            Bonjour ! Je suis Gemini, votre assistant voyage personnel. Comment puis-je vous aider dans vos aventures aujourd'hui ?
                        </div>
                    </div>
                    <div class="chat-input-area">
                        <input type="text" id="chatInput" class="chat-input" placeholder="Posez votre question sur un voyage..." onkeypress="if(event.key === 'Enter') sendMessage()">
                        <button class="chat-send-btn" onclick="sendMessage()">
                            <span class="material-symbols-outlined">send</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    let postModal;
    let modalEl;
    let modalBody;

    document.addEventListener('DOMContentLoaded', () => {
        modalEl = document.getElementById('postModal');
        modalBody = document.getElementById('modalBody');
        postModal = new bootstrap.Modal(modalEl);
    });

    function openPostModal(url) {
        if (!postModal) {
            const el = document.getElementById('postModal');
            postModal = new bootstrap.Modal(el);
            modalBody = document.getElementById('modalBody');
        }

        modalBody.innerHTML = `
            <div class="text-center py-5">
                <div class="spinner-border" role="status" style="color:#10B981;"></div>
                <p class="mt-3 text-muted small">Connexion au serveur...</p>
            </div>
        `;
        postModal.show();

        fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(response => response.text())
            .then(html => {
                const range = document.createRange();
                const fragment = range.createContextualFragment(html);
                modalBody.innerHTML = '';
                modalBody.appendChild(fragment);
                
                setTimeout(() => {
                    if (window.initPosteForm) {
                        window.initPosteForm();
                    }
                }, 20);
            })
            .catch(error => {
                modalBody.innerHTML = '<div class="alert alert-danger m-4 rounded-4">Erreur de chargement.</div>';
            });
    }

    // --- Gemini Chat Control ---
    let chatModal;
    document.addEventListener('DOMContentLoaded', () => {
        chatModal = new bootstrap.Modal(document.getElementById('chatModal'));
        
        // Close AI menu when clicking outside
        document.addEventListener('click', (e) => {
            const selector = document.getElementById('aiSelector');
            if (selector && !selector.contains(e.target)) {
                closeAISelector();
            }
        });
    });

    function toggleAISelector() {
        const container = document.getElementById('aiSelector');
        const menu = document.getElementById('aiMenu');
        container.classList.toggle('open');
        menu.style.display = container.classList.contains('open') ? 'block' : 'none';
    }

    function closeAISelector() {
        const container = document.getElementById('aiSelector');
        const menu = document.getElementById('aiMenu');
        if(container) container.classList.remove('open');
        if(menu) menu.style.display = 'none';
    }

    function selectAI(value, name) {
        document.getElementById('aiModelSelectorValue').value = value;
        document.getElementById('selectedAIName').innerText = name;
        
        // Update active class
        document.querySelectorAll('.gv-ai-selector-item').forEach(item => {
            item.classList.remove('active');
            if (item.innerText.includes(value === 'gemini' ? 'Gemini' : 'Groq')) {
                item.classList.add('active');
            }
        });
        
        closeAISelector();
    }

    function openChatModal() {
        chatModal.show();
    }

    function sendMessage() {
        const input = document.getElementById('chatInput');
        const text = input.value.trim();
        if (!text) return;

        appendMessage('user', text);
        input.value = '';

        const indicator = showTypingIndicator();
        const model = document.getElementById('aiModelSelectorValue').value;
        const route = model === 'groq' ? '{{ path('app_groq_chat') }}' : '{{ path('app_gemini_chat') }}';

        // Call our AI API
        fetch(route, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({ message: text })
        })
        .then(response => response.json())
        .then(data => {
            indicator.remove();
            if (data.error) {
                appendMessage('ai', "Erreur : " + data.error);
            } else {
                appendMessage('ai', data.response);
            }
        })
        .catch(error => {
            indicator.remove();
            appendMessage('ai', "Désolé, une erreur de connexion est survenue.");
            console.error('Chat error:', error);
        });
    }

    function appendMessage(type, text) {
        const container = document.getElementById('chatMessages');
        const msg = document.createElement('div');
        msg.className = `chat-message ${type}`;

        if (type === 'ai' && text.includes('[POST_SUGGESTION]')) {
            const parts = text.split('[POST_SUGGESTION]');
            const normalText = parts[0];
            let suggestionBlock = parts[1].split('[/POST_SUGGESTION]')[0];
            
            try {
                const suggestion = JSON.parse(suggestionBlock);
                const safeSuggestion = suggestionBlock.replace(/'/g, "&apos;");
                msg.innerHTML = `
                    <div>${normalText}</div>
                    <div class="mt-3 p-3 bg-white border rounded-3 shadow-sm" style="color:#00342d;">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="material-symbols-outlined text-success" style="font-size:1.1rem;">auto_awesome</span>
                            <span class="fw-bold small">Suggestion de Publication</span>
                        </div>
                        <div class="small mb-3 text-muted" style="font-style:italic;">"${suggestion.contenu.substring(0, 80)}..."</div>
                        <button class="btn btn-sm btn-success w-100 rounded-pill py-2 fw-bold" 
                                onclick='fillPostForm(${safeSuggestion})'>
                            Remplir le formulaire
                        </button>
                    </div>
                `;
            } catch (e) {
                msg.textContent = text;
            }
        } else {
            msg.textContent = text;
        }

        container.appendChild(msg);
        container.scrollTop = container.scrollHeight;
    }

    function fillPostForm(data) {
        // Open modal
        openPostModal('{{ path('app_poste_new') }}');

        // Close chat modal
        chatModal.hide();

        // Wait for form to load
        const checkExist = setInterval(() => {
            const form = document.getElementById('publication-form');
            if (form) {
                clearInterval(checkExist);
                
                // Fill fields
                const textarea = form.querySelector('textarea');
                const locInput = document.getElementById('poste_localisation');
                
                if (textarea) textarea.value = data.contenu;
                if (locInput) locInput.value = data.localisation || '';
                
                // Set type
                if (data.type === 'MEDIA') {
                    const btnPhoto = document.getElementById('btn-photo-video');
                    if (btnPhoto) btnPhoto.click();
                    
                    if (data.imageUrl) {
                        const extInput = document.getElementById('poste_externalImageUrl');
                        if (extInput) extInput.value = data.imageUrl;
                        
                        // Show preview
                        const imgPreview = document.getElementById('image-preview');
                        const previewContainer = document.getElementById('preview-image-container');
                        const noPreview = document.getElementById('no-preview');
                        
                        if (imgPreview) {
                            imgPreview.src = data.imageUrl;
                            if (previewContainer) previewContainer.style.display = 'block';
                            if (noPreview) noPreview.style.display = 'none';
                        }
                    }
                } else {
                    const btnText = document.getElementById('btn-status-texte');
                    if (btnText) btnText.click();
                }

                // Trigger validation/counter
                if (textarea) textarea.dispatchEvent(new Event('input'));
            }
        }, 100);
    }

    function showTypingIndicator() {
        const container = document.getElementById('chatMessages');
        const div = document.createElement('div');
        div.className = 'chat-message ai';
        div.innerHTML = `
            <div class="typing-indicator">
                <div class="typing-dot"></div>
                <div class="typing-dot"></div>
                <div class="typing-dot"></div>
            </div>
        `;
        container.appendChild(div);
        container.scrollTop = container.scrollHeight;
        return div;
    }
    // --- Mentions Manager ---
    const MentionsManager = {
        activeInput: null,
        listEl: null,
        query: '',
        selectedIndex: -1,
        users: [],

        init() {
            // Use capture to handle inputs in modals and post items
            document.addEventListener('input', (e) => {
                const tag = e.target.tagName;
                if (tag === 'TEXTAREA' || (tag === 'INPUT' && e.target.type === 'text')) {
                    this.handleInput(e);
                }
            }, true);

            document.addEventListener('keydown', (e) => this.handleKeyDown(e), true);
            document.addEventListener('click', (e) => {
                if (this.listEl && !this.listEl.contains(e.target)) this.close();
            });
        },

        handleInput(e) {
            const input = e.target;
            const cursor = input.selectionStart;
            const text = input.value.substring(0, cursor);
            const match = text.match(/@(\w*)$/);

            if (match) {
                this.activeInput = input;
                this.query = match[1];
                this.showList();
                this.fetchUsers(this.query);
            } else {
                if (this.listEl) this.close();
            }
        },

        async fetchUsers(q) {
            try {
                const res = await fetch(`{{ path('api_users_search') }}?q=${q}`);
                this.users = await res.json();
                this.renderList();
            } catch (err) {
                console.error('Mentions fetch error:', err);
            }
        },

        showList() {
            if (!this.listEl) {
                this.listEl = document.createElement('div');
                this.listEl.className = 'gv-mentions-list';
                document.body.appendChild(this.listEl);
            }
            this.positionList();
        },

        positionList() {
            if (!this.activeInput || !this.listEl) return;
            const rect = this.activeInput.getBoundingClientRect();
            
            // Positioning below input
            this.listEl.style.top = `${window.scrollY + rect.bottom + 8}px`;
            this.listEl.style.left = `${window.scrollX + rect.left}px`;
            
            // Avoid overflowing right
            const listRect = this.listEl.getBoundingClientRect();
            if (listRect.right > window.innerWidth) {
                this.listEl.style.left = `${window.innerWidth - listRect.width - 20}px`;
            }
        },

        renderList() {
            if (!this.listEl) return;
            if (this.users.length === 0) {
                this.listEl.innerHTML = '<div class="p-3 text-muted small text-center">Aucun utilisateur trouvé</div>';
                return;
            }

            this.listEl.innerHTML = this.users.map((u, i) => `
                <div class="gv-mention-item ${i === this.selectedIndex ? 'active' : ''}" data-index="${i}">
                    <img src="${u.photo || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(u.name)}" class="gv-mention-avatar">
                    <div class="gv-mention-info">
                        <span class="gv-mention-name">${u.name}</span>
                        <span class="gv-mention-tag">@${u.tag}</span>
                    </div>
                </div>
            `).join('');

            this.listEl.querySelectorAll('.gv-mention-item').forEach(item => {
                item.addEventListener('click', (e) => {
                    e.preventDefault();
                    e.stopPropagation();
                    this.selectUser(parseInt(item.dataset.index));
                });
            });
        },

        handleKeyDown(e) {
            if (!this.listEl) return;

            if (e.key === 'ArrowDown') {
                e.preventDefault();
                this.selectedIndex = (this.selectedIndex + 1) % this.users.length;
                this.renderList();
            } else if (e.key === 'ArrowUp') {
                e.preventDefault();
                this.selectedIndex = (this.selectedIndex - 1 + this.users.length) % this.users.length;
                this.renderList();
            } else if (e.key === 'Enter' && this.selectedIndex >= 0) {
                e.preventDefault();
                this.selectUser(this.selectedIndex);
            } else if (e.key === 'Escape') {
                this.close();
            }
        },

        selectUser(index) {
            const user = this.users[index];
            if (!user || !this.activeInput) return;

            const cursor = this.activeInput.selectionStart;
            const text = this.activeInput.value;
            const before = text.substring(0, cursor).replace(/@\w*$/, `@${user.tag} `);
            const after = text.substring(cursor);

            this.activeInput.value = before + after;
            this.activeInput.focus();
            this.activeInput.setSelectionRange(before.length, before.length);
            
            // Trigger input event for constraints (like char counter)
            this.activeInput.dispatchEvent(new Event('input', { bubbles: true }));
            
            this.close();
        },

        close() {
            if (this.listEl) {
                this.listEl.remove();
                this.listEl = null;
            }
            this.activeInput = null;
            this.users = [];
            this.selectedIndex = -1;
        }
    };

    /* --- Mentions Logic --- */
    function highlightMentions() {
        // Targets post text and comment contents
        const elements = document.querySelectorAll('.post-text, .comment-bubble p');
        elements.forEach(el => {
            // We use textContent for analysis to avoid infinite loops with innerHTML
            const originalHTML = el.innerHTML;
            // Simple regex to find @word but avoiding matches inside tags already
            // Actually, for safety with nl2br, we can just do a replace on the HTML
            // but carefully.
            if (el.dataset.mentionsProcessed) return;
            
            el.innerHTML = el.innerHTML.replace(/(@[a-zA-Z0-9_]+)/g, '<span class="text-primary fw-bold" style="color: #2563eb !important;">$1</span>');
            el.dataset.mentionsProcessed = 'true';
        });
    }

    document.addEventListener('DOMContentLoaded', () => {
        MentionsManager.init();
        highlightMentions();
        
        // Also observe for new comments added dynamically
        const observer = new MutationObserver((mutations) => {
            highlightMentions();
        });
        observer.observe(document.body, { childList: true, subtree: true });
    });
</script>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Créer un compte | GoVibe — Curated Odyssey{% endblock %}

{% block header %}{% endblock %}
{% block footer %}{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
<style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
        font-family: 'Manrope', sans-serif !important;
        background: linear-gradient(135deg, #0a1a14 0%, #00261c 50%, #0d0d0d 100%) !important;
        min-height: 100vh !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        padding: 1rem !important;
        overflow-x: hidden !important;
        margin: 0 !important;
    }

    .auth-bg-grid {
        position: fixed; top: 0; left: 0; width: 200%; height: 200%;
        background-size: 60px 60px;
        background-image:
            linear-gradient(to right, rgba(16, 185, 129, 0.04) 1px, transparent 1px),
            linear-gradient(to bottom, rgba(16, 185, 129, 0.04) 1px, transparent 1px);
        transform: perspective(600px) rotateX(55deg) translateY(-80px) translateZ(-300px);
        animation: authGridFlow 25s linear infinite;
        z-index: 0; pointer-events: none;
    }
    @keyframes authGridFlow {
        0% { transform: perspective(600px) rotateX(55deg) translateY(0) translateZ(-300px); }
        100% { transform: perspective(600px) rotateX(55deg) translateY(60px) translateZ(-300px); }
    }

    .auth-orb { position: fixed; border-radius: 50%; filter: blur(100px); opacity: 0.35; z-index: 0; pointer-events: none; }
    .auth-orb-1 { width: 500px; height: 500px; background: radial-gradient(circle, #10B981, #064E3B); top: -5%; left: -5%; animation: orbDrift1 12s ease-in-out infinite alternate; }
    .auth-orb-2 { width: 350px; height: 350px; background: radial-gradient(circle, #fbbf24, #92400e); bottom: -10%; right: -5%; animation: orbDrift2 15s ease-in-out infinite alternate; }
    .auth-orb-3 { width: 200px; height: 200px; background: radial-gradient(circle, #06b6d4, #0e7490); top: 50%; right: 20%; animation: orbDrift3 10s ease-in-out infinite alternate; }
    @keyframes orbDrift1 { 0% { transform: translate(0, 0) scale(1); } 100% { transform: translate(40px, 30px) scale(1.08); } }
    @keyframes orbDrift2 { 0% { transform: translate(0, 0) scale(1); } 100% { transform: translate(-30px, -40px) scale(1.12); } }
    @keyframes orbDrift3 { 0% { transform: translate(0, 0) scale(1); } 100% { transform: translate(20px, -20px) scale(0.9); } }

    .auth-main {
        width: 100%; max-width: 1100px;
        display: grid; grid-template-columns: 1fr 1.2fr;
        border-radius: 2rem; overflow: hidden;
        box-shadow: 0 50px 100px -20px rgba(0, 0, 0, 0.6), 0 0 0 1px rgba(255, 255, 255, 0.05), inset 0 1px 0 0 rgba(255, 255, 255, 0.05);
        position: relative; z-index: 10;
        transform: translateY(20px); opacity: 0;
        animation: authCardReveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
    }
    @keyframes authCardReveal { to { transform: translateY(0); opacity: 1; } }
    @media (max-width: 768px) { .auth-main { grid-template-columns: 1fr; max-width: 520px; } }

    .auth-editorial {
        background: linear-gradient(160deg, #00342d 0%, #013220 40%, #001a12 100%);
        padding: 3rem; display: flex; flex-direction: column; justify-content: space-between;
        position: relative; overflow: hidden;
    }
    @media (max-width: 768px) { .auth-editorial { display: none; } }
    .auth-editorial::before {
        content: ''; position: absolute; inset: 0;
        background: radial-gradient(ellipse at 30% 80%, rgba(16, 185, 129, 0.15) 0%, transparent 60%),
                    radial-gradient(ellipse at 80% 20%, rgba(251, 191, 36, 0.08) 0%, transparent 50%);
        pointer-events: none;
    }
    .editorial-brand { position: relative; z-index: 2; font-family: 'Noto Serif', serif; font-weight: 700; font-style: italic; font-size: 1.75rem; color: #fff; }
    .editorial-content { position: relative; z-index: 2; }
    .editorial-title { font-family: 'Noto Serif', serif; font-size: 2.75rem; line-height: 1.15; color: #fff; font-weight: 700; margin-bottom: 1rem; }
    .editorial-title em { color: #a0f2e1; font-style: italic; }
    .editorial-desc { color: rgba(160, 242, 225, 0.6); font-size: 1.05rem; line-height: 1.6; max-width: 320px; }
    .editorial-hero-img {
        position: absolute; right: -15%; top: 15%; width: 130%; height: 75%;
        object-fit: cover; mix-blend-mode: luminosity; opacity: 0.25;
        border-radius: 0 0 0 8rem; pointer-events: none;
        mask-image: linear-gradient(to left, black 30%, transparent 100%);
        -webkit-mask-image: linear-gradient(to left, black 30%, transparent 100%);
    }
    .editorial-dots { position: relative; z-index: 2; display: flex; gap: 0.5rem; }
    .editorial-dots span { height: 4px; border-radius: 4px; background: rgba(160, 242, 225, 0.25); }
    .editorial-dots span:first-child { width: 3rem; background: #a0f2e1; }
    .editorial-dots span:nth-child(2), .editorial-dots span:nth-child(3) { width: 1rem; }

    .auth-form-panel {
        background: rgba(252, 249, 248, 0.97); padding: 2.5rem 3rem;
        display: flex; flex-direction: column; justify-content: center; position: relative;
        overflow-y: auto; max-height: 100vh;
    }
    @media (max-width: 768px) { .auth-form-panel { padding: 2rem 1.5rem; } }

    .auth-form-inner { max-width: 440px; width: 100%; margin: 0 auto; }

    .auth-form-title { font-family: 'Noto Serif', serif; font-size: 2rem; font-weight: 700; color: #1c1b1b; margin-bottom: 0.5rem; }
    .auth-form-subtitle { color: #707975; font-size: 0.95rem; margin-bottom: 2rem; line-height: 1.5; }

    .gv-field { margin-bottom: 1.25rem; }
    .gv-field-label {
        display: flex; align-items: center; gap: 0.5rem;
        font-size: 0.8rem; font-weight: 700; color: #3f4945;
        text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem;
    }
    .gv-field-label .material-symbols-outlined { font-size: 1.1rem; color: #707975; }

    .gv-input {
        width: 100%; padding: 0.9rem 1.25rem; background: #e5e2e1;
        border: 2px solid transparent; border-radius: 0.75rem;
        font-size: 1rem; color: #1c1b1b; font-family: 'Manrope', sans-serif;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); outline: none;
        box-sizing: border-box;
    }
    .gv-input::placeholder { color: rgba(112, 121, 117, 0.5); }
    .gv-input:focus { background: #fff; border-color: rgba(0, 52, 45, 0.15); box-shadow: 0 0 0 4px rgba(0, 52, 45, 0.06); }

    .gv-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    @media (max-width: 480px) { .gv-form-row { grid-template-columns: 1fr; } }

    .gv-check-row { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.25rem; }
    .gv-check-row input[type="checkbox"] { width: 1.15rem; height: 1.15rem; border-radius: 0.25rem; border: 2px solid #bfc9c4; accent-color: #00342d; cursor: pointer; }
    .gv-check-row label { font-size: 0.85rem; color: #3f4945; cursor: pointer; margin-bottom: 0; }

    .gv-btn-primary {
        width: 100%; padding: 1rem;
        background: linear-gradient(135deg, #00342d 0%, #004d43 70%, #046b5e 100%);
        color: #fff; border: none; border-radius: 0.75rem;
        font-size: 1.05rem; font-weight: 700; font-family: 'Manrope', sans-serif;
        cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 0.5rem;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 12px 28px -8px rgba(0, 52, 45, 0.4), inset 0 1px 0 0 rgba(160, 242, 225, 0.15);
        position: relative; overflow: hidden;
    }
    .gv-btn-primary::before {
        content: ''; position: absolute; inset: 0;
        background: linear-gradient(135deg, transparent 0%, rgba(255,255,255,0.08) 50%, transparent 100%);
        transform: translateX(-100%); transition: transform 0.6s ease;
    }
    .gv-btn-primary:hover::before { transform: translateX(100%); }
    .gv-btn-primary:hover { transform: translateY(-2px) scale(1.01); box-shadow: 0 18px 40px -10px rgba(0, 52, 45, 0.5); }
    .gv-btn-primary:active { transform: translateY(0) scale(0.99); }
    .gv-btn-primary:disabled { opacity: 0.6; cursor: not-allowed; transform: none !important; }

    .gv-btn-secondary {
        width: 100%; padding: 0.85rem;
        background: transparent;
        color: #00342d; border: 2px solid rgba(0, 52, 45, 0.2); border-radius: 0.75rem;
        font-size: 0.95rem; font-weight: 700; font-family: 'Manrope', sans-serif;
        cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 0.5rem;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .gv-btn-secondary:hover { background: rgba(0, 52, 45, 0.05); border-color: rgba(0, 52, 45, 0.4); }

    .gv-auth-footer { text-align: center; margin-top: 1.5rem; font-size: 0.9rem; color: #707975; }
    .gv-auth-footer a { color: #00342d; font-weight: 800; text-decoration: none; margin-left: 0.25rem; }
    .gv-auth-footer a:hover { text-decoration: underline; color: #046b5e; }

    .gv-alert { padding: 0.85rem 1rem; border-radius: 0.75rem; font-size: 0.85rem; margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.5rem; }
    .gv-alert-error { background: rgba(186, 26, 26, 0.08); border: 1px solid rgba(186, 26, 26, 0.2); color: #93000a; }
    .gv-alert-success { background: rgba(16, 185, 129, 0.08); border: 1px solid rgba(16, 185, 129, 0.2); color: #005046; }

    #authParticles { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; pointer-events: none; }

    /* Override base template */
    .auth-form-panel form { animation: none !important; }
    .auth-form-panel form .form-label,
    .auth-form-panel form .form-control { all: unset; }
    .auth-form-panel form input[type="email"],
    .auth-form-panel form input[type="password"],
    .auth-form-panel form input[type="text"],
    .auth-form-panel form input[type="tel"],
    .auth-form-panel form input[type="number"] {
        all: unset;
        width: 100%; padding: 0.9rem 1.25rem; background: #e5e2e1;
        border: 2px solid transparent; border-radius: 0.75rem;
        font-size: 1rem; color: #1c1b1b; font-family: 'Manrope', sans-serif;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); box-sizing: border-box;
    }
    .auth-form-panel form input[type="email"]:focus,
    .auth-form-panel form input[type="password"]:focus,
    .auth-form-panel form input[type="text"]:focus,
    .auth-form-panel form input[type="tel"]:focus,
    .auth-form-panel form input[type="number"]:focus {
        background: #fff; border-color: rgba(0, 52, 45, 0.15);
        box-shadow: 0 0 0 4px rgba(0, 52, 45, 0.06); outline: none;
    }
    .auth-form-panel form input::placeholder { color: rgba(112, 121, 117, 0.5); }
    .auth-form-panel .text-danger { color: #93000a !important; font-size: 0.8rem; margin-top: 0.25rem; }

    .govibe-navbar, .govibe-footer, .container.position-relative { display: none !important; }
    .floating-element { display: none !important; }

    /* ─── Face ID Section ─── */
    .face-enrollment-section {
        margin-bottom: 1.5rem;
        padding: 1.25rem;
        background: rgba(0, 52, 45, 0.03);
        border: 2px dashed rgba(0, 52, 45, 0.15);
        border-radius: 1rem;
        transition: all 0.3s ease;
    }
    .face-enrollment-section.captured {
        border-color: #10B981;
        background: rgba(16, 185, 129, 0.05);
        border-style: solid;
    }
    .face-section-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.75rem;
        font-size: 0.8rem;
        font-weight: 700;
        color: #3f4945;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .face-section-header .material-symbols-outlined { font-size: 1.1rem; color: #707975; }
    .face-section-desc {
        font-size: 0.8rem;
        color: #707975;
        margin-bottom: 1rem;
        line-height: 1.5;
    }

    .face-webcam-register {
        position: relative;
        width: 100%;
        aspect-ratio: 4/3;
        background: #1c1b1b;
        border-radius: 0.85rem;
        overflow: hidden;
        margin-bottom: 0.75rem;
        display: none;
    }
    .face-webcam-register.active { display: block; }
    .face-webcam-register video {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transform: scaleX(-1);
    }
    .face-webcam-register canvas { display: none; }
    .face-reg-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: none;
    }
    .face-reg-guide {
        width: 140px;
        height: 180px;
        border: 3px solid rgba(160, 242, 225, 0.5);
        border-radius: 50%;
        box-shadow: 0 0 0 9999px rgba(0, 0, 0, 0.3);
        animation: frPulse 2s ease-in-out infinite;
    }
    .face-reg-guide.scanning { border-color: #fbbf24; animation: frScan 1s linear infinite; }
    .face-reg-guide.success { border-color: #10B981; animation: none; box-shadow: 0 0 0 9999px rgba(0, 0, 0, 0.3), 0 0 20px rgba(16, 185, 129, 0.5); }
    .face-reg-guide.error { border-color: #ef4444; animation: none; }
    @keyframes frPulse { 0%, 100% { border-color: rgba(160, 242, 225, 0.5); } 50% { border-color: rgba(160, 242, 225, 0.9); } }
    @keyframes frScan { 0% { border-color: #fbbf24; } 50% { border-color: #f59e0b; } 100% { border-color: #fbbf24; } }

    .face-reg-status {
        position: absolute;
        bottom: 0.5rem;
        left: 50%;
        transform: translateX(-50%);
        background: rgba(0, 0, 0, 0.7);
        color: #a0f2e1;
        padding: 0.35rem 0.85rem;
        border-radius: 2rem;
        font-size: 0.7rem;
        font-weight: 700;
        backdrop-filter: blur(8px);
        white-space: nowrap;
    }
    .face-reg-status.error { color: #fca5a5; }
    .face-reg-status.success { color: #6ee7b7; }

    .face-captured-badge {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem 1rem;
        background: rgba(16, 185, 129, 0.08);
        border: 1px solid rgba(16, 185, 129, 0.25);
        border-radius: 0.6rem;
        color: #005046;
        font-size: 0.8rem;
        font-weight: 700;
    }
    .face-captured-badge .material-symbols-outlined { font-size: 1.1rem; color: #10B981; }
</style>
{% endblock %}

{% block body %}
<div class="auth-bg-grid"></div>
<div class="auth-orb auth-orb-1"></div>
<div class="auth-orb auth-orb-2"></div>
<div class="auth-orb auth-orb-3"></div>
<canvas id="authParticles"></canvas>

<main class="auth-main">
    <div class="auth-editorial">
        <div class="editorial-brand">GoVibe</div>
        <div class="editorial-content">
            <h2 class="editorial-title">Join the <em>adventure</em> today.</h2>
            <p class="editorial-desc">Create your account and start planning your dream vacations with curated luxury experiences.</p>
        </div>
        <img src="{{ asset('images/auth-hero-3d.png') }}" alt="Luxury travel 3D illustration" class="editorial-hero-img">
        <div class="editorial-dots"><span></span><span></span><span></span></div>
    </div>

    <div class="auth-form-panel">
        <div class="auth-form-inner">
            <h3 class="auth-form-title">Rejoignez GoVibe</h3>
            <p class="auth-form-subtitle">Créez votre compte et configurez votre Face ID sécurisé.</p>

            {% for message in app.flashes('success') %}
                <div class="gv-alert gv-alert-success">
                    <span class="material-symbols-outlined" style="font-size:1.1rem;">check_circle</span>
                    {{ message }}
                </div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="gv-alert gv-alert-error">
                    <span class="material-symbols-outlined" style="font-size:1.1rem;">error</span>
                    {{ message }}
                </div>
            {% endfor %}

            {{ form_start(registrationForm, {'attr': {'class': 'modern-form', 'novalidate': 'novalidate', 'id': 'registrationForm'}}) }}

                <div class="gv-form-row">
                    <div class="gv-field">
                        <label class="gv-field-label">
                            <span class="material-symbols-outlined">person</span> Nom
                        </label>
                        {{ form_widget(registrationForm.nom, {'attr': {'class': 'gv-input', 'placeholder': 'Votre nom'}}) }}
                        <div class="text-danger">{{ form_errors(registrationForm.nom) }}</div>
                    </div>
                    <div class="gv-field">
                        <label class="gv-field-label">
                            <span class="material-symbols-outlined">person</span> Prénom
                        </label>
                        {{ form_widget(registrationForm.prenom, {'attr': {'class': 'gv-input', 'placeholder': 'Votre prénom'}}) }}
                        <div class="text-danger">{{ form_errors(registrationForm.prenom) }}</div>
                    </div>
                </div>

                <div class="gv-field">
                    <label class="gv-field-label">
                        <span class="material-symbols-outlined">mail</span> Adresse Email
                    </label>
                    {{ form_widget(registrationForm.email, {'attr': {'class': 'gv-input', 'placeholder': 'votre@email.com'}}) }}
                    <div class="text-danger">{{ form_errors(registrationForm.email) }}</div>
                </div>

                <div class="gv-field">
                    <label class="gv-field-label">
                        <span class="material-symbols-outlined">call</span> Numéro de téléphone
                    </label>
                    {{ form_widget(registrationForm.tel, {'attr': {'class': 'gv-input', 'placeholder': '+216 00 000 000'}}) }}
                    <div class="text-danger">{{ form_errors(registrationForm.tel) }}</div>
                </div>

                <div class="gv-field">
                    <label class="gv-field-label">
                        <span class="material-symbols-outlined">lock</span> Mot de passe
                    </label>
                    {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'gv-input', 'placeholder': '••••••••'}}) }}
                    <div class="text-danger">{{ form_errors(registrationForm.plainPassword) }}</div>
                </div>

                <!-- ═══ Face ID Enrollment Section ═══ -->
                <div class="face-enrollment-section" id="faceEnrollSection">
                    <div class="face-section-header">
                        <span class="material-symbols-outlined">face</span>
                        Configuration Face ID
                    </div>
                    <p class="face-section-desc">
                        Capturez votre visage pour activer la connexion biométrique Face ID.
                    </p>

                    <div class="face-webcam-register" id="faceWebcamRegister">
                        <video id="faceVideoRegister" autoplay playsinline muted></video>
                        <canvas id="faceCanvasRegister"></canvas>
                        <div class="face-reg-overlay">
                            <div class="face-reg-guide" id="faceGuideRegister"></div>
                        </div>
                        <div class="face-reg-status" id="faceStatusRegister">Positionnez votre visage</div>
                    </div>

                    <div id="faceCapturedBadge" style="display:none;">
                        <div class="face-captured-badge">
                            <span class="material-symbols-outlined">check_circle</span>
                            <span id="faceCapturedText">Face ID capturé avec succès !</span>
                        </div>
                    </div>

                    <div id="faceRegError" class="gv-alert gv-alert-error" style="display:none; margin-top:0.5rem; margin-bottom:0;">
                        <span class="material-symbols-outlined" style="font-size:1.1rem;">error</span>
                        <span id="faceRegErrorText"></span>
                    </div>

                    <div style="display:flex; gap:0.5rem; margin-top:0.75rem;" id="faceButtonsRow">
                        <button type="button" class="gv-btn-secondary" id="btnStartCamera" onclick="startRegisterWebcam()" style="flex:1;">
                            <span class="material-symbols-outlined" style="font-size:1rem;">videocam</span>
                            Ouvrir caméra
                        </button>
                        <button type="button" class="gv-btn-secondary" id="btnCaptureFace" onclick="captureRegisterFace()" style="flex:1; display:none;">
                            <span class="material-symbols-outlined" style="font-size:1rem;">photo_camera</span>
                            Capturer
                        </button>
                    </div>
                </div>

                <!-- Hidden field to store face encoding JSON -->
                <input type="hidden" name="face_encoding_data" id="faceEncodingData" value="">

                <div class="gv-check-row">
                    {{ form_widget(registrationForm.agreeTerms) }}
                    <label>J'accepte les conditions d'utilisation</label>
                </div>

                <button type="submit" class="gv-btn-primary" id="btnSubmitRegister">
                    Créer mon compte
                    <span class="material-symbols-outlined" style="font-size:1.2rem;">check_circle</span>
                </button>
            {{ form_end(registrationForm) }}

            <div class="gv-auth-footer">
                Déjà inscrit ?
                <a href="{{ path('app_login') }}">Connectez-vous</a>
            </div>
        </div>
    </div>
</main>

<div style="position:fixed;top:-10%;left:-10%;width:24rem;height:24rem;background:rgba(0,52,45,0.1);border-radius:50%;filter:blur(120px);pointer-events:none;z-index:0;"></div>
<div style="position:fixed;bottom:-10%;right:-10%;width:24rem;height:24rem;background:rgba(61,42,0,0.1);border-radius:50%;filter:blur(120px);pointer-events:none;z-index:0;"></div>

<script>
// ─── Registration Face Enrollment ───
let regStream = null;

async function startRegisterWebcam() {
    const webcamContainer = document.getElementById('faceWebcamRegister');
    const video = document.getElementById('faceVideoRegister');
    const status = document.getElementById('faceStatusRegister');
    const btnStart = document.getElementById('btnStartCamera');
    const btnCapture = document.getElementById('btnCaptureFace');

    try {
        regStream = await navigator.mediaDevices.getUserMedia({
            video: { width: 640, height: 480, facingMode: 'user' }
        });
        video.srcObject = regStream;
        webcamContainer.classList.add('active');
        btnStart.style.display = 'none';
        btnCapture.style.display = 'flex';
        status.textContent = 'Positionnez votre visage dans le cercle';
        status.className = 'face-reg-status';
    } catch (err) {
        console.error('Webcam error:', err);
        const errorDiv = document.getElementById('faceRegError');
        const errorText = document.getElementById('faceRegErrorText');
        errorDiv.style.display = 'flex';
        errorText.textContent = 'Impossible d\'accéder à la caméra. Vérifiez les permissions.';
    }
}

async function captureRegisterFace() {
    const video = document.getElementById('faceVideoRegister');
    const canvas = document.getElementById('faceCanvasRegister');
    const guide = document.getElementById('faceGuideRegister');
    const status = document.getElementById('faceStatusRegister');
    const btnCapture = document.getElementById('btnCaptureFace');
    const errorDiv = document.getElementById('faceRegError');
    const errorText = document.getElementById('faceRegErrorText');

    errorDiv.style.display = 'none';

    // Capture frame
    guide.className = 'face-reg-guide scanning';
    status.textContent = 'Analyse du visage...';
    btnCapture.disabled = true;
    btnCapture.innerHTML = '<span class="material-symbols-outlined" style="font-size:1rem;">hourglass_top</span> Encodage...';

    canvas.width = video.videoWidth;
    canvas.height = video.videoHeight;
    const ctx = canvas.getContext('2d');
    ctx.drawImage(video, 0, 0);
    const base64Image = canvas.toDataURL('image/jpeg', 0.9);

    try {
        const response = await fetch('{{ path("app_register_encode_face") }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ image: base64Image }),
        });

        const data = await response.json();

        if (data.success && data.encoding) {
            // Store encoding in hidden field
            document.getElementById('faceEncodingData').value = JSON.stringify(data.encoding);

            // Show success
            guide.className = 'face-reg-guide success';
            status.textContent = '✅ Visage encodé !';
            status.className = 'face-reg-status success';

            // Update UI
            const section = document.getElementById('faceEnrollSection');
            section.classList.add('captured');

            const badge = document.getElementById('faceCapturedBadge');
            badge.style.display = 'block';

            // Stop webcam after capture
            setTimeout(() => {
                if (regStream) {
                    regStream.getTracks().forEach(track => track.stop());
                    regStream = null;
                }
                document.getElementById('faceWebcamRegister').classList.remove('active');
                btnCapture.style.display = 'none';

                // Show recapture button
                const btnStart = document.getElementById('btnStartCamera');
                btnStart.style.display = 'flex';
                btnStart.innerHTML = '<span class="material-symbols-outlined" style="font-size:1rem;">refresh</span> Recapturer';
            }, 1500);

            return;
        }

        // Error
        guide.className = 'face-reg-guide error';
        status.textContent = data.message || 'Échec';
        status.className = 'face-reg-status error';
        errorDiv.style.display = 'flex';
        errorText.textContent = data.message || 'Impossible d\'encoder le visage.';

        setTimeout(() => {
            guide.className = 'face-reg-guide';
            status.textContent = 'Positionnez votre visage';
            status.className = 'face-reg-status';
        }, 3000);

    } catch (err) {
        console.error('Face encode error:', err);
        guide.className = 'face-reg-guide error';
        status.textContent = 'Erreur réseau';
        status.className = 'face-reg-status error';
        errorDiv.style.display = 'flex';
        errorText.textContent = 'Service Face ID indisponible. Vous pourrez configurer Face ID plus tard.';
    }

    btnCapture.disabled = false;
    btnCapture.innerHTML = '<span class="material-symbols-outlined" style="font-size:1rem;">photo_camera</span> Capturer';
}

// ─── Particle system ───
(function() {
    const canvas = document.getElementById('authParticles');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    let particles = [];
    const PARTICLE_COUNT = 50;
    function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
    resize(); window.addEventListener('resize', resize);
    class Particle {
        constructor() { this.reset(); }
        reset() {
            this.x = Math.random() * canvas.width; this.y = Math.random() * canvas.height;
            this.size = Math.random() * 2 + 0.5; this.speedX = (Math.random() - 0.5) * 0.4;
            this.speedY = (Math.random() - 0.5) * 0.4; this.opacity = Math.random() * 0.4 + 0.1;
        }
        update() {
            this.x += this.speedX; this.y += this.speedY;
            if (this.x < 0 || this.x > canvas.width) this.speedX *= -1;
            if (this.y < 0 || this.y > canvas.height) this.speedY *= -1;
        }
        draw() {
            ctx.beginPath(); ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(160, 242, 225, ${this.opacity})`; ctx.fill();
        }
    }
    for (let i = 0; i < PARTICLE_COUNT; i++) particles.push(new Particle());
    function animate() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        particles.forEach(p => { p.update(); p.draw(); });
        for (let i = 0; i < particles.length; i++) {
            for (let j = i + 1; j < particles.length; j++) {
                const dx = particles[i].x - particles[j].x, dy = particles[i].y - particles[j].y;
                const dist = Math.sqrt(dx * dx + dy * dy);
                if (dist < 120) {
                    ctx.beginPath(); ctx.moveTo(particles[i].x, particles[i].y);
                    ctx.lineTo(particles[j].x, particles[j].y);
                    ctx.strokeStyle = `rgba(160, 242, 225, ${0.06 * (1 - dist / 120)})`;
                    ctx.lineWidth = 0.5; ctx.stroke();
                }
            }
        }
        requestAnimationFrame(animate);
    }
    animate();
})();
</script>
{% endblock %}

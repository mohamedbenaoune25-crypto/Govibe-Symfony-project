{% extends is_granted('ROLE_ADMIN') ? 'admin/base_admin.html.twig' : 'base.html.twig' %}

{% block title %}Planning des Sessions — GoVibe{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Manrope:wght@200..800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
<style>
body { font-family: 'Manrope', sans-serif !important; background: #fcf9f8 !important; }
.material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24; }

.gv-sess-hero {
    position: relative; padding: 170px 0 110px;
    background: linear-gradient(160deg, #00342d 0%, #013220 40%, #001a12 100%);
    overflow: hidden; text-align: center; border-radius: 0 0 3rem 3rem;
    box-shadow: 0 20px 50px rgba(0,52,45,0.15);
}
.gv-sess-hero::before { content:''; position:absolute; inset:0; background: radial-gradient(ellipse at 30% 80%, rgba(16,185,129,0.15) 0%, transparent 60%), radial-gradient(ellipse at 80% 20%, rgba(233,193,118,0.08) 0%, transparent 50%); pointer-events:none; }
.gv-sess-hero::after { content:''; position:absolute; inset:0; background-image: radial-gradient(rgba(160,242,225,0.06) 1px, transparent 1px); background-size:24px 24px; pointer-events:none; }
.gv-hero-icon-bg { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); font-size:20rem; color:rgba(255,255,255,0.02); pointer-events:none; font-variation-settings:'FILL' 1; }

.gv-hero-title { font-family:'Noto Serif',serif; font-size:clamp(2.2rem,4.5vw,3.5rem); color:#fff; font-weight:700; margin-bottom:0.75rem; position:relative; z-index:2; animation:heroFadeIn 0.8s ease both; }
.gv-hero-title em { color:#a0f2e1; font-style:italic; font-weight:300; }
.gv-hero-sub { color:rgba(160,242,225,0.7); font-size:1.05rem; position:relative; z-index:2; animation:heroFadeIn 0.8s ease 0.2s both; max-width:600px; margin:0 auto 1.5rem; }
@keyframes heroFadeIn { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }

.gv-hero-actions { display:flex; justify-content:center; gap:1rem; flex-wrap:wrap; position:relative; z-index:2; animation:heroFadeIn 0.8s ease 0.4s both; }
.gv-btn-gold { padding:0.85rem 2rem; background:linear-gradient(135deg,#e9c176,#ca9028); color:#3d2a00; border:none; border-radius:0.75rem; font-weight:700; font-size:0.95rem; text-decoration:none; display:inline-flex; align-items:center; gap:0.5rem; transition:all 0.3s; box-shadow:0 10px 25px -5px rgba(233,193,118,0.4); font-family:'Manrope',sans-serif; }
.gv-btn-gold:hover { transform:translateY(-2px); box-shadow:0 15px 35px -5px rgba(233,193,118,0.5); color:#3d2a00; }
.gv-btn-ghost { padding:0.85rem 2rem; background:transparent; color:#a0f2e1; border:1.5px solid rgba(160,242,225,0.25); border-radius:0.75rem; font-weight:700; font-size:0.95rem; text-decoration:none; display:inline-flex; align-items:center; gap:0.5rem; transition:all 0.3s; font-family:'Manrope',sans-serif; }
.gv-btn-ghost:hover { background:rgba(255,255,255,0.08); color:#a0f2e1; }

.gv-sess-container { max-width:1200px; margin:-45px auto 80px; position:relative; z-index:10; padding:0 2rem; }

.gv-table-card {
    background:#fff; border-radius:1.5rem; box-shadow:0 20px 50px rgba(0,0,0,0.04);
    overflow:hidden; border:1px solid rgba(0,52,45,0.05);
}
.gv-table { width:100%; border-collapse:collapse; }
.gv-table th {
    background:#f8f7f5; color:#3c494f; font-weight:700; text-transform:uppercase;
    letter-spacing:0.1em; font-size:0.72rem; padding:1.25rem 1.5rem;
    border-bottom:2px solid rgba(0,52,45,0.04); text-align:left;
}
.gv-table td {
    padding:1.25rem 1.5rem; border-bottom:1px solid rgba(0,52,45,0.04);
    vertical-align:middle; transition:background 0.3s;
}
.gv-table tbody tr:hover td { background:rgba(160,242,225,0.04); }

.gv-act-name { font-family:'Noto Serif',serif; font-weight:700; color:#00342d; font-size:1rem; text-decoration:none; }
.gv-act-name:hover { color:#046b5e; }
.gv-act-loc { color:#707975; font-size:0.8rem; margin-top:0.2rem; }

.gv-badge-places {
    display:inline-flex; align-items:center; gap:0.3rem; padding:0.4rem 0.85rem;
    border-radius:2rem; font-size:0.75rem; font-weight:800;
}
.gv-badge-ok { background:rgba(16,185,129,0.1); color:#005046; border:1px solid rgba(160,242,225,0.5); }
.gv-badge-warn { background:rgba(233,193,118,0.15); color:#92400e; border:1px solid rgba(233,193,118,0.3); }

.gv-icon-btn {
    width:38px; height:38px; border-radius:50%; display:flex; align-items:center; justify-content:center;
    border:none; cursor:pointer; transition:all 0.25s; text-decoration:none;
}
.gv-icon-btn-edit { background:rgba(0,52,45,0.06); color:#00342d; }
.gv-icon-btn-edit:hover { background:#00342d; color:#fff; }

.gv-empty { text-align:center; padding:4rem 2rem; }
.gv-empty-icon { font-size:3.5rem; color:#cde1db; margin-bottom:1rem; font-variation-settings:'FILL' 1; }
.gv-empty h4 { font-family:'Noto Serif',serif; font-size:1.3rem; color:#00342d; font-weight:700; margin-bottom:0.5rem; }
.gv-empty p { color:#546067; }
</style>
{% endblock %}

{% block body %}
<div class="gv-sess-hero">
    <span class="material-symbols-outlined gv-hero-icon-bg">event</span>
    <div class="container">
        <h1 class="gv-hero-title">Planning des <em>Sessions</em></h1>
        <p class="gv-hero-sub">Gérez le calendrier et les disponibilités des activités GoVibe.</p>
        <div class="gv-hero-actions">
            <a href="{{ path('app_activite_session_new') }}" class="gv-btn-gold">
                <span class="material-symbols-outlined" style="font-size:1.1rem;">calendar_add_on</span>
                Programmer une Session
            </a>
            <a href="{{ path('app_activite_index') }}" class="gv-btn-ghost">
                <span class="material-symbols-outlined" style="font-size:1.1rem;">arrow_back</span>
                Liste des Activités
            </a>
        </div>
    </div>
</div>

<div class="gv-sess-container">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} rounded-4 border-0 shadow-sm mb-4" style="background:#eafaf1; color:#005046; border:1px solid #a0f2e1!important; font-weight:600;">
                <i class="bi bi-check-circle-fill me-2"></i> {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="gv-table-card">
        <div class="table-responsive">
            <table class="gv-table">
                <thead>
                    <tr>
                        <th>Activité</th>
                        <th>Date</th>
                        <th>Heure</th>
                        <th>Capacité</th>
                        <th>Restant</th>
                        <th style="text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for session in sessions %}
                    <tr>
                        <td>
                            <a href="{{ path('app_activite_session_show', {'idSession': session.idSession}) }}" class="gv-act-name">{{ session.activite.name }}</a>
                            <div class="gv-act-loc">
                                <span class="material-symbols-outlined" style="font-size:0.85rem; vertical-align:-2px; color:#10B981;">location_on</span>
                                {{ session.activite.localisation }}
                            </div>
                        </td>
                        <td style="font-weight:700; color:#00342d;">{{ session.date ? session.date|date('d/m/Y') : '' }}</td>
                        <td style="font-weight:600; color:#546067;">{{ session.heure ? session.heure|date('H:i') : '' }}</td>
                        <td style="font-weight:700; color:#00342d;">{{ session.capacite }}</td>
                        <td>
                            <span class="gv-badge-places {{ session.nbrPlacesRestant > 5 ? 'gv-badge-ok' : 'gv-badge-warn' }}">
                                {{ session.nbrPlacesRestant }} Places
                            </span>
                        </td>
                        <td style="text-align:right;">
                            <div class="d-flex gap-2 justify-content-end">
                                <a href="{{ path('app_activite_session_edit', {'idSession': session.idSession}) }}" class="gv-icon-btn gv-icon-btn-edit" title="Modifier">
                                    <span class="material-symbols-outlined" style="font-size:1.1rem;">edit</span>
                                </a>
                                {{ include('activite_session/_delete_form.html.twig', {'session': session}) }}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6">
                            <div class="gv-empty">
                                <span class="material-symbols-outlined gv-empty-icon">event_busy</span>
                                <h4>Aucune session programmée</h4>
                                <p>Créez votre première session pour commencer.</p>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}

{% extends is_granted('ROLE_ADMIN') ? 'admin/base_admin.html.twig' : 'base.html.twig' %}

{% block title %}Nouvelle Session — GoVibe{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Manrope:wght@200..800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
<style>
body { font-family: 'Manrope', sans-serif !important; background: #fcf9f8 !important; }
.material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24; }

.gv-form-hero {
    position: relative; padding: 160px 0 100px;
    background: linear-gradient(160deg, #00342d 0%, #013220 40%, #001a12 100%);
    overflow: hidden; text-align: center; border-radius: 0 0 3rem 3rem;
    box-shadow: 0 20px 50px rgba(0,52,45,0.15);
}
.gv-form-hero::before { content:''; position:absolute; inset:0; background: radial-gradient(ellipse at 30% 80%, rgba(16,185,129,0.15) 0%, transparent 60%), radial-gradient(ellipse at 80% 20%, rgba(233,193,118,0.08) 0%, transparent 50%); pointer-events:none; }
.gv-form-hero::after { content:''; position:absolute; inset:0; background-image: radial-gradient(rgba(160,242,225,0.06) 1px, transparent 1px); background-size:24px 24px; pointer-events:none; }
.gv-hero-icon-bg { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); font-size:20rem; color:rgba(255,255,255,0.02); pointer-events:none; font-variation-settings:'FILL' 1; }
.gv-form-hero h1 { font-family:'Noto Serif',serif; font-size:clamp(2rem,4vw,3rem); color:#fff; font-weight:700; margin-bottom:0.5rem; position:relative; z-index:2; }
.gv-form-hero h1 em { color:#a0f2e1; font-style:italic; font-weight:300; }
.gv-form-hero p { color:rgba(160,242,225,0.7); font-size:1.05rem; position:relative; z-index:2; }

.gv-form-container { max-width:700px; margin:-50px auto 80px; position:relative; z-index:10; padding:0 2rem; }
.gv-form-card {
    background:rgba(255,255,255,0.97); backdrop-filter:blur(20px) saturate(180%);
    border:1px solid rgba(0,52,45,0.06); border-radius:1.5rem; padding:3rem;
    box-shadow:0 20px 60px rgba(0,52,45,0.08);
}
.gv-form-card .form-label { font-weight:700; color:#00342d; font-size:0.85rem; text-transform:uppercase; letter-spacing:0.06em; }
.gv-form-card .form-control, .gv-form-card .form-select {
    border:1.5px solid rgba(0,52,45,0.08); border-radius:0.75rem; padding:0.85rem 1rem;
    font-family:'Manrope',sans-serif; font-weight:500; font-size:0.95rem; transition:all 0.25s;
}
.gv-form-card .form-control:focus, .gv-form-card .form-select:focus { border-color:#10B981; box-shadow:0 0 0 3px rgba(16,185,129,0.12); }
.gv-form-submit {
    padding:1rem 2.5rem; background:linear-gradient(135deg,#e9c176,#ca9028); color:#3d2a00;
    border:none; border-radius:0.75rem; font-weight:700; font-size:1.05rem; cursor:pointer;
    transition:all 0.3s; box-shadow:0 10px 25px -5px rgba(233,193,118,0.4);
    font-family:'Manrope',sans-serif; display:inline-flex; align-items:center; gap:0.5rem;
}
.gv-form-submit:hover { transform:translateY(-2px); box-shadow:0 15px 35px -5px rgba(233,193,118,0.5); }
.gv-back-link { display:inline-flex; align-items:center; gap:0.4rem; font-weight:700; font-size:0.9rem; color:#546067; text-decoration:none; padding:0.7rem 1.5rem; border-radius:0.75rem; border:1.5px solid rgba(0,52,45,0.08); transition:all 0.25s; }
.gv-back-link:hover { border-color:rgba(0,52,45,0.2); background:rgba(0,52,45,0.03); color:#00342d; }
</style>
{% endblock %}

{% block body %}
<div class="gv-form-hero">
    <span class="material-symbols-outlined gv-hero-icon-bg">calendar_add_on</span>
    <div class="container">
        <h1>Programmer une <em>Session</em></h1>
        <p>Définissez la date et l'heure pour une activité spécifique.</p>
    </div>
</div>

<div class="gv-form-container">
    <div class="gv-form-card">
        {{ form_start(form) }}
            {{ include('activite_session/_form.html.twig') }}
        {{ form_end(form) }}

        <div class="text-center mt-4">
            <a href="{{ path('app_activite_session_index') }}" class="gv-back-link">
                <span class="material-symbols-outlined" style="font-size:1rem;">arrow_back</span>
                Retour au planning
            </a>
        </div>
    </div>
</div>
{% endblock %}

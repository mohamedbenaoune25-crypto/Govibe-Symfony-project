{% extends 'base.html.twig' %}

{% block title %}Détails de la Session - GoVibe{% endblock %}

{% block body %}
<div class="container-fluid py-5 text-center mb-5 border-bottom rounded-bottom-5 px-lg-5 shadow-sm bg-white">
    <div class="d-flex align-items-center justify-content-center gap-3 mb-3">
        <span class="badge rounded-pill bg-light text-dark border px-3">Session programmée</span>
    </div>
    <h1 class="display-3 fw-bold text-dark mb-2">Détails de la <span style="color: #52BE80;">Session</span></h1>
    <p class="text-secondary fs-5">Activité : <strong>{{ session.activite.name }}</strong></p>
</div>

<div class="container mb-5 pb-5 px-lg-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-lg rounded-5 p-5 bg-white animate-fade-in-up">
                <div class="d-flex flex-column gap-4">
                    <div class="d-flex align-items-center gap-4 border-bottom pb-4">
                        <div class="p-3 bg-light rounded-circle text-success d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                            <i class="bi bi-calendar-check fs-2"></i>
                        </div>
                        <div>
                            <h5 class="text-secondary small text-uppercase mb-1">Date planifiée</h5>
                            <p class="h4 fw-bold mb-0">{{ session.date|date('d/m/Y') }}</p>
                        </div>
                    </div>

                    <div class="d-flex align-items-center gap-4 border-bottom pb-4">
                        <div class="p-3 bg-light rounded-circle text-primary d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                            <i class="bi bi-clock-history fs-2"></i>
                        </div>
                        <div>
                            <h5 class="text-secondary small text-uppercase mb-1">Heure de début</h5>
                            <p class="h4 fw-bold mb-0">{{ session.heure|date('H:i') }}</p>
                        </div>
                    </div>

                    <div class="row text-center g-3 mt-2">
                        <div class="col-6">
                            <div class="p-3 rounded-4 bg-light">
                                <h5 class="small text-uppercase text-secondary mb-1">Capacité</h5>
                                <p class="h4 fw-bold mb-0" style="color: #52BE80;">{{ session.capacite }}</p>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-3 rounded-4 bg-light">
                                <h5 class="small text-uppercase text-secondary mb-1">Libres</h5>
                                <p class="h4 fw-bold mb-0">{{ session.nbrPlacesRestant }}</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-center gap-3 mt-5 pt-4">
                    <a href="{{ path('app_activite_session_index') }}" class="btn btn-outline-secondary rounded-pill px-4 border-2 fw-bold">
                        Planning complet
                    </a>
                    <a href="{{ path('app_activite_session_edit', {'idSession': session.idSession}) }}" class="btn btn-success rounded-pill px-4 border-0 shadow fw-bold transition-all hover-lift-2" style="background-color: #52BE80;">
                        Modifier
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
<style>
    body { background-color: #F8F9F9 !important; }
    .rounded-bottom-5 { border-bottom-left-radius: 4rem !important; border-bottom-right-radius: 4rem !important; }
    .animate-fade-in-up { animation: fadeInUp 0.6s ease-out; }
    @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
</style>
{% endblock %}

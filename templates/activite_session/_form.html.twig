<div class="row g-4">
    <div class="col-12">
        {{ form_row(form.activite) }}
    </div>
    <div class="col-md-6">
        {{ form_row(form.date) }}
    </div>
    <div class="col-md-6">
        {{ form_row(form.heure) }}
    </div>
    <div class="col-md-6">
        {{ form_row(form.capacite) }}
    </div>
    <div class="col-md-6">
        {{ form_row(form.nbrPlacesRestant) }}
    </div>
    <div class="col-12 text-center mt-4">
        <button class="gv-form-submit">
            <span class="material-symbols-outlined" style="font-size:1.1rem;">check_circle</span>
            {{ button_label|default('Enregistrer la session') }}
        </button>
    </div>
</div>

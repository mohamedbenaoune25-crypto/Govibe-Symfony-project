{% extends 'base.html.twig' %}

{% block title %}Modifier Réservation — GoVibe{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Manrope:wght@200..800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
<style>
body { font-family:'Manrope',sans-serif !important; background:#fcf9f8 !important; }
.material-symbols-outlined { font-variation-settings:'FILL' 0,'wght' 300,'GRAD' 0,'opsz' 24; }
.gv-form-hero { position:relative; padding:160px 0 100px; background:linear-gradient(160deg,#00342d 0%,#013220 40%,#001a12 100%); overflow:hidden; text-align:center; border-radius:0 0 3rem 3rem; box-shadow:0 20px 50px rgba(0,52,45,0.15); }
.gv-form-hero::before { content:''; position:absolute; inset:0; background:radial-gradient(ellipse at 30% 80%,rgba(16,185,129,0.15) 0%,transparent 60%),radial-gradient(ellipse at 80% 20%,rgba(233,193,118,0.08) 0%,transparent 50%); pointer-events:none; }
.gv-form-hero::after { content:''; position:absolute; inset:0; background-image:radial-gradient(rgba(160,242,225,0.06) 1px,transparent 1px); background-size:24px 24px; pointer-events:none; }
.gv-hero-icon-bg { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); font-size:20rem; color:rgba(255,255,255,0.02); pointer-events:none; font-variation-settings:'FILL' 1; }
.gv-form-hero h1 { font-family:'Noto Serif',serif; font-size:clamp(2rem,4vw,3rem); color:#fff; font-weight:700; margin-bottom:0.5rem; position:relative; z-index:2; }
.gv-form-hero h1 em { color:#a0f2e1; font-style:italic; font-weight:300; }
.gv-form-hero p { color:rgba(160,242,225,0.7); font-size:1.05rem; position:relative; z-index:2; }
.gv-form-container { max-width:750px; margin:-50px auto 80px; position:relative; z-index:10; padding:0 2rem; }
.gv-form-card { background:rgba(255,255,255,0.97); backdrop-filter:blur(20px) saturate(180%); border:1px solid rgba(0,52,45,0.06); border-radius:1.5rem; padding:2.5rem; box-shadow:0 20px 60px rgba(0,52,45,0.08); }
.gv-form-card .form-label, .gv-form-card label { font-weight:700 !important; color:#00342d !important; font-size:0.85rem !important; text-transform:uppercase; letter-spacing:0.06em; }
.gv-form-card .form-control, .gv-form-card .form-select { border:1.5px solid rgba(0,52,45,0.08) !important; border-radius:0.75rem !important; padding:0.85rem 1rem !important; font-family:'Manrope',sans-serif !important; font-weight:500 !important; font-size:0.95rem !important; transition:all 0.25s !important; }
.gv-form-card .form-control:focus, .gv-form-card .form-select:focus { border-color:#10B981 !important; box-shadow:0 0 0 3px rgba(16,185,129,0.12) !important; }
.gv-form-footer { display:flex; justify-content:space-between; align-items:center; gap:1rem; flex-wrap:wrap; margin-top:1.5rem; padding-top:1.5rem; border-top:1px solid rgba(0,52,45,0.06); }
.gv-back-link { display:inline-flex; align-items:center; gap:0.4rem; font-weight:700; font-size:0.9rem; color:#546067; text-decoration:none; padding:0.7rem 1.5rem; border-radius:0.75rem; border:1.5px solid rgba(0,52,45,0.08); transition:all 0.25s; font-family:'Manrope',sans-serif; }
.gv-back-link:hover { border-color:rgba(0,52,45,0.2); background:rgba(0,52,45,0.03); color:#00342d; }
.gv-danger-section { margin-top:2rem; background:rgba(186,26,26,0.03); border:1.5px solid rgba(186,26,26,0.1); border-radius:1.25rem; padding:1.5rem; }
.gv-danger-title { font-weight:700; color:#93000a; font-size:0.9rem; display:flex; align-items:center; gap:0.4rem; margin-bottom:0.75rem; }
.gv-danger-section p { color:#707975; font-size:0.85rem; margin-bottom:0.75rem; }
.gv-danger-section .btn-danger { background:#ba1a1a; color:#fff; border:none; border-radius:0.6rem; padding:0.6rem 1.25rem; font-weight:700; font-size:0.85rem; cursor:pointer; transition:all 0.25s; font-family:'Manrope',sans-serif; display:inline-flex; align-items:center; gap:0.3rem; }
.gv-danger-section .btn-danger:hover { background:#93000a; }
</style>
{% endblock %}

{% block body %}
<div class="gv-form-hero">
    <span class="material-symbols-outlined gv-hero-icon-bg">edit</span>
    <div class="container">
        <h1>Modifier la <em>Réservation</em></h1>
        <p>#{{ reservation.id }} — {{ reservation.user.prenom }} {{ reservation.user.nom }}</p>
    </div>
</div>

<div class="gv-form-container">
    <div class="gv-form-card">
        {{ include('reservation/_form.html.twig') }}
        <div class="gv-form-footer">
            <a href="{{ path('app_reservation_index') }}" class="gv-back-link"><span class="material-symbols-outlined" style="font-size:1rem;">arrow_back</span> Retour</a>
            <a href="{{ path('app_reservation_show', {'id': reservation.id}) }}" class="gv-back-link"><span class="material-symbols-outlined" style="font-size:1rem;">visibility</span> Voir la réservation</a>
        </div>
    </div>
    <div class="gv-danger-section">
        <div class="gv-danger-title"><span class="material-symbols-outlined" style="font-size:1rem;">warning</span> Suppression</div>
        <p>La suppression de cette réservation est irréversible.</p>
        {{ include('reservation/_delete_form.html.twig') }}
    </div>
</div>
{% endblock %}
{% extends 'base.html.twig' %}

{% block title %}Modifier la Réservation - GoVibe{% endblock %}

{% block body %}
<div class="container-fluid py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card form-card shadow-lg border-0">
                    <div class="card-header bg-emerald text-white">
                        <h3 class="mb-0">
                            <i class="bi bi-pencil me-2"></i>Modifier la Réservation
                        </h3>
                        <p class="mb-0 mt-1 opacity-75">#{{ reservation.id }} - {{ reservation.user.prenom }} {{ reservation.user.nom }}</p>
                    </div>
                    <div class="card-body p-4">
                        {{ include('reservation/_form.html.twig') }}
                    </div>
                    <div class="card-footer bg-light">
                        <div class="d-flex justify-content-between">
                            <a href="{{ path('app_reservation_index') }}" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-2"></i>Retour à la liste
                            </a>
                            <a href="{{ path('app_reservation_show', {'id': reservation.id}) }}" class="btn btn-info">
                                <i class="bi bi-eye me-2"></i>Voir la réservation
                            </a>
                        </div>
                    </div>
                </div>

                <div class="card danger-card shadow-lg border-0 mt-4">
                    <div class="card-header bg-danger text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-exclamation-triangle me-2"></i>Suppression
                        </h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-3">
                            Attention : La suppression de cette réservation est irréversible.
                        </p>
                        {{ include('reservation/_delete_form.html.twig') }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.bg-emerald {
    background-color: var(--primary-emerald) !important;
}

.form-card, .danger-card {
    background: var(--glass-card);
    backdrop-filter: blur(10px);
    border-radius: 15px;
}

.form-control:focus {
    border-color: var(--primary-emerald);
    box-shadow: 0 0 0 0.2rem rgba(34, 197, 94, 0.25);
}

.btn-primary {
    background-color: var(--primary-emerald);
    border-color: var(--primary-emerald);
}

.btn-primary:hover {
    background-color: var(--accent-green);
    border-color: var(--accent-green);
}

.btn-info {
    background-color: #0dcaf0;
    border-color: #0dcaf0;
}

.btn-info:hover {
    background-color: #31d2f2;
    border-color: #31d2f2;
}
</style>
{% endblock %}
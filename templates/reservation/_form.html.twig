{{ form_start(form, {'attr': {'class': 'gv-reservation-form'}}) }}
    <div class="row g-4">
        <div class="col-md-6">
            {{ form_label(form.dateDebut, 'Date de début') }}
            {{ form_widget(form.dateDebut, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.dateDebut) }}
        </div>
        <div class="col-md-6">
            {{ form_label(form.dateFin, 'Date de fin') }}
            {{ form_widget(form.dateFin, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.dateFin) }}
        </div>
        <div class="col-md-6">
            {{ form_label(form.prixTotal, 'Prix total (€)') }}
            {{ form_widget(form.prixTotal, {'attr': {'class': 'form-control', 'placeholder': 'Prix total'}}) }}
            {{ form_errors(form.prixTotal) }}
        </div>
        {% if form.statut is defined %}
            <div class="col-md-6">
                {{ form_label(form.statut, 'Statut') }}
                {{ form_widget(form.statut, {'attr': {'class': 'form-select'}}) }}
                {{ form_errors(form.statut) }}
            </div>
        {% endif %}
        <div class="col-12">
            {{ form_label(form.chambre, 'Chambre') }}
            {{ form_widget(form.chambre, {'attr': {'class': 'form-select'}}) }}
            {{ form_errors(form.chambre) }}
        </div>
        {% if form.hotel is defined %}
            <div class="col-12">
                {{ form_label(form.hotel, 'Hôtel') }}
                {{ form_widget(form.hotel, {'attr': {'class': 'form-select'}}) }}
                {{ form_errors(form.hotel) }}
            </div>
        {% endif %}
    </div>
    <div class="text-center mt-4">
        <button class="gv-form-submit">
            <span class="material-symbols-outlined" style="font-size:1.1rem;">check_circle</span>
            {{ button_label|default('Sauvegarder la réservation') }}
        </button>
    </div>
{{ form_end(form) }}

<style>
.gv-form-submit {
    padding: 1rem 2.5rem; background: linear-gradient(135deg, #e9c176, #ca9028); color: #3d2a00;
    border: none; border-radius: 0.75rem; font-weight: 700; font-size: 1.05rem; cursor: pointer;
    transition: all 0.3s; box-shadow: 0 10px 25px -5px rgba(233,193,118,0.4);
    font-family: 'Manrope', sans-serif; display: inline-flex; align-items: center; gap: 0.5rem;
}
.gv-form-submit:hover { transform: translateY(-2px); box-shadow: 0 15px 35px -5px rgba(233,193,118,0.5); }

.gv-reservation-form .invalid-feedback { display:block; color:#93000a; font-size:0.85rem; margin-top:0.3rem; }
</style>
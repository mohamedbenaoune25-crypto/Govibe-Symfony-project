{{ form_start(form, {'attr': {'class': 'gv-reservation-form', 'novalidate': 'novalidate'}}) }}
    {% if form.vars.submitted and not form.vars.valid %}
        <div class="alert alert-danger" role="alert">
            <strong>{{ 'common.error'|trans }} :</strong> {{ form_errors(form) }}
        </div>
    {% endif %}
    <div class="row g-4">
        {% if form.typeChambre is defined %}
            <div class="col-md-6">
                {{ form_label(form.typeChambre, 'reservation.form.room_type'|trans, {'label_attr': {'class': 'gv-form-label'}}) }}
                {{ form_widget(form.typeChambre, {'attr': {'class': 'form-select' ~ (form.typeChambre.vars.errors|length ? ' is-invalid' : '')}}) }}
                {% if form.typeChambre.vars.errors|length %}<div class="invalid-feedback d-block">{{ form_errors(form.typeChambre) }}</div>{% endif %}
            </div>
        {% endif %}
        <div class="col-md-6">
            {{ form_label(form.dateDebut, 'reservation.form.date_start'|trans, {'label_attr': {'class': 'gv-form-label'}}) }}
            {{ form_widget(form.dateDebut, {'attr': {'class': 'form-control' ~ (form.dateDebut.vars.errors|length ? ' is-invalid' : '')}}) }}
            {% if form.dateDebut.vars.errors|length %}<div class="invalid-feedback d-block">{{ form_errors(form.dateDebut) }}</div>{% endif %}
        </div>
        <div class="col-md-6">
            {{ form_label(form.dateFin, 'reservation.form.date_end'|trans, {'label_attr': {'class': 'gv-form-label'}}) }}
            {{ form_widget(form.dateFin, {'attr': {'class': 'form-control' ~ (form.dateFin.vars.errors|length ? ' is-invalid' : '')}}) }}
            {% if form.dateFin.vars.errors|length %}<div class="invalid-feedback d-block">{{ form_errors(form.dateFin) }}</div>{% endif %}
        </div>
        <div class="col-md-6">
            <label class="gv-form-label">{{ 'reservation.form.total_price'|trans }}</label>
            <div id="reservation-price-breakdown" class="card border-info" style="display:none;">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Prix de base:</span>
                        <span id="reservation-base-price">-</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2" id="reservation-holiday-info" style="display:none;">
                        <span><small class="text-muted">Nuits en jours feriés:</small></span>
                        <span><small class="text-muted" id="reservation-holiday-nights">-</small></span>
                    </div>
                    <div class="d-flex justify-content-between mb-2" id="reservation-supplement-info" style="display:none;">
                        <span><small class="text-success">+ Supplement:</small></span>
                        <span><small class="text-success" id="reservation-supplement">-</small></span>
                    </div>
                    <hr style="margin: 0.5rem 0;" />
                    <div class="d-flex justify-content-between fw-bold">
                        <span>Total:</span>
                        <span id="reservation-estimated-total">-</span>
                    </div>
                </div>
            </div>
            <small class="text-muted">Calcul automatique selon la chambre et les dates.</small>
        </div>
        {% if form.statut is defined %}
            <div class="col-md-6">
                {{ form_label(form.statut, 'reservation.form.status'|trans, {'label_attr': {'class': 'gv-form-label'}}) }}
                {{ form_widget(form.statut, {'attr': {'class': 'form-select' ~ (form.statut.vars.errors|length ? ' is-invalid' : '')}}) }}
                {% if form.statut.vars.errors|length %}<div class="invalid-feedback d-block">{{ form_errors(form.statut) }}</div>{% endif %}
            </div>
        {% endif %}
        <div class="col-12">
            {{ form_label(form.chambre, 'reservation.form.room'|trans, {'label_attr': {'class': 'gv-form-label'}}) }}
            {{ form_widget(form.chambre, {'attr': {'class': 'form-select' ~ (form.chambre.vars.errors|length ? ' is-invalid' : '')}}) }}
            {% if form.chambre.vars.errors|length %}<div class="invalid-feedback d-block">{{ form_errors(form.chambre) }}</div>{% endif %}
        </div>
        <div class="col-12">
            <div id="reservation-disponibilite" class="gv-availability-note" aria-live="polite">{{ 'reservation.form.available_rooms'|trans }} : -</div>
        </div>
        {% if form.hotel is defined %}
            <div class="col-12 d-none">
                {{ form_label(form.hotel, 'common.hotel'|trans, {'label_attr': {'class': 'gv-form-label'}}) }}
                {{ form_widget(form.hotel, {'attr': {'class': 'form-select' ~ (form.hotel.vars.errors|length ? ' is-invalid' : '')}}) }}
                {% if form.hotel.vars.errors|length %}<div class="invalid-feedback d-block">{{ form_errors(form.hotel) }}</div>{% endif %}
            </div>
        {% endif %}
    </div>
    <div class="text-center mt-4">
        <button class="gv-form-submit">
            <span class="material-symbols-outlined" style="font-size:1.1rem;">check_circle</span>
            {{ button_label|default('reservation.form.save_default'|trans) }}
        </button>
    </div>
{{ form_end(form) }}

<style>
.gv-form-submit {
    padding: 1rem 2.5rem; background: linear-gradient(135deg, #e9c176, #ca9028); color: #3d2a00;
    border: none; border-radius: 0.75rem; font-weight: 700; font-size: 1.05rem; cursor: pointer;
    transition: all 0.3s; box-shadow: 0 10px 25px -5px rgba(233,193,118,0.4);
    font-family: 'Manrope', sans-serif; display: inline-flex; align-items: center; gap: 0.5rem;
}
.gv-form-submit:hover { transform: translateY(-2px); box-shadow: 0 15px 35px -5px rgba(233,193,118,0.5); }

.gv-form-label {
    display: block;
    margin-bottom: 0.45rem;
    font-weight: 700;
    color: #1f2937;
    font-size: 0.92rem;
}

.gv-reservation-form .form-control,
.gv-reservation-form .form-select {
    min-height: 48px;
    border-radius: 0.65rem;
    border: 1px solid #cfd8e3;
    padding: 0.62rem 0.78rem;
}

.gv-reservation-form .form-control:focus,
.gv-reservation-form .form-select:focus {
    border-color: #1f8d78;
    box-shadow: 0 0 0 0.2rem rgba(31, 141, 120, 0.18);
}

.gv-reservation-form .form-control.is-invalid,
.gv-reservation-form .form-select.is-invalid,
.gv-reservation-form .form-control.is-invalid:focus,
.gv-reservation-form .form-select.is-invalid:focus {
    border-color: #dc3545 !important;
    box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.2) !important;
}

.gv-reservation-form .invalid-feedback { display:block; color:#93000a; font-size:0.85rem; margin-top:0.3rem; }

.gv-availability-note {
    border: 1px solid rgba(0, 52, 45, 0.12);
    border-radius: 0.7rem;
    padding: 0.65rem 0.9rem;
    font-size: 0.9rem;
    font-weight: 700;
    color: #00342d;
    background: rgba(160, 242, 225, 0.18);
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
    var hotelSelect = document.getElementById('{{ form.hotel is defined ? form.hotel.vars.id : '' }}');
    var typeSelect = document.getElementById('{{ form.typeChambre is defined ? form.typeChambre.vars.id : '' }}');
    var chambreSelect = document.getElementById('{{ form.chambre.vars.id }}');
    var dispoEl = document.getElementById('reservation-disponibilite');
    var dateDebutInput = document.getElementById('{{ form.dateDebut.vars.id }}');
    var dateFinInput = document.getElementById('{{ form.dateFin.vars.id }}');
    var estimatedTotalLabel = document.getElementById('reservation-estimated-total');
    var priceBreakdown = document.getElementById('reservation-price-breakdown');
    var basePriceLabel = document.getElementById('reservation-base-price');
    var holidayInfo = document.getElementById('reservation-holiday-info');
    var holidayNightsLabel = document.getElementById('reservation-holiday-nights');
    var supplementInfo = document.getElementById('reservation-supplement-info');
    var supplementLabel = document.getElementById('reservation-supplement');

    var holidays = [];
    var supplementPercentage = 0;

    if (!chambreSelect || !dispoEl) {
        return;
    }

    var chambreOptions = Array.prototype.slice.call(chambreSelect.options).filter(function (opt) {
        return opt.value !== '';
    });

    function normalize(value) {
        return (value || '').toString().trim().toLowerCase();
    }

    function parseDate(value) {
        if (!value) {
            return null;
        }

        var date = new Date(value + 'T00:00:00');
        return Number.isNaN(date.getTime()) ? null : date;
    }

    function diffDays(start, end) {
        var msPerDay = 24 * 60 * 60 * 1000;
        return Math.round((end.getTime() - start.getTime()) / msPerDay);
    }

    function formatIsoDate(date) {
        var y = date.getFullYear();
        var m = String(date.getMonth() + 1).padStart(2, '0');
        var d = String(date.getDate()).padStart(2, '0');
        return y + '-' + m + '-' + d;
    }

    function countHolidayNights(start, end) {
        var count = 0;
        var current = new Date(start.getTime());

        while (current < end) {
            if (holidays.indexOf(formatIsoDate(current)) !== -1) {
                count += 1;
            }
            current.setDate(current.getDate() + 1);
        }

        return count;
    }

    function getUnitPrice(option) {
        var standard = parseFloat(option.getAttribute('data-prix-standard') || '0');
        var high = parseFloat(option.getAttribute('data-prix-haute') || '0');
        var low = parseFloat(option.getAttribute('data-prix-basse') || '0');

        if (standard > 0) {
            return standard;
        }

        if (high > 0) {
            return high;
        }

        return low > 0 ? low : 0;
    }

    function updateEstimatedTotal() {
        if (!estimatedTotalLabel || !chambreSelect || !priceBreakdown) {
            return;
        }

        var option = chambreSelect.selectedOptions.length ? chambreSelect.selectedOptions[0] : null;
        if (!option || option.value === '') {
            estimatedTotalLabel.textContent = '-';
            priceBreakdown.style.display = 'none';
            return;
        }

        var start = parseDate(dateDebutInput ? dateDebutInput.value : '');
        var end = parseDate(dateFinInput ? dateFinInput.value : '');
        var unit = getUnitPrice(option);

        if (!start || !end || end <= start || unit <= 0) {
            estimatedTotalLabel.textContent = '-';
            priceBreakdown.style.display = 'none';
            return;
        }

        var nights = diffDays(start, end);
        if (nights <= 0) {
            estimatedTotalLabel.textContent = '-';
            priceBreakdown.style.display = 'none';
            return;
        }

        var baseTotal = unit * nights;
        var holidayNights = countHolidayNights(start, end);
        var holidaySupplement = holidayNights > 0
            ? (unit * (supplementPercentage / 100) * holidayNights)
            : 0;
        var total = baseTotal + holidaySupplement;

        basePriceLabel.textContent = baseTotal.toFixed(2) + ' €';
        estimatedTotalLabel.textContent = total.toFixed(2) + ' €';

        if (holidayNights > 0) {
            holidayNightsLabel.textContent = holidayNights + ' nuit' + (holidayNights > 1 ? 's' : '');
            supplementLabel.textContent = '+ ' + holidaySupplement.toFixed(2) + ' € (' + supplementPercentage + '%)';
            holidayInfo.style.display = 'flex';
            supplementInfo.style.display = 'flex';
        } else {
            holidayInfo.style.display = 'none';
            supplementInfo.style.display = 'none';
        }

        priceBreakdown.style.display = 'block';
    }

    function syncHotelFromChambre() {
        if (!hotelSelect || !chambreSelect || !chambreSelect.selectedOptions.length) {
            return;
        }

        var option = chambreSelect.selectedOptions[0];
        var hotelId = option.getAttribute('data-hotel-id') || '';
        if (hotelId !== '') {
            hotelSelect.value = hotelId;
        }
    }

    function applyFilters() {
        var selectedHotel = hotelSelect ? hotelSelect.value : '';
        var selectedType = typeSelect ? normalize(typeSelect.value) : '';
        var totalDisponibles = 0;

        chambreOptions.forEach(function (option) {
            var optionHotel = option.getAttribute('data-hotel-id') || '';
            var optionType = normalize(option.getAttribute('data-type'));
            var optionDisponibles = parseInt(option.getAttribute('data-disponibles') || '0', 10);

            var hotelMatch = !selectedHotel || optionHotel === selectedHotel;
            var typeMatch = !selectedType || optionType === selectedType;
            var visible = hotelMatch && typeMatch;

            option.hidden = !visible;
            option.disabled = !visible;

            if (visible && !isNaN(optionDisponibles)) {
                totalDisponibles += optionDisponibles;
            }
        });

        if (chambreSelect.selectedOptions.length && chambreSelect.selectedOptions[0].disabled) {
            chambreSelect.value = '';
        }

        if (selectedType) {
            dispoEl.textContent = '{{ 'reservation.form.available_rooms_for_type'|trans }} : ' + totalDisponibles;
        } else {
            dispoEl.textContent = '{{ 'reservation.form.available_rooms'|trans }} : ' + totalDisponibles;
        }
    }

    if (hotelSelect) {
        hotelSelect.addEventListener('change', applyFilters);
    }

    if (typeSelect) {
        typeSelect.addEventListener('change', applyFilters);
    }

    chambreSelect.addEventListener('change', updateEstimatedTotal);
    chambreSelect.addEventListener('change', syncHotelFromChambre);

    if (dateDebutInput) {
        dateDebutInput.addEventListener('change', updateEstimatedTotal);
    }

    if (dateFinInput) {
        dateFinInput.addEventListener('change', updateEstimatedTotal);
    }

    fetch('{{ path('app_reservation_holidays_api') }}')
        .then(function (response) {
            if (!response.ok) {
                throw new Error('API holidays unavailable');
            }
            return response.json();
        })
        .then(function (data) {
            holidays = Array.isArray(data.holidays) ? data.holidays : [];
            supplementPercentage = Number(data.supplementPercentage || 0);
            updateEstimatedTotal();
        })
        .catch(function () {
            holidays = [];
            supplementPercentage = 0;
            updateEstimatedTotal();
        });

    applyFilters();
    syncHotelFromChambre();
    updateEstimatedTotal();
});
</script>
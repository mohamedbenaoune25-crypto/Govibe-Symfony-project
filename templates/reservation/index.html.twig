{% extends 'base.html.twig' %}

{% block title %}{{ 'reservation.index.meta_title'|trans }}{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Manrope:wght@200..800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
<style>
body { font-family: 'Manrope', sans-serif !important; background: #fcf9f8 !important; }
.material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24; }

/* ─── Hero ─── */
.gv-res-hero {
    position: relative; padding: 170px 0 110px;
    background: linear-gradient(160deg, #00342d 0%, #013220 40%, #001a12 100%);
    overflow: hidden; text-align: center; border-radius: 0 0 3rem 3rem;
    box-shadow: 0 20px 50px rgba(0,52,45,0.15);
}
.gv-res-hero::before { content:''; position:absolute; inset:0; background: radial-gradient(ellipse at 30% 80%, rgba(16,185,129,0.15) 0%, transparent 60%), radial-gradient(ellipse at 80% 20%, rgba(233,193,118,0.08) 0%, transparent 50%); pointer-events:none; }
.gv-res-hero::after { content:''; position:absolute; inset:0; background-image: radial-gradient(rgba(160,242,225,0.06) 1px, transparent 1px); background-size:24px 24px; pointer-events:none; }
.gv-hero-icon-bg { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); font-size:20rem; color:rgba(255,255,255,0.02); pointer-events:none; font-variation-settings:'FILL' 1; }

.gv-hero-title { font-family:'Noto Serif',serif; font-size:clamp(2.2rem,4.5vw,3.5rem); color:#fff; font-weight:700; margin-bottom:0.75rem; position:relative; z-index:2; animation:heroFadeIn 0.8s ease both; }
.gv-hero-title em { color:#a0f2e1; font-style:italic; font-weight:300; }
.gv-hero-sub { color:rgba(160,242,225,0.7); font-size:1.05rem; position:relative; z-index:2; animation:heroFadeIn 0.8s ease 0.2s both; max-width:550px; margin:0 auto 1.5rem; }
@keyframes heroFadeIn { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }

.gv-hero-cta {
    display:inline-flex; align-items:center; gap:0.5rem; padding:0.85rem 2rem;
    background:linear-gradient(135deg,#e9c176,#ca9028); color:#3d2a00; border:none;
    border-radius:0.75rem; font-weight:700; font-size:0.95rem; text-decoration:none;
    transition:all 0.3s; box-shadow:0 10px 25px -5px rgba(233,193,118,0.4);
    font-family:'Manrope',sans-serif; position:relative; z-index:2;
}
.gv-hero-cta:hover { transform:translateY(-2px); box-shadow:0 15px 35px -5px rgba(233,193,118,0.5); color:#3d2a00; }

/* ─── Container ─── */
.gv-container { max-width:1200px; margin:-45px auto 80px; position:relative; z-index:10; padding:0 2rem; }

/* ─── Search Bar ─── */
.gv-search-card {
    background:rgba(255,255,255,0.97); backdrop-filter:blur(20px) saturate(180%);
    border:1px solid rgba(0,52,45,0.06); border-radius:1.25rem; padding:1.5rem 2rem;
    box-shadow:0 15px 40px rgba(0,52,45,0.06); margin-bottom:2rem;
}
.gv-search-card .form-label { font-weight:700; color:#00342d; font-size:0.78rem; text-transform:uppercase; letter-spacing:0.06em; }
.gv-search-card .form-control, .gv-search-card .form-select {
    border:1.5px solid rgba(0,52,45,0.08); border-radius:0.7rem; padding:0.7rem 1rem;
    font-family:'Manrope',sans-serif; font-weight:500; font-size:0.9rem; transition:all 0.25s;
}
.gv-search-card .form-control:focus, .gv-search-card .form-select:focus { border-color:#10B981; box-shadow:0 0 0 3px rgba(16,185,129,0.12); }
.gv-search-btn {
    padding:0.7rem 1.25rem; background:linear-gradient(135deg,#00342d,#046b5e); color:#fff;
    border:none; border-radius:0.7rem; cursor:pointer; transition:all 0.3s;
    box-shadow:0 4px 12px rgba(0,52,45,0.2);
}
.gv-search-btn:hover { transform:translateY(-2px); box-shadow:0 8px 20px rgba(0,52,45,0.3); }
.gv-reset-link { padding:0.7rem 1.25rem; border-radius:0.7rem; border:1.5px solid rgba(0,52,45,0.08); color:#546067; text-decoration:none; font-weight:700; font-size:0.85rem; display:inline-flex; align-items:center; gap:0.3rem; transition:all 0.25s; }
.gv-reset-link:hover { border-color:rgba(0,52,45,0.2); background:rgba(0,52,45,0.03); color:#00342d; }

/* ─── Cards Grid ─── */
.gv-card-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(380px,1fr)); gap:2rem; }
@media (max-width:768px) { .gv-card-grid { grid-template-columns:1fr; } }

.gv-res-card {
    background:rgba(255,255,255,0.97); backdrop-filter:blur(20px) saturate(180%);
    border:1px solid rgba(0,52,45,0.06); border-radius:1.25rem; overflow:hidden;
    box-shadow:0 12px 35px rgba(0,52,45,0.06); transition:all 0.35s;
}
.gv-res-card:hover { transform:translateY(-6px); box-shadow:0 24px 50px rgba(0,52,45,0.12); }

.gv-res-card-header {
    background:linear-gradient(135deg,#00342d,#046b5e); color:#fff; padding:1.25rem 1.5rem;
    display:flex; justify-content:space-between; align-items:center;
}
.gv-res-card-header h6 { font-family:'Noto Serif',serif; font-weight:700; margin:0; font-size:1rem; }

.gv-status-badge { padding:0.4rem 1rem; border-radius:2rem; font-size:0.7rem; font-weight:800; text-transform:uppercase; letter-spacing:0.05em; }
.gv-status-confirmed { background:rgba(160,242,225,0.2); color:#a0f2e1; border:1px solid rgba(160,242,225,0.3); }
.gv-status-pending { background:rgba(233,193,118,0.2); color:#fde68a; border:1px solid rgba(233,193,118,0.3); }
.gv-status-cancelled { background:rgba(239,68,68,0.2); color:#fca5a5; border:1px solid rgba(239,68,68,0.3); }

.gv-res-card-body { padding:1.5rem; }
.gv-info-item { display:flex; align-items:center; gap:0.6rem; margin-bottom:0.6rem; font-size:0.9rem; color:#3c494f; }
.gv-info-item .material-symbols-outlined { font-size:1.1rem; color:#10B981; }
.gv-info-item strong { color:#00342d; }

.gv-date-grid { display:grid; grid-template-columns:1fr 1fr; gap:0.75rem; margin:1rem 0; }
.gv-date-box { background:rgba(0,52,45,0.03); border:1px solid rgba(0,52,45,0.05); padding:0.75rem; border-radius:0.75rem; text-align:center; }
.gv-date-label { font-size:0.7rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#546067; margin-bottom:0.2rem; }
.gv-date-value { font-weight:700; color:#00342d; font-size:0.95rem; }

.gv-price-box { background:rgba(16,185,129,0.06); border:1px solid rgba(16,185,129,0.12); padding:0.85rem; border-radius:0.75rem; text-align:center; }
.gv-price-label { font-size:0.7rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#546067; margin-bottom:0.2rem; }
.gv-price-value { font-family:'Noto Serif',serif; font-size:1.25rem; font-weight:700; color:#10B981; }

.gv-res-card-footer { padding:0 1.5rem 1.5rem; display:flex; justify-content:space-between; align-items:center; gap:0.5rem; flex-wrap:wrap; }
.gv-action-sm {
    padding:0.45rem 0.85rem; border-radius:0.6rem; font-weight:700; font-size:0.78rem;
    text-decoration:none; display:inline-flex; align-items:center; gap:0.25rem;
    transition:all 0.25s; font-family:'Manrope',sans-serif; border:none; cursor:pointer;
}
.gv-action-view { background:rgba(0,52,45,0.06); color:#00342d; }
.gv-action-view:hover { background:#00342d; color:#fff; }
.gv-action-hotel { background:rgba(16,185,129,0.08); color:#005046; }
.gv-action-hotel:hover { background:#10B981; color:#fff; }
.gv-action-edit { background:linear-gradient(135deg,#00342d,#046b5e); color:#fff; box-shadow:0 4px 10px rgba(0,52,45,0.15); }
.gv-action-edit:hover { transform:translateY(-2px); box-shadow:0 8px 18px rgba(0,52,45,0.25); color:#fff; }
.gv-action-pay { background:linear-gradient(135deg,#e9c176,#ca9028); color:#3d2a00; box-shadow:0 4px 10px rgba(233,193,118,0.25); }
.gv-action-pay:hover { transform:translateY(-2px); box-shadow:0 8px 18px rgba(233,193,118,0.35); color:#3d2a00; }
.gv-action-delete { background:rgba(186,26,26,0.06); color:#93000a; border:1px solid rgba(186,26,26,0.1); }
.gv-action-delete:hover { background:#ba1a1a; color:#fff; border-color:transparent; }

/* ─── Empty ─── */
.gv-empty { text-align:center; padding:5rem 2rem; background:#fff; border-radius:1.5rem; box-shadow:0 20px 50px rgba(0,0,0,0.04); grid-column:1/-1; }
.gv-empty-icon { font-size:4rem; color:#cde1db; margin-bottom:1rem; font-variation-settings:'FILL' 1; }
.gv-empty h4 { font-family:'Noto Serif',serif; font-size:1.4rem; color:#00342d; font-weight:700; margin-bottom:0.5rem; }
.gv-empty p { color:#546067; margin-bottom:2rem; }

/* ─── Reveal ─── */
.gv-reveal { opacity:0; transform:translateY(25px); transition:opacity 0.6s ease, transform 0.6s ease; }
.gv-reveal.is-visible { opacity:1; transform:translateY(0); }
</style>
{% endblock %}

{% block body %}
<div class="gv-res-hero">
    <span class="material-symbols-outlined gv-hero-icon-bg">calendar_month</span>
    <div class="container">
        <h1 class="gv-hero-title">{{ 'reservation.index.hero_title_prefix'|trans }} <em>{{ 'reservation.index.hero_title_emphasis'|trans }}</em></h1>
        <p class="gv-hero-sub">{{ 'reservation.index.hero_subtitle'|trans }}</p>
        {% if not is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_reservation_new') }}" class="gv-hero-cta">
            <span class="material-symbols-outlined" style="font-size:1.1rem;">add_circle</span>
            {{ 'reservation.index.create'|trans }}
        </a>
        {% endif %}
    </div>
</div>

<div class="gv-container">
    <!-- Search -->
    <div class="gv-search-card">
        <form method="GET" action="{{ path('app_reservation_index') }}" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label for="search" class="form-label">
                    <span class="material-symbols-outlined" style="font-size:0.95rem; vertical-align:-2px; color:#10B981;">search</span> {{ 'common.search'|trans }}
                </label>
                <input type="text" class="form-control" id="search" name="search" placeholder="{{ 'reservation.index.search_placeholder'|trans }}" value="{{ search }}">
            </div>
            <div class="col-md-3">
                <label for="sortBy" class="form-label">
                    <span class="material-symbols-outlined" style="font-size:0.95rem; vertical-align:-2px; color:#10B981;">sort</span> {{ 'common.sort_by'|trans }}
                </label>
                <select class="form-select" id="sortBy" name="sortBy">
                    <option value="dateDebut" {% if sortBy == 'dateDebut' %}selected{% endif %}>{{ 'reservation.index.sort_arrival'|trans }}</option>
                    <option value="dateFin" {% if sortBy == 'dateFin' %}selected{% endif %}>{{ 'reservation.index.sort_departure'|trans }}</option>
                    <option value="prixTotal" {% if sortBy == 'prixTotal' %}selected{% endif %}>{{ 'reservation.index.sort_total'|trans }}</option>
                    <option value="statut" {% if sortBy == 'statut' %}selected{% endif %}>{{ 'reservation.index.sort_status'|trans }}</option>
                    <option value="createdAt" {% if sortBy == 'createdAt' %}selected{% endif %}>{{ 'reservation.index.sort_created'|trans }}</option>
                </select>
            </div>
            <div class="col-md-2">
                <label for="sortDir" class="form-label">
                    <span class="material-symbols-outlined" style="font-size:0.95rem; vertical-align:-2px; color:#10B981;">swap_vert</span> {{ 'common.order'|trans }}
                </label>
                <select class="form-select" id="sortDir" name="sortDir">
                    <option value="ASC" {% if sortDir == 'ASC' %}selected{% endif %}>{{ 'common.ascending'|trans }} ↑</option>
                    <option value="DESC" {% if sortDir == 'DESC' %}selected{% endif %}>{{ 'common.descending'|trans }} ↓</option>
                </select>
            </div>
            <div class="col-md-1">
                <button type="submit" class="gv-search-btn w-100">
                    <span class="material-symbols-outlined" style="font-size:1.2rem;">search</span>
                </button>
            </div>
            {% if search or sortBy != 'dateDebut' or sortDir != 'DESC' %}
            <div class="col-md-1">
                <a href="{{ path('app_reservation_index') }}" class="gv-reset-link w-100 text-center">
                    <span class="material-symbols-outlined" style="font-size:1rem;">refresh</span>
                </a>
            </div>
            {% endif %}
        </form>
    </div>

    <!-- Cards -->
    <div class="gv-card-grid">
        {% for reservation in reservations %}
        <div class="gv-res-card gv-reveal">
            <div class="gv-res-card-header">
                <h6>{{ 'reservation.index.card_title'|trans({'%id%': reservation.id}) }}</h6>
                {% if reservation.statut == 'ACCEPTEE' or reservation.statut == 'CONFIRMEE' %}
                    <span class="gv-status-badge gv-status-confirmed">{{ 'reservation.status.accepted'|trans }}</span>
                {% elseif reservation.statut == 'REFUSEE' or reservation.statut == 'ANNULEE' %}
                    <span class="gv-status-badge gv-status-cancelled">{{ 'reservation.status.refused'|trans }}</span>
                {% else %}
                    <span class="gv-status-badge gv-status-pending">{{ 'reservation.status.pending'|trans }}</span>
                {% endif %}
            </div>
            <div class="gv-res-card-body">
                <div class="gv-info-item">
                    <span class="material-symbols-outlined">person</span>
                    <strong>{{ reservation.user.prenom }} {{ reservation.user.nom }}</strong>
                    <small style="color:#707975;">({{ reservation.user.email }})</small>
                </div>
                <div class="gv-info-item">
                    <span class="material-symbols-outlined">apartment</span>
                    <strong>{{ reservation.hotel ? translated_hotel_value(reservation.hotel, 'nom') : '-' }}</strong>
                </div>
                <div class="gv-info-item">
                    <span class="material-symbols-outlined">door_open</span>
                    {{ reservation.chambre.type }}
                </div>

                <div class="gv-date-grid">
                    <div class="gv-date-box">
                        <div class="gv-date-label">{{ 'reservation.common.arrival'|trans }}</div>
                        <div class="gv-date-value">{{ reservation.dateDebut|date('d/m/Y') }}</div>
                    </div>
                    <div class="gv-date-box">
                        <div class="gv-date-label">{{ 'reservation.common.departure'|trans }}</div>
                        <div class="gv-date-value">{{ reservation.dateFin|date('d/m/Y') }}</div>
                    </div>
                </div>

                <div class="gv-price-box">
                    <div class="gv-price-label">{{ 'reservation.common.total_price'|trans }}</div>
                    <div class="gv-price-value">{{ reservation.prixTotal }}€</div>
                </div>
            </div>
            <div class="gv-res-card-footer">
                <div class="d-flex gap-2 flex-wrap">
                    <a href="{{ path('app_reservation_show', {'id': reservation.id}) }}" class="gv-action-sm gv-action-view">
                        <span class="material-symbols-outlined" style="font-size:0.9rem;">visibility</span> {{ 'common.view_details'|trans }}
                    </a>
                    {% if reservation.hotel %}
                        <a href="{{ path('app_hotel_show', {'id': reservation.hotel.id}) }}" class="gv-action-sm gv-action-hotel">
                            <span class="material-symbols-outlined" style="font-size:0.9rem;">apartment</span> {{ 'common.hotel'|trans }}
                        </a>
                    {% endif %}
                </div>
                <div class="d-flex gap-2">
                    {% if reservation.statut == 'EN_ATTENTE' %}
                    <form method="post" action="{{ path('app_reservation_pay', {'id': reservation.id}) }}" class="m-0">
                        <input type="hidden" name="_token" value="{{ csrf_token('pay' ~ reservation.id) }}">
                        <button class="gv-action-sm gv-action-pay" type="submit">
                            <span class="material-symbols-outlined" style="font-size:0.9rem;">credit_card</span> Payer
                        </button>
                    </form>
                    {% endif %}
                    <a href="{{ path('app_reservation_edit', {'id': reservation.id}) }}" class="gv-action-sm gv-action-edit">
                        <span class="material-symbols-outlined" style="font-size:0.9rem;">edit</span> {{ 'common.edit'|trans }}
                    </a>
                    <form method="post" action="{{ path('app_reservation_delete', {'id': reservation.id}) }}" onsubmit="return confirm('{{ 'reservation.index.delete_confirm'|trans }}');" class="m-0">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reservation.id) }}">
                        <button class="gv-action-sm gv-action-delete" type="submit">
                            <span class="material-symbols-outlined" style="font-size:0.9rem;">delete</span> {{ 'common.delete'|trans }}
                        </button>
                    </form>
                </div>
            </div>
        </div>
        {% else %}
        <div class="gv-empty">
            <span class="material-symbols-outlined gv-empty-icon">event_busy</span>
            <h4>{{ 'reservation.index.empty_title'|trans }}</h4>
            <p>{{ 'reservation.index.empty_subtitle'|trans }}</p>
            {% if not is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_reservation_new') }}" class="gv-hero-cta">
                <span class="material-symbols-outlined" style="font-size:1.1rem;">add_circle</span>
                {{ 'reservation.index.create_first'|trans }}
            </a>
            {% endif %}
        </div>
        {% endfor %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    var reveals = document.querySelectorAll('.gv-reveal');
    if (reveals.length) {
        var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
                if (entry.isIntersecting) { entry.target.classList.add('is-visible'); observer.unobserve(entry.target); }
            });
        }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });
        reveals.forEach(function(el, i) { el.style.transitionDelay = (i * 80) + 'ms'; observer.observe(el); });
    }
});
</script>
{% endblock %}
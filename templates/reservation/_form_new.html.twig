{{ form_start(form, {'attr': {'class': 'gv-reservation-form', 'novalidate': 'novalidate'}}) }}
    {% if form.vars.errors|length > 0 %}
        <div class="alert alert-danger" role="alert">
            {{ form_errors(form) }}
        </div>
    {% endif %}
    <div class="row g-4">
        {% if form.typeChambre is defined %}
            <div class="col-md-6">
                {{ form_label(form.typeChambre, 'reservation.form.room_type'|trans) }}
                {{ form_widget(form.typeChambre, {'attr': {'class': 'form-select'}}) }}
            </div>
        {% endif %}
        <div class="col-md-6">
            {{ form_label(form.dateDebut, 'reservation.form.date_start'|trans) }}
            {{ form_widget(form.dateDebut, {'attr': {'class': 'form-control' ~ (form.dateDebut.vars.errors|length ? ' is-invalid' : '')}}) }}
            {% if form.dateDebut.vars.errors|length %}<div class="invalid-feedback">{{ 'common.required_field'|trans }}</div>{% endif %}
        </div>
        <div class="col-md-6">
            {{ form_label(form.dateFin, 'reservation.form.date_end'|trans) }}
            {{ form_widget(form.dateFin, {'attr': {'class': 'form-control' ~ (form.dateFin.vars.errors|length ? ' is-invalid' : '')}}) }}
            {% if form.dateFin.vars.errors|length %}<div class="invalid-feedback">{{ 'common.required_field'|trans }}</div>{% endif %}
        </div>
        <div class="col-md-6">
            <label class="form-label">{{ 'reservation.form.total_price'|trans }}</label>
            <div id="reservation-price-breakdown" class="card border-info" style="display:none;">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Prix de base:</span>
                        <span id="reservation-base-price">-</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2" id="reservation-holiday-info" style="display:none;">
                        <span><small class="text-muted">Nuits en jours feriés:</small></span>
                        <span><small class="text-muted" id="reservation-holiday-nights">-</small></span>
                    </div>
                    <div class="d-flex justify-content-between mb-2" id="reservation-supplement-info" style="display:none;">
                        <span><small class="text-success">+ Supplement:</small></span>
                        <span><small class="text-success" id="reservation-supplement">-</small></span>
                    </div>
                    <hr style="margin: 0.5rem 0;" />
                    <div class="d-flex justify-content-between fw-bold">
                        <span>Total:</span>
                        <span id="reservation-estimated-total">-</span>
                    </div>
                </div>
            </div>
            <input type="text" id="reservation-estimated-total-input" class="form-control" value="-" readonly style="display:none;">
            <small class="text-muted">Calcul automatique selon la chambre et les dates.</small>
        </div>
        {% if form.statut is defined %}
            <div class="col-md-6">
                {{ form_label(form.statut, 'reservation.form.status'|trans) }}
                {{ form_widget(form.statut, {'attr': {'class': 'form-select' ~ (form.statut.vars.errors|length ? ' is-invalid' : '')}}) }}
                {% if form.statut.vars.errors|length %}<div class="invalid-feedback">{{ 'common.required_field'|trans }}</div>{% endif %}
            </div>
        {% endif %}
        <div class="col-12">
            {{ form_label(form.chambre, 'reservation.form.room'|trans) }}
            {{ form_widget(form.chambre, {'attr': {'class': 'form-select' ~ (form.chambre.vars.errors|length ? ' is-invalid' : '')}}) }}
            {% if form.chambre.vars.errors|length %}<div class="invalid-feedback">{{ 'common.required_field'|trans }}</div>{% endif %}
        </div>
        <div class="col-12">
            <div id="reservation-disponibilite" class="gv-availability-note" aria-live="polite">{{ 'reservation.form.available_rooms'|trans }} : -</div>
        </div>
        {% if form.hotel is defined %}
            <div class="col-12">
                {{ form_label(form.hotel, 'common.hotel'|trans) }}
                {{ form_widget(form.hotel, {'attr': {'class': 'form-select' ~ (form.hotel.vars.errors|length ? ' is-invalid' : '')}}) }}
                {% if form.hotel.vars.errors|length %}<div class="invalid-feedback">{{ 'common.required_field'|trans }}</div>{% endif %}
            </div>
        {% endif %}
    </div>
    <div class="text-center mt-4">
        <button class="gv-form-submit">
            <span class="material-symbols-outlined" style="font-size:1.1rem;">check_circle</span>
            {{ button_label|default('reservation.form.save_default'|trans) }}
        </button>
    </div>
{{ form_end(form) }}

<style>
.gv-form-submit {
    padding: 1rem 2.5rem; background: linear-gradient(135deg, #e9c176, #ca9028); color: #3d2a00;
    border: none; border-radius: 0.75rem; font-weight: 700; font-size: 1.05rem; cursor: pointer;
    transition: all 0.3s; box-shadow: 0 10px 25px -5px rgba(233,193,118,0.4);
    font-family: 'Manrope', sans-serif; display: inline-flex; align-items: center; gap: 0.5rem;
}
.gv-form-submit:hover { transform: translateY(-2px); box-shadow: 0 15px 35px -5px rgba(233,193,118,0.5); }

.gv-reservation-form .invalid-feedback { display:block; color:#93000a; font-size:0.85rem; margin-top:0.3rem; }

.gv-availability-note {
    border: 1px solid rgba(0, 52, 45, 0.12);
    border-radius: 0.7rem;
    padding: 0.65rem 0.9rem;
    font-size: 0.9rem;
    font-weight: 700;
    color: #00342d;
    background: rgba(160, 242, 225, 0.18);
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
    var hotelSelect = document.getElementById('{{ form.hotel is defined ? form.hotel.vars.id : '' }}');
    var typeSelect = document.getElementById('{{ form.typeChambre is defined ? form.typeChambre.vars.id : '' }}');
    var chambreSelect = document.getElementById('{{ form.chambre.vars.id }}');
    var dispoEl = document.getElementById('reservation-disponibilite');
    var dateDebutInput = document.getElementById('{{ form.dateDebut.vars.id }}');
    var dateFinInput = document.getElementById('{{ form.dateFin.vars.id }}');
    var estimatedTotalEl = document.getElementById('reservation-estimated-total');
    var priceBreakdownEl = document.getElementById('reservation-price-breakdown');
    var basePriceEl = document.getElementById('reservation-base-price');
    var holidayNightsEl = document.getElementById('reservation-holiday-nights');
    var supplementEl = document.getElementById('reservation-supplement');
    var holidayInfoEl = document.getElementById('reservation-holiday-info');
    var supplementInfoEl = document.getElementById('reservation-supplement-info');

    if (!chambreSelect || !dispoEl) {
        return;
    }

    var chambreOptions = Array.prototype.slice.call(chambreSelect.options).filter(function (opt) {
        return opt.value !== '';
    });

    // Charger les jours fériés depuis l'API
    var holidays = [];
    var supplementPercentage = 0;
    
    fetch('{{ path("app_reservation_holidays_api") }}')
        .then(function(response) { return response.json(); })
        .catch(function() { return { holidays: [], supplementPercentage: 0 }; })
        .then(function(data) {
            holidays = data.holidays || [];
            supplementPercentage = data.supplementPercentage || 0;
            updateEstimatedTotal(); // Recalculer après chargement
        });

    function normalize(value) {
        return (value || '').toString().trim().toLowerCase();
    }

    function parseDate(value) {
        if (!value) {
            return null;
        }

        var date = new Date(value + 'T00:00:00');
        return Number.isNaN(date.getTime()) ? null : date;
    }

    function dateToString(date) {
        var year = date.getFullYear();
        var month = String(date.getMonth() + 1).padStart(2, '0');
        var day = String(date.getDate()).padStart(2, '0');
        return year + '-' + month + '-' + day;
    }

    function diffDays(start, end) {
        var msPerDay = 24 * 60 * 60 * 1000;
        return Math.round((end.getTime() - start.getTime()) / msPerDay);
    }

    function getUnitPrice(option) {
        var standard = parseFloat(option.getAttribute('data-prix-standard') || '0');
        var high = parseFloat(option.getAttribute('data-prix-haute') || '0');
        var low = parseFloat(option.getAttribute('data-prix-basse') || '0');

        if (standard > 0) {
            return standard;
        }

        if (high > 0) {
            return high;
        }

        return low > 0 ? low : 0;
    }

    function countHolidayNights(start, end) {
        var count = 0;
        var current = new Date(start);
        
        while (current < end) {
            var dateStr = dateToString(current);
            if (holidays.indexOf(dateStr) !== -1) {
                count++;
            }
            current.setDate(current.getDate() + 1);
        }
        
        return count;
    }

    function updateEstimatedTotal() {
        if (!estimatedTotalEl || !chambreSelect) {
            priceBreakdownEl.style.display = 'none';
            return;
        }

        var option = chambreSelect.selectedOptions.length ? chambreSelect.selectedOptions[0] : null;
        if (!option || option.value === '') {
            estimatedTotalEl.textContent = '-';
            priceBreakdownEl.style.display = 'none';
            return;
        }

        var start = parseDate(dateDebutInput ? dateDebutInput.value : '');
        var end = parseDate(dateFinInput ? dateFinInput.value : '');
        var unit = getUnitPrice(option);

        if (!start || !end || end <= start || unit <= 0) {
            estimatedTotalEl.textContent = '-';
            priceBreakdownEl.style.display = 'none';
            return;
        }

        var nights = diffDays(start, end);
        if (nights <= 0) {
            estimatedTotalEl.textContent = '-';
            priceBreakdownEl.style.display = 'none';
            return;
        }

        // Calculer le prix de base
        var basePrice = (unit * nights);

        // Calculer les nuits de jours fériés
        var holidayNights = countHolidayNights(start, end);
        var supplementAmount = 0;
        
        if (holidayNights > 0) {
            supplementAmount = (unit * (supplementPercentage / 100)) * holidayNights;
        }

        var totalPrice = basePrice + supplementAmount;

        // Mettre à jour l'affichage
        basePriceEl.textContent = basePrice.toFixed(2) + ' €';
        estimatedTotalEl.textContent = totalPrice.toFixed(2) + ' €';

        if (holidayNights > 0) {
            holidayNightsEl.textContent = holidayNights + ' nuit' + (holidayNights > 1 ? 's' : '');
            supplementEl.textContent = '+ ' + supplementAmount.toFixed(2) + ' €';
            holidayInfoEl.style.display = 'flex';
            supplementInfoEl.style.display = 'flex';
        } else {
            holidayInfoEl.style.display = 'none';
            supplementInfoEl.style.display = 'none';
        }

        priceBreakdownEl.style.display = 'block';
    }

    function applyFilters() {
        var selectedHotel = hotelSelect ? hotelSelect.value : '';
        var selectedType = typeSelect ? normalize(typeSelect.value) : '';
        var totalDisponibles = 0;

        chambreOptions.forEach(function (option) {
            var optionHotel = option.getAttribute('data-hotel-id') || '';
            var optionType = normalize(option.getAttribute('data-type'));
            var optionDisponibles = parseInt(option.getAttribute('data-disponibles') || '0', 10);

            var hotelMatch = !selectedHotel || optionHotel === selectedHotel;
            var typeMatch = !selectedType || optionType === selectedType;
            var visible = hotelMatch && typeMatch;

            option.hidden = !visible;
            option.disabled = !visible;

            if (visible && !isNaN(optionDisponibles)) {
                totalDisponibles += optionDisponibles;
            }
        });

        if (chambreSelect.selectedOptions.length && chambreSelect.selectedOptions[0].disabled) {
            chambreSelect.value = '';
        }

        if (selectedType) {
            dispoEl.textContent = '{{ 'reservation.form.available_rooms_for_type'|trans }} : ' + totalDisponibles;
        } else {
            dispoEl.textContent = '{{ 'reservation.form.available_rooms'|trans }} : ' + totalDisponibles;
        }
    }

    if (hotelSelect) {
        hotelSelect.addEventListener('change', applyFilters);
    }

    if (typeSelect) {
        typeSelect.addEventListener('change', applyFilters);
    }

    chambreSelect.addEventListener('change', updateEstimatedTotal);

    if (dateDebutInput) {
        dateDebutInput.addEventListener('change', updateEstimatedTotal);
    }

    if (dateFinInput) {
        dateFinInput.addEventListener('change', updateEstimatedTotal);
    }

    applyFilters();
    updateEstimatedTotal();
});
</script>

{% extends 'admin/base_admin.html.twig' %}

{% block page_title %}Gestion des Vols{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold" style="color:var(--admin-primary); margin:0;">
        <i class="bi bi-airplane-fill me-2" style="color:var(--admin-accent);"></i> Flotte & Vols Programmés
    </h4>
    <a href="{{ path('app_admin_vols_new') }}" onclick="openDetailModal(this.href); return false;" class="btn btn-sm" style="background:var(--admin-accent);color:white;font-weight:600;"><i class="bi bi-plus-lg me-1"></i> Nouveau Vol</a>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    {% for vol in vols %}
    <div class="col">
        <div class="admin-card h-100 position-relative d-flex flex-column" style="overflow: hidden; padding: 25px;">
            <div class="position-absolute" style="top: 20px; right: 20px;">
                <span class="badge" style="background:rgba(13, 110, 253, 0.1);color:#0d6efd;border:1px solid rgba(13, 110, 253, 0.2);padding:6px 12px;font-weight:600;">{{ vol.classeChaise }}</span>
            </div>

            <div class="text-center mt-3 mb-4">
                <div style="width:70px;height:70px;border-radius:16px;background:rgba(10, 25, 47, 0.04);color:var(--admin-primary);font-weight:700;display:flex;align-items:center;justify-content:center;font-size:24px;border:1px solid var(--border-color);margin:0 auto 15px;">
                    <i class="bi bi-airplane"></i>
                </div>
                <h5 class="fw-bold mb-1" style="color:var(--admin-primary); font-family:'Outfit', sans-serif;">{{ vol.departureAirport }} <i class="bi bi-arrow-right text-muted mx-1" style="font-size:14px;"></i> {{ vol.destination }}</h5>
                <p class="text-muted mb-0" style="font-size: 13px;">Vol ID <strong>{{ vol.flightId }}</strong> &bull; {{ vol.airline }}</p>
                <div class="mt-3 d-flex justify-content-center gap-4 text-muted" style="font-size: 11px; text-transform:uppercase; letter-spacing:0.5px;">
                    <div>Départ<br><strong style="font-size:14px;color:#333;">{{ vol.departureTime ? vol.departureTime|date('H:i') : '-' }}</strong></div>
                    <div>Arrivée<br><strong style="font-size:14px;color:#333;">{{ vol.arrivalTime ? vol.arrivalTime|date('H:i') : '-' }}</strong></div>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-3 p-3" style="background:#F8FAFC; border-radius:12px; border:1px solid #E2E8F0;">
                <div class="text-center w-50" style="border-right: 1px solid #E2E8F0;">
                    <div style="font-size:10px; font-weight:600; text-transform:uppercase; color:#64748B;">Places</div>
                    {% if vol.availableSeats < 10 %}
                        <div class="text-danger fw-bold"><i class="bi bi-exclamation-circle"></i> {{ vol.availableSeats }}</div>
                    {% else %}
                        <div class="text-success fw-bold">{{ vol.availableSeats }}</div>
                    {% endif %}
                </div>
                <div class="text-center w-50">
                    <div style="font-size:10px; font-weight:600; text-transform:uppercase; color:#64748B;">Prix</div>
                    <div style="font-size:16px; font-weight:700; color:var(--admin-primary);">{{ vol.prix }} €</div>
                </div>
            </div>

            <div class="mt-auto d-flex gap-2">
                <a href="{{ path('app_admin_vols_edit', {'flightId': vol.flightId}) }}" onclick="openDetailModal(this.href); return false;" class="btn flex-grow-1" style="background:#F8FAFC;color:#0F172A;border:1px solid #E2E8F0;font-size:14px;font-weight:500;">
                    <i class="bi bi-pencil-square me-1"></i> Modifier
                </a>
                
                <form method="post" action="{{ path('app_admin_vols_delete', {'flightId': vol.flightId}) }}" class="flex-grow-1" onsubmit="return confirm('Êtes-vous sûr de vouloir annuler et supprimer ce vol ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ vol.flightId) }}">
                    <button class="btn w-100" style="background:#FEF2F2;color:#DC2626;border:1px solid #FECACA;font-size:14px;font-weight:500;">
                        <i class="bi bi-trash3-fill me-1"></i> Supprimer
                    </button>
                </form>
            </div>
        </div>
    </div>
    {% else %}
    <div class="col-12 w-100">
        <div class="admin-card text-center py-5">
            <i class="bi bi-cloud-slash text-muted" style="font-size:40px;"></i>
            <p class="text-muted mt-2">Aucun vol n'est actuellement programmé.</p>
        </div>
    </div>
    {% endfor %}
</div>
{% endblock %}

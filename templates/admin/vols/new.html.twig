{% extends 'admin/base_admin.html.twig' %}

{% block page_title %}{{ vol.flightId ? 'Modifier le Vol ' ~ vol.flightId : 'Créer un Nouveau Vol' }}{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .form-group label {
        font-weight: 600; font-size: 13px; text-transform: uppercase; color: #666; margin-bottom: 8px; letter-spacing: 0.5px;
    }
    .form-control, .form-select {
        border-radius: 8px; padding: 12px 15px; border: 1.5px solid #eaeaea; background-color: #fafafa;
    }
    .form-control:focus, .form-select:focus {
        background-color: white; border-color: var(--admin-accent); box-shadow: 0 0 0 4px rgba(80, 200, 120, 0.1);
    }
    .btn-submit {
        background: var(--admin-accent); color: white; border: none; border-radius: 8px;
        padding: 12px 25px; font-weight: 600; font-size: 15px; transition: all 0.3s;
    }
    .btn-submit:hover { background: #3fa563; transform: translateY(-2px); }
</style>
{% endblock %}

{% block body %}
<div class="admin-card">
    <div class="admin-card-header">
        <i class="bi bi-airplane"></i> Informations du Vol
    </div>
    <div class="admin-card-body">
        <a href="{{ path('app_admin_vols_index') }}" class="btn btn-sm btn-light mb-4"><i class="bi bi-arrow-left"></i> Retour à la flotte</a>

        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            <div class="row g-4 mb-4">
                <div class="col-md-6 form-group">
                    {{ form_label(form.flightId) }}
                    {{ form_widget(form.flightId, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.flightId) }}
                </div>
                <div class="col-md-6 form-group">
                    {{ form_label(form.airline) }}
                    {{ form_widget(form.airline, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.airline) }}
                </div>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-md-6 form-group">
                    {{ form_label(form.departureAirport) }}
                    {{ form_widget(form.departureAirport, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.departureAirport) }}
                </div>
                <div class="col-md-6 form-group">
                    {{ form_label(form.destination) }}
                    {{ form_widget(form.destination, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.destination) }}
                </div>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-md-6 form-group">
                    {{ form_label(form.departureTime) }}
                    {{ form_widget(form.departureTime, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.departureTime) }}
                </div>
                <div class="col-md-6 form-group">
                    {{ form_label(form.arrivalTime) }}
                    {{ form_widget(form.arrivalTime, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.arrivalTime) }}
                </div>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-md-4 form-group">
                    {{ form_label(form.classeChaise) }}
                    {{ form_widget(form.classeChaise, {'attr': {'class': 'form-select'}}) }}
                    {{ form_errors(form.classeChaise) }}
                </div>
                <div class="col-md-4 form-group">
                    {{ form_label(form.prix) }}
                    <div class="input-group">
                        {{ form_widget(form.prix, {'attr': {'class': 'form-control'}}) }}
                        <span class="input-group-text">€</span>
                    </div>
                    {{ form_errors(form.prix) }}
                </div>
                <div class="col-md-4 form-group">
                    {{ form_label(form.availableSeats) }}
                    {{ form_widget(form.availableSeats, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.availableSeats) }}
                </div>
            </div>

            <div class="form-group mb-4">
                {{ form_label(form.description) }}
                {{ form_widget(form.description, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.description) }}
            </div>

            <div class="text-end">
                <button type="submit" class="btn-submit">{{ button_label|default('Enregistrer le vol') }}</button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}

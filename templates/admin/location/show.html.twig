{% extends 'admin/base_admin.html.twig' %}

{% block title %}Détails Location - Admin GoVibe{% endblock %}

{% block page_title %}Détails Location{% endblock %}

{% block body %}
<style>
    :root {
        --primary-emerald: #50C878;
        --dark-green: #013220;
        --light-green: #2E8B57;
    }

    .detail-hero {
        background: linear-gradient(135deg, var(--dark-green) 0%, var(--light-green) 100%);
        color: white;
        padding: 40px 0;
        margin-bottom: 40px;
    }

    .detail-hero h1 {
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 5px;
    }

    .detail-container {
        max-width: 1000px;
        margin: 0 auto;
    }

    .detail-card {
        background: white;
        border-radius: 10px;
        padding: 25px;
        margin-bottom: 20px;
        box-shadow: 0 2px 15px rgba(0, 0, 0, 0.1);
    }

    .card-title {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--dark-green);
        margin-bottom: 15px;
        padding-bottom: 10px;
        border-bottom: 2px solid var(--primary-emerald);
    }

    .detail-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 15px;
    }

    .detail-item {
        padding: 12px;
        background: #f8f9fa;
        border-radius: 6px;
    }

    .detail-label {
        font-size: 0.75rem;
        color: #666;
        text-transform: uppercase;
        font-weight: 600;
    }

    .detail-value {
        font-size: 1.1rem;
        color: var(--dark-green);
        font-weight: 700;
        margin-top: 5px;
    }

    .status-badge {
        display: inline-block;
        padding: 8px 16px;
        border-radius: 20px;
        font-weight: 600;
    }

    .status-en_attente {
        background-color: #fff3cd;
        color: #856404;
    }

    .status-confirmee {
        background-color: #d4edda;
        color: #155724;
    }

    .status-annulee {
        background-color: #f8d7da;
        color: #721c24;
    }

    .action-section {
        background: #f8f9fa;
        padding: 15px;
        border-radius: 6px;
        margin-top: 15px;
    }

    .action-title {
        font-weight: 700;
        color: var(--dark-green);
        margin-bottom: 10px;
    }

    .action-buttons {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .btn-action {
        padding: 10px 16px;
        border: none;
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 0.85rem;
    }

    .btn-primary {
        background-color: var(--primary-emerald);
        color: white;
    }

    .btn-primary:hover {
        background-color: var(--light-green);
        transform: translateY(-2px);
    }

    .btn-success {
        background-color: #28a745;
        color: white;
    }

    .btn-success:hover {
        background-color: #218838;
    }

    .btn-danger {
        background-color: #dc3545;
        color: white;
    }

    .btn-danger:hover {
        background-color: #c82333;
    }

    .btn-secondary {
        background-color: #6c757d;
        color: white;
    }

    .btn-secondary:hover {
        background-color: #5a6268;
    }

    .alert {
        padding: 15px;
        border-radius: 6px;
        margin-bottom: 20px;
    }

    .stats-summary {
        background: linear-gradient(135deg, rgba(80, 200, 120, 0.1) 0%, rgba(46, 139, 87, 0.1) 100%);
        padding: 20px;
        border-radius: 8px;
        border: 2px solid var(--primary-emerald);
    }

    .stat-row {
        display: flex;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 1px solid rgba(80, 200, 120, 0.2);
    }

    .stat-row:last-child {
        border-bottom: none;
    }

    .stat-label {
        color: #666;
    }

    .stat-value {
        font-weight: 700;
        color: var(--primary-emerald);
    }

    .total-amount {
        display: flex;
        justify-content: space-between;
        padding: 15px 0;
        border-top: 2px solid var(--primary-emerald);
        margin-top: 10px;
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--primary-emerald);
    }

    .back-button {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        color: var(--primary-emerald);
        font-weight: 600;
        margin-bottom: 20px;
    }

    .back-button:hover {
        color: var(--light-green);
    }

    .section-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        margin-bottom: 20px;
    }

    .map-box {
        height: 360px;
        border-radius: 8px;
        border: 1px solid #d8e0e5;
        margin-top: 12px;
    }
</style>

<div class="detail-hero">
    <div class="container">
        <h1><i class="bi bi-list-check"></i> Gestion Location</h1>
        <p>{{ location.reference }}</p>
    </div>
</div>

<div class="container detail-container">
    <a href="{{ path('app_admin_location_index') }}" class="back-button">
        <i class="bi bi-arrow-left"></i> Retour
    </a>

    <!-- Alertes -->
    {% if location.statut == 'EN_ATTENTE' %}
    <div class="alert alert-warning">
        <i class="bi bi-clock me-2"></i>
        <strong>En Attente:</strong> Cette location doit être confirmée ou annulée.
    </div>
    {% elseif location.statut == 'CONFIRMEE' %}
    <div class="alert alert-success">
        <i class="bi bi-check-circle me-2"></i>
        <strong>Confirmée:</strong> Cette location a été confirmée.
    </div>
    {% elseif location.statut == 'ANNULEA' %}
    <div class="alert alert-danger">
        <i class="bi bi-x-circle me-2"></i>
        <strong>Annulée:</strong> Cette location a été annulée.
    </div>
    {% endif %}

    <!-- Infos principales -->
    <div class="detail-card">
        <div class="card-title">
            <i class="bi bi-info-circle"></i> Informations Principales
        </div>

        <div class="detail-grid">
            <div class="detail-item">
                <div class="detail-label">Référence</div>
                <div class="detail-value">{{ location.reference }}</div>
            </div>
            <div class="detail-item">
                <div class="detail-label">Statut</div>
                <div>
                    <span class="status-badge status-{{ location.statut|lower|replace({'_': ''}) }}">
                        {{ location.statut }}
                    </span>
                </div>
            </div>
            <div class="detail-item">
                <div class="detail-label">Créé le</div>
                <div class="detail-value">{{ location.dateCreation|date('d/m/Y H:i') }}</div>
            </div>
        </div>
    </div>

    <!-- Section Client & Voiture -->
    <div class="section-row">
        <!-- Infos Client -->
        <div class="detail-card">
            <div class="card-title">
                <i class="bi bi-person"></i> Informations Client
            </div>

            {% set user = location.user %}
            <div class="detail-item">
                <div class="detail-label">Nom Complet</div>
                <div class="detail-value">{{ user.prenom }} {{ user.nom }}</div>
            </div>
            <div class="detail-item" style="margin-top: 10px;">
                <div class="detail-label">Email</div>
                <div class="detail-value" style="word-break: break-all;">{{ user.email }}</div>
            </div>
        </div>

        <!-- Infos Voiture -->
        <div class="detail-card">
            <div class="card-title">
                <i class="bi bi-car-front-fill"></i> Voiture Louée
            </div>

            {% set voiture = location.voiture %}
            <div class="detail-grid" style="grid-template-columns: 1fr;">
                <div class="detail-item">
                    <div class="detail-label">Marque & Modèle</div>
                    <div class="detail-value">{{ voiture.marque }} {{ voiture.modele }}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Matricule</div>
                    <div class="detail-value">{{ voiture.matricule }}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Année</div>
                    <div class="detail-value">{{ voiture.annee }}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Type Carburant</div>
                    <div class="detail-value">{{ voiture.typeCarburant }}</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Période & Montants -->
    <div class="section-row">
        <div class="detail-card">
            <div class="card-title">
                <i class="bi bi-calendar-event"></i> Période de Location
            </div>

            <div class="detail-grid" style="grid-template-columns: 1fr;">
                <div class="detail-item">
                    <div class="detail-label">Date Début</div>
                    <div class="detail-value">{{ location.dateDebut|date('d/m/Y') }}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Date Fin</div>
                    <div class="detail-value">{{ location.dateFin|date('d/m/Y') }}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Nombre de Jours</div>
                    <div class="detail-value">{{ location.nbJours }} jour(s)</div>
                </div>
            </div>
        </div>

        <div class="detail-card">
            <div class="card-title">
                <i class="bi bi-cash-coin"></i> Résumé Financier
            </div>

            <div class="stats-summary">
                <div class="stat-row">
                    <span class="stat-label">Prix/jour</span>
                    <span class="stat-value">{{ '%0.2f'|format(voiture.prixJour) }} DT</span>
                </div>
                <div class="stat-row">
                    <span class="stat-label">Nombre jours</span>
                    <span class="stat-value">× {{ location.nbJours }}</span>
                </div>
                <div class="total-amount">
                    <span>Montant Total</span>
                    <span>{{ '%0.2f'|format(location.montantTotal) }} DT</span>
                </div>
            </div>
        </div>
    </div>

    {% if voiture.latitude and voiture.longitude %}
    <div class="detail-card">
        <div class="card-title">
            <i class="bi bi-signpost-split"></i> Distance et Itineraire
        </div>
        <p class="text-muted">API gratuite sans cle: OpenStreetMap + OSRM.</p>
        <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
            <button type="button" class="btn-action btn-primary" id="adminLocationLocateBtn">
                <i class="bi bi-crosshair"></i> Calculer depuis ma position
            </button>
            <small class="text-muted" id="adminLocationMapStatus">Aucun calcul effectue</small>
        </div>
        <div class="detail-grid" style="grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));">
            <div class="detail-item"><div class="detail-label">Distance</div><div class="detail-value" id="adminLocationDistance">-</div></div>
            <div class="detail-item"><div class="detail-label">Duree</div><div class="detail-value" id="adminLocationDuration">-</div></div>
        </div>
        <div id="adminLocationMap" class="map-box"></div>
    </div>
    {% endif %}

    <!-- Actions d'administration -->
    <div class="detail-card">
        <div class="action-section">
            <div class="action-title">
                <i class="bi bi-gear"></i> Actions d'Administration
            </div>

            <div class="action-buttons">
                <a href="{{ path('app_admin_location_index') }}" class="btn-action btn-secondary">
                    <i class="bi bi-arrow-left"></i> Retour
                </a>

                {% if location.statut == 'EN_ATTENTE' %}
                <form method="POST" action="{{ path('app_admin_location_confirm', {id: location.idLocation}) }}" style="display: inline;" onsubmit="return confirm('Confirmer cette location?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('confirm' ~ location.idLocation) }}">
                    <button type="submit" class="btn-action btn-success">
                        <i class="bi bi-check-circle"></i> Confirmer
                    </button>
                </form>

                <form method="POST" action="{{ path('app_admin_location_cancel', {id: location.idLocation}) }}" style="display: inline;" onsubmit="return confirm('Annuler cette location?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('cancel' ~ location.idLocation) }}">
                    <button type="submit" class="btn-action btn-danger">
                        <i class="bi bi-x-circle"></i> Annuler
                    </button>
                </form>
                {% elseif location.statut == 'CONFIRMEE' %}
                <form method="POST" action="{{ path('app_admin_location_cancel', {id: location.idLocation}) }}" style="display: inline;" onsubmit="return confirm('Annuler cette location confirmée?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('cancel' ~ location.idLocation) }}">
                    <button type="submit" class="btn-action btn-danger">
                        <i class="bi bi-x-circle"></i> Annuler
                    </button>
                </form>
                {% endif %}
            </div>
        </div>
    </div>
</div>

{% if voiture.latitude and voiture.longitude %}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    const destinationLat = parseFloat('{{ voiture.latitude }}');
    const destinationLng = parseFloat('{{ voiture.longitude }}');
    const statusEl = document.getElementById('adminLocationMapStatus');
    const distanceEl = document.getElementById('adminLocationDistance');
    const durationEl = document.getElementById('adminLocationDuration');
    const locateBtn = document.getElementById('adminLocationLocateBtn');

    const map = L.map('adminLocationMap').setView([destinationLat, destinationLng], 13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '&copy; OpenStreetMap contributors'
    }).addTo(map);

    L.marker([destinationLat, destinationLng]).addTo(map)
        .bindPopup('Voiture louee: {{ voiture.marque|e('js') }} {{ voiture.modele|e('js') }}')
        .openPopup();

    let userMarker = null;
    let routeLayer = null;

    function formatDuration(seconds) {
        const minutes = Math.round(seconds / 60);
        const hours = Math.floor(minutes / 60);
        const remainingMinutes = minutes % 60;
        if (hours <= 0) {
            return minutes + ' min';
        }
        return hours + ' h ' + remainingMinutes + ' min';
    }

    async function drawRoute(userLat, userLng) {
        const url = 'https://router.project-osrm.org/route/v1/driving/'
            + userLng + ',' + userLat + ';' + destinationLng + ',' + destinationLat
            + '?overview=full&geometries=geojson';
        const response = await fetch(url);
        const data = await response.json();

        if (!data.routes || !data.routes.length) {
            throw new Error('No route');
        }

        const route = data.routes[0];
        if (routeLayer) {
            map.removeLayer(routeLayer);
        }

        routeLayer = L.geoJSON(route.geometry, {
            style: { color: '#0d6efd', weight: 5, opacity: 0.8 }
        }).addTo(map);

        distanceEl.textContent = (route.distance / 1000).toFixed(2) + ' km';
        durationEl.textContent = formatDuration(route.duration);

        map.fitBounds(L.latLngBounds([[userLat, userLng], [destinationLat, destinationLng]]).pad(0.2));
    }

    locateBtn?.addEventListener('click', function () {
        if (!navigator.geolocation) {
            statusEl.textContent = 'Geolocalisation non supportee.';
            return;
        }

        statusEl.textContent = 'Localisation en cours...';
        navigator.geolocation.getCurrentPosition(async function (position) {
            const userLat = position.coords.latitude;
            const userLng = position.coords.longitude;

            if (userMarker) {
                map.removeLayer(userMarker);
            }

            userMarker = L.marker([userLat, userLng]).addTo(map).bindPopup('Votre position');

            try {
                await drawRoute(userLat, userLng);
                statusEl.textContent = 'Itineraire calcule avec succes.';
            } catch (error) {
                statusEl.textContent = 'Impossible de calculer l\'itineraire actuellement.';
            }
        }, function () {
            statusEl.textContent = 'Permission de localisation refusee ou indisponible.';
        }, {
            enableHighAccuracy: true,
            timeout: 15000,
            maximumAge: 0,
        });
    });

    setTimeout(function () { map.invalidateSize(); }, 200);
});
</script>
{% endif %}
{% endblock %}

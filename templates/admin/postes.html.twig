{% extends 'admin/base_admin.html.twig' %}

{% block page_title %}Gestion des Publications{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold" style="color:var(--admin-primary); margin:0;">
        <i class="bi bi-chat-square-text-fill me-2" style="color:var(--admin-accent);"></i> Toutes les Publications
    </h4>
</div>

<div class="admin-card">
    <div class="admin-table-responsive">
        <table class="table admin-table">
            <thead>
                <tr>
                    <th>Auteur</th>
                    <th>Type</th>
                    <th>Contenu / Image</th>
                    <th>Date</th>
                    <th>Forum</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for p in postes %}
                <tr>
                    <td>
                        <div class="d-flex align-items-center gap-3">
                            <div style="width:36px;height:36px;border-radius:10px;background:rgba(10, 25, 47, 0.04);color:var(--admin-primary);font-weight:700;display:flex;align-items:center;justify-content:center;font-size:14px;border:1px solid var(--border-color);">
                                {{ p.user.prenom|first|upper }}
                            </div>
                            <div>
                                <div class="fw-bold" style="font-size:14px;">{{ p.user.prenom }} {{ p.user.nom }}</div>
                                <div class="text-muted" style="font-size:12px;">{{ p.user.email }}</div>
                            </div>
                        </div>
                    </td>
                    <td>
                        <span class="badge" style="background:{% if p.type == 'MEDIA' %}rgba(34, 197, 94, 0.1){% else %}rgba(59, 130, 246, 0.1){% endif %};color:{% if p.type == 'MEDIA' %}#16a34a{% else %}#2563eb{% endif %};border:1px solid rgba(0,0,0,0.05);padding:5px 10px;font-weight:600;font-size:11px;">
                            {{ p.type }}
                        </span>
                    </td>
                    <td style="max-width: 300px;">
                        {% if p.type == 'MEDIA' and p.url %}
                            <div class="d-flex align-items-center gap-2">
                                <img src="{{ p.url }}" alt="Post image" style="width:40px;height:40px;border-radius:6px;object-fit:cover;border:1px solid var(--border-color);">
                                <span class="text-truncate" style="font-size:13px;">{{ p.contenu|default('Sans contenu') }}</span>
                            </div>
                        {% else %}
                            <div class="text-truncate" style="font-size:13px; color:var(--text-main);">{{ p.contenu }}</div>
                        {% endif %}
                    </td>
                    <td style="font-size:13px; color:var(--text-muted);">
                        {{ p.dateCreation|date('d/m/Y H:i') }}
                    </td>
                    <td>
                        {% if p.forum %}
                            <span class="badge" style="background:rgba(245, 158, 11, 0.1);color:#d97706;border:1px solid rgba(245, 158, 11, 0.2);padding:4px 8px;font-size:11px;">
                                {{ p.forum.name }}
                            </span>
                        {% else %}
                            <span class="text-muted small">Global</span>
                        {% endif %}
                    </td>
                    <td class="text-end">
                        <form method="post" action="{{ path('app_admin_poste_delete', {'id': p.postId}) }}" onsubmit="return confirm('Supprimer cette publication ?');" style="display:inline-block;">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ p.postId) }}">
                            <button class="btn btn-pro text-danger" style="padding: 6px 12px;">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </form>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="6" class="text-center py-5 text-muted">Aunuce publication trouvée.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

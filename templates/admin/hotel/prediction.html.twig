<script>
document.addEventListener('DOMContentLoaded', function () {
    var section = document.getElementById('ai-alert-section');
    if (!section) {
        return;
    }

    var buttons = section.querySelectorAll('[data-alert-filter]');
    var items = section.querySelectorAll('.alert-item[data-alert-type]');
    var emptyFiltered = document.getElementById('alert-empty-filtered');
    var emptyStatic = document.getElementById('alert-empty-static');

    function applyFilter(type) {
        var visibleCount = 0;

        items.forEach(function (item) {
            var itemType = item.getAttribute('data-alert-type');
            var visible = (type === 'all') || (itemType === type);
            item.style.display = visible ? '' : 'none';
            if (visible) {
                visibleCount += 1;
            }
        });

        if (emptyStatic) {
            emptyStatic.style.display = items.length === 0 ? 'inline-flex' : 'none';
        }

        if (emptyFiltered) {
            emptyFiltered.style.display = (items.length > 0 && visibleCount === 0) ? 'inline-flex' : 'none';
        }
    }

    buttons.forEach(function (button) {
        button.addEventListener('click', function () {
            var type = button.getAttribute('data-alert-filter') || 'all';
            buttons.forEach(function (btn) { btn.classList.remove('is-active'); });
            button.classList.add('is-active');
            applyFilter(type);
        });
    });

    applyFilter('all');
});
</script>

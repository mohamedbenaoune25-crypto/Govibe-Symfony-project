{% extends 'admin/base_admin.html.twig' %}

{% block title %}{{ 'admin.hotel.index.title'|trans|auto_translate }}{% endblock %}
{% block page_title %}{{ 'admin.hotel.index.page_title'|trans|auto_translate }}{% endblock %}

{% block body %}
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="admin-card h-100">
            <div class="admin-card-body">
                <div class="text-muted small mb-1">{{ 'admin.hotel.index.stats.hotels'|trans|auto_translate }}</div>
                <div class="fs-3 fw-bold text-success">{{ stats.totalHotels }}</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="admin-card h-100">
            <div class="admin-card-body">
                <div class="text-muted small mb-1">{{ 'admin.hotel.index.stats.rooms'|trans|auto_translate }}</div>
                <div class="fs-3 fw-bold text-primary">{{ stats.totalChambres }}</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="admin-card h-100">
            <div class="admin-card-body">
                <div class="text-muted small mb-1">{{ 'admin.hotel.index.stats.reservations'|trans|auto_translate }}</div>
                <div class="fs-3 fw-bold text-warning">{{ stats.totalReservations }}</div>
            </div>
        </div>
    </div>
</div>

<div class="admin-card mb-4">
    <div class="admin-card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-building me-2 text-muted"></i> {{ 'admin.hotel.index.list_heading'|trans|auto_translate }}</span>
        <div class="d-flex flex-wrap gap-2">
            <a href="{{ path('app_admin_hotels_prediction') }}" class="btn btn-outline-primary py-1 px-3">
                <i class="bi bi-graph-up-arrow me-1"></i>{{ 'admin.hotel.actions.prediction'|trans|auto_translate }}
            </a>
            <a href="{{ path('app_admin_reports_statistics_pdf') }}" class="btn btn-outline-danger py-1 px-3">
                <i class="bi bi-file-earmark-pdf me-1"></i>{{ 'common.export_pdf'|trans|auto_translate }}
            </a>
            <a href="{{ path('app_admin_reports_statistics_excel') }}" class="btn btn-outline-success py-1 px-3">
                <i class="bi bi-file-earmark-spreadsheet me-1"></i>{{ 'common.export_excel'|trans|auto_translate }}
            </a>
            <a href="{{ path('app_admin_hotels_new') }}" class="btn btn-primary-pro py-1 px-3">
                <i class="bi bi-plus-lg me-1"></i>{{ 'admin.hotel.actions.add'|trans|auto_translate }}
            </a>
        </div>
    </div>
    <div class="admin-card-body">
        <form method="get" class="row g-3 align-items-end mb-4">
            <div class="col-md-5">
                <label class="form-label">{{ 'common.search'|trans|auto_translate }}</label>
                <input type="text" name="search" value="{{ search }}" class="form-control" placeholder="{{ 'admin.hotel.index.search_placeholder'|trans|auto_translate }}">
            </div>
            <div class="col-md-3">
                <label class="form-label">{{ 'common.sort_by'|trans|auto_translate }}</label>
                <select name="sortBy" class="form-select">
                    <option value="nom" {% if sortBy == 'nom' %}selected{% endif %}>{{ 'common.name'|trans|auto_translate }}</option>
                    <option value="ville" {% if sortBy == 'ville' %}selected{% endif %}>{{ 'common.city'|trans|auto_translate }}</option>
                    <option value="budget" {% if sortBy == 'budget' %}selected{% endif %}>{{ 'common.budget'|trans|auto_translate }}</option>
                    <option value="nombreEtoiles" {% if sortBy == 'nombreEtoiles' %}selected{% endif %}>{{ 'common.stars'|trans|auto_translate }}</option>
                    <option value="createdAt" {% if sortBy == 'createdAt' %}selected{% endif %}>{{ 'common.creation'|trans|auto_translate }}</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">{{ 'common.order'|trans|auto_translate }}</label>
                <select name="sortDir" class="form-select">
                    <option value="asc" {% if sortDir|lower == 'asc' %}selected{% endif %}>ASC</option>
                    <option value="desc" {% if sortDir|lower == 'desc' %}selected{% endif %}>DESC</option>
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button class="btn btn-pro w-100" type="submit">{{ 'common.filter'|trans|auto_translate }}</button>
                <a class="btn btn-outline-secondary w-100" href="{{ path('app_admin_hotels_index') }}">{{ 'common.reset'|trans|auto_translate }}</a>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table admin-table align-middle">
                <thead>
                    <tr>
                        <th>{{ 'common.name'|trans|auto_translate }}</th>
                        <th>{{ 'common.city'|trans|auto_translate }}</th>
                        <th>{{ 'common.address'|trans|auto_translate }}</th>
                        <th>{{ 'common.budget'|trans|auto_translate }}</th>
                        <th>{{ 'common.rooms'|trans|auto_translate }}</th>
                        <th class="text-end">{{ 'common.actions'|trans|auto_translate }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for hotel in hotels %}
                        {% set adminHotelName = translated_hotel_value(hotel, 'nom') %}
                        {% set adminHotelAddress = translated_hotel_value(hotel, 'adresse') %}
                        {% set adminHotelCity = translated_hotel_value(hotel, 'ville') %}
                        <tr>
                            <td class="fw-semibold">{{ adminHotelName }}</td>
                            <td>{{ adminHotelCity }}</td>
                            <td>{{ adminHotelAddress }}</td>
                            <td>{{ hotel.budget ?: '-' }}</td>
                            <td>{{ hotel.chambres|length }}</td>
                            <td class="text-end">
                                <div class="d-inline-flex flex-wrap justify-content-end gap-1">
                                    <a href="{{ path('app_admin_hotels_show', {'id': hotel.id}) }}" class="btn btn-sm btn-pro">
                                        <i class="bi bi-eye me-1"></i>{{ 'common.view'|trans|auto_translate }}
                                    </a>
                                    <a href="{{ path('app_admin_hotels_edit', {'id': hotel.id}) }}" class="btn btn-sm btn-primary-pro">
                                        <i class="bi bi-pencil-square me-1"></i>{{ 'common.edit'|trans|auto_translate }}
                                    </a>
                                    <a href="{{ path('app_admin_chambres_index', {'hotel': hotel.id}) }}" class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-door-open me-1"></i>{{ 'common.rooms'|trans|auto_translate }}
                                    </a>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">{{ 'admin.hotel.index.empty'|trans|auto_translate }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
{% extends 'admin/base_admin.html.twig' %}

{% block title %}{{ 'admin.hotel.show.title'|trans }}{% endblock %}
{% block page_title %}{{ 'admin.hotel.show.page_title'|trans }}{% endblock %}

{% block body %}
{% set adminHotelName = translated_hotel_value(hotel, 'nom') %}
{% set adminHotelAddress = translated_hotel_value(hotel, 'adresse') %}
{% set adminHotelCity = translated_hotel_value(hotel, 'ville') %}
{% set adminHotelDescription = translated_hotel_description(hotel) %}
<div class="row g-4">
    <div class="col-lg-8">
        <div class="admin-card">
            <div class="admin-card-header d-flex justify-content-between align-items-center">
                <span>{{ adminHotelName }}</span>
                <span class="badge bg-success">{{ 'admin.hotel.show.rooms_count'|trans({'%count%': hotel.chambres|length}) }}</span>
            </div>
            <div class="admin-card-body">
                <p><strong>{{ 'common.address'|trans }}:</strong> {{ adminHotelAddress }}</p>
                <p><strong>{{ 'common.city'|trans }}:</strong> {{ adminHotelCity }}</p>
                <p><strong>{{ 'common.stars'|trans }}:</strong> {{ hotel.nombreEtoiles ?: '-' }}</p>
                <p><strong>{{ 'common.budget'|trans }}:</strong> {{ hotel.budget ?: '-' }}</p>
                <p><strong>{{ 'common.description'|trans }}:</strong><br>{{ adminHotelDescription ?: '-' }}</p>

                <h6 class="mt-4 mb-3">{{ 'admin.hotel.show.related_rooms'|trans }}</h6>
                <div class="table-responsive">
                    <table class="table admin-table">
                        <thead>
                            <tr>
                                <th>{{ 'common.type'|trans }}</th>
                                <th>{{ 'common.capacity'|trans }}</th>
                                <th>{{ 'common.price'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for chambre in hotel.chambres %}
                                <tr>
                                    <td>{{ chambre.type }}</td>
                                    <td>{{ chambre.capacite }}</td>
                                    <td>{{ chambre.prixStandard ?: '-' }}</td>
                                </tr>
                            {% else %}
                                <tr><td colspan="3" class="text-muted text-center py-4">{{ 'admin.hotel.show.no_related_rooms'|trans }}</td></tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="admin-card mb-4">
            <div class="admin-card-header">{{ 'common.actions'|trans }}</div>
            <div class="admin-card-body d-grid gap-2">
                <a href="{{ path('app_admin_hotels_edit', {'id': hotel.id}) }}" class="btn btn-primary-pro">
                    <i class="bi bi-pencil-square me-1"></i>{{ 'admin.hotel.actions.edit'|trans }}
                </a>
                <a href="{{ path('app_admin_chambres_index', {'hotel': hotel.id}) }}" class="btn btn-pro">
                    <i class="bi bi-door-open me-1"></i>{{ 'admin.hotel.actions.manage_rooms'|trans }}
                </a>
                <a href="{{ path('app_admin_reservations_index', {'hotel': hotel.id}) }}" class="btn btn-pro">
                    <i class="bi bi-calendar-check me-1"></i>{{ 'admin.hotel.actions.view_reservations'|trans }}
                </a>
                <a href="{{ path('app_admin_hotels_index') }}" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>{{ 'common.back_to_list'|trans }}
                </a>
            </div>
        </div>
        <div class="admin-card">
            <div class="admin-card-header text-danger">{{ 'common.deletion'|trans }}</div>
            <div class="admin-card-body">
                {{ form_start(delete_form) }}
                <button class="btn btn-danger" type="submit" onclick="return confirm('{{ 'admin.hotel.confirm_delete'|trans }}');">{{ 'admin.hotel.actions.delete'|trans }}</button>
                {{ form_end(delete_form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
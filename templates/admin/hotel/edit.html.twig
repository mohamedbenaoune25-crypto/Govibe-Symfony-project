{% extends 'admin/base_admin.html.twig' %}

{% block title %}{{ 'admin.hotel.edit.title'|trans }}{% endblock %}
{% block page_title %}{{ 'admin.hotel.edit.page_title'|trans }}{% endblock %}

{% block body %}
<div class="admin-card mb-4">
    <div class="admin-card-body">
        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
        {% if form.vars.errors|length > 0 %}
            <div class="alert alert-danger" role="alert">
                {{ form_errors(form) }}
            </div>
        {% endif %}
        <div class="row g-3">
            {{ form_row(form.nom, {'attr': {'class': 'form-control'}}) }}
            {{ form_row(form.adresse, {'attr': {'class': 'form-control'}}) }}
            {{ form_row(form.ville, {'attr': {'class': 'form-control'}}) }}
            {{ form_row(form.nombreEtoiles, {'attr': {'class': 'form-control'}}) }}
            {{ form_row(form.budget, {'attr': {'class': 'form-control'}}) }}
            {{ form_row(form.description, {'attr': {'class': 'form-control', 'rows': 5}}) }}
            {{ form_row(form.photoUrl, {'attr': {'class': 'form-control'}}) }}
        </div>
        <div class="mt-4 d-flex gap-2">
            <button class="btn btn-primary-pro" type="submit">
                <i class="bi bi-check2-square me-1"></i>{{ 'common.update'|trans }}
            </button>
            <a href="{{ path('app_admin_hotels_index') }}" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>{{ 'common.back_to_list'|trans }}
            </a>
        </div>
        {{ form_end(form) }}
    </div>
</div>

<div class="admin-card">
    <div class="admin-card-header text-danger">{{ 'common.deletion'|trans }}</div>
    <div class="admin-card-body">
        {{ form_start(delete_form) }}
        <button class="btn btn-danger" type="submit" onclick="return confirm('{{ 'admin.hotel.confirm_delete'|trans }}');">{{ 'admin.hotel.actions.delete'|trans }}</button>
        {{ form_end(delete_form) }}
    </div>
</div>
{% endblock %}
{% extends 'admin/base_admin.html.twig' %}

{% block title %}Modifier un hôtel{% endblock %}
{% block page_title %}Modifier un hôtel{% endblock %}

{% block body %}
<div class="admin-card mb-4">
    <div class="admin-card-body">
        {{ form_start(form) }}
        <div class="row g-3">
            {{ form_row(form.nom, {'attr': {'class': 'form-control'}}) }}
            {{ form_row(form.adresse, {'attr': {'class': 'form-control'}}) }}
            {{ form_row(form.ville, {'attr': {'class': 'form-control'}}) }}
            {{ form_row(form.nombreEtoiles, {'attr': {'class': 'form-control'}}) }}
            {{ form_row(form.budget, {'attr': {'class': 'form-control'}}) }}
            {{ form_row(form.description, {'attr': {'class': 'form-control', 'rows': 5}}) }}
            {{ form_row(form.photoUrl, {'attr': {'class': 'form-control'}}) }}
        </div>
        <div class="mt-4 d-flex gap-2">
            <button class="btn btn-primary-pro" type="submit">
                <i class="bi bi-check2-square me-1"></i>Mettre à jour
            </button>
            <a href="{{ path('app_admin_hotels_index') }}" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Retour à la liste
            </a>
        </div>
        {{ form_end(form) }}
    </div>
</div>

<div class="admin-card">
    <div class="admin-card-header text-danger">Suppression</div>
    <div class="admin-card-body">
        {{ form_start(delete_form) }}
        <button class="btn btn-danger" type="submit" onclick="return confirm('Confirmer la suppression de cet hôtel ?');">Supprimer l'hôtel</button>
        {{ form_end(delete_form) }}
    </div>
</div>
{% endblock %}
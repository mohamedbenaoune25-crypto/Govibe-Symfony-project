{% extends 'admin/base_admin.html.twig' %}

{% block title %}{{ 'admin.chambre.new.title'|trans|auto_translate }}{% endblock %}
{% block page_title %}{{ 'admin.chambre.new.page_title'|trans|auto_translate }}{% endblock %}

{% block body %}
<div class="go-form-page">
    <div class="go-form-card chambre-form-card">
        <div class="go-form-card-header chambre-form-header">
            <h2 class="mb-1 fs-4"><i class="bi bi-door-open me-2"></i>{{ 'admin.chambre.new.heading'|trans|auto_translate }}</h2>
            <p class="mb-0 opacity-75">{{ 'admin.chambre.new.subtitle'|trans|auto_translate }}</p>
        </div>
        <div class="go-form-card-body chambre-form-body">
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

            <section class="form-section mb-4">
                <h5 class="form-section-title"><i class="bi bi-info-circle me-2"></i>{{ 'admin.chambre.form.general_info'|trans|auto_translate }}</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        {{ form_row(form.type, {
                            'label': 'admin.chambre.form.type'|trans|auto_translate,
                            'attr': {
                                'class': 'form-control' ~ (form.vars.submitted and not form.type.vars.valid ? ' is-invalid' : ''),
                                'placeholder': 'admin.chambre.form.type_placeholder'|trans|auto_translate
                            }
                        }) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_row(form.capacite, {
                            'label': 'admin.chambre.form.capacity_people'|trans|auto_translate,
                            'attr': {
                                'class': 'form-control' ~ (form.vars.submitted and not form.capacite.vars.valid ? ' is-invalid' : ''),
                                'min': 1,
                                'placeholder': 'admin.chambre.form.capacity_placeholder'|trans|auto_translate
                            }
                        }) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_row(form.nombreDeChambres, {
                            'label': 'common.number_of_rooms'|trans|auto_translate,
                            'attr': {
                                'class': 'form-control' ~ (form.vars.submitted and not form.nombreDeChambres.vars.valid ? ' is-invalid' : ''),
                                'min': 1,
                                'placeholder': 'admin.chambre.form.number_placeholder'|trans|auto_translate
                            }
                        }) }}
                    </div>
                    <div class="col-12">
                        {{ form_row(form.equipements, {
                            'label': 'common.equipments'|trans|auto_translate,
                            'attr': {
                                'class': 'form-control' ~ (form.vars.submitted and not form.equipements.vars.valid ? ' is-invalid' : ''),
                                'placeholder': 'admin.chambre.form.equipments_placeholder'|trans|auto_translate
                            }
                        }) }}
                    </div>
                </div>
            </section>

            <section class="form-section mb-4">
                <h5 class="form-section-title"><i class="bi bi-cash-stack me-2"></i>{{ 'admin.chambre.form.pricing'|trans|auto_translate }}</h5>
                <div class="row g-3">
                    <div class="col-md-4">
                        {{ form_row(form.prixStandard, {
                            'label': 'common.standard_price'|trans|auto_translate,
                            'attr': {
                                'class': 'form-control' ~ (form.vars.submitted and not form.prixStandard.vars.valid ? ' is-invalid' : ''),
                                'placeholder': '0.00',
                                'step': '0.01',
                                'min': 0
                            }
                        }) }}
                    </div>
                    <div class="col-md-4">
                        {{ form_row(form.prixHauteSaison, {
                            'label': 'common.high_season_price'|trans|auto_translate,
                            'attr': {
                                'class': 'form-control' ~ (form.vars.submitted and not form.prixHauteSaison.vars.valid ? ' is-invalid' : ''),
                                'placeholder': '0.00',
                                'step': '0.01',
                                'min': 0
                            }
                        }) }}
                    </div>
                    <div class="col-md-4">
                        {{ form_row(form.prixBasseSaison, {
                            'label': 'common.low_season_price'|trans|auto_translate,
                            'attr': {
                                'class': 'form-control' ~ (form.vars.submitted and not form.prixBasseSaison.vars.valid ? ' is-invalid' : ''),
                                'placeholder': '0.00',
                                'step': '0.01',
                                'min': 0
                            }
                        }) }}
                    </div>
                </div>
            </section>

            <section class="form-section mb-4">
                <h5 class="form-section-title"><i class="bi bi-building me-2"></i>{{ 'admin.chambre.form.association'|trans|auto_translate }}</h5>
                <div class="row g-3">
                    {% if form.hotel is defined %}
                        <div class="col-12">
                            {{ form_row(form.hotel, {
                                'label': 'admin.chambre.form.associated_hotel'|trans|auto_translate,
                                'attr': {'class': 'form-select' ~ (form.vars.submitted and not form.hotel.vars.valid ? ' is-invalid' : '')}
                            }) }}
                        </div>
                    {% elseif hotel is defined and hotel %}
                        <div class="col-12">
                            <label class="form-label">{{ 'admin.chambre.form.associated_hotel'|trans|auto_translate }}</label>
                            <input type="text" class="form-control" value="{{ translated_hotel_value(hotel, 'nom') }}" readonly>
                        </div>
                    {% endif %}
                </div>
            </section>

            <div class="mt-4 d-flex flex-wrap justify-content-end gap-2">
                <a href="{{ path('app_admin_hotels_index') }}" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>{{ 'admin.chambre.actions.back_hotels'|trans|auto_translate }}
                </a>
                <button class="btn btn-primary-pro" type="submit">
                    <i class="bi bi-check-circle me-1"></i>{{ 'admin.chambre.actions.save'|trans|auto_translate }}
                </button>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.chambre-form-card {
    max-width: 980px;
    margin: 0 auto;
}

.chambre-form-header {
    background: linear-gradient(135deg, var(--admin-primary), #0d5a42);
}

.chambre-form-body {
    background: linear-gradient(180deg, rgba(243, 244, 246, 0.45), #fff 35%);
}

.form-section {
    padding: 18px;
    border: 1px solid #E5E7EB;
    border-radius: 16px;
    background: #fff;
    box-shadow: 0 4px 12px rgba(15, 23, 42, 0.04);
}

.form-section-title {
    color: var(--admin-primary);
    font-weight: 700;
    font-size: 15px;
    margin-bottom: 14px;
}

.chambre-form-body .form-control.is-invalid,
.chambre-form-body .form-select.is-invalid,
.chambre-form-body .form-control.is-invalid:focus,
.chambre-form-body .form-select.is-invalid:focus {
    border-color: #dc3545 !important;
    box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.2) !important;
}

.chambre-form-body .invalid-feedback,
.chambre-form-body .form-error-message {
    color: #b42318;
    font-weight: 600;
}

.chambre-form-body .invalid-feedback ul,
.chambre-form-body .invalid-feedback li,
.chambre-form-body .form-error-message li {
    color: #b42318;
}

.chambre-form-body .invalid-feedback ul,
.chambre-form-body .form-error-message {
    list-style: none;
    margin: 0;
    padding: 0;
}

.chambre-form-body .invalid-feedback li,
.chambre-form-body .form-error-message li {
    margin: 0;
}
</style>
{% endblock %}
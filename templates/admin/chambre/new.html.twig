{% extends 'admin/base_admin.html.twig' %}

{% block title %}{{ 'admin.chambre.new.title'|trans }}{% endblock %}
{% block page_title %}{{ 'admin.chambre.new.page_title'|trans }}{% endblock %}

{% block body %}
<div class="go-form-page">
    <div class="go-form-card chambre-form-card">
        <div class="go-form-card-header chambre-form-header">
            <h2 class="mb-1 fs-4"><i class="bi bi-door-open me-2"></i>{{ 'admin.chambre.new.heading'|trans }}</h2>
            <p class="mb-0 opacity-75">{{ 'admin.chambre.new.subtitle'|trans }}</p>
        </div>
        <div class="go-form-card-body chambre-form-body">
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            {% if form.vars.errors|length > 0 %}
                <div class="alert alert-danger" role="alert">
                    {{ form_errors(form) }}
                </div>
            {% endif %}

            <section class="form-section mb-4">
                <h5 class="form-section-title"><i class="bi bi-info-circle me-2"></i>{{ 'admin.chambre.form.general_info'|trans }}</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        {{ form_row(form.type, {
                            'label': 'admin.chambre.form.type'|trans,
                            'attr': {'class': 'form-control', 'placeholder': 'admin.chambre.form.type_placeholder'|trans}
                        }) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_row(form.capacite, {
                            'label': 'admin.chambre.form.capacity_people'|trans,
                            'attr': {'class': 'form-control', 'min': 1, 'placeholder': 'admin.chambre.form.capacity_placeholder'|trans}
                        }) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_row(form.nombreDeChambres, {
                            'label': 'common.number_of_rooms'|trans,
                            'attr': {'class': 'form-control', 'min': 1, 'placeholder': 'admin.chambre.form.number_placeholder'|trans}
                        }) }}
                    </div>
                    <div class="col-12">
                        {{ form_row(form.equipements, {
                            'label': 'common.equipments'|trans,
                            'attr': {'class': 'form-control', 'placeholder': 'admin.chambre.form.equipments_placeholder'|trans}
                        }) }}
                    </div>
                </div>
            </section>

            <section class="form-section mb-4">
                <h5 class="form-section-title"><i class="bi bi-cash-stack me-2"></i>{{ 'admin.chambre.form.pricing'|trans }}</h5>
                <div class="row g-3">
                    <div class="col-md-4">
                        {{ form_row(form.prixStandard, {
                            'label': 'common.standard_price'|trans,
                            'attr': {'class': 'form-control', 'placeholder': '0.00', 'step': '0.01', 'min': 0}
                        }) }}
                    </div>
                    <div class="col-md-4">
                        {{ form_row(form.prixHauteSaison, {
                            'label': 'common.high_season_price'|trans,
                            'attr': {'class': 'form-control', 'placeholder': '0.00', 'step': '0.01', 'min': 0}
                        }) }}
                    </div>
                    <div class="col-md-4">
                        {{ form_row(form.prixBasseSaison, {
                            'label': 'common.low_season_price'|trans,
                            'attr': {'class': 'form-control', 'placeholder': '0.00', 'step': '0.01', 'min': 0}
                        }) }}
                    </div>
                </div>
            </section>

            <section class="form-section mb-4">
                <h5 class="form-section-title"><i class="bi bi-building me-2"></i>{{ 'admin.chambre.form.association'|trans }}</h5>
                <div class="row g-3">
                    {% if form.hotel is defined %}
                        <div class="col-12">
                            {{ form_row(form.hotel, {
                                'label': 'admin.chambre.form.associated_hotel'|trans,
                                'attr': {'class': 'form-select'}
                            }) }}
                        </div>
                    {% elseif hotel is defined and hotel %}
                        <div class="col-12">
                            <label class="form-label">{{ 'admin.chambre.form.associated_hotel'|trans }}</label>
                            <input type="text" class="form-control" value="{{ translated_hotel_value(hotel, 'nom') }}" readonly>
                        </div>
                    {% endif %}
                </div>
            </section>

            <div class="mt-4 d-flex flex-wrap justify-content-end gap-2">
                <a href="{{ path('app_admin_hotels_index') }}" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>{{ 'admin.chambre.actions.back_hotels'|trans }}
                </a>
                <button class="btn btn-primary-pro" type="submit">
                    <i class="bi bi-check-circle me-1"></i>{{ 'admin.chambre.actions.save'|trans }}
                </button>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.chambre-form-card {
    max-width: 980px;
    margin: 0 auto;
}

.chambre-form-header {
    background: linear-gradient(135deg, var(--admin-primary), #0d5a42);
}

.chambre-form-body {
    background: linear-gradient(180deg, rgba(243, 244, 246, 0.45), #fff 35%);
}

.form-section {
    padding: 18px;
    border: 1px solid #E5E7EB;
    border-radius: 16px;
    background: #fff;
    box-shadow: 0 4px 12px rgba(15, 23, 42, 0.04);
}

.form-section-title {
    color: var(--admin-primary);
    font-weight: 700;
    font-size: 15px;
    margin-bottom: 14px;
}
</style>
{% endblock %}
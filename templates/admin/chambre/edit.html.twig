{% extends 'admin/base_admin.html.twig' %}

{% block title %}{{ 'admin.chambre.edit.title'|trans }}{% endblock %}
{% block page_title %}{{ 'admin.chambre.edit.page_title'|trans }}{% endblock %}

{% block body %}
<div class="admin-card mb-4">
    <div class="admin-card-body">
        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
        {% if form.vars.errors|length > 0 %}
            <div class="alert alert-danger" role="alert">
                {{ form_errors(form) }}
            </div>
        {% endif %}
        <div class="row g-3">
            {{ form_row(form.type, {'attr': {'class': 'form-control'}}) }}
            {{ form_row(form.capacite, {'attr': {'class': 'form-control'}}) }}
            {{ form_row(form.nombreDeChambres, {'attr': {'class': 'form-control'}}) }}
            {{ form_row(form.equipements, {'attr': {'class': 'form-control'}}) }}
            {{ form_row(form.prixStandard, {'attr': {'class': 'form-control'}}) }}
            {{ form_row(form.prixHauteSaison, {'attr': {'class': 'form-control'}}) }}
            {{ form_row(form.prixBasseSaison, {'attr': {'class': 'form-control'}}) }}
            {{ form_row(form.hotel, {'attr': {'class': 'form-select'}}) }}
        </div>
        <div class="mt-4 d-flex gap-2">
            <button class="btn btn-primary-pro" type="submit">{{ 'common.update'|trans }}</button>
            <a href="{{ path('app_admin_hotels_index') }}" class="btn btn-pro">{{ 'admin.chambre.actions.back_hotels'|trans }}</a>
        </div>
        {{ form_end(form) }}
    </div>
</div>

<div class="admin-card">
    <div class="admin-card-header text-danger">{{ 'common.deletion'|trans }}</div>
    <div class="admin-card-body">
        {{ form_start(delete_form) }}
        <button class="btn btn-danger" type="submit">{{ 'common.delete'|trans }}</button>
        {{ form_end(delete_form) }}
    </div>
</div>
{% endblock %}
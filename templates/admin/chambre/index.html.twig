{% extends 'admin/base_admin.html.twig' %}

{% block title %}{{ 'admin.chambre.index.title'|trans|auto_translate }}{% endblock %}
{% block page_title %}{{ 'admin.chambre.index.page_title'|trans|auto_translate }}{% endblock %}

{% block body %}
<div class="admin-card mb-4">
    <div class="admin-card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-door-open me-2 text-muted"></i> {{ 'admin.chambre.index.heading'|trans|auto_translate }}{% if hotel %} {{ 'admin.chambre.index.of_hotel'|trans|auto_translate }} {{ translated_hotel_value(hotel, 'nom') }}{% endif %}</span>
        <div class="d-flex gap-2">
            <a href="{{ path('app_admin_hotels_index') }}" class="btn btn-pro py-1 px-3">{{ 'admin.chambre.actions.back_hotels'|trans|auto_translate }}</a>
            {% if hotel and quick_add_form is defined and quick_add_form %}
                <button type="button" class="btn btn-primary-pro py-1 px-3" data-bs-toggle="modal" data-bs-target="#addChambreModal">
                    {{ 'admin.chambre.actions.add_room'|trans|auto_translate }}
                </button>
            {% else %}
                <a href="{{ path('app_admin_chambres_new') }}" class="btn btn-primary-pro py-1 px-3">{{ 'common.add'|trans|auto_translate }}</a>
            {% endif %}
        </div>
    </div>
    <div class="admin-card-body">
        {% if hotel %}
            <div class="alert alert-info d-flex justify-content-between align-items-center mb-4">
                <span>{{ 'admin.chambre.index.active_filter_hotel'|trans|auto_translate }} <strong>{{ translated_hotel_value(hotel, 'nom') }}</strong></span>
                <a href="{{ path('app_admin_chambres_index') }}" class="btn btn-sm btn-outline-secondary">{{ 'admin.chambre.actions.view_all'|trans|auto_translate }}</a>
            </div>
        {% endif %}
        <form method="get" class="row g-3 align-items-end mb-4">
            <div class="col-md-5">
                <label class="form-label">{{ 'common.search'|trans|auto_translate }}</label>
                <input type="text" name="search" value="{{ search }}" class="form-control" placeholder="{{ 'admin.chambre.index.search_placeholder'|trans|auto_translate }}">
            </div>
            <div class="col-md-3">
                <label class="form-label">{{ 'common.sort_by'|trans|auto_translate }}</label>
                <select name="sortBy" class="form-select">
                    <option value="type" {% if sortBy == 'type' %}selected{% endif %}>{{ 'common.type'|trans|auto_translate }}</option>
                    <option value="capacite" {% if sortBy == 'capacite' %}selected{% endif %}>{{ 'common.capacity'|trans|auto_translate }}</option>
                    <option value="nombreDeChambres" {% if sortBy == 'nombreDeChambres' %}selected{% endif %}>{{ 'common.number_of_rooms'|trans|auto_translate }}</option>
                    <option value="prixStandard" {% if sortBy == 'prixStandard' %}selected{% endif %}>{{ 'common.standard_price'|trans|auto_translate }}</option>
                    <option value="prixHauteSaison" {% if sortBy == 'prixHauteSaison' %}selected{% endif %}>{{ 'common.high_season'|trans|auto_translate }}</option>
                    <option value="prixBasseSaison" {% if sortBy == 'prixBasseSaison' %}selected{% endif %}>{{ 'common.low_season'|trans|auto_translate }}</option>
                    <option value="createdAt" {% if sortBy == 'createdAt' %}selected{% endif %}>{{ 'common.creation'|trans|auto_translate }}</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">{{ 'common.order'|trans|auto_translate }}</label>
                <select name="sortDir" class="form-select">
                    <option value="ASC" {% if sortDir|upper == 'ASC' %}selected{% endif %}>ASC</option>
                    <option value="DESC" {% if sortDir|upper == 'DESC' %}selected{% endif %}>DESC</option>
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                {% if hotel %}
                    <input type="hidden" name="hotel" value="{{ hotel.id }}">
                {% endif %}
                <button class="btn btn-pro w-100" type="submit">{{ 'common.filter'|trans|auto_translate }}</button>
                <a class="btn btn-outline-secondary w-100" href="{{ path('app_admin_chambres_index') }}">{{ 'common.reset'|trans|auto_translate }}</a>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table admin-table align-middle">
                <thead>
                    <tr>
                        <th>{{ 'common.type'|trans|auto_translate }}</th>
                        <th>{{ 'common.hotel'|trans|auto_translate }}</th>
                        <th>{{ 'common.capacity'|trans|auto_translate }}</th>
                        <th>{{ 'common.number_of_rooms'|trans|auto_translate }}</th>
                        <th>{{ 'common.standard_price'|trans|auto_translate }}</th>
                        <th class="text-end">{{ 'common.actions'|trans|auto_translate }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for chambre in chambres %}
                        <tr>
                            <td class="fw-semibold">{{ chambre.type|auto_translate }}</td>
                            <td>{{ chambre.hotel ? translated_hotel_value(chambre.hotel, 'nom') : '-' }}</td>
                            <td>{{ chambre.capacite ?: '-' }}</td>
                            <td>{{ chambre.nombreDeChambres ?: '-' }}</td>
                            <td>{{ chambre.prixStandard ?: '-' }}</td>
                            <td class="text-end">
                                <a href="{{ path('app_admin_chambres_show', {'id': chambre.id}) }}" class="btn btn-sm btn-pro">{{ 'common.view'|trans|auto_translate }}</a>
                                <a href="{{ path('app_admin_chambres_edit', {'id': chambre.id}) }}" class="btn btn-sm btn-primary-pro">{{ 'common.edit'|trans|auto_translate }}</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4" id="empty-chambres-row">{{ 'admin.chambre.index.empty'|trans|auto_translate }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{% if hotel and quick_add_form is defined and quick_add_form %}
    <div class="modal fade" id="addChambreModal" tabindex="-1" aria-labelledby="addChambreModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header quick-add-header">
                    <div>
                        <h5 class="modal-title" id="addChambreModalLabel">{{ 'admin.chambre.actions.add_room'|trans|auto_translate }}</h5>
                        <small class="text-white-50">{{ 'common.hotel'|trans|auto_translate }}: {{ translated_hotel_value(hotel, 'nom') }}</small>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body quick-add-body">
                    <div id="quick-add-error" class="alert alert-danger d-none" role="alert"></div>
                    {{ form_start(quick_add_form, {'attr': {'id': 'quick-add-chambre-form', 'novalidate': 'novalidate'}}) }}

                    <div class="quick-add-section mb-3">
                        <h6 class="quick-add-title"><i class="bi bi-info-circle me-2"></i>{{ 'admin.chambre.form.info'|trans|auto_translate }}</h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                {{ form_row(quick_add_form.type, {
                                    'label': 'admin.chambre.form.type'|trans|auto_translate,
                                    'attr': {'placeholder': 'admin.chambre.form.type_placeholder'|trans|auto_translate}
                                }) }}
                            </div>
                            <div class="col-md-6">
                                {{ form_row(quick_add_form.capacite, {
                                    'label': 'common.capacity'|trans|auto_translate,
                                    'attr': {'min': 1, 'placeholder': 'admin.chambre.form.capacity_placeholder'|trans|auto_translate}
                                }) }}
                            </div>
                            <div class="col-12">
                                {{ form_row(quick_add_form.equipements, {
                                    'label': 'common.equipments'|trans|auto_translate,
                                    'attr': {'placeholder': 'admin.chambre.form.equipments_placeholder'|trans|auto_translate}
                                }) }}
                            </div>
                        </div>
                    </div>

                    <div class="quick-add-section mb-2">
                        <h6 class="quick-add-title"><i class="bi bi-cash-stack me-2"></i>{{ 'admin.chambre.form.pricing'|trans|auto_translate }}</h6>
                        <div class="row g-3">
                            <div class="col-md-4">{{ form_row(quick_add_form.prixStandard, {'label': 'common.standard_price'|trans|auto_translate, 'attr': {'step': '0.01', 'min': 0, 'placeholder': '0.00'}}) }}</div>
                            <div class="col-md-4">{{ form_row(quick_add_form.prixHauteSaison, {'label': 'common.high_season'|trans|auto_translate, 'attr': {'step': '0.01', 'min': 0, 'placeholder': '0.00'}}) }}</div>
                            <div class="col-md-4">{{ form_row(quick_add_form.prixBasseSaison, {'label': 'common.low_season'|trans|auto_translate, 'attr': {'step': '0.01', 'min': 0, 'placeholder': '0.00'}}) }}</div>
                        </div>
                    </div>

                    <div class="mt-4 d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">{{ 'common.cancel'|trans|auto_translate }}</button>
                        <button type="submit" class="btn btn-primary-pro" id="quick-add-submit-btn">{{ 'common.add'|trans|auto_translate }}</button>
                    </div>
                    {{ form_end(quick_add_form) }}
                </div>
            </div>
        </div>
    </div>

    <script>
    document.addEventListener('DOMContentLoaded', function () {
        const form = document.getElementById('quick-add-chambre-form');
        if (!form) {
            return;
        }

        const modalElement = document.getElementById('addChambreModal');
        const modalInstance = bootstrap.Modal.getOrCreateInstance(modalElement);
        const submitButton = document.getElementById('quick-add-submit-btn');
        const errorBox = document.getElementById('quick-add-error');
        const tableBody = document.querySelector('.admin-table tbody');

        const showUrlTemplate = '{{ path('app_admin_chambres_show', {'id': '__id__'}) }}';
        const editUrlTemplate = '{{ path('app_admin_chambres_edit', {'id': '__id__'}) }}';

        const formatValue = (value) => (value === null || value === undefined || value === '' ? '-' : value);
        const fieldSelectors = ['input', 'select', 'textarea'];

        const clearFieldErrors = () => {
            form.querySelectorAll(fieldSelectors.join(',')).forEach((field) => {
                field.classList.remove('is-invalid');
                const parent = field.closest('.mb-3, .col-md-4, .col-md-6, .col-12');
                if (!parent) {
                    return;
                }

                parent.querySelectorAll('.quick-add-inline-error').forEach((node) => node.remove());
            });
        };

        const setFieldErrors = (fieldErrors) => {
            if (!fieldErrors || typeof fieldErrors !== 'object') {
                return;
            }

            Object.entries(fieldErrors).forEach(([fieldName, messages]) => {
                const field = form.querySelector(`[name$="[${fieldName}]"]`);
                if (!field) {
                    return;
                }

                field.classList.add('is-invalid');

                const parent = field.closest('.mb-3, .col-md-4, .col-md-6, .col-12');
                if (!parent) {
                    return;
                }

                const feedback = document.createElement('div');
                feedback.className = 'invalid-feedback d-block quick-add-inline-error';
                feedback.textContent = Array.isArray(messages) && messages.length > 0 ? messages[0] : '{{ 'admin.chambre.index.quick_add_error'|trans|auto_translate }}';
                parent.appendChild(feedback);
            });
        };

        form.addEventListener('submit', async function (event) {
            event.preventDefault();
            submitButton.disabled = true;
            errorBox.classList.add('d-none');
            errorBox.textContent = '';
            clearFieldErrors();

            try {
                const response = await fetch(form.action, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: new FormData(form)
                });

                const payload = await response.json();

                if (!response.ok || !payload.success) {
                    if (payload.fieldErrors) {
                        setFieldErrors(payload.fieldErrors);
                    }

                    throw new Error(payload.message || '{{ 'admin.chambre.index.quick_add_error'|trans|auto_translate }}');
                }

                const emptyRow = document.getElementById('empty-chambres-row');
                if (emptyRow) {
                    emptyRow.closest('tr').remove();
                }

                const chambre = payload.chambre;
                const showUrl = showUrlTemplate.replace('__id__', chambre.id);
                const editUrl = editUrlTemplate.replace('__id__', chambre.id);

                const row = document.createElement('tr');
                row.innerHTML = `
                    <td class="fw-semibold">${formatValue(chambre.type)}</td>
                    <td>${formatValue(chambre.hotel)}</td>
                    <td>${formatValue(chambre.capacite)}</td>
                    <td>${formatValue(chambre.nombreDeChambres)}</td>
                    <td>${formatValue(chambre.prixStandard)}</td>
                    <td class="text-end">
                        <a href="${showUrl}" class="btn btn-sm btn-pro">{{ 'common.view'|trans|auto_translate }}</a>
                        <a href="${editUrl}" class="btn btn-sm btn-primary-pro">{{ 'common.edit'|trans|auto_translate }}</a>
                    </td>
                `;

                if (tableBody) {
                    tableBody.prepend(row);
                }

                form.reset();
                clearFieldErrors();
                modalInstance.hide();
            } catch (error) {
                if (!form.querySelector('.quick-add-inline-error')) {
                    errorBox.textContent = error.message;
                    errorBox.classList.remove('d-none');
                }
            } finally {
                submitButton.disabled = false;
            }
        });
    });
    </script>
{% endif %}

{% if hotel and quick_add_form is defined and quick_add_form %}
    <style>
    .quick-add-header {
        background: linear-gradient(135deg, var(--admin-primary), #0d5a42);
        color: #fff;
        border-bottom: none;
    }

    .quick-add-body {
        background: linear-gradient(180deg, rgba(243, 244, 246, 0.5), #fff 30%);
    }

    .quick-add-section {
        border: 1px solid #E5E7EB;
        border-radius: 14px;
        padding: 14px;
        background: #fff;
    }

    .quick-add-title {
        color: var(--admin-primary);
        font-weight: 700;
        margin-bottom: 12px;
        font-size: 14px;
    }
    </style>
{% endif %}
{% endblock %}
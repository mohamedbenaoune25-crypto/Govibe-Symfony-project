{% extends 'base.html.twig' %}

{% block title %}Ajouter une Chambre - GoVibe{% endblock %}

{% block body %}
<div class="container-fluid py-5">
    <div class="container">
        <!-- Breadcrumb Navigation -->
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb bg-transparent p-0">
                <li class="breadcrumb-item">
                    <a href="{{ path('app_hotel_index') }}" class="text-emerald text-decoration-none">
                        <i class="bi bi-house me-2"></i>Hôtels
                    </a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">
                    Ajouter une Chambre
                </li>
            </ol>
        </nav>
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card form-card shadow-lg border-0">
                    <div class="card-header bg-emerald text-white">
                        <h3 class="mb-0">
                            <i class="bi bi-plus-circle me-2"></i>Ajouter une Nouvelle Chambre
                        </h3>
                    </div>
                    <div class="card-body p-4">
                        {{ include('chambre/_form.html.twig') }}
                    </div>
                    <div class="card-footer bg-light">
                        <div class="d-flex justify-content-between">
                            <a href="{{ path('app_hotel_index') }}" class="btn btn-outline-info">
                                <i class="bi bi-building me-2"></i>Voir les hôtels
                            </a>
                            <a href="{{ path('app_chambre_index') }}" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-2"></i>Retour à la liste
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.bg-emerald {
    background-color: var(--primary-emerald) !important;
}

.form-card {
    background: var(--glass-card);
    backdrop-filter: blur(10px);
    border-radius: 15px;
}

.form-control:focus {
    border-color: var(--primary-emerald);
    box-shadow: 0 0 0 0.2rem rgba(34, 197, 94, 0.25);
}

.btn-primary {
    background-color: var(--primary-emerald);
    border-color: var(--primary-emerald);
}

.btn-primary:hover {
    background-color: var(--accent-green);
    border-color: var(--accent-green);
}
</style>
{% endblock %}
{% extends 'base.html.twig' %}

{% block title %}{{ 'chambre.index.meta_title'|trans }}{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Manrope:wght@200..800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
<style>
body { font-family: 'Manrope', sans-serif !important; background: #fcf9f8 !important; }
.material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24; }

/* ─── Hero ─── */
.gv-ch-hero {
    position: relative; padding: 170px 0 110px;
    background: linear-gradient(160deg, #00342d 0%, #013220 40%, #001a12 100%);
    overflow: hidden; text-align: center; border-radius: 0 0 3rem 3rem;
    box-shadow: 0 20px 50px rgba(0,52,45,0.15);
}
.gv-ch-hero::before { content:''; position:absolute; inset:0; background: radial-gradient(ellipse at 30% 80%, rgba(16,185,129,0.15) 0%, transparent 60%), radial-gradient(ellipse at 80% 20%, rgba(233,193,118,0.08) 0%, transparent 50%); pointer-events:none; }
.gv-ch-hero::after { content:''; position:absolute; inset:0; background-image: radial-gradient(rgba(160,242,225,0.06) 1px, transparent 1px); background-size:24px 24px; pointer-events:none; }
.gv-hero-icon-bg { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); font-size:20rem; color:rgba(255,255,255,0.02); pointer-events:none; font-variation-settings:'FILL' 1; }

.gv-hero-breadcrumb { display:inline-flex; align-items:center; gap:0.5rem; padding:0.4rem 1rem; border-radius:2rem; font-size:0.72rem; font-weight:700; color:rgba(255,255,255,0.9); background:rgba(160,242,225,0.1); border:1px solid rgba(160,242,225,0.15); backdrop-filter:blur(8px); letter-spacing:0.05em; text-transform:uppercase; margin-bottom:1rem; position:relative; z-index:2; }
.gv-hero-breadcrumb a { color:rgba(255,255,255,0.8); text-decoration:none; }
.gv-hero-breadcrumb a:hover { color:#a0f2e1; }
.gv-hero-breadcrumb .accent { color:#a0f2e1; }

.gv-hero-title { font-family:'Noto Serif',serif; font-size:clamp(2.2rem,4.5vw,3.5rem); color:#fff; font-weight:700; margin-bottom:0.75rem; position:relative; z-index:2; animation:heroFadeIn 0.8s ease both; }
.gv-hero-title em { color:#a0f2e1; font-style:italic; font-weight:300; }
.gv-hero-sub { color:rgba(160,242,225,0.7); font-size:1.05rem; position:relative; z-index:2; animation:heroFadeIn 0.8s ease 0.2s both; max-width:550px; margin:0 auto; }
@keyframes heroFadeIn { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }

/* ─── Container ─── */
.gv-container { max-width:1200px; margin:-45px auto 80px; position:relative; z-index:10; padding:0 2rem; }

/* ─── Search ─── */
.gv-search-card {
    background:rgba(255,255,255,0.97); backdrop-filter:blur(20px) saturate(180%);
    border:1px solid rgba(0,52,45,0.06); border-radius:1.25rem; padding:1.5rem 2rem;
    box-shadow:0 15px 40px rgba(0,52,45,0.06); margin-bottom:2rem;
}
.gv-search-card .form-label { font-weight:700; color:#00342d; font-size:0.78rem; text-transform:uppercase; letter-spacing:0.06em; }
.gv-search-card .form-control, .gv-search-card .form-select {
    border:1.5px solid rgba(0,52,45,0.08); border-radius:0.7rem; padding:0.7rem 1rem;
    font-family:'Manrope',sans-serif; font-weight:500; font-size:0.9rem; transition:all 0.25s;
}
.gv-search-card .form-control:focus, .gv-search-card .form-select:focus { border-color:#10B981; box-shadow:0 0 0 3px rgba(16,185,129,0.12); }
.gv-search-btn { padding:0.7rem 1.25rem; background:linear-gradient(135deg,#00342d,#046b5e); color:#fff; border:none; border-radius:0.7rem; cursor:pointer; transition:all 0.3s; box-shadow:0 4px 12px rgba(0,52,45,0.2); }
.gv-search-btn:hover { transform:translateY(-2px); box-shadow:0 8px 20px rgba(0,52,45,0.3); }
.gv-reset-link { padding:0.7rem 1.25rem; border-radius:0.7rem; border:1.5px solid rgba(0,52,45,0.08); color:#546067; text-decoration:none; font-weight:700; font-size:0.85rem; display:inline-flex; align-items:center; gap:0.3rem; transition:all 0.25s; }
.gv-reset-link:hover { border-color:rgba(0,52,45,0.2); background:rgba(0,52,45,0.03); color:#00342d; }

/* ─── Cards ─── */
.gv-card-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(340px,1fr)); gap:1.75rem; }
@media (max-width:768px) { .gv-card-grid { grid-template-columns:1fr; } }

.gv-ch-card {
    background:rgba(255,255,255,0.97); backdrop-filter:blur(20px) saturate(180%);
    border:1px solid rgba(0,52,45,0.06); border-radius:1.25rem; overflow:hidden;
    box-shadow:0 12px 35px rgba(0,52,45,0.06); transition:all 0.35s;
    display:flex; flex-direction:column;
}
.gv-ch-card:hover { transform:translateY(-6px); box-shadow:0 24px 50px rgba(0,52,45,0.12); }

.gv-ch-card-body { padding:1.5rem; flex:1; display:flex; flex-direction:column; }

.gv-ch-card-top { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:1rem; }
.gv-ch-type { font-family:'Noto Serif',serif; font-weight:700; color:#00342d; font-size:1.15rem; }
.gv-hotel-badge { display:inline-flex; align-items:center; gap:0.3rem; padding:0.35rem 0.85rem; border-radius:2rem; font-size:0.72rem; font-weight:700; background:linear-gradient(135deg,#00342d,#046b5e); color:#fff; text-decoration:none; transition:all 0.25s; }
.gv-hotel-badge:hover { transform:translateY(-1px); box-shadow:0 4px 10px rgba(0,52,45,0.2); color:#fff; }

.gv-ch-detail { display:flex; align-items:center; gap:0.5rem; margin-bottom:0.5rem; font-size:0.9rem; color:#3c494f; }
.gv-ch-detail .material-symbols-outlined { font-size:1rem; color:#10B981; }

.gv-ch-prices { margin-top:auto; padding-top:1rem; border-top:1px solid rgba(0,52,45,0.05); }
.gv-ch-price-row { display:flex; justify-content:space-between; align-items:center; padding:0.35rem 0; }
.gv-ch-price-label { font-size:0.82rem; color:#546067; }
.gv-ch-price-val { font-weight:700; font-size:0.95rem; }
.gv-ch-price-standard { color:#10B981; }
.gv-ch-price-high { color:#e9c176; }
.gv-ch-price-low { color:#5aa7cc; }

.gv-ch-card-footer { padding:0 1.5rem 1.5rem; display:flex; justify-content:space-between; gap:0.5rem; }
.gv-action-sm { padding:0.5rem 1rem; border-radius:0.6rem; font-weight:700; font-size:0.8rem; text-decoration:none; display:inline-flex; align-items:center; gap:0.3rem; transition:all 0.25s; font-family:'Manrope',sans-serif; }
.gv-action-view { background:rgba(0,52,45,0.06); color:#00342d; }
.gv-action-view:hover { background:#00342d; color:#fff; }
.gv-action-hotel-link { background:rgba(16,185,129,0.08); color:#005046; }
.gv-action-hotel-link:hover { background:#10B981; color:#fff; }

/* ─── Empty ─── */
.gv-empty { text-align:center; padding:5rem 2rem; background:#fff; border-radius:1.5rem; box-shadow:0 20px 50px rgba(0,0,0,0.04); grid-column:1/-1; }
.gv-empty-icon { font-size:4rem; color:#cde1db; margin-bottom:1rem; font-variation-settings:'FILL' 1; }
.gv-empty h4 { font-family:'Noto Serif',serif; font-size:1.4rem; color:#00342d; font-weight:700; margin-bottom:0.5rem; }
.gv-empty p { color:#546067; }

/* ─── Reveal ─── */
.gv-reveal { opacity:0; transform:translateY(25px); transition:opacity 0.6s ease, transform 0.6s ease; }
.gv-reveal.is-visible { opacity:1; transform:translateY(0); }
</style>
{% endblock %}

{% block body %}
<div class="gv-ch-hero">
    <span class="material-symbols-outlined gv-hero-icon-bg">door_open</span>
    <div class="container">
        <div class="gv-hero-breadcrumb">
            <a href="{{ path('app_hotel_index') }}">
                <span class="material-symbols-outlined" style="font-size:0.9rem;">apartment</span> {{ 'nav.hotels'|trans }}
            </a>
            <span class="material-symbols-outlined" style="font-size:0.7rem; opacity:0.5;">chevron_right</span>
            <span class="accent">{{ 'common.rooms'|trans }}</span>
        </div>
        <h1 class="gv-hero-title">{{ 'chambre.index.hero_title_prefix'|trans }} <em>{{ 'chambre.index.hero_title_emphasis'|trans }}</em></h1>
        <p class="gv-hero-sub">{{ 'chambre.index.hero_subtitle'|trans }}</p>
    </div>
</div>

<div class="gv-container">
    <!-- Search -->
    <div class="gv-search-card">
        <form method="GET" action="{{ path('app_chambre_index') }}" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label for="search" class="form-label">
                    <span class="material-symbols-outlined" style="font-size:0.95rem; vertical-align:-2px; color:#10B981;">search</span> {{ 'common.search'|trans }}
                </label>
                <input type="text" class="form-control" id="search" name="search" placeholder="{{ 'chambre.index.search_placeholder'|trans }}" value="{{ search }}">
            </div>
            <div class="col-md-3">
                <label for="sortBy" class="form-label">
                    <span class="material-symbols-outlined" style="font-size:0.95rem; vertical-align:-2px; color:#10B981;">sort</span> {{ 'common.sort_by'|trans }}
                </label>
                <select class="form-select" id="sortBy" name="sortBy">
                    <option value="type" {% if sortBy == 'type' %}selected{% endif %}>{{ 'chambre.index.sort_type'|trans }}</option>
                    <option value="capacite" {% if sortBy == 'capacite' %}selected{% endif %}>{{ 'common.capacity'|trans }}</option>
                    <option value="nombreDeChambres" {% if sortBy == 'nombreDeChambres' %}selected{% endif %}>{{ 'common.number_of_rooms'|trans }}</option>
                    <option value="prixStandard" {% if sortBy == 'prixStandard' %}selected{% endif %}>{{ 'common.standard_price'|trans }}</option>
                    <option value="prixHauteSaison" {% if sortBy == 'prixHauteSaison' %}selected{% endif %}>{{ 'common.high_season_price'|trans }}</option>
                    <option value="prixBasseSaison" {% if sortBy == 'prixBasseSaison' %}selected{% endif %}>{{ 'common.low_season_price'|trans }}</option>
                    <option value="createdAt" {% if sortBy == 'createdAt' %}selected{% endif %}>{{ 'common.creation_date'|trans }}</option>
                </select>
            </div>
            <div class="col-md-2">
                <label for="sortDir" class="form-label">
                    <span class="material-symbols-outlined" style="font-size:0.95rem; vertical-align:-2px; color:#10B981;">swap_vert</span> {{ 'common.order'|trans }}
                </label>
                <select class="form-select" id="sortDir" name="sortDir">
                    <option value="ASC" {% if sortDir == 'ASC' %}selected{% endif %}>{{ 'common.ascending'|trans }} ↑</option>
                    <option value="DESC" {% if sortDir == 'DESC' %}selected{% endif %}>{{ 'common.descending'|trans }} ↓</option>
                </select>
            </div>
            <div class="col-md-1">
                <button type="submit" class="gv-search-btn w-100">
                    <span class="material-symbols-outlined" style="font-size:1.2rem;">search</span>
                </button>
            </div>
            {% if search or sortBy != 'type' or sortDir != 'ASC' %}
            <div class="col-md-1">
                <a href="{{ path('app_chambre_index') }}" class="gv-reset-link w-100 text-center">
                    <span class="material-symbols-outlined" style="font-size:1rem;">refresh</span>
                </a>
            </div>
            {% endif %}
        </form>
    </div>

    <!-- Cards -->
    <div class="gv-card-grid">
        {% for chambre in chambres %}
        {% set roomHotelName = translated_hotel_value(chambre.hotel, 'nom') %}
        <div class="gv-ch-card gv-reveal">
            <div class="gv-ch-card-body">
                <div class="gv-ch-card-top">
                    <span class="gv-ch-type">{{ chambre.type }}</span>
                    <a href="{{ path('app_hotel_show', {'id': chambre.hotel.id}) }}" class="gv-hotel-badge" title="{{ 'chambre.index.view_hotel_title'|trans }}">
                        <span class="material-symbols-outlined" style="font-size:0.85rem;">apartment</span>
                        {{ roomHotelName }}
                    </a>
                </div>

                <div class="gv-ch-detail">
                    <span class="material-symbols-outlined">group</span>
                    {{ 'common.capacity'|trans }} : <strong>{{ 'chambre.index.people_count'|trans({'%count%': chambre.capacite}) }}</strong>
                </div>
                <div class="gv-ch-detail">
                    <span class="material-symbols-outlined">meeting_room</span>
                    {{ 'common.number_of_rooms'|trans }} : <strong>{{ chambre.nombreDeChambres }}</strong>
                </div>
                {% if chambre.equipements %}
                <div class="gv-ch-detail">
                    <span class="material-symbols-outlined">build</span>
                    {{ chambre.equipements }}
                </div>
                {% endif %}

                <div class="gv-ch-prices">
                    {% if chambre.prixStandard %}
                    <div class="gv-ch-price-row">
                        <span class="gv-ch-price-label">{{ 'common.standard_price'|trans }}</span>
                        <span class="gv-ch-price-val gv-ch-price-standard">{{ chambre.prixStandard }}€</span>
                    </div>
                    {% endif %}
                    {% if chambre.prixHauteSaison %}
                    <div class="gv-ch-price-row">
                        <span class="gv-ch-price-label">{{ 'common.high_season'|trans }}</span>
                        <span class="gv-ch-price-val gv-ch-price-high">{{ chambre.prixHauteSaison }}€</span>
                    </div>
                    {% endif %}
                    {% if chambre.prixBasseSaison %}
                    <div class="gv-ch-price-row">
                        <span class="gv-ch-price-label">{{ 'common.low_season'|trans }}</span>
                        <span class="gv-ch-price-val gv-ch-price-low">{{ chambre.prixBasseSaison }}€</span>
                    </div>
                    {% endif %}
                </div>
            </div>
            <div class="gv-ch-card-footer">
                <a href="{{ path('app_chambre_show', {'id': chambre.id}) }}" class="gv-action-sm gv-action-view">
                    <span class="material-symbols-outlined" style="font-size:0.9rem;">visibility</span> {{ 'common.view_details'|trans }}
                </a>
                <a href="{{ path('app_hotel_show', {'id': chambre.hotel.id}) }}" class="gv-action-sm gv-action-hotel-link">
                    <span class="material-symbols-outlined" style="font-size:0.9rem;">apartment</span> {{ 'chambre.index.associated_hotel'|trans }}
                </a>
            </div>
        </div>
        {% else %}
        <div class="gv-empty">
            <span class="material-symbols-outlined gv-empty-icon">door_open</span>
            <h4>{{ 'chambre.index.empty_title'|trans }}</h4>
            <p>{{ 'chambre.index.empty_subtitle'|trans }}</p>
        </div>
        {% endfor %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    var reveals = document.querySelectorAll('.gv-reveal');
    if (reveals.length) {
        var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
                if (entry.isIntersecting) { entry.target.classList.add('is-visible'); observer.unobserve(entry.target); }
            });
        }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });
        reveals.forEach(function(el, i) { el.style.transitionDelay = (i * 80) + 'ms'; observer.observe(el); });
    }
});
</script>
{% endblock %}
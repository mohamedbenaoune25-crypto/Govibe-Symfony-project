{% extends 'base.html.twig' %}

{% block title %}Connexion | GoVibe — Curated Odyssey{% endblock %}

{% block header %}{% endblock %}
{% block footer %}{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
<style>
    /* ═══════════════════════════════════════════════════
       GoVibe Auth — Ultra Futuristic 3D Design
       Premium luxury travel login experience
    ═══════════════════════════════════════════════════ */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
        font-family: 'Manrope', sans-serif !important;
        background: linear-gradient(135deg, #0a1a14 0%, #00261c 50%, #0d0d0d 100%) !important;
        min-height: 100vh !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        padding: 1rem !important;
        overflow-x: hidden !important;
        margin: 0 !important;
    }

    /* ─── Animated Background Grid ─── */
    .auth-bg-grid {
        position: fixed;
        top: 0; left: 0; width: 200%; height: 200%;
        background-size: 60px 60px;
        background-image:
            linear-gradient(to right, rgba(16, 185, 129, 0.04) 1px, transparent 1px),
            linear-gradient(to bottom, rgba(16, 185, 129, 0.04) 1px, transparent 1px);
        transform: perspective(600px) rotateX(55deg) translateY(-80px) translateZ(-300px);
        animation: authGridFlow 25s linear infinite;
        z-index: 0;
        pointer-events: none;
    }
    @keyframes authGridFlow {
        0% { transform: perspective(600px) rotateX(55deg) translateY(0) translateZ(-300px); }
        100% { transform: perspective(600px) rotateX(55deg) translateY(60px) translateZ(-300px); }
    }

    /* ─── Floating Orbs ─── */
    .auth-orb {
        position: fixed;
        border-radius: 50%;
        filter: blur(100px);
        opacity: 0.35;
        z-index: 0;
        pointer-events: none;
    }
    .auth-orb-1 { width: 500px; height: 500px; background: radial-gradient(circle, #10B981, #064E3B); top: -5%; left: -5%; animation: orbDrift1 12s ease-in-out infinite alternate; }
    .auth-orb-2 { width: 350px; height: 350px; background: radial-gradient(circle, #fbbf24, #92400e); bottom: -10%; right: -5%; animation: orbDrift2 15s ease-in-out infinite alternate; }
    .auth-orb-3 { width: 200px; height: 200px; background: radial-gradient(circle, #06b6d4, #0e7490); top: 50%; right: 20%; animation: orbDrift3 10s ease-in-out infinite alternate; }
    @keyframes orbDrift1 { 0% { transform: translate(0, 0) scale(1); } 100% { transform: translate(40px, 30px) scale(1.08); } }
    @keyframes orbDrift2 { 0% { transform: translate(0, 0) scale(1); } 100% { transform: translate(-30px, -40px) scale(1.12); } }
    @keyframes orbDrift3 { 0% { transform: translate(0, 0) scale(1); } 100% { transform: translate(20px, -20px) scale(0.9); } }

    /* ─── Main Container ─── */
    .auth-main {
        width: 100%;
        max-width: 1100px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        border-radius: 2rem;
        overflow: hidden;
        box-shadow:
            0 50px 100px -20px rgba(0, 0, 0, 0.6),
            0 0 0 1px rgba(255, 255, 255, 0.05),
            inset 0 1px 0 0 rgba(255, 255, 255, 0.05);
        position: relative;
        z-index: 10;
        transform: translateY(20px);
        opacity: 0;
        animation: authCardReveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
    }
    @keyframes authCardReveal {
        to { transform: translateY(0); opacity: 1; }
    }
    @media (max-width: 768px) {
        .auth-main { grid-template-columns: 1fr; max-width: 480px; }
    }

    /* ─── Left Panel: Editorial ─── */
    .auth-editorial {
        background: linear-gradient(160deg, #00342d 0%, #013220 40%, #001a12 100%);
        padding: 3rem;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        position: relative;
        overflow: hidden;
    }
    @media (max-width: 768px) { .auth-editorial { display: none; } }

    .auth-editorial::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at 30% 80%, rgba(16, 185, 129, 0.15) 0%, transparent 60%),
                    radial-gradient(ellipse at 80% 20%, rgba(251, 191, 36, 0.08) 0%, transparent 50%);
        pointer-events: none;
    }

    .editorial-brand {
        position: relative; z-index: 2;
        font-family: 'Noto Serif', serif;
        font-weight: 700;
        font-style: italic;
        font-size: 1.75rem;
        color: #fff;
        letter-spacing: -0.02em;
    }

    .editorial-content {
        position: relative; z-index: 2;
    }
    .editorial-title {
        font-family: 'Noto Serif', serif;
        font-size: 2.75rem;
        line-height: 1.15;
        color: #fff;
        font-weight: 700;
        margin-bottom: 1rem;
    }
    .editorial-title em {
        color: #a0f2e1;
        font-style: italic;
    }
    .editorial-desc {
        color: rgba(160, 242, 225, 0.6);
        font-size: 1.05rem;
        line-height: 1.6;
        max-width: 320px;
    }

    .editorial-hero-img {
        position: absolute;
        right: -15%;
        top: 15%;
        width: 130%;
        height: 75%;
        object-fit: cover;
        mix-blend-mode: luminosity;
        opacity: 0.25;
        border-radius: 0 0 0 8rem;
        pointer-events: none;
        mask-image: linear-gradient(to left, black 30%, transparent 100%);
        -webkit-mask-image: linear-gradient(to left, black 30%, transparent 100%);
    }

    .editorial-dots {
        position: relative; z-index: 2;
        display: flex; gap: 0.5rem;
    }
    .editorial-dots span {
        height: 4px; border-radius: 4px; background: rgba(160, 242, 225, 0.25); transition: all 0.3s ease;
    }
    .editorial-dots span:first-child { width: 3rem; background: #a0f2e1; }
    .editorial-dots span:nth-child(2) { width: 1rem; }
    .editorial-dots span:nth-child(3) { width: 1rem; }

    /* ─── Right Panel: Form ─── */
    .auth-form-panel {
        background: rgba(252, 249, 248, 0.97);
        padding: 3rem 3.5rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
    }
    @media (max-width: 768px) {
        .auth-form-panel { padding: 2rem 1.5rem; }
    }

    .auth-form-inner {
        max-width: 400px;
        width: 100%;
        margin: 0 auto;
    }

    .auth-form-title {
        font-family: 'Noto Serif', serif;
        font-size: 2.25rem;
        font-weight: 700;
        color: #1c1b1b;
        margin-bottom: 0.5rem;
    }
    .auth-form-subtitle {
        color: #707975;
        font-size: 0.95rem;
        margin-bottom: 2.5rem;
        line-height: 1.5;
    }

    /* ─── Form Fields ─── */
    .gv-field { margin-bottom: 1.5rem; }
    .gv-field-label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.8rem;
        font-weight: 700;
        color: #3f4945;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.5rem;
    }
    .gv-field-label .material-symbols-outlined { font-size: 1.1rem; color: #707975; }

    .gv-input {
        width: 100%;
        padding: 1rem 1.25rem;
        background: #e5e2e1;
        border: 2px solid transparent;
        border-radius: 0.75rem;
        font-size: 1rem;
        color: #1c1b1b;
        font-family: 'Manrope', sans-serif;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        outline: none;
    }
    .gv-input::placeholder { color: rgba(112, 121, 117, 0.5); }
    .gv-input:focus {
        background: #fff;
        border-color: rgba(0, 52, 45, 0.15);
        box-shadow: 0 0 0 4px rgba(0, 52, 45, 0.06);
    }

    .gv-input-wrap {
        position: relative;
    }
    .gv-pwd-toggle {
        position: absolute;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: #707975;
        cursor: pointer;
        padding: 0;
        display: flex;
        transition: color 0.2s ease;
    }
    .gv-pwd-toggle:hover { color: #00342d; }

    .gv-field-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 0.5rem;
    }
    .gv-forgot-link {
        font-size: 0.8rem;
        font-weight: 700;
        color: #00342d;
        text-decoration: none;
        transition: color 0.2s ease;
    }
    .gv-forgot-link:hover { color: #046b5e; text-decoration: underline; }

    /* ─── Checkbox ─── */
    .gv-check-row {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1.5rem;
    }
    .gv-check-row input[type="checkbox"] {
        width: 1.15rem; height: 1.15rem;
        border-radius: 0.25rem;
        border: 2px solid #bfc9c4;
        accent-color: #00342d;
        cursor: pointer;
    }
    .gv-check-row label {
        font-size: 0.85rem;
        color: #3f4945;
        cursor: pointer;
        margin-bottom: 0;
    }

    /* ─── Primary Button ─── */
    .gv-btn-primary {
        width: 100%;
        padding: 1.1rem;
        background: linear-gradient(135deg, #00342d 0%, #004d43 70%, #046b5e 100%);
        color: #fff;
        border: none;
        border-radius: 0.75rem;
        font-size: 1.05rem;
        font-weight: 700;
        font-family: 'Manrope', sans-serif;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow:
            0 12px 28px -8px rgba(0, 52, 45, 0.4),
            inset 0 1px 0 0 rgba(160, 242, 225, 0.15);
        position: relative;
        overflow: hidden;
    }
    .gv-btn-primary::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, transparent 0%, rgba(255,255,255,0.08) 50%, transparent 100%);
        transform: translateX(-100%);
        transition: transform 0.6s ease;
    }
    .gv-btn-primary:hover::before { transform: translateX(100%); }
    .gv-btn-primary:hover {
        transform: translateY(-2px) scale(1.01);
        box-shadow: 0 18px 40px -10px rgba(0, 52, 45, 0.5);
    }
    .gv-btn-primary:active { transform: translateY(0) scale(0.99); }

    /* ─── Divider ─── */
    .gv-divider {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin: 2rem 0;
    }
    .gv-divider::before, .gv-divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: rgba(191, 201, 196, 0.4);
    }
    .gv-divider span {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: #bfc9c4;
    }

    /* ─── Social Buttons ─── */
    .gv-social-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }
    .gv-social-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.6rem;
        padding: 0.9rem;
        border: 1.5px solid rgba(191, 201, 196, 0.4);
        border-radius: 0.75rem;
        background: transparent;
        cursor: pointer;
        font-weight: 700;
        font-size: 0.9rem;
        color: #1c1b1b;
        font-family: 'Manrope', sans-serif;
        transition: all 0.2s ease;
    }
    .gv-social-btn:hover {
        background: rgba(0, 52, 45, 0.04);
        border-color: rgba(0, 52, 45, 0.2);
    }
    .gv-social-btn .material-symbols-outlined {
        font-size: 1.2rem;
        font-variation-settings: 'FILL' 1;
    }

    /* ─── Footer Links ─── */
    .gv-auth-footer {
        text-align: center;
        margin-top: 2rem;
        font-size: 0.9rem;
        color: #707975;
    }
    .gv-auth-footer a {
        color: #00342d;
        font-weight: 800;
        text-decoration: none;
        margin-left: 0.25rem;
        transition: color 0.2s ease;
    }
    .gv-auth-footer a:hover { text-decoration: underline; color: #046b5e; }

    .gv-bottom-links {
        position: absolute;
        bottom: 1.5rem;
        left: 0;
        right: 0;
        display: flex;
        justify-content: center;
        gap: 1.5rem;
    }
    .gv-bottom-links a {
        font-size: 0.6rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: #bfc9c4;
        text-decoration: none;
        transition: color 0.2s ease;
    }
    .gv-bottom-links a:hover { color: #00342d; }

    /* ─── Alerts ─── */
    .gv-alert {
        padding: 0.85rem 1rem;
        border-radius: 0.75rem;
        font-size: 0.85rem;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .gv-alert-error {
        background: rgba(186, 26, 26, 0.08);
        border: 1px solid rgba(186, 26, 26, 0.2);
        color: #93000a;
    }
    .gv-alert-success {
        background: rgba(16, 185, 129, 0.08);
        border: 1px solid rgba(16, 185, 129, 0.2);
        color: #005046;
    }

    /* ─── Particle Canvas ─── */
    #authParticles {
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100%;
        z-index: 1;
        pointer-events: none;
    }

    /* Override base template form styles */
    .auth-form-panel form { animation: none !important; }
    .auth-form-panel form .form-label { all: unset; }
    .auth-form-panel form .form-control { all: unset; }
    .auth-form-panel form input[type="email"],
    .auth-form-panel form input[type="password"] {
        all: unset;
        width: 100%;
        padding: 1rem 1.25rem;
        background: #e5e2e1;
        border: 2px solid transparent;
        border-radius: 0.75rem;
        font-size: 1rem;
        color: #1c1b1b;
        font-family: 'Manrope', sans-serif;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-sizing: border-box;
    }
    .auth-form-panel form input[type="email"]:focus,
    .auth-form-panel form input[type="password"]:focus {
        background: #fff;
        border-color: rgba(0, 52, 45, 0.15);
        box-shadow: 0 0 0 4px rgba(0, 52, 45, 0.06);
        outline: none;
    }
    .auth-form-panel form input::placeholder { color: rgba(112, 121, 117, 0.5); }

    /* Hide base template navbar stuff */
    .govibe-navbar, .govibe-footer, .container.position-relative { display: none !important; }
    .floating-element { display: none !important; }
</style>
{% endblock %}

{% block body %}
<!-- Background Effects -->
<div class="auth-bg-grid"></div>
<div class="auth-orb auth-orb-1"></div>
<div class="auth-orb auth-orb-2"></div>
<div class="auth-orb auth-orb-3"></div>
<canvas id="authParticles"></canvas>

<main class="auth-main">
    <!-- Left Side: Editorial 3D Illustration -->
    <div class="auth-editorial">
        <div class="editorial-brand">GoVibe</div>

        <div class="editorial-content">
            <h2 class="editorial-title">Your next <em>odyssey</em> begins here.</h2>
            <p class="editorial-desc">Curated experiences for the sophisticated traveler. Step into a world of seamless luxury.</p>
        </div>

        <img src="{{ asset('images/auth-hero-3d.png') }}" alt="Luxury travel 3D illustration" class="editorial-hero-img">

        <div class="editorial-dots">
            <span></span>
            <span></span>
            <span></span>
        </div>
    </div>

    <!-- Right Side: Login Form -->
    <div class="auth-form-panel">
        <div class="auth-form-inner">
            <h3 class="auth-form-title">Bon Retour</h3>
            <p class="auth-form-subtitle">Veuillez entrer vos identifiants pour accéder à votre espace.</p>

            {% for message in app.flashes('success') %}
                <div class="gv-alert gv-alert-success">
                    <span class="material-symbols-outlined" style="font-size:1.1rem;">check_circle</span>
                    {{ message }}
                </div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="gv-alert gv-alert-error">
                    <span class="material-symbols-outlined" style="font-size:1.1rem;">error</span>
                    {{ message }}
                </div>
            {% endfor %}
            {% if error %}
                <div class="gv-alert gv-alert-error">
                    <span class="material-symbols-outlined" style="font-size:1.1rem;">warning</span>
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <form method="post" action="{{ path('app_login') }}">
                <div class="gv-field">
                    <label class="gv-field-label" for="inputEmail">
                        <span class="material-symbols-outlined">mail</span> Adresse Email
                    </label>
                    <input type="email" value="{{ last_username }}" name="_username" id="inputEmail" class="gv-input" autocomplete="email" required autofocus placeholder="voyageur@govibe.com">
                </div>

                <div class="gv-field">
                    <div style="display:flex; justify-content:space-between; align-items:center;">
                        <label class="gv-field-label" for="inputPassword" style="margin-bottom:0;">
                            <span class="material-symbols-outlined">lock</span> Mot de passe
                        </label>
                        <a href="{{ path('app_forgot_password') }}" class="gv-forgot-link">Mot de passe oublié ?</a>
                    </div>
                    <div class="gv-input-wrap" style="margin-top:0.5rem;">
                        <input type="password" name="_password" id="inputPassword" class="gv-input" autocomplete="current-password" required placeholder="••••••••">
                        <button type="button" class="gv-pwd-toggle" onclick="togglePwd('inputPassword', this)">
                            <span class="material-symbols-outlined">visibility</span>
                        </button>
                    </div>
                </div>

                <div class="gv-check-row">
                    <input type="checkbox" id="remember">
                    <label for="remember">Rester connecté pendant 30 jours</label>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <button type="submit" class="gv-btn-primary">
                    Connexion à GoVibe
                    <span class="material-symbols-outlined" style="font-size:1.2rem;">arrow_forward</span>
                </button>
            </form>

            <div class="gv-divider"><span>Ou continuer avec</span></div>

            <div class="gv-social-row">
                <button class="gv-social-btn" type="button">
                    <span class="material-symbols-outlined">google</span> Google
                </button>
                <button class="gv-social-btn" type="button">
                    <span class="material-symbols-outlined">smartphone</span> Apple
                </button>
            </div>

            <div class="gv-auth-footer">
                Pas encore de compte ?
                <a href="{{ path('app_register') }}">Créer un compte GoVibe</a>
            </div>
        </div>

        <div class="gv-bottom-links">
            <a href="#">Confidentialité</a>
            <a href="#">Conditions</a>
            <a href="#">Centre d'aide</a>
        </div>
    </div>
</main>

<!-- Floating Decorative Blurs -->
<div style="position:fixed;top:-10%;left:-10%;width:24rem;height:24rem;background:rgba(0,52,45,0.1);border-radius:50%;filter:blur(120px);pointer-events:none;z-index:0;"></div>
<div style="position:fixed;bottom:-10%;right:-10%;width:24rem;height:24rem;background:rgba(61,42,0,0.1);border-radius:50%;filter:blur(120px);pointer-events:none;z-index:0;"></div>

<script>
    // Password toggle
    function togglePwd(inputId, btn) {
        const input = document.getElementById(inputId);
        const icon = btn.querySelector('.material-symbols-outlined');
        if (input.type === 'password') {
            input.type = 'text';
            icon.textContent = 'visibility_off';
        } else {
            input.type = 'password';
            icon.textContent = 'visibility';
        }
    }

    // Particle system
    (function() {
        const canvas = document.getElementById('authParticles');
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        let particles = [];
        const PARTICLE_COUNT = 50;

        function resize() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }
        resize();
        window.addEventListener('resize', resize);

        class Particle {
            constructor() { this.reset(); }
            reset() {
                this.x = Math.random() * canvas.width;
                this.y = Math.random() * canvas.height;
                this.size = Math.random() * 2 + 0.5;
                this.speedX = (Math.random() - 0.5) * 0.4;
                this.speedY = (Math.random() - 0.5) * 0.4;
                this.opacity = Math.random() * 0.4 + 0.1;
            }
            update() {
                this.x += this.speedX;
                this.y += this.speedY;
                if (this.x < 0 || this.x > canvas.width) this.speedX *= -1;
                if (this.y < 0 || this.y > canvas.height) this.speedY *= -1;
            }
            draw() {
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(160, 242, 225, ${this.opacity})`;
                ctx.fill();
            }
        }

        for (let i = 0; i < PARTICLE_COUNT; i++) particles.push(new Particle());

        function animate() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            particles.forEach(p => { p.update(); p.draw(); });

            // Draw connections
            for (let i = 0; i < particles.length; i++) {
                for (let j = i + 1; j < particles.length; j++) {
                    const dx = particles[i].x - particles[j].x;
                    const dy = particles[i].y - particles[j].y;
                    const dist = Math.sqrt(dx * dx + dy * dy);
                    if (dist < 120) {
                        ctx.beginPath();
                        ctx.moveTo(particles[i].x, particles[i].y);
                        ctx.lineTo(particles[j].x, particles[j].y);
                        ctx.strokeStyle = `rgba(160, 242, 225, ${0.06 * (1 - dist / 120)})`;
                        ctx.lineWidth = 0.5;
                        ctx.stroke();
                    }
                }
            }
            requestAnimationFrame(animate);
        }
        animate();
    })();
</script>
{% endblock %}

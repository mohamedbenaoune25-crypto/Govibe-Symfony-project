{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe | GoVibe — Curated Odyssey{% endblock %}

{% block header %}{% endblock %}
{% block footer %}{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
<style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
        font-family: 'Manrope', sans-serif !important;
        background: linear-gradient(135deg, #0a1a14 0%, #00261c 50%, #0d0d0d 100%) !important;
        min-height: 100vh !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        padding: 1rem !important;
        overflow-x: hidden !important;
        margin: 0 !important;
    }

    .auth-bg-grid {
        position: fixed; top: 0; left: 0; width: 200%; height: 200%;
        background-size: 60px 60px;
        background-image:
            linear-gradient(to right, rgba(16, 185, 129, 0.04) 1px, transparent 1px),
            linear-gradient(to bottom, rgba(16, 185, 129, 0.04) 1px, transparent 1px);
        transform: perspective(600px) rotateX(55deg) translateY(-80px) translateZ(-300px);
        animation: authGridFlow 25s linear infinite;
        z-index: 0; pointer-events: none;
    }
    @keyframes authGridFlow {
        0% { transform: perspective(600px) rotateX(55deg) translateY(0) translateZ(-300px); }
        100% { transform: perspective(600px) rotateX(55deg) translateY(60px) translateZ(-300px); }
    }

    .auth-orb { position: fixed; border-radius: 50%; filter: blur(100px); opacity: 0.35; z-index: 0; pointer-events: none; }
    .auth-orb-1 { width: 500px; height: 500px; background: radial-gradient(circle, #10B981, #064E3B); top: -5%; left: -5%; animation: orbDrift1 12s ease-in-out infinite alternate; }
    .auth-orb-2 { width: 350px; height: 350px; background: radial-gradient(circle, #fbbf24, #92400e); bottom: -10%; right: -5%; animation: orbDrift2 15s ease-in-out infinite alternate; }
    .auth-orb-3 { width: 200px; height: 200px; background: radial-gradient(circle, #06b6d4, #0e7490); top: 50%; right: 20%; animation: orbDrift3 10s ease-in-out infinite alternate; }
    @keyframes orbDrift1 { 0% { transform: translate(0, 0) scale(1); } 100% { transform: translate(40px, 30px) scale(1.08); } }
    @keyframes orbDrift2 { 0% { transform: translate(0, 0) scale(1); } 100% { transform: translate(-30px, -40px) scale(1.12); } }
    @keyframes orbDrift3 { 0% { transform: translate(0, 0) scale(1); } 100% { transform: translate(20px, -20px) scale(0.9); } }

    .auth-main {
        width: 100%; max-width: 1100px;
        display: grid; grid-template-columns: 1fr 1fr;
        border-radius: 2rem; overflow: hidden;
        box-shadow: 0 50px 100px -20px rgba(0, 0, 0, 0.6), 0 0 0 1px rgba(255, 255, 255, 0.05), inset 0 1px 0 0 rgba(255, 255, 255, 0.05);
        position: relative; z-index: 10;
        transform: translateY(20px); opacity: 0;
        animation: authCardReveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
    }
    @keyframes authCardReveal { to { transform: translateY(0); opacity: 1; } }
    @media (max-width: 768px) { .auth-main { grid-template-columns: 1fr; max-width: 480px; } }

    .auth-editorial {
        background: linear-gradient(160deg, #00342d 0%, #013220 40%, #001a12 100%);
        padding: 3rem; display: flex; flex-direction: column; justify-content: space-between;
        position: relative; overflow: hidden;
    }
    @media (max-width: 768px) { .auth-editorial { display: none; } }
    .auth-editorial::before {
        content: ''; position: absolute; inset: 0;
        background: radial-gradient(ellipse at 30% 80%, rgba(16, 185, 129, 0.15) 0%, transparent 60%),
                    radial-gradient(ellipse at 80% 20%, rgba(251, 191, 36, 0.08) 0%, transparent 50%);
        pointer-events: none;
    }
    .editorial-brand { position: relative; z-index: 2; font-family: 'Noto Serif', serif; font-weight: 700; font-style: italic; font-size: 1.75rem; color: #fff; }
    .editorial-content { position: relative; z-index: 2; }
    .editorial-title { font-family: 'Noto Serif', serif; font-size: 2.75rem; line-height: 1.15; color: #fff; font-weight: 700; margin-bottom: 1rem; }
    .editorial-title em { color: #a0f2e1; font-style: italic; }
    .editorial-desc { color: rgba(160, 242, 225, 0.6); font-size: 1.05rem; line-height: 1.6; max-width: 320px; }
    .editorial-hero-img {
        position: absolute; right: -15%; top: 15%; width: 130%; height: 75%;
        object-fit: cover; mix-blend-mode: luminosity; opacity: 0.25;
        border-radius: 0 0 0 8rem; pointer-events: none;
        mask-image: linear-gradient(to left, black 30%, transparent 100%);
        -webkit-mask-image: linear-gradient(to left, black 30%, transparent 100%);
    }
    .editorial-dots { position: relative; z-index: 2; display: flex; gap: 0.5rem; }
    .editorial-dots span { height: 4px; border-radius: 4px; background: rgba(160, 242, 225, 0.25); }
    .editorial-dots span:first-child { width: 3rem; background: #a0f2e1; }
    .editorial-dots span:nth-child(2), .editorial-dots span:nth-child(3) { width: 1rem; }

    /* ─── Shield Icon Animation ─── */
    .shield-container {
        width: 80px; height: 80px; margin: 0 auto 1.5rem;
        background: linear-gradient(135deg, rgba(0, 52, 45, 0.08), rgba(16, 185, 129, 0.08));
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        position: relative;
    }
    .shield-container::before {
        content: '';
        position: absolute;
        inset: -3px;
        border-radius: 50%;
        border: 2px dashed rgba(16, 185, 129, 0.25);
        animation: shieldSpin 20s linear infinite;
    }
    @keyframes shieldSpin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    .shield-container .material-symbols-outlined {
        font-size: 2.2rem;
        color: #00342d;
        font-variation-settings: 'FILL' 1;
    }

    /* ─── Step Indicator ─── */
    .step-indicator {
        display: flex; align-items: center; justify-content: center; gap: 0.5rem;
        margin-bottom: 2rem;
    }
    .step-dot {
        width: 2rem; height: 4px; border-radius: 4px;
        transition: all 0.3s ease;
    }
    .step-dot.completed { background: #10B981; }
    .step-dot.active { background: #00342d; width: 3rem; }
    .step-dot.pending { background: #e5e2e1; }

    .auth-form-panel {
        background: rgba(252, 249, 248, 0.97); padding: 3rem 3.5rem;
        display: flex; flex-direction: column; justify-content: center; position: relative;
    }
    @media (max-width: 768px) { .auth-form-panel { padding: 2rem 1.5rem; } }

    .auth-form-inner { max-width: 400px; width: 100%; margin: 0 auto; }
    .auth-form-title { font-family: 'Noto Serif', serif; font-size: 2rem; font-weight: 700; color: #1c1b1b; margin-bottom: 0.5rem; text-align: center; }
    .auth-form-subtitle { color: #707975; font-size: 0.95rem; margin-bottom: 2rem; line-height: 1.5; text-align: center; }

    .gv-field { margin-bottom: 1.5rem; }
    .gv-field-label {
        display: flex; align-items: center; gap: 0.5rem;
        font-size: 0.8rem; font-weight: 700; color: #3f4945;
        text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem;
    }
    .gv-field-label .material-symbols-outlined { font-size: 1.1rem; color: #707975; }

    .gv-input {
        width: 100%; padding: 1rem 1.25rem; background: #e5e2e1;
        border: 2px solid transparent; border-radius: 0.75rem;
        font-size: 1rem; color: #1c1b1b; font-family: 'Manrope', sans-serif;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); outline: none;
        box-sizing: border-box;
    }
    .gv-input::placeholder { color: rgba(112, 121, 117, 0.5); }
    .gv-input:focus { background: #fff; border-color: rgba(0, 52, 45, 0.15); box-shadow: 0 0 0 4px rgba(0, 52, 45, 0.06); }

    /* ─── OTP Code Input Styling ─── */
    .gv-code-hint {
        display: flex; align-items: center; gap: 0.5rem;
        background: rgba(16, 185, 129, 0.05);
        border: 1px solid rgba(16, 185, 129, 0.15);
        border-radius: 0.5rem; padding: 0.6rem 0.8rem;
        margin-bottom: 1.5rem; font-size: 0.8rem; color: #3f4945;
    }
    .gv-code-hint .material-symbols-outlined {
        font-size: 1rem; color: #10B981;
    }

    .gv-btn-primary {
        width: 100%; padding: 1.1rem;
        background: linear-gradient(135deg, #00342d 0%, #004d43 70%, #046b5e 100%);
        color: #fff; border: none; border-radius: 0.75rem;
        font-size: 1.05rem; font-weight: 700; font-family: 'Manrope', sans-serif;
        cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 0.5rem;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 12px 28px -8px rgba(0, 52, 45, 0.4), inset 0 1px 0 0 rgba(160, 242, 225, 0.15);
        position: relative; overflow: hidden;
    }
    .gv-btn-primary::before {
        content: ''; position: absolute; inset: 0;
        background: linear-gradient(135deg, transparent 0%, rgba(255,255,255,0.08) 50%, transparent 100%);
        transform: translateX(-100%); transition: transform 0.6s ease;
    }
    .gv-btn-primary:hover::before { transform: translateX(100%); }
    .gv-btn-primary:hover { transform: translateY(-2px) scale(1.01); box-shadow: 0 18px 40px -10px rgba(0, 52, 45, 0.5); }
    .gv-btn-primary:active { transform: translateY(0) scale(0.99); }

    .gv-auth-footer { text-align: center; margin-top: 2rem; font-size: 0.9rem; color: #707975; }
    .gv-auth-footer a { color: #00342d; font-weight: 800; text-decoration: none; display: inline-flex; align-items: center; gap: 0.3rem; }
    .gv-auth-footer a:hover { text-decoration: underline; color: #046b5e; }

    .gv-alert { padding: 0.85rem 1rem; border-radius: 0.75rem; font-size: 0.85rem; margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.5rem; }
    .gv-alert-error { background: rgba(186, 26, 26, 0.08); border: 1px solid rgba(186, 26, 26, 0.2); color: #93000a; }
    .gv-alert-success { background: rgba(16, 185, 129, 0.08); border: 1px solid rgba(16, 185, 129, 0.2); color: #005046; }

    #authParticles { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; pointer-events: none; }

    .auth-form-panel form { animation: none !important; }
    .auth-form-panel form .form-label,
    .auth-form-panel form .form-control { all: unset; }
    .auth-form-panel form input[type="password"],
    .auth-form-panel form input[type="text"] {
        all: unset;
        width: 100%; padding: 1rem 1.25rem; background: #e5e2e1;
        border: 2px solid transparent; border-radius: 0.75rem;
        font-size: 1rem; color: #1c1b1b; font-family: 'Manrope', sans-serif;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); box-sizing: border-box;
    }
    .auth-form-panel form input[type="password"]:focus,
    .auth-form-panel form input[type="text"]:focus {
        background: #fff; border-color: rgba(0, 52, 45, 0.15);
        box-shadow: 0 0 0 4px rgba(0, 52, 45, 0.06); outline: none;
    }
    .auth-form-panel form input::placeholder { color: rgba(112, 121, 117, 0.5); }
    .auth-form-panel .text-danger { color: #93000a !important; font-size: 0.8rem; margin-top: 0.25rem; }

    .govibe-navbar, .govibe-footer, .container.position-relative { display: none !important; }
    .floating-element { display: none !important; }
</style>
{% endblock %}

{% block body %}
<div class="auth-bg-grid"></div>
<div class="auth-orb auth-orb-1"></div>
<div class="auth-orb auth-orb-2"></div>
<div class="auth-orb auth-orb-3"></div>
<canvas id="authParticles"></canvas>

<main class="auth-main">
    <div class="auth-editorial">
        <div class="editorial-brand">GoVibe</div>
        <div class="editorial-content">
            <h2 class="editorial-title">Almost there, <em>secure</em> your account.</h2>
            <p class="editorial-desc">Enter the verification code and choose a strong new password to protect your odyssey.</p>
        </div>
        <img src="{{ asset('images/auth-hero-3d.png') }}" alt="Luxury travel 3D illustration" class="editorial-hero-img">
        <div class="editorial-dots"><span></span><span></span><span></span></div>
    </div>

    <div class="auth-form-panel">
        <div class="auth-form-inner">
            <div class="shield-container">
                <span class="material-symbols-outlined">verified_user</span>
            </div>

            <h3 class="auth-form-title">Sécuriser le compte</h3>
            <p class="auth-form-subtitle">Entrez le code reçu et choisissez votre nouveau mot de passe.</p>

            <!-- Steps -->
            <div class="step-indicator">
                <span class="step-dot completed"></span>
                <span class="step-dot active"></span>
                <span class="step-dot pending"></span>
            </div>

            {% for message in app.flashes('success') %}
                <div class="gv-alert gv-alert-success">
                    <span class="material-symbols-outlined" style="font-size:1.1rem;">check_circle</span>
                    {{ message }}
                </div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="gv-alert gv-alert-error">
                    <span class="material-symbols-outlined" style="font-size:1.1rem;">error</span>
                    {{ message }}
                </div>
            {% endfor %}

            <div class="gv-code-hint">
                <span class="material-symbols-outlined">info</span>
                Un code à 6 caractères a été envoyé à votre adresse email.
            </div>

            {{ form_start(resetForm) }}
                <div class="gv-field">
                    <label class="gv-field-label">
                        <span class="material-symbols-outlined">shield</span> Code de vérification
                    </label>
                    {{ form_widget(resetForm.token, {'attr': {'class': 'gv-input', 'placeholder': 'XXXXXX', 'style': 'text-align:center; font-size:1.4rem; letter-spacing:0.5em; font-weight:700;'}}) }}
                    <div class="text-danger">{{ form_errors(resetForm.token) }}</div>
                </div>

                <div class="gv-field">
                    <label class="gv-field-label">
                        <span class="material-symbols-outlined">lock</span> Nouveau mot de passe
                    </label>
                    {{ form_widget(resetForm.plainPassword, {'attr': {'class': 'gv-input', 'placeholder': '••••••••'}}) }}
                    <div class="text-danger">{{ form_errors(resetForm.plainPassword) }}</div>
                </div>

                <button type="submit" class="gv-btn-primary">
                    Confirmer la modification
                    <span class="material-symbols-outlined" style="font-size:1.2rem;">check_circle</span>
                </button>
            {{ form_end(resetForm) }}

            <div class="gv-auth-footer">
                <a href="{{ path('app_login') }}">
                    <span class="material-symbols-outlined" style="font-size:1rem;">arrow_back</span>
                    Retour à la connexion
                </a>
            </div>
        </div>
    </div>
</main>

<div style="position:fixed;top:-10%;left:-10%;width:24rem;height:24rem;background:rgba(0,52,45,0.1);border-radius:50%;filter:blur(120px);pointer-events:none;z-index:0;"></div>
<div style="position:fixed;bottom:-10%;right:-10%;width:24rem;height:24rem;background:rgba(61,42,0,0.1);border-radius:50%;filter:blur(120px);pointer-events:none;z-index:0;"></div>

<script>
(function() {
    const canvas = document.getElementById('authParticles');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    let particles = [];
    const PARTICLE_COUNT = 50;
    function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
    resize(); window.addEventListener('resize', resize);
    class Particle {
        constructor() { this.reset(); }
        reset() {
            this.x = Math.random() * canvas.width; this.y = Math.random() * canvas.height;
            this.size = Math.random() * 2 + 0.5; this.speedX = (Math.random() - 0.5) * 0.4;
            this.speedY = (Math.random() - 0.5) * 0.4; this.opacity = Math.random() * 0.4 + 0.1;
        }
        update() {
            this.x += this.speedX; this.y += this.speedY;
            if (this.x < 0 || this.x > canvas.width) this.speedX *= -1;
            if (this.y < 0 || this.y > canvas.height) this.speedY *= -1;
        }
        draw() {
            ctx.beginPath(); ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(160, 242, 225, ${this.opacity})`; ctx.fill();
        }
    }
    for (let i = 0; i < PARTICLE_COUNT; i++) particles.push(new Particle());
    function animate() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        particles.forEach(p => { p.update(); p.draw(); });
        for (let i = 0; i < particles.length; i++) {
            for (let j = i + 1; j < particles.length; j++) {
                const dx = particles[i].x - particles[j].x, dy = particles[i].y - particles[j].y;
                const dist = Math.sqrt(dx * dx + dy * dy);
                if (dist < 120) {
                    ctx.beginPath(); ctx.moveTo(particles[i].x, particles[i].y);
                    ctx.lineTo(particles[j].x, particles[j].y);
                    ctx.strokeStyle = `rgba(160, 242, 225, ${0.06 * (1 - dist / 120)})`;
                    ctx.lineWidth = 0.5; ctx.stroke();
                }
            }
        }
        requestAnimationFrame(animate);
    }
    animate();
})();
</script>
{% endblock %}

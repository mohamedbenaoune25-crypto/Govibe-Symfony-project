<!-- ═══ SCROLL-DRIVEN VIDEO ENGINE ═══ -->
<script>
document.addEventListener('DOMContentLoaded', () => {

    // ═══ CANVAS SCROLL-VIDEO ENGINE ═══
    const canvas = document.getElementById('heroCanvas');
    const ctx = canvas.getContext('2d');
    const heroSection = document.getElementById('heroSection');
    const heroContent = document.getElementById('heroContent');
    const heroProgress = document.getElementById('heroProgress');
    const scrollIndicator = document.getElementById('scrollIndicator');

    const TOTAL_FRAMES = 240;
    const frames = [];
    let imagesLoaded = 0;
    let currentFrame = 0;

    // Set canvas resolution to match container
    function resizeCanvas() {
        const rect = canvas.parentElement.getBoundingClientRect();
        canvas.width = rect.width * window.devicePixelRatio;
        canvas.height = rect.height * window.devicePixelRatio;
        ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
        drawFrame(currentFrame);
    }

    // Draw a single frame on the canvas (cover fit)
    function drawFrame(index) {
        const img = frames[index];
        if (!img || !img.complete) return;

        const cw = canvas.width / window.devicePixelRatio;
        const ch = canvas.height / window.devicePixelRatio;
        const iw = img.naturalWidth;
        const ih = img.naturalHeight;

        // "object-fit: cover" logic
        const scale = Math.max(cw / iw, ch / ih);
        const sw = iw * scale;
        const sh = ih * scale;
        const sx = (cw - sw) / 2;
        const sy = (ch - sh) / 2;

        ctx.clearRect(0, 0, cw, ch);
        ctx.drawImage(img, sx, sy, sw, sh);
    }

    // Preload all frames
    function preloadFrames() {
        for (let i = 1; i <= TOTAL_FRAMES; i++) {
            const img = new Image();
            const num = String(i).padStart(3, '0');
            img.src = `/images/wireframes/ezgif-frame-${num}.png`;
            img.onload = () => {
                imagesLoaded++;
                // Draw the first frame immediately when it loads
                if (i === 1) {
                    drawFrame(0);
                }
            };
            frames.push(img);
        }
    }

    // ═══ SCROLL HANDLER ═══
    let ticking = false;

    function onScroll() {
        const scrollY = window.pageYOffset;
        const heroTop = heroSection.offsetTop;
        const heroHeight = heroSection.offsetHeight;
        const viewH = window.innerHeight;

        // scrollable range = heroHeight - viewH (sticky takes one viewport)
        const scrollRange = heroHeight - viewH;
        const rawProgress = (scrollY - heroTop) / scrollRange;
        const progress = Math.max(0, Math.min(1, rawProgress));

        // ── Calculate which frame to show ──
        const frameIndex = Math.min(TOTAL_FRAMES - 1, Math.floor(progress * (TOTAL_FRAMES - 1)));
        if (frameIndex !== currentFrame) {
            currentFrame = frameIndex;
            drawFrame(currentFrame);
        }

        // ── Progress bar ──
        if (heroProgress) {
            heroProgress.style.width = (progress * 100) + '%';
        }

        // ── Fade out hero content (between 0% and 40% of progress) ──
        if (heroContent) {
            const contentProgress = Math.min(1, progress * 2.5);
            heroContent.style.opacity = Math.max(0, 1 - contentProgress);
            heroContent.style.transform = `translateY(${-contentProgress * 60}px)`;
        }

        // ── Scroll indicator — hide quickly ──
        if (scrollIndicator) {
            const indOpacity = Math.max(0, 1 - progress * 8);
            scrollIndicator.style.opacity = indOpacity;
            scrollIndicator.style.pointerEvents = progress > 0.05 ? 'none' : 'auto';
        }

        ticking = false;
    }

    window.addEventListener('scroll', () => {
        if (!ticking) {
            requestAnimationFrame(onScroll);
            ticking = true;
        }
    }, { passive: true });

    window.addEventListener('resize', resizeCanvas);

    // Initialize
    resizeCanvas();
    preloadFrames();
    onScroll();

    // ─── Scroll Reveal ───
    const reveals = document.querySelectorAll('.gv-reveal');
    const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                revealObserver.unobserve(entry.target);
            }
        });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    reveals.forEach(el => revealObserver.observe(el));

    // ─── Counter Animation ───
    const counters = document.querySelectorAll('.gv-counter');
    const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const el = entry.target;
                const target = +el.dataset.target;
                const speed = 150;
                const inc = target / speed;

                const updateCount = () => {
                    const current = +el.innerText.replace(/[^0-9]/g, '');
                    if (current < target) {
                        let next = Math.ceil(current + inc);
                        if (next > target) next = target;
                        if (target >= 1000) {
                            el.innerText = (next / 1000).toFixed(next >= target ? 0 : 1) + 'K+';
                        } else {
                            el.innerText = next + '+';
                        }
                        requestAnimationFrame(updateCount);
                    } else {
                        if (target >= 1000) {
                            el.innerText = (target / 1000) + 'K+';
                        } else {
                            el.innerText = target + '+';
                        }
                    }
                };
                updateCount();
                counterObserver.unobserve(el);
            }
        });
    }, { threshold: 0.3 });
    counters.forEach(el => counterObserver.observe(el));

    // ─── Smooth navbar transition ───
    const navbar = document.getElementById('mainNav');
    if (navbar) {
        const checkScroll = () => {
            if (window.scrollY > 80) {
                navbar.classList.add('scrolled');
            } else {
                navbar.classList.remove('scrolled');
            }
        };
        checkScroll();
        window.addEventListener('scroll', checkScroll, { passive: true });
    }
});
</script>


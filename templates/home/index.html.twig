.gv-cat-icon .material-symbols-outlined { font-size: 1.75rem; color: #00342d; transition: color 0.3s; }
.gv-cat-item:hover .gv-cat-icon {
    background: linear-gradient(135deg, #00342d, #046b5e);
    box-shadow: 0 10px 30px rgba(0, 52, 45, 0.2);
}

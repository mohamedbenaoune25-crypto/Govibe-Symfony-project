<!-- Call to Action -->
<div class="cta-section" style="padding: 100px 0; background: linear-gradient(135deg, #064E3B, #10B981); color: white; text-align: center; position: relative; overflow: hidden; margin-top: 50px;">
    <div class="cta-content" data-aos="zoom-in" style="position: relative; z-index: 1; max-width: 800px; margin: 0 auto; padding: 0 20px;">

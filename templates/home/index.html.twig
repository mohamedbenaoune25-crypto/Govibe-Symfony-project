{% extends 'base.html.twig' %}

{% block title %}GoVibe | Curated Odyssey — Voyages Premium{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Manrope:wght@200..800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════════
   GoVibe Homepage — Ultra Premium Futuristic Design
   €20,000 level enterprise travel experience
═══════════════════════════════════════════════════ */

/* ─── Reset & Base ─── */
*, *::before, *::after { box-sizing: border-box; }

body {
    font-family: 'Manrope', sans-serif !important;
    background: #fcf9f8 !important;
    color: #1c1b1b !important;
    overflow-x: hidden !important;
    margin: 0 !important;
    padding-top: 0 !important;
}

.material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
}

/* ─── Custom scrollbar ─── */
::-webkit-scrollbar { width: 8px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(0, 52, 45, 0.2); border-radius: 10px; }
::-webkit-scrollbar-thumb:hover { background: rgba(0, 52, 45, 0.4); }

/* ─── SCROLL-DRIVEN VIDEO HERO ─── */
.gv-hero {
    position: relative;
    height: 300vh; /* 3x viewport to give long scroll room for the video */
    overflow: visible;
}

.gv-hero-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    min-height: 600px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
}

/* Canvas fills the entire sticky container */
.gv-hero-canvas {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: url('{{ asset('images/home-hero5.png') }}') center/cover no-repeat;
}
.gv-hero-canvas canvas {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

/* Dark gradient overlay on top of the canvas */
.gv-hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
        180deg,
        rgba(0, 52, 45, 0.55) 0%,
        rgba(0, 52, 45, 0.25) 25%,
        rgba(0, 0, 0, 0.10) 50%,
        rgba(252, 249, 248, 0.6) 85%,
        rgba(252, 249, 248, 1) 100%
    );
    pointer-events: none;
}

/* Scroll progress bar at the bottom of hero */
.gv-hero-progress {
    position: absolute;
    bottom: 0; left: 0;
    height: 3px;
    background: linear-gradient(90deg, #e9c176, #a0f2e1);
    z-index: 20;
    width: 0%;
    transition: width 0.05s linear;
}

/* ─── Hero text content ─── */
.gv-hero-content {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 1200px;
    padding: 0 2rem 5rem;
    text-align: center;
    will-change: transform, opacity;
    align-self: flex-end;
}

.gv-hero-title {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2.5rem, 6vw, 5rem);
    color: #fff;
    margin-bottom: 1rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    text-shadow: 0 4px 30px rgba(0, 0, 0, 0.4);
    opacity: 0;
    transform: translateY(30px);
    animation: heroTextIn 1s cubic-bezier(0.16, 1, 0.3, 1) 0.5s forwards;
}
.gv-hero-title em {
    font-style: italic;
    font-weight: 300;
    color: #e9c176;
}

.gv-hero-sub {
    font-size: clamp(0.95rem, 1.8vw, 1.2rem);
    color: rgba(255, 255, 255, 0.9);
    font-weight: 400;
    max-width: 620px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
    letter-spacing: 0.01em;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
    opacity: 0;
    transform: translateY(20px);
    animation: heroTextIn 1s cubic-bezier(0.16, 1, 0.3, 1) 0.7s forwards;
}

@keyframes heroTextIn {
    to { opacity: 1; transform: translateY(0); }
}

/* ─── Glass Search Bar ─── */
.gv-search-glass {
    background: rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 1.5rem;
    padding: 0.75rem;
    box-shadow: 0 30px 60px -15px rgba(0, 0, 0, 0.3);
    opacity: 0;
    transform: translateY(30px);
    animation: heroTextIn 1s cubic-bezier(0.16, 1, 0.3, 1) 0.9s forwards;
    max-width: 900px;
    margin: 0 auto;
}

.gv-search-inner {
    background: rgba(255, 255, 255, 0.95);
    border-radius: 1rem;
    padding: 0.5rem 1rem;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr auto;
    gap: 0;
    align-items: center;
}
@media (max-width: 768px) {
    .gv-search-inner { grid-template-columns: 1fr; gap: 0.5rem; }
}

.gv-search-field {
    padding: 0.75rem 1.25rem;
    border-right: 1px solid rgba(191, 201, 196, 0.2);
}
.gv-search-field:last-of-type { border-right: none; }
@media (max-width: 768px) { .gv-search-field { border-right: none; border-bottom: 1px solid rgba(191, 201, 196, 0.2); } }

.gv-search-label {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #546067;
    margin-bottom: 0.2rem;
    display: block;
}
.gv-search-input {
    border: none;
    outline: none;
    background: transparent;
    width: 100%;
    font-size: 0.95rem;
    font-weight: 500;
    color: #1c1b1b;
    font-family: 'Manrope', sans-serif;
}
.gv-search-input::placeholder { color: #bfc9c4; }

.gv-search-btn {
    padding: 1rem 2rem;
    background: linear-gradient(135deg, #00342d 0%, #004d43 70%, #046b5e 100%);
    color: #fff;
    border: none;
    border-radius: 0.75rem;
    font-weight: 700;
    font-family: 'Manrope', sans-serif;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s ease;
    box-shadow: 0 8px 20px -6px rgba(0, 52, 45, 0.4);
    white-space: nowrap;
}
.gv-search-btn:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 12px 30px -6px rgba(0, 52, 45, 0.5);
}

/* ─── SCROLL INDICATOR ─── */
.gv-scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 15;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255,255,255,0.7);
    animation: bounceScroll 2s ease-in-out infinite;
}
.gv-scroll-indicator span { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.2em; }
.gv-scroll-indicator .material-symbols-outlined { font-size: 1.5rem; }
@keyframes bounceScroll {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
}

/* ═══ SECTION SHARED STYLES ═══ */
.gv-section {
    padding: 6rem 2rem;
    max-width: 1400px;
    margin: 0 auto;
}

.gv-section-header {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 4rem;
    gap: 1.5rem;
}

.gv-section-title {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2rem, 4vw, 3.25rem);
    color: #00342d;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
}
.gv-section-desc {
    color: #546067;
    font-size: 1.1rem;
    max-width: 500px;
    line-height: 1.6;
}

.gv-view-all {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    color: #3d2a00;
    text-decoration: none;
    font-size: 0.95rem;
    border-bottom: 2px solid transparent;
    padding-bottom: 2px;
    transition: all 0.2s ease;
}
.gv-view-all:hover { border-color: #3d2a00; color: #3d2a00; }

/* ═══ DESTINATIONS SECTION ═══ */
.gv-dest-grid {
    display: grid;
    grid-template-columns: 7fr 5fr;
    gap: 2rem;
}
@media (max-width: 768px) { .gv-dest-grid { grid-template-columns: 1fr; } }

.gv-dest-feature {
    position: relative;
    border-radius: 2.5rem 0.5rem 2.5rem 0.5rem;
    overflow: hidden;
    height: 500px;
    cursor: pointer;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 20px 60px -15px rgba(0, 0, 0, 0.08);
}
.gv-dest-feature:hover {
    transform: translateY(-6px);
    box-shadow: 0 30px 80px -15px rgba(0, 0, 0, 0.15);
}
.gv-dest-feature img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
}
.gv-dest-feature:hover img { transform: scale(1.08); }

.gv-dest-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(0, 52, 45, 0.85) 100%);
}

.gv-dest-badge {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    padding: 0.5rem 1rem;
    border-radius: 2rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: #fff;
    font-size: 0.85rem;
    font-weight: 700;
}
.gv-dest-badge .material-symbols-outlined {
    color: #e9c176;
    font-size: 1rem;
    font-variation-settings: 'FILL' 1;
}

.gv-dest-info {
    position: absolute;
    bottom: 2.5rem;
    left: 2.5rem;
    color: #fff;
}
.gv-dest-info .gv-dest-region {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    opacity: 0.7;
    margin-bottom: 0.5rem;
    display: block;
}
.gv-dest-info h3 {
    font-family: 'Noto Serif', serif;
    font-size: 2.25rem;
    margin-bottom: 0.5rem;
    font-weight: 700;
}
.gv-dest-info p {
    font-size: 0.9rem;
    opacity: 0.7;
    max-width: 300px;
    line-height: 1.5;
}

.gv-dest-stack {
    display: flex;
    flex-direction: column;
    gap: 2rem;
}

.gv-dest-mini {
    position: relative;
    border-radius: 1rem;
    overflow: hidden;
    flex: 1;
    cursor: pointer;
    transition: all 0.5s ease;
    box-shadow: 0 8px 30px -10px rgba(0, 0, 0, 0.08);
}
.gv-dest-mini:hover { transform: translateY(-4px); box-shadow: 0 15px 40px -10px rgba(0, 0, 0, 0.15); }
.gv-dest-mini img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.7s ease; }
.gv-dest-mini:hover img { transform: scale(1.08); }
.gv-dest-mini::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.2);
    transition: background 0.3s ease;
}
.gv-dest-mini:hover::after { background: rgba(0, 0, 0, 0.4); }
.gv-dest-mini-label {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: #fff;
    z-index: 2;
    text-align: center;
}
.gv-dest-mini-label h3 { font-family: 'Noto Serif', serif; font-size: 1.5rem; }
.gv-dest-mini-label span { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.2em; opacity: 0.7; }

/* ═══ SERVICES SECTION ═══ */
.gv-services-bg {
    background: #f6f3f2;
    padding: 6rem 2rem;
}
.gv-services-inner {
    max-width: 1400px;
    margin: 0 auto;
}
.gv-services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
}
@media (max-width: 768px) { .gv-services-grid { grid-template-columns: 1fr; } }

.gv-service-card {
    background: #fff;
    padding: 2.5rem;
    border-radius: 1.5rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
    position: relative;
    overflow: hidden;
}
.gv-service-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 4px;
    background: linear-gradient(90deg, #00342d, #046b5e, #10B981);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s ease;
}
.gv-service-card:hover::before { transform: scaleX(1); }
.gv-service-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 30px 60px -15px rgba(0, 0, 0, 0.1);
}

.gv-service-icon {
    width: 4rem; height: 4rem;
    background: rgba(0, 52, 45, 0.06);
    border-radius: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    transition: all 0.3s ease;
}
.gv-service-icon .material-symbols-outlined { font-size: 1.75rem; color: #00342d; transition: color 0.3s; }
.gv-service-card:hover .gv-service-icon {
    background: linear-gradient(135deg, #00342d, #046b5e);
}
.gv-service-card:hover .gv-service-icon .material-symbols-outlined { color: #fff; }

.gv-service-card h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.5rem;
    color: #00342d;
    margin-bottom: 0.75rem;
    font-weight: 700;
}
.gv-service-card p {
    color: #546067;
    line-height: 1.6;
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
}
.gv-service-accent {
    height: 3px;
    width: 3rem;
    background: #e9c176;
    border-radius: 3px;
}

/* ═══ TESTIMONIAL SECTION ═══ */
.gv-testimonial-section {
    padding: 6rem 2rem;
    max-width: 1400px;
    margin: 0 auto;
    overflow: hidden;
}
.gv-testimonial-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
}
@media (max-width: 768px) { .gv-testimonial-grid { grid-template-columns: 1fr; gap: 3rem; } }

.gv-testimonial-visual {
    position: relative;
}
.gv-testimonial-img {
    width: 80%;
    border-radius: 2.5rem 0.5rem 2.5rem 0.5rem;
    overflow: hidden;
    box-shadow: 0 30px 80px -20px rgba(0, 0, 0, 0.15);
    position: relative;
    z-index: 2;
}
.gv-testimonial-img img { width: 100%; height: 500px; object-fit: cover; }

.gv-testimonial-bg-shape {
    position: absolute;
    bottom: -2rem; right: -2rem;
    width: 60%;
    height: 350px;
    background: rgba(0, 52, 45, 0.06);
    border-radius: 1rem;
    z-index: 0;
}
.gv-testimonial-quote-icon {
    position: absolute;
    top: -2rem; left: -2rem;
    font-size: 10rem;
    color: rgba(233, 193, 118, 0.15);
    font-variation-settings: 'FILL' 1;
    z-index: 1;
}

.gv-testimonial-text h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2rem, 3.5vw, 3rem);
    color: #00342d;
    margin-bottom: 2rem;
    line-height: 1.2;
    font-weight: 700;
}

.gv-testimonial-quote {
    border-left: 4px solid #e9c176;
    padding-left: 2rem;
    margin-bottom: 2rem;
}
.gv-testimonial-quote p {
    font-style: italic;
    font-size: 1.15rem;
    color: #3f4945;
    line-height: 1.7;
    margin-bottom: 1.5rem;
}

.gv-testimonial-author {
    display: flex;
    align-items: center;
    gap: 1rem;
}
.gv-testimonial-author-img {
    width: 3rem; height: 3rem;
    border-radius: 50%;
    overflow: hidden;
}
.gv-testimonial-author-img img { width: 100%; height: 100%; object-fit: cover; }
.gv-testimonial-author-name { font-weight: 700; color: #00342d; }
.gv-testimonial-author-role { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.15em; color: #546067; }

.gv-testimonial-nav {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
}
.gv-testimonial-nav button {
    width: 3rem; height: 3rem;
    border-radius: 50%;
    border: 1.5px solid #bfc9c4;
    background: transparent;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #3f4945;
    transition: all 0.2s ease;
}
.gv-testimonial-nav button:hover {
    background: #00342d;
    color: #fff;
    border-color: #00342d;
}

/* ═══ CTA SECTION ═══ */
.gv-cta-section {
    padding: 2rem 2rem 4rem;
    max-width: 1200px;
    margin: 0 auto;
}
.gv-cta-block {
    background: linear-gradient(135deg, #00342d 0%, #004d43 50%, #013220 100%);
    border-radius: 2.5rem;
    padding: 5rem 3rem;
    text-align: center;
    position: relative;
    overflow: hidden;
    box-shadow: 0 30px 80px -20px rgba(0, 52, 45, 0.4);
}
.gv-cta-block::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(160, 242, 225, 0.08) 1px, transparent 1px);
    background-size: 20px 20px;
    opacity: 0.5;
}
.gv-cta-block h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: #a0f2e1;
    margin-bottom: 1.5rem;
    position: relative;
    z-index: 2;
    font-weight: 700;
}
.gv-cta-block p {
    color: rgba(160, 242, 225, 0.6);
    font-size: 1.15rem;
    max-width: 600px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
    position: relative;
    z-index: 2;
}
.gv-cta-buttons {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    position: relative;
    z-index: 2;
}
.gv-cta-primary {
    padding: 1rem 2.5rem;
    background: #3d2a00;
    color: #fff;
    border: none;
    border-radius: 0.75rem;
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: 'Manrope', sans-serif;
    box-shadow: 0 8px 20px -5px rgba(61, 42, 0, 0.4);
    text-decoration: none;
}
.gv-cta-primary:hover { transform: scale(1.05) translateY(-2px); }
.gv-cta-secondary {
    padding: 1rem 2.5rem;
    background: transparent;
    color: #a0f2e1;
    border: 1.5px solid rgba(160, 242, 225, 0.25);
    border-radius: 0.75rem;
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: 'Manrope', sans-serif;
    text-decoration: none;
}
.gv-cta-secondary:hover { background: rgba(255, 255, 255, 0.08); color: #a0f2e1; }

/* ═══ SCROLL REVEAL ANIMATIONS ═══ */
.gv-reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1), transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
}
.gv-reveal.is-visible { opacity: 1; transform: translateY(0); }
.gv-reveal-delay-1 { transition-delay: 0.1s; }
.gv-reveal-delay-2 { transition-delay: 0.2s; }
.gv-reveal-delay-3 { transition-delay: 0.3s; }

/* ═══ STATS COUNTER ═══ */
.gv-stats-bar {
    padding: 4rem 2rem;
    background: linear-gradient(180deg, #fcf9f8 0%, #f6f3f2 100%);
}
.gv-stats-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
}
@media (max-width: 768px) { .gv-stats-inner { grid-template-columns: repeat(2, 1fr); } }

.gv-stat-item {
    text-align: center;
    padding: 1.5rem;
    transition: transform 0.3s ease;
}
.gv-stat-item:hover { transform: translateY(-5px); }
.gv-stat-number {
    font-family: 'Noto Serif', serif;
    font-size: 3rem;
    font-weight: 700;
    background: linear-gradient(135deg, #00342d, #046b5e);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    line-height: 1.1;
    margin-bottom: 0.5rem;
}
.gv-stat-label {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #546067;
}

/* ═══ CATEGORIES ═══ */
.gv-categories {
    padding: 4rem 2rem 6rem;
    max-width: 1200px;
    margin: 0 auto;
}
.gv-cat-row {
    display: flex;
    justify-content: center;
    gap: 2.5rem;
    flex-wrap: wrap;
}
.gv-cat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
.gv-cat-item:hover { transform: translateY(-10px) scale(1.05); }
.gv-cat-icon {

{% extends 'base.html.twig' %}

{% block title %}Accueil - GoVibe{% endblock %}

{% block stylesheets %}
<link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet" />
<style>
    :root {
        --primary-emerald: #10B981;
        --dark-green: #064E3B;
        --light-green: #D1FAE5;
        --bg-creme: #F9FAFB;
        --btn-hover: #059669;
        --text-color: #1F2937;
        --glass-bg: rgba(255, 255, 255, 0.15);
        --glass-border: rgba(255, 255, 255, 0.2);
        --glass-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.37);
    }
    
    body {
        background: linear-gradient(rgba(5, 35, 24, 0.50), rgba(5, 35, 24, 0.40)), url('{{ asset('images/home-hero5.png') }}') center/cover fixed no-repeat;
        font-family: 'Inter', sans-serif;
        color: var(--text-color);
        overflow-x: hidden;
    }

    /* Hero Section with Parallax & Glassmorphism */
    .hero-section {
        position: relative;
        height: 100vh;
        min-height: 700px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        background: radial-gradient(circle at top left, #064E3B 0%, #111827 50%, #000000 100%);
    }
    
    .hero-bg {
        display: none;
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: transparent;
        z-index: -1;
    }

    /* Animated Cyber Grid Background */
    .cyber-grid {
        position: absolute;
        top: 0;
        left: 0;
        width: 200%;
        height: 200%;
        background-size: 50px 50px;
        background-image: 
            linear-gradient(to right, rgba(16, 185, 129, 0.05) 1px, transparent 1px),
            linear-gradient(to bottom, rgba(16, 185, 129, 0.05) 1px, transparent 1px);
        transform: perspective(500px) rotateX(60deg) translateY(-100px) translateZ(-200px);
        animation: gridMove 20s linear infinite;
        z-index: 0;
    }

    @keyframes gridMove {
        0% { transform: perspective(500px) rotateX(60deg) translateY(0) translateZ(-200px); }
        100% { transform: perspective(500px) rotateX(60deg) translateY(50px) translateZ(-200px); }
    }

    /* Glowing Orbs */
    .glow-orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.5;
        z-index: 0;
        animation: orbFloat 10s infinite alternate;
    }
    .orb-1 { width: 400px; height: 400px; background: #10B981; top: 10%; left: 10%; }
    .orb-2 { width: 300px; height: 300px; background: #064E3B; bottom: 20%; right: 10%; animation-delay: -5s; }

    @keyframes orbFloat {
        0% { transform: translate(0, 0) scale(1); }
        100% { transform: translate(50px, 50px) scale(1.1); }
    }

    .hero-content {
        text-align: left;
        z-index: 1;
        color: white;
        padding: 0 40px;
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        max-width: 1400px;
    }

    .hero-text-side {
        max-width: 600px;
    }

    .hero-logo {
        width: 120px;
        margin-bottom: 20px;
        animation: floatImg 6s ease-in-out infinite;
        filter: drop-shadow(0 10px 15px rgba(0,0,0,0.3));
    }

    @keyframes floatImg {
        0% { transform: translateY(0px); }
        50% { transform: translateY(-10px); }
        100% { transform: translateY(0px); }
    }

    .hero-title {
        font-size: 5.5rem;
        font-weight: 900;
        line-height: 1.1;
        margin-bottom: 20px;
        background: linear-gradient(to right, #ffffff, #A7F3D0);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        letter-spacing: -2px;
    }
    
    .hero-subtitle {
        font-size: 1.4rem;
        font-weight: 300;
        margin-bottom: 40px;
        color: #D1FAE5;
        line-height: 1.6;
    }

    /* 3D Floating Elements */
    .hero-visual-side {
        position: relative;
        width: 500px;
        height: 500px;
        perspective: 1000px;
    }

    .glass-card-3d {
        position: absolute;
        width: 300px;
        height: 400px;
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 30px;
        padding: 30px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        animation: float3D 8s ease-in-out infinite;
    }

    .card-1 { right: 0; top: 50px; z-index: 2; transform: rotateY(-15deg) rotateX(10deg); }
    .card-2 { left: 0; bottom: 0; z-index: 1; transform: rotateY(15deg) rotateX(-10deg); animation-delay: -4s; background: rgba(16, 185, 129, 0.1); }

    .glass-card-img {
        width: 100%;
        height: 180px;
        border-radius: 15px;
        background: rgba(255,255,255,0.1);
        margin-bottom: 20px;
        overflow: hidden;
    }

    .glass-card-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.8;
    }

    .glass-card-title {
        font-size: 1.2rem;
        font-weight: 700;
        color: white;
        margin-bottom: 10px;
    }

    .glass-card-pill {
        display: inline-block;
        padding: 5px 15px;
        background: rgba(16, 185, 129, 0.2);
        color: #10B981;
        border-radius: 50px;
        font-size: 0.8rem;
        font-weight: 600;
        margin-bottom: 10px;
    }

    @keyframes float3D {
        0% { transform: translateY(0px) rotateY(-15deg) rotateX(10deg); }
        50% { transform: translateY(-20px) rotateY(-5deg) rotateX(5deg); }
        100% { transform: translateY(0px) rotateY(-15deg) rotateX(10deg); }
    }

    /* Floating Particles in Hero */
    .particle {
        position: absolute;
        background: rgba(255, 255, 255, 0.5);
        border-radius: 50%;
        animation: floatUp 15s infinite linear;
        pointer-events: none;
        z-index: 0;
    }

    @keyframes floatUp {
        0% { transform: translateY(100vh) scale(0); opacity: 0; }
        50% { opacity: 1; }
        100% { transform: translateY(-20vh) scale(1.5); opacity: 0; }
    }

    /* Search Bar - Glassmorphism */
    .search-bar-wrapper {
        position: relative;
        margin-top: -80px;
        z-index: 10;
        padding: 0 20px;
    }

    .search-bar-container {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 24px;
        padding: 15px;
        display: flex;
        gap: 15px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
        align-items: center;
        max-width: 1000px;
        margin: 0 auto;
        flex-wrap: wrap;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .search-bar-container:hover {
        transform: translateY(-5px);
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.12);
    }
    
    .search-input-group {
        flex: 1;
        min-width: 200px;
        display: flex;
        align-items: center;
        background: white;
        padding: 12px 20px;
        border-radius: 16px;
        border: 1px solid rgba(0,0,0,0.05);
        transition: all 0.3s ease;
    }

    .search-input-group:focus-within {
        border-color: var(--primary-emerald);
        box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
    }
    
    .search-input-group i {
        font-size: 24px;
        color: var(--primary-emerald);
        margin-right: 15px;
    }
    
    .search-input-group label {
        display: block;
        font-size: 12px;
        text-transform: uppercase;
        color: #6B7280;
        font-weight: 700;
        margin-bottom: 2px;
        letter-spacing: 0.5px;
    }
    
    .search-input-group input {
        border: none;
        outline: none;
        width: 100%;
        color: var(--dark-green);
        font-size: 15px;
        font-weight: 500;
        background: transparent;
    }
    
    .btn-search {
        background: linear-gradient(135deg, var(--primary-emerald), var(--dark-green));
        color: white;
        border: none;
        padding: 0 35px;
        height: 60px;
        border-radius: 16px;
        font-weight: 600;
        font-size: 16px;
        cursor: pointer;
        transition: all 0.3s;
        box-shadow: 0 10px 20px rgba(16, 185, 129, 0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }
    
    .btn-search:hover {
        transform: translateY(-2px);
        box-shadow: 0 15px 25px rgba(16, 185, 129, 0.4);
    }

    /* Stats Section */
    .stats-bar {
        padding: 60px 0;
        background: linear-gradient(180deg, var(--bg-creme) 0%, white 100%);
        margin-top: 40px;
    }
    
    .stat-item {
        padding: 20px;
        transition: transform 0.3s;
    }

    .stat-item:hover {
        transform: translateY(-10px);
    }
    
    .stat-number {
        font-size: 3.5rem;
        font-weight: 800;
        color: var(--dark-green);
        line-height: 1;
        margin-bottom: 10px;
        background: linear-gradient(135deg, var(--dark-green), var(--primary-emerald));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    
    .stat-label {
        font-size: 1.1rem;
        font-weight: 600;
        color: #6B7280;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    /* Categories Section */
    .section-title {
        font-size: 3rem;
        font-weight: 800;
        color: var(--dark-green);
        text-align: center;
        margin-bottom: 50px;
        position: relative;
    }

    .section-title::after {
        content: '';
        position: absolute;
        bottom: -15px;
        left: 50%;
        transform: translateX(-50%);
        width: 80px;
        height: 6px;
        background: var(--primary-emerald);
        border-radius: 3px;
    }

    .categories-section {
        padding: 80px 0;
        background-color: white;
    }
    
    .category-bubbles {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 30px;
    }
    
    .category-bubble {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-decoration: none;
        color: var(--dark-green);
        width: 140px;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    
    .category-bubble:hover {
        transform: translateY(-15px) scale(1.05);
    }
    
    .bubble-icon {
        width: 90px;
        height: 90px;
        border-radius: 50%;
        background: var(--light-green);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 35px;
        color: var(--primary-emerald);
        margin-bottom: 15px;
        box-shadow: 0 10px 25px rgba(16, 185, 129, 0.15);
        transition: all 0.3s;
        border: 2px solid transparent;
    }
    
    .category-bubble:hover .bubble-icon {
        background: var(--primary-emerald);
        color: white;
        box-shadow: 0 15px 35px rgba(16, 185, 129, 0.3);
        border-color: rgba(255,255,255,0.5);
    }
    
    .bubble-label {
        font-weight: 700;
        font-size: 1.1rem;
        transition: color 0.3s;
    }

    .category-bubble:hover .bubble-label {
        color: var(--primary-emerald);
    }

    /* Activities Grid */
    .activities-section {
        padding: 60px 0 100px;
        background-color: white;
    }
    
    .activity-card {
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.06);
        transition: all 0.3s;
        height: 100%;
        background: var(--bg-creme);
    }
    .activity-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 40px rgba(0,0,0,0.12);
    }
    .activity-img {
        height: 250px;
        width: 100%;
        background-color: #ddd; /* Skeleton bg */
        object-fit: cover;
    }
    .activity-body {
        padding: 25px;
    }
    .activity-category {
        font-size: 12px;
        text-transform: uppercase;
        font-weight: 700;
        color: var(--primary-emerald);
        margin-bottom: 10px;
        display: block;
    }
    .activity-title {
        font-size: 20px;
        font-weight: 700;
        color: var(--dark-green);
        margin-bottom: 15px;
    }
    .activity-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-top: 1px solid rgba(0,0,0,0.1);
        padding-top: 15px;
        margin-top: 15px;
    }
    .activity-price {
        font-weight: 700;
        font-size: 18px;
    }
</style>
{% endblock %}

{% block body %}

<!-- Hero Section -->

{% extends 'base.html.twig' %}

{% block title %}Nouvelle Requête - GoVibe — Signature Service{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Manrope:wght@200..800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
<link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet" />
<style>
/* ═══════════════════════════════════════════════════
   GoVibe Reclamations New Form — Ultra Premium Design
═══════════════════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; }

body {
    font-family: 'Manrope', sans-serif !important;
    background: #fcf9f8 !important;
    color: #1c1b1b !important;
    overflow-x: hidden !important;
}

.material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24; }

/* ─── Hero Section ─── */
.gv-rec-hero {
    position: relative;
    padding: 180px 0 100px;
    background: linear-gradient(160deg, #00342d 0%, #013220 40%, #001a12 100%);
    overflow: hidden;
    text-align: center;
    border-radius: 0 0 3rem 3rem;
    box-shadow: 0 20px 50px rgba(0, 52, 45, 0.15);
}

.gv-rec-hero::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse at 30% 80%, rgba(16, 185, 129, 0.15) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 20%, rgba(233, 193, 118, 0.08) 0%, transparent 50%);
    pointer-events: none;
}

.gv-hero-title {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: #fff;
    font-weight: 700;
    margin-bottom: 1rem;
    position: relative;
    z-index: 2;
}
.gv-hero-title em { color: #e9c176; font-style: italic; font-weight: 300; }

.gv-hero-sub {
    color: rgba(233, 193, 118, 0.8);
    font-size: 1.15rem;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
    position: relative;
    z-index: 2;
}

/* ─── Floating Element in Hero ─── */
.gv-hero-shield {
    position: absolute;
    top: 50%; right: 10%;
    transform: translateY(-50%);
    font-size: 20rem;
    color: rgba(255, 255, 255, 0.02);
    z-index: 1;
    pointer-events: none;
    font-variation-settings: 'FILL' 1;
}

/* ─── Main Content Container ─── */
.gv-rec-container {
    max-width: 800px;
    margin: -60px auto 100px;
    position: relative;
    z-index: 10;
    padding: 0 2rem;
}

/* ─── Form Glass Panel ─── */
.gv-form-glass {
    background: #fff;
    border-radius: 1.5rem;
    padding: 3rem 4rem;
    box-shadow: 0 30px 60px -15px rgba(0, 52, 45, 0.08);
    border: 1px solid rgba(0, 52, 45, 0.05);
}
@media (max-width: 768px) {
    .gv-form-glass { padding: 2rem; }
}

.gv-form-header {
    text-align: center;
    margin-bottom: 2.5rem;
}
.gv-form-header .material-symbols-outlined {
    font-size: 3rem;
    color: #00342d;
    margin-bottom: 1rem;
    background: rgba(0, 52, 45, 0.05);
    padding: 1rem;
    border-radius: 50%;
}
.gv-form-header h3 {
    font-family: 'Noto Serif', serif;
    font-weight: 700;
    font-size: 1.75rem;
    color: #1c1b1b;
}

/* ─── Form Inputs ─── */
.gv-form-group {
    margin-bottom: 1.5rem;
}
.gv-form-group label {
    display: block;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #546067;
    margin-bottom: 0.5rem;
}
.gv-form-control {
    width: 100%;
    padding: 1rem 1.25rem;
    border: 2px solid transparent;
    background: #f6f3f2;
    border-radius: 0.75rem;
    color: #1c1b1b;
    font-family: 'Manrope', sans-serif;
    font-size: 1rem;
    transition: all 0.3s ease;
}
.gv-form-control::placeholder { color: #bfc9c4; font-weight: 500; }
.gv-form-control:focus {
    background: #fff;
    border-color: rgba(0, 52, 45, 0.15);
    box-shadow: 0 0 0 4px rgba(0, 52, 45, 0.05);
    outline: none;
}

/* Override Symfony injected classes if needed */
.form-control { all: unset; }
input[type="text"].form-control, textarea.form-control {
    width: 100%; padding: 1rem 1.25rem; border: 2px solid transparent;
    background: #f6f3f2; border-radius: 0.75rem; color: #1c1b1b;
    font-family: 'Manrope', sans-serif; font-size: 1rem; transition: all 0.3s ease; box-sizing: border-box;
}
input[type="text"].form-control:focus, textarea.form-control:focus {
    background: #fff; border-color: rgba(0, 52, 45, 0.15); box-shadow: 0 0 0 4px rgba(0, 52, 45, 0.05); outline: none;
}
label.form-label {
    display: block; font-size: 0.8rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.1em; color: #546067; margin-bottom: 0.5rem;
}

/* ─── Buttons ─── */
.gv-btn-primary {
    width: 100%;
    padding: 1.15rem 2rem;
    background: linear-gradient(135deg, #00342d 0%, #004d43 70%, #046b5e 100%);
    color: #fff;
    border: none;
    border-radius: 0.75rem;
    font-weight: 700;
    font-size: 1.05rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    transition: all 0.3s ease;
    box-shadow: 0 12px 30px -8px rgba(0, 52, 45, 0.4);
    margin-top: 2rem;
}
.gv-btn-primary:hover {
    transform: translateY(-2px) scale(1.01);
    box-shadow: 0 18px 40px -10px rgba(0, 52, 45, 0.5);
}

.gv-btn-back {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1.5rem;
    color: #707975;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
    transition: color 0.3s ease;
}
.gv-btn-back:hover { color: #00342d; text-decoration: underline; }

/* Error state styling */
.invalid-feedback {
    display: block;
    color: #ba1a1a;
    font-size: 0.8rem;
    margin-top: 0.5rem;
    font-weight: 600;
}
</style>
{% endblock %}

{% block body %}
<!-- ─── HERO ─── -->
<div class="gv-rec-hero">
    <span class="material-symbols-outlined gv-hero-shield">drafts</span>
    <div class="container" data-aos="zoom-in" data-aos-duration="1000">
        <h1 class="gv-hero-title">Nouvelle <em>Réclamation</em></h1>
        <p class="gv-hero-sub">Détaillez le motif de votre réclamation. Notre équipe traitera votre demande dans les plus brefs délais et avec le plus grand soin.</p>
    </div>
</div>

<!-- ─── MAIN CONTENT ─── -->
<div class="gv-rec-container">
    <div class="gv-form-glass" data-aos="fade-up" data-aos-delay="200" data-aos-duration="800">
        
        <div class="gv-form-header">
            <span class="material-symbols-outlined">design_services</span>
            <h3>Formuler une Requête</h3>
        </div>

        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            
            <div class="gv-form-group" data-aos="fade-up" data-aos-delay="300">
                {{ form_label(form.sujet, 'Objet de la requête', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.sujet, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Modification de la réservation de vol...'}}) }}
                {{ form_errors(form.sujet) }}
            </div>
            
            <div class="gv-form-group" data-aos="fade-up" data-aos-delay="400">
                {{ form_label(form.message, 'Détails du message', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.message, {'attr': {'class': 'form-control', 'rows': '6', 'placeholder': 'Veuillez nous fournir un maximum de détails concernant votre demande...'}}) }}
                {{ form_errors(form.message) }}
            </div>

            <div data-aos="fade-up" data-aos-delay="500">
                <button type="submit" class="gv-btn-primary" style="background: linear-gradient(135deg, #e9c176 0%, #ca9028 100%); color: #3d2a00; box-shadow: 0 10px 25px -5px rgba(233, 193, 118, 0.4);">
                    <span class="material-symbols-outlined">send</span> Envoyer la réclamation
                </button>
                
                <a href="{{ path('app_reclamation_index') }}" class="gv-btn-back">
                    <span class="material-symbols-outlined" style="font-size:1.1rem;">keyboard_backspace</span> 
                    Retour à l'historique
                </a>
            </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        AOS.init({ once: true, offset: 50 });
    });
</script>
{% endblock %}

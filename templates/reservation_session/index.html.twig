{% extends 'base.html.twig' %}

{% block title %}Mes Réservations - GoVibe{% endblock %}

{% block body %}
<div class="container-fluid py-5 text-center mb-5 border-bottom rounded-bottom-5 px-lg-5 shadow-sm bg-white">
    <div class="d-flex align-items-center justify-content-center gap-3 mb-3">
        <span class="badge rounded-pill bg-light text-dark border px-3">Historique des Aventures</span>
    </div>
    <h1 class="display-3 fw-bold text-dark mb-2">Mes <span style="color: #2ECC71;">Réservations</span></h1>
    <p class="text-secondary fs-5">Retrouvez toutes vos sessions d'activités programmées</p>
</div>

<div class="container mb-5 pb-5 px-lg-5">
    <div class="row">
        <div class="col-12">
            {% for message in app.flashes('success') %}
                <div class="alert alert-success border-0 rounded-4 shadow-sm mb-4 animate-fade-in">
                    <i class="bi bi-check-circle-fill me-2"></i> {{ message }}
                </div>
            {% endfor %}
            {% for message in app.flashes('warning') %}
                <div class="alert alert-warning border-0 rounded-4 shadow-sm mb-4 animate-fade-in">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> {{ message }}
                </div>
            {% endfor %}
            {% for message in app.flashes('danger') %}
                <div class="alert alert-danger border-0 rounded-4 shadow-sm mb-4 animate-fade-in">
                    <i class="bi bi-x-circle-fill me-2"></i> {{ message }}
                </div>
            {% endfor %}

            <div class="card border-0 shadow-lg rounded-5 overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 custom-table">
                        <thead class="bg-light text-uppercase small fw-bold">
                            <tr>
                                <th class="ps-4 py-4">Activité</th>
                                <th class="py-4">Session Date/Heure</th>
                                <th class="py-4 text-center">Places</th>
                                <th class="py-4">Réservé le</th>
                                <th class="pe-4 py-4 text-end">Gestion</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for reservation in reservations %}
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center gap-3 py-2">
                                            <div class="p-3 bg-light rounded-4 text-success shadow-sm">
                                                <i class="bi bi-rocket-takeoff fs-4"></i>
                                            </div>
                                            <div>
                                                <div class="fw-bold fs-5 text-dark">{{ reservation.session.activite.name }}</div>
                                                <div class="text-muted small"><i class="bi bi-geo-alt me-1"></i> {{ reservation.session.activite.localisation }}</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex flex-column">
                                            <span class="fw-bold text-dark"><i class="bi bi-calendar-check me-2 text-success"></i> {{ reservation.session.date|date('d/m/Y') }}</span>
                                            <span class="text-muted small"><i class="bi bi-clock me-2"></i> {{ reservation.session.heure|date('H:i') }}</span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge rounded-pill bg-success px-3 py-2 fs-6" style="background-color: rgba(46, 204, 113, 0.1) !important; color: #2ECC71 !important; border: 1px solid rgba(46, 204, 113, 0.2);">
                                            {{ reservation.nbPlaces }}
                                        </span>
                                    </td>
                                    <td class="text-muted small">
                                        {{ reservation.reservedAt|date('d/m/Y') }}<br>
                                        <span class="opacity-50 fs-xs">{{ reservation.reservedAt|date('H:i') }}</span>
                                    </td>
                                    <td class="pe-4 text-end">
                                        <form method="post" action="{{ path('app_reservation_session_cancel', {'idReservation': reservation.idReservation}) }}" onsubmit="return confirm('Voulez-vous vraiment annuler cette réservation ? Cette action est irréversible.');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('cancel' ~ reservation.idReservation) }}">
                                            <button class="btn btn-outline-danger btn-sm rounded-pill px-4 py-2 fw-bold border-2 transition-all hover-lift-2">
                                                <i class="bi bi-x-circle me-1"></i> Annuler
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="5" class="text-center py-5">
                                        <div class="text-muted mb-4">
                                            <i class="bi bi-calendar-x fs-1 opacity-25"></i>
                                        </div>
                                        <p class="fs-4 fw-light text-secondary mb-4">Vous n'avez pas encore de réservations d'activités.</p>
                                        <a href="{{ path('app_activite_index') }}" class="btn btn-success btn-lg rounded-pill px-5 shadow-sm border-0 transition-all hover-lift-2" style="background-color: #2ECC71;">
                                            Explorer les Activités
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
<style>
    body { background-color: #F8F9F9 !important; }
    .rounded-bottom-5 { border-bottom-left-radius: 4rem !important; border-bottom-right-radius: 4rem !important; }
    .custom-table tbody tr { transition: all 0.2s; border-bottom: 1px solid #F2F4F4; }
    .custom-table tbody tr:hover { background-color: rgba(46, 204, 113, 0.02); }
    .hover-lift-2:hover { transform: translateY(-3px); }
    .animate-fade-in { animation: fadeIn 0.5s ease-out; }
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    .fs-xs { font-size: 0.75rem; }
</style>
{% endblock %}

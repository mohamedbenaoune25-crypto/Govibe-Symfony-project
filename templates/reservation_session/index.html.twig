{% extends is_granted('ROLE_ADMIN') ? 'admin/base_admin.html.twig' : 'base.html.twig' %}

{% block title %}Mes Réservations — GoVibe{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Manrope:wght@200..800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
<style>
body { font-family: 'Manrope', sans-serif !important; background: #fcf9f8 !important; }
.material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24; }

/* ─── Hero ─── */
.gv-res-hero {
    position: relative; padding: 170px 0 110px;
    background: linear-gradient(160deg, #00342d 0%, #013220 40%, #001a12 100%);
    overflow: hidden; text-align: center; border-radius: 0 0 3rem 3rem;
    box-shadow: 0 20px 50px rgba(0,52,45,0.15);
}
.gv-res-hero::before { content:''; position:absolute; inset:0; background: radial-gradient(ellipse at 30% 80%, rgba(16,185,129,0.15) 0%, transparent 60%), radial-gradient(ellipse at 80% 20%, rgba(233,193,118,0.08) 0%, transparent 50%); pointer-events:none; }
.gv-res-hero::after { content:''; position:absolute; inset:0; background-image: radial-gradient(rgba(160,242,225,0.06) 1px, transparent 1px); background-size:24px 24px; pointer-events:none; }
.gv-hero-icon-bg { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); font-size:20rem; color:rgba(255,255,255,0.02); pointer-events:none; font-variation-settings:'FILL' 1; }

.gv-hero-badge { display:inline-flex; align-items:center; gap:0.3rem; padding:0.4rem 1rem; border-radius:2rem; font-size:0.72rem; font-weight:800; background:rgba(160,242,225,0.12); color:#a0f2e1; border:1px solid rgba(160,242,225,0.2); position:relative; z-index:2; text-transform:uppercase; letter-spacing:0.06em; margin-bottom:0.75rem; }

.gv-hero-title { font-family:'Noto Serif',serif; font-size:clamp(2.2rem,4.5vw,3.5rem); color:#fff; font-weight:700; margin-bottom:0.75rem; position:relative; z-index:2; animation:heroFadeIn 0.8s ease both; }
.gv-hero-title em { color:#a0f2e1; font-style:italic; font-weight:300; }
.gv-hero-sub { color:rgba(160,242,225,0.7); font-size:1.05rem; position:relative; z-index:2; animation:heroFadeIn 0.8s ease 0.2s both; max-width:550px; margin:0 auto 1.5rem; }
@keyframes heroFadeIn { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }

.gv-hero-actions { display:flex; justify-content:center; gap:0.75rem; flex-wrap:wrap; position:relative; z-index:2; animation:heroFadeIn 0.8s ease 0.4s both; }
.gv-btn-outline-light { padding:0.7rem 1.5rem; background:rgba(255,255,255,0.08); color:#fff; border:1px solid rgba(255,255,255,0.15); border-radius:0.75rem; font-weight:700; font-size:0.9rem; text-decoration:none; display:inline-flex; align-items:center; gap:0.5rem; backdrop-filter:blur(8px); transition:all 0.3s; font-family:'Manrope',sans-serif; }
.gv-btn-outline-light:hover { background:rgba(255,255,255,0.15); color:#fff; transform:translateY(-2px); }

/* ─── Container ─── */
.gv-res-container { max-width:1200px; margin:-45px auto 80px; position:relative; z-index:10; padding:0 2rem; }

/* ─── Table Card ─── */
.gv-table-card {
    background:#fff; border-radius:1.5rem; box-shadow:0 20px 50px rgba(0,0,0,0.04);
    overflow:hidden; border:1px solid rgba(0,52,45,0.05);
}
.gv-table { width:100%; border-collapse:collapse; }
.gv-table th { background:#f8f7f5; color:#3c494f; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; font-size:0.72rem; padding:1.25rem 1.5rem; border-bottom:2px solid rgba(0,52,45,0.04); text-align:left; }
.gv-table td { padding:1.25rem 1.5rem; border-bottom:1px solid rgba(0,52,45,0.04); vertical-align:middle; transition:background 0.3s; }
.gv-table tbody tr:hover td { background:rgba(160,242,225,0.04); }

.gv-res-act-name { font-family:'Noto Serif',serif; font-weight:700; color:#00342d; font-size:1rem; }
.gv-res-act-loc { color:#707975; font-size:0.8rem; margin-top:0.15rem; display:flex; align-items:center; gap:0.25rem; }
.gv-res-act-loc .material-symbols-outlined { font-size:0.85rem; color:#10B981; }

.gv-res-date { font-weight:700; color:#00342d; display:flex; align-items:center; gap:0.35rem; }
.gv-res-date .material-symbols-outlined { font-size:1rem; color:#10B981; }
.gv-res-time { color:#707975; font-size:0.8rem; display:flex; align-items:center; gap:0.25rem; margin-top:0.15rem; }
.gv-res-time .material-symbols-outlined { font-size:0.85rem; }

.gv-badge-places { display:inline-flex; align-items:center; padding:0.45rem 1rem; border-radius:2rem; font-size:0.8rem; font-weight:800; background:rgba(16,185,129,0.08); color:#005046; border:1px solid rgba(16,185,129,0.15); }

.gv-res-reserved-at { color:#707975; font-size:0.85rem; }
.gv-res-reserved-time { color:#bfc9c4; font-size:0.75rem; }

.gv-action-btn-sm { padding:0.5rem 1rem; border-radius:0.6rem; font-weight:700; font-size:0.8rem; text-decoration:none; display:inline-flex; align-items:center; gap:0.3rem; transition:all 0.25s; border:none; cursor:pointer; font-family:'Manrope',sans-serif; }
.gv-action-btn-sm:hover { transform:translateY(-2px); }
.gv-action-edit { background:rgba(0,52,45,0.06); color:#00342d; }
.gv-action-edit:hover { background:linear-gradient(135deg,#00342d,#046b5e); color:#fff; }
.gv-action-cancel { background:rgba(186,26,26,0.06); color:#93000a; }
.gv-action-cancel:hover { background:#ba1a1a; color:#fff; }

/* ─── Icon Row ─── */
.gv-act-icon { width:42px; height:42px; border-radius:0.75rem; display:flex; align-items:center; justify-content:center; background:rgba(0,52,45,0.04); flex-shrink:0; }
.gv-act-icon .material-symbols-outlined { font-size:1.3rem; color:#10B981; }

/* ─── Empty ─── */
.gv-empty { text-align:center; padding:4rem 2rem; }
.gv-empty-icon { font-size:3.5rem; color:#cde1db; margin-bottom:1rem; font-variation-settings:'FILL' 1; }
.gv-empty h4 { font-family:'Noto Serif',serif; font-size:1.3rem; color:#00342d; font-weight:700; margin-bottom:0.5rem; }
.gv-empty p { color:#546067; margin-bottom:1.5rem; }
.gv-btn-emerald { padding:0.85rem 2rem; background:linear-gradient(135deg,#00342d,#046b5e); color:#fff; border:none; border-radius:0.75rem; font-weight:700; font-size:0.95rem; text-decoration:none; display:inline-flex; align-items:center; gap:0.5rem; transition:all 0.3s; box-shadow:0 8px 20px -6px rgba(0,52,45,0.4); font-family:'Manrope',sans-serif; }
.gv-btn-emerald:hover { transform:translateY(-2px); box-shadow:0 12px 30px -6px rgba(0,52,45,0.5); color:#fff; }
</style>
{% endblock %}

{% block body %}
<div class="gv-res-hero">
    <span class="material-symbols-outlined gv-hero-icon-bg">confirmation_number</span>
    <div class="container">
        <span class="gv-hero-badge">
            <span class="material-symbols-outlined" style="font-size:0.9rem;">history</span>
            Historique des Aventures
        </span>
        <h1 class="gv-hero-title">Mes <em>Réservations</em></h1>
        <p class="gv-hero-sub">Retrouvez toutes vos sessions d'activités programmées</p>
        <div class="gv-hero-actions">
            <a href="{{ path('app_reservation_session_pdf') }}" class="gv-btn-outline-light">
                <span class="material-symbols-outlined" style="font-size:1rem;">picture_as_pdf</span> Exporter PDF
            </a>
            <a href="{{ path('app_reservation_session_stats') }}" class="gv-btn-outline-light">
                <span class="material-symbols-outlined" style="font-size:1rem;">bar_chart</span> Statistiques
            </a>
        </div>
    </div>
</div>

<div class="gv-res-container">
    {% for message in app.flashes('success') %}
        <div class="alert alert-success border-0 rounded-4 shadow-sm mb-4" style="background:#eafaf1; color:#005046; border:1px solid #a0f2e1!important; font-weight:600;">
            <i class="bi bi-check-circle-fill me-2"></i> {{ message }}
        </div>
    {% endfor %}
    {% for message in app.flashes('warning') %}
        <div class="alert alert-warning border-0 rounded-4 shadow-sm mb-4" style="background:rgba(233,193,118,0.1); color:#92400e; border:1px solid rgba(233,193,118,0.3)!important; font-weight:600;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> {{ message }}
        </div>
    {% endfor %}
    {% for message in app.flashes('danger') %}
        <div class="alert alert-danger border-0 rounded-4 shadow-sm mb-4" style="background:#fef2f2; color:#93000a; border:1px solid rgba(186,26,26,0.15)!important; font-weight:600;">
            <i class="bi bi-x-circle-fill me-2"></i> {{ message }}
        </div>
    {% endfor %}

    <div class="gv-table-card">
        <div class="table-responsive">
            <table class="gv-table">
                <thead>
                    <tr>
                        <th>Activité</th>
                        <th>Session Date/Heure</th>
                        <th style="text-align:center;">Places</th>
                        <th>Réservé le</th>
                        <th style="text-align:right;">Gestion</th>
                    </tr>
                </thead>
                <tbody>
                {% for reservation in reservations %}
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <div class="gv-act-icon">
                                    <span class="material-symbols-outlined">hiking</span>
                                </div>
                                <div>
                                    <div class="gv-res-act-name">{{ reservation.session.activite.name }}</div>
                                    <div class="gv-res-act-loc">
                                        <span class="material-symbols-outlined">location_on</span>
                                        {{ reservation.session.activite.localisation }}
                                    </div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="gv-res-date">
                                <span class="material-symbols-outlined">event</span>
                                {{ reservation.session.date|date('d/m/Y') }}
                            </div>
                            <div class="gv-res-time">
                                <span class="material-symbols-outlined">schedule</span>
                                {{ reservation.session.heure|date('H:i') }}
                            </div>
                        </td>
                        <td style="text-align:center;">
                            <span class="gv-badge-places">{{ reservation.nbPlaces }}</span>
                        </td>
                        <td>
                            <div class="gv-res-reserved-at">{{ reservation.reservedAt|date('d/m/Y') }}</div>
                            <div class="gv-res-reserved-time">{{ reservation.reservedAt|date('H:i') }}</div>
                        </td>
                        <td style="text-align:right;">
                            <div class="d-flex justify-content-end gap-2">
                                <a href="{{ path('app_reservation_session_edit', {'idReservation': reservation.idReservation}) }}" class="gv-action-btn-sm gv-action-edit">
                                    <span class="material-symbols-outlined" style="font-size:0.95rem;">edit</span> Modifier
                                </a>
                                <form method="post" action="{{ path('app_reservation_session_cancel', {'idReservation': reservation.idReservation}) }}" onsubmit="return confirm('Voulez-vous vraiment annuler cette réservation ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('cancel' ~ reservation.idReservation) }}">
                                    <button class="gv-action-btn-sm gv-action-cancel">
                                        <span class="material-symbols-outlined" style="font-size:0.95rem;">cancel</span> Annuler
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5">
                            <div class="gv-empty">
                                <span class="material-symbols-outlined gv-empty-icon">event_busy</span>
                                <h4>Aucune réservation d'activité</h4>
                                <p>Vous n'avez pas encore réservé de session. Explorez les activités disponibles.</p>
                                <a href="{{ path('app_activite_index') }}" class="gv-btn-emerald">
                                    <span class="material-symbols-outlined" style="font-size:1.1rem;">explore</span>
                                    Explorer les Activités
                                </a>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}

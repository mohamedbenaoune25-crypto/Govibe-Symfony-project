{% extends is_granted('ROLE_ADMIN') ? 'admin/base_admin.html.twig' : 'base.html.twig' %}

{% block title %}Modifier Réservation — GoVibe{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Manrope:wght@200..800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
<style>
body { font-family: 'Manrope', sans-serif !important; background: #fcf9f8 !important; }
.material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24; }

/* ─── Hero ─── */
.gv-edit-hero {
    position: relative; padding: 160px 0 100px;
    background: linear-gradient(160deg, #00342d 0%, #013220 40%, #001a12 100%);
    overflow: hidden; text-align: center; border-radius: 0 0 3rem 3rem;
    box-shadow: 0 20px 50px rgba(0,52,45,0.15);
}
.gv-edit-hero::before { content:''; position:absolute; inset:0; background: radial-gradient(ellipse at 30% 80%, rgba(16,185,129,0.18) 0%, transparent 55%), radial-gradient(ellipse at 80% 20%, rgba(233,193,118,0.1) 0%, transparent 45%); pointer-events:none; }
.gv-edit-hero::after { content:''; position:absolute; inset:0; background-image: radial-gradient(rgba(160,242,225,0.06) 1px, transparent 1px); background-size:24px 24px; pointer-events:none; }
.gv-hero-icon-bg { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); font-size:20rem; color:rgba(255,255,255,0.015); pointer-events:none; font-variation-settings:'FILL' 1; }

.gv-hero-step { display:inline-flex; align-items:center; gap:0.3rem; padding:0.4rem 1rem; border-radius:2rem; font-size:0.72rem; font-weight:800; background:rgba(233,193,118,0.15); color:#fde68a; border:1px solid rgba(233,193,118,0.25); text-transform:uppercase; letter-spacing:0.06em; position:relative; z-index:2; margin-bottom:0.75rem; }
.gv-edit-hero h1 { font-family:'Noto Serif',serif; font-size:clamp(2rem,4vw,3rem); color:#fff; font-weight:700; margin-bottom:0.5rem; position:relative; z-index:2; }
.gv-edit-hero h1 em { color:#a0f2e1; font-style:italic; font-weight:300; }
.gv-edit-hero p { color:rgba(160,242,225,0.7); font-size:1.05rem; position:relative; z-index:2; }

/* ─── Container ─── */
.gv-edit-container { max-width:900px; margin:-50px auto 80px; position:relative; z-index:10; padding:0 2rem; }

/* ─── Split Card ─── */
.gv-split-card {
    background:rgba(255,255,255,0.97); backdrop-filter:blur(20px) saturate(180%);
    border:1px solid rgba(0,52,45,0.06); border-radius:1.5rem; overflow:hidden;
    box-shadow:0 20px 60px rgba(0,52,45,0.08); display:grid; grid-template-columns:2fr 3fr;
}
@media (max-width:768px) { .gv-split-card { grid-template-columns:1fr; } }

/* Left Panel */
.gv-edit-sidebar {
    background: linear-gradient(160deg, #00342d, #013220);
    padding: 2.5rem; color: #fff; display: flex; flex-direction: column; justify-content: center;
    position: relative; overflow: hidden;
}
.gv-edit-sidebar::before { content:''; position:absolute; inset:0; background: radial-gradient(circle at 30% 80%, rgba(16,185,129,0.15), transparent 60%); pointer-events:none; }

.gv-sidebar-icon { font-size:2.5rem; color:#a0f2e1; margin-bottom:1.25rem; font-variation-settings:'FILL' 1; opacity:0.8; position:relative; z-index:2; }
.gv-sidebar-label { font-size:0.7rem; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:rgba(255,255,255,0.5); margin-bottom:0.3rem; position:relative; z-index:2; }
.gv-sidebar-title { font-family:'Noto Serif',serif; font-weight:700; font-size:1.15rem; margin-bottom:0.2rem; position:relative; z-index:2; }
.gv-sidebar-detail { color:rgba(160,242,225,0.7); font-size:0.9rem; display:flex; align-items:center; gap:0.4rem; margin-bottom:0.3rem; position:relative; z-index:2; }
.gv-sidebar-detail .material-symbols-outlined { font-size:1rem; color:#a0f2e1; }

.gv-sidebar-price-section { margin-top:2rem; padding-top:1.5rem; border-top:1px solid rgba(255,255,255,0.1); position:relative; z-index:2; }
.gv-sidebar-price { font-family:'Noto Serif',serif; font-size:2rem; font-weight:700; color:#a0f2e1; }
.gv-sidebar-price small { font-size:0.9rem; color:rgba(160,242,225,0.5); font-family:'Manrope',sans-serif; }

/* Right Panel */
.gv-edit-form { padding: 2.5rem; }
.gv-form-title { font-family:'Noto Serif',serif; font-weight:700; font-size:1.15rem; color:#00342d; margin-bottom:1.5rem; display:flex; align-items:center; gap:0.5rem; }
.gv-form-title .material-symbols-outlined { font-size:1.1rem; color:#10B981; }
.gv-form-label { font-weight:700; color:#00342d; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.06em; margin-bottom:0.5rem; display:block; }

/* Stepper */
.gv-stepper { display:flex; align-items:center; border:1.5px solid rgba(0,52,45,0.08); border-radius:0.75rem; overflow:hidden; background:#fff; }
.gv-stepper-btn { width:52px; height:52px; border:none; background:rgba(0,52,45,0.03); display:flex; align-items:center; justify-content:center; cursor:pointer; transition:all 0.2s; color:#00342d; }
.gv-stepper-btn:hover { background:rgba(16,185,129,0.1); color:#10B981; }
.gv-stepper-btn .material-symbols-outlined { font-size:1.3rem; }
.gv-stepper-input { flex:1; border:none !important; text-align:center; font-weight:700; font-size:1.2rem; font-family:'Noto Serif',serif !important; color:#00342d; padding:0.75rem 0 !important; -moz-appearance:textfield; }
.gv-stepper-input::-webkit-inner-spin-button, .gv-stepper-input::-webkit-outer-spin-button { -webkit-appearance:none; margin:0; }
.gv-stepper-input:focus { outline:none; box-shadow:none !important; }
.gv-form-help { font-size:0.82rem; color:#707975; margin-top:0.5rem; display:flex; align-items:center; gap:0.3rem; }
.gv-form-help .material-symbols-outlined { font-size:0.9rem; color:#10B981; }

/* Total */
.gv-total-box { background:rgba(16,185,129,0.06); border:1.5px solid rgba(16,185,129,0.12); border-radius:1rem; padding:1.25rem 1.5rem; margin:1.5rem 0 2rem; display:flex; justify-content:space-between; align-items:center; }
.gv-total-label { font-weight:700; color:#546067; font-size:0.9rem; }
.gv-total-value { font-family:'Noto Serif',serif; font-size:1.5rem; font-weight:700; color:#10B981; }

/* Buttons */
.gv-btn-save { width:100%; padding:1rem; background:linear-gradient(135deg,#e9c176,#ca9028); color:#3d2a00; border:none; border-radius:0.75rem; font-weight:700; font-size:1.05rem; cursor:pointer; transition:all 0.3s; box-shadow:0 10px 25px -5px rgba(233,193,118,0.4); font-family:'Manrope',sans-serif; display:flex; align-items:center; justify-content:center; gap:0.5rem; }
.gv-btn-save:hover { transform:translateY(-2px); box-shadow:0 15px 35px -5px rgba(233,193,118,0.5); }
.gv-btn-cancel-link { display:block; text-align:center; margin-top:0.75rem; color:#707975; font-weight:600; font-size:0.9rem; text-decoration:none; padding:0.6rem; border-radius:0.5rem; transition:all 0.2s; }
.gv-btn-cancel-link:hover { background:rgba(0,52,45,0.04); color:#00342d; }
</style>
{% endblock %}

{% block body %}
<div class="gv-edit-hero">
    <span class="material-symbols-outlined gv-hero-icon-bg">edit_note</span>
    <div class="container">
        <span class="gv-hero-step">
            <span class="material-symbols-outlined" style="font-size:0.85rem;">edit</span> Modification de réservation
        </span>
        <h1>Ajustez vos <em>Places</em></h1>
        <p>{{ activite.name }} — {{ activite.localisation }}</p>
    </div>
</div>

<div class="gv-edit-container">
    <div class="gv-split-card">
        <!-- Sidebar -->
        <div class="gv-edit-sidebar">
            <span class="material-symbols-outlined gv-sidebar-icon">edit_calendar</span>
            <div class="gv-sidebar-label">Détails de la session</div>
            <div class="gv-sidebar-title">{{ activite.name }}</div>
            <div class="gv-sidebar-detail">
                <span class="material-symbols-outlined">event</span>
                {{ session.date|date('d/m/Y') }}
            </div>
            <div class="gv-sidebar-detail">
                <span class="material-symbols-outlined">schedule</span>
                {{ session.heure|date('H:i') }}
            </div>
            <div class="gv-sidebar-detail">
                <span class="material-symbols-outlined">location_on</span>
                {{ activite.localisation }}
            </div>

            <div class="gv-sidebar-price-section">
                <div class="gv-sidebar-label">Prix unitaire</div>
                <div class="gv-sidebar-price">{{ activite.prix }} <small>DT</small></div>
            </div>
        </div>

        <!-- Form -->
        <div class="gv-edit-form">
            <div class="gv-form-title">
                <span class="material-symbols-outlined">tune</span> Modifier le nombre de participants
            </div>

            <form action="{{ path('app_reservation_session_update', {'idReservation': reservation.idReservation}) }}" method="post" id="editForm">
                <label class="gv-form-label">Nouveau nombre de places</label>
                <div class="gv-stepper">
                    <button type="button" class="gv-stepper-btn" id="btnMinus">
                        <span class="material-symbols-outlined">remove</span>
                    </button>
                    <input type="number" name="nbPlaces" id="nbPlaces" class="gv-stepper-input" value="{{ reservation.nbPlaces }}" min="1" max="{{ session.nbrPlacesRestant + reservation.nbPlaces }}">
                    <button type="button" class="gv-stepper-btn" id="btnPlus">
                        <span class="material-symbols-outlined">add</span>
                    </button>
                </div>
                <div class="gv-form-help">
                    <span class="material-symbols-outlined">info</span>
                    Maximum possible : {{ session.nbrPlacesRestant + reservation.nbPlaces }} places
                </div>

                <div class="gv-total-box">
                    <span class="gv-total-label">Nouveau Total</span>
                    <span class="gv-total-value" id="totalPrice">{{ (reservation.nbPlaces * activite.prix)|number_format(2) }} DT</span>
                </div>

                <button type="submit" class="gv-btn-save">
                    <span class="material-symbols-outlined" style="font-size:1.1rem;">save</span>
                    Enregistrer les modifications
                </button>
                <a href="{{ path('app_reservation_session_index') }}" class="gv-btn-cancel-link">Annuler</a>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const nbInput = document.getElementById('nbPlaces');
    const btnMinus = document.getElementById('btnMinus');
    const btnPlus = document.getElementById('btnPlus');
    const totalSpan = document.getElementById('totalPrice');
    const unitPrice = parseFloat("{{ activite.prix }}");
    const maxPlaces = parseInt("{{ session.nbrPlacesRestant + reservation.nbPlaces }}");

    function updateTotal() {
        const count = parseInt(nbInput.value) || 1;
        const total = (count * unitPrice).toFixed(2);
        totalSpan.textContent = total + ' DT';
    }

    btnMinus.addEventListener('click', () => { if (nbInput.value > 1) { nbInput.value--; updateTotal(); } });
    btnPlus.addEventListener('click', () => { if (nbInput.value < maxPlaces) { nbInput.value++; updateTotal(); } });
    nbInput.addEventListener('change', () => {
        if (nbInput.value < 1) nbInput.value = 1;
        if (nbInput.value > maxPlaces) nbInput.value = maxPlaces;
        updateTotal();
    });
});
</script>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Modifier Réservation #{{ reservation.idReservation }} | GoVibe{% endblock %}

{% block stylesheets %}
<style>
    .form-hero {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
        padding: 120px 0 80px; position: relative; overflow: hidden;
    }
    .form-hero::before {
        content:''; position:absolute; inset:0;
        background: radial-gradient(circle at 70% 40%, rgba(255,193,7,0.08) 0%, transparent 65%);
    }
    .form-card { background:white; border-radius:24px; box-shadow:0 10px 40px rgba(0,0,0,0.1); overflow:hidden; margin-top:-40px; }
    .form-card-header { background:linear-gradient(135deg,#1a1a2e,#0f3460); padding:28px 36px; display:flex; align-items:center; gap:16px; }
    .form-card-header .hico { width:48px; height:48px; background:rgba(255,193,7,0.2); border:1px solid rgba(255,193,7,0.4); border-radius:14px; display:flex; align-items:center; justify-content:center; font-size:1.4rem; color:#ffc107; flex-shrink:0; }
    .form-card-header h2 { font-family:'Outfit',sans-serif; font-size:1.4rem; font-weight:700; color:white; margin:0; }
    .form-card-header p  { font-size:13px; color:rgba(255,255,255,0.55); margin:4px 0 0; }

    .form-body { padding:36px; }
    .field-group { margin-bottom:24px; }
    .field-label { font-size:12px; font-weight:700; color:#555; text-transform:uppercase; letter-spacing:0.8px; margin-bottom:8px; display:flex; align-items:center; gap:6px; }
    .field-label i { color:#ffc107; }
    .field-required { color:#dc3545; margin-left:2px; }
    .form-control, .form-select { border:2px solid #e9ecef; border-radius:12px; padding:12px 16px; font-size:15px; transition:border-color 0.2s,box-shadow 0.2s; background:#fcfcfc; }
    .form-control:focus, .form-select:focus { border-color:#ffc107; box-shadow:0 0 0 3px rgba(255,193,7,0.12); background:white; outline:none; }
    .invalid-feedback { font-size:12px; color:#dc3545; margin-top:6px; }

    .warn-box { background:#fff8e1; border:1px solid #ffe082; border-radius:12px; padding:14px 18px; font-size:13px; color:#856404; display:flex; gap:10px; align-items:flex-start; margin-bottom:24px; }
    .warn-box i { color:#ffc107; font-size:1.1rem; flex-shrink:0; margin-top:1px; }

    .current-info { background:#f0e8ff; border:1px solid #c9b8df; border-radius:14px; padding:16px 20px; margin-bottom:24px; }
    .current-info .ci-label { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.8px; color:#9370DB; margin-bottom:8px; }
    .current-info .ci-value { font-size:15px; font-weight:700; color:#2d1b69; font-family:'Outfit',sans-serif; }
    .current-info .ci-meta { font-size:12px; color:#888; margin-top:4px; }

    .form-footer { background:#f8f9fa; padding:24px 36px; display:flex; justify-content:space-between; align-items:center; border-top:1px solid #eee; flex-wrap:wrap; gap:12px; }
    .btn-cancel { background:white; border:2px solid #dee2e6; color:#555; border-radius:12px; padding:11px 24px; font-weight:600; text-decoration:none; display:inline-flex; align-items:center; gap:8px; transition:all 0.2s; }
    .btn-cancel:hover { border-color:#2d1b69; color:#2d1b69; }
    .btn-save { background:linear-gradient(135deg,#ffc107,#fd7e14); color:white; border:0; border-radius:12px; padding:12px 32px; font-weight:700; font-size:15px; display:inline-flex; align-items:center; gap:8px; transition:all 0.3s; cursor:pointer; box-shadow:0 4px 15px rgba(255,193,7,0.35); }
    .btn-save:hover { transform:translateY(-2px); box-shadow:0 8px 25px rgba(255,193,7,0.45); }
</style>
{% endblock %}

{% block body %}
<div class="form-hero">
    <div class="container position-relative">
        <p style="font-size:13px; margin-bottom:16px;">
            <a href="{{ path('app_reservation_session_index') }}" style="color:#ffc107; text-decoration:none;">
                <i class="bi bi-ticket-perforated me-1"></i>Réservations
            </a>
            <span style="color:rgba(255,255,255,0.4); margin:0 8px;">/</span>
            <a href="{{ path('app_reservation_session_show', {'id': reservation.idReservation}) }}" style="color:#ffc107; text-decoration:none;">
                #{{ reservation.idReservation }}
            </a>
            <span style="color:rgba(255,255,255,0.4); margin:0 8px;">/</span>
            <span class="text-white-50">Modifier</span>
        </p>
        <h1 style="font-family:'Outfit',sans-serif; font-size:clamp(1.8rem,4vw,2.8rem); font-weight:700; color:white; margin-bottom:10px;">
            Modifier la <span style="color:#ffc107;">Réservation</span> #{{ reservation.idReservation }}
        </h1>
        <p class="text-white-50" style="font-size:15px;">
            <i class="bi bi-person-fill me-1" style="color:#ffc107;"></i> {{ reservation.userRef }}
        </p>
    </div>
</div>

<div class="container pb-5">
    <div class="form-card">
        <div class="form-card-header">
            <div class="hico"><i class="bi bi-pencil-square"></i></div>
            <div>
                <h2>Modifier la réservation</h2>
                <p>Modifiez la session, le nombre de places ou la référence du réservant.</p>
            </div>
        </div>

        <div class="form-body">
            {# Infos actuelles #}
            {% if reservation.session %}
                <div class="current-info">
                    <div class="ci-label"><i class="bi bi-info-circle-fill me-1"></i>Réservation actuelle</div>
                    <div class="ci-value">
                        {{ reservation.session.activite ? reservation.session.activite.name : 'Activité inconnue' }}
                        — {{ reservation.session.date ? reservation.session.date|date('d/m/Y') : '?' }}
                    </div>
                    <div class="ci-meta">
                        <i class="bi bi-people me-1"></i>{{ reservation.nbPlaces }} place(s) réservée(s)
                        &nbsp;·&nbsp;
                        <i class="bi bi-person me-1"></i>{{ reservation.userRef }}
                    </div>
                </div>
            {% endif %}

            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

            <div class="warn-box">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <div>Si vous changez de session, les places de l'ancienne session seront <strong>automatiquement restituées</strong> et déduites de la nouvelle.</div>
            </div>

            <div class="row g-4">
                <div class="col-12">
                    <div class="field-group">
                        <div class="field-label"><i class="bi bi-calendar-event-fill"></i> Session <span class="field-required">*</span></div>
                        {{ form_widget(form.session, {'attr': {'class': 'form-select'}}) }}
                        {{ form_errors(form.session) }}
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="field-group">
                        <div class="field-label"><i class="bi bi-people-fill"></i> Nombre de places <span class="field-required">*</span></div>
                        {{ form_widget(form.nbPlaces, {'attr': {'class': 'form-control', 'min': 1}}) }}
                        {{ form_errors(form.nbPlaces) }}
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="field-group">
                        <div class="field-label"><i class="bi bi-person-badge-fill"></i> Référence utilisateur <span class="field-required">*</span></div>
                        {{ form_widget(form.userRef, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.userRef) }}
                    </div>
                </div>
            </div>

            {{ form_rest(form) }}

            <div class="form-footer mt-4 mx-n4" style="margin-left:-36px; margin-right:-36px;">
                <a href="{{ path('app_reservation_session_show', {'id': reservation.idReservation}) }}" class="btn-cancel">
                    <i class="bi bi-x-circle"></i> Annuler
                </a>
                <button type="submit" class="btn-save">
                    <i class="bi bi-check-circle-fill"></i> Enregistrer les modifications
                </button>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}

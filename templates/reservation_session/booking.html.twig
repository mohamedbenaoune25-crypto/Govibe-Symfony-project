{% extends is_granted('ROLE_ADMIN') ? 'admin/base_admin.html.twig' : 'base.html.twig' %}

{% block title %}Réserver une Session — GoVibe{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Manrope:wght@200..800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
<style>
body { font-family: 'Manrope', sans-serif !important; background: #fcf9f8 !important; }
.material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24; }

/* ─── Hero ─── */
.gv-book-hero {
    position: relative; padding: 160px 0 100px;
    background: linear-gradient(160deg, #00342d 0%, #013220 40%, #001a12 100%);
    overflow: hidden; text-align: center; border-radius: 0 0 3rem 3rem;
    box-shadow: 0 20px 50px rgba(0,52,45,0.15);
}
.gv-book-hero::before { content:''; position:absolute; inset:0; background: radial-gradient(ellipse at 30% 80%, rgba(16,185,129,0.18) 0%, transparent 55%), radial-gradient(ellipse at 80% 20%, rgba(233,193,118,0.1) 0%, transparent 45%); pointer-events:none; }
.gv-book-hero::after { content:''; position:absolute; inset:0; background-image: radial-gradient(rgba(160,242,225,0.06) 1px, transparent 1px); background-size:24px 24px; pointer-events:none; }
.gv-hero-icon-bg { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); font-size:20rem; color:rgba(255,255,255,0.015); pointer-events:none; font-variation-settings:'FILL' 1; }

.gv-hero-step { display:inline-flex; align-items:center; gap:0.3rem; padding:0.4rem 1rem; border-radius:2rem; font-size:0.72rem; font-weight:800; background:rgba(233,193,118,0.15); color:#fde68a; border:1px solid rgba(233,193,118,0.25); text-transform:uppercase; letter-spacing:0.06em; position:relative; z-index:2; margin-bottom:0.75rem; }
.gv-book-hero h1 { font-family:'Noto Serif',serif; font-size:clamp(2rem,4vw,3rem); color:#fff; font-weight:700; margin-bottom:0.5rem; position:relative; z-index:2; }
.gv-book-hero h1 em { color:#a0f2e1; font-style:italic; font-weight:300; }
.gv-book-hero p { color:rgba(160,242,225,0.7); font-size:1.05rem; position:relative; z-index:2; }

/* ─── Container ─── */
.gv-book-container { max-width:900px; margin:-50px auto 80px; position:relative; z-index:10; padding:0 2rem; }

/* ─── Split Card ─── */
.gv-split-card {
    background:rgba(255,255,255,0.97); backdrop-filter:blur(20px) saturate(180%);
    border:1px solid rgba(0,52,45,0.06); border-radius:1.5rem; overflow:hidden;
    box-shadow:0 20px 60px rgba(0,52,45,0.08); display:grid; grid-template-columns:2fr 3fr;
}
@media (max-width:768px) { .gv-split-card { grid-template-columns:1fr; } }

/* Left Panel */
.gv-book-sidebar {
    background: linear-gradient(160deg, #00342d, #013220);
    padding: 2.5rem; color: #fff; display: flex; flex-direction: column; justify-content: center;
    position: relative; overflow: hidden;
}
.gv-book-sidebar::before { content:''; position:absolute; inset:0; background: radial-gradient(circle at 30% 80%, rgba(16,185,129,0.15), transparent 60%); pointer-events:none; }

.gv-sidebar-icon { font-size:2.5rem; color:#a0f2e1; margin-bottom:1.25rem; font-variation-settings:'FILL' 1; opacity:0.8; position:relative; z-index:2; }
.gv-sidebar-label { font-size:0.7rem; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:rgba(255,255,255,0.5); margin-bottom:0.3rem; position:relative; z-index:2; }
.gv-sidebar-title { font-family:'Noto Serif',serif; font-weight:700; font-size:1.15rem; margin-bottom:0.2rem; position:relative; z-index:2; }
.gv-sidebar-detail { color:rgba(160,242,225,0.7); font-size:0.9rem; display:flex; align-items:center; gap:0.4rem; margin-bottom:0.3rem; position:relative; z-index:2; }
.gv-sidebar-detail .material-symbols-outlined { font-size:1rem; color:#a0f2e1; }

.gv-sidebar-price-section { margin-top:2rem; padding-top:1.5rem; border-top:1px solid rgba(255,255,255,0.1); position:relative; z-index:2; }
.gv-sidebar-price { font-family:'Noto Serif',serif; font-size:2rem; font-weight:700; color:#a0f2e1; }
.gv-sidebar-price small { font-size:0.9rem; color:rgba(160,242,225,0.5); font-family:'Manrope',sans-serif; }

/* Right Panel */
.gv-book-form { padding: 2.5rem; }

.gv-form-title { font-family:'Noto Serif',serif; font-weight:700; font-size:1.15rem; color:#00342d; margin-bottom:1.5rem; display:flex; align-items:center; gap:0.5rem; }
.gv-form-title .material-symbols-outlined { font-size:1.1rem; color:#10B981; }

.gv-form-label { font-weight:700; color:#00342d; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.06em; margin-bottom:0.5rem; display:block; }

/* Quantity Stepper */
.gv-stepper {
    display:flex; align-items:center; border:1.5px solid rgba(0,52,45,0.08);
    border-radius:0.75rem; overflow:hidden; background:#fff;
}
.gv-stepper-btn {
    width:52px; height:52px; border:none; background:rgba(0,52,45,0.03);
    display:flex; align-items:center; justify-content:center; cursor:pointer;
    transition:all 0.2s; color:#00342d;
}
.gv-stepper-btn:hover { background:rgba(16,185,129,0.1); color:#10B981; }
.gv-stepper-btn .material-symbols-outlined { font-size:1.3rem; }
.gv-stepper-input {
    flex:1; border:none !important; text-align:center; font-weight:700; font-size:1.2rem;
    font-family:'Noto Serif',serif !important; color:#00342d; padding:0.75rem 0 !important;
    -moz-appearance:textfield;
}
.gv-stepper-input::-webkit-inner-spin-button,
.gv-stepper-input::-webkit-outer-spin-button { -webkit-appearance:none; margin:0; }
.gv-stepper-input:focus { outline:none; box-shadow:none !important; }
.gv-form-help { font-size:0.82rem; color:#707975; margin-top:0.5rem; display:flex; align-items:center; gap:0.3rem; }
.gv-form-help .material-symbols-outlined { font-size:0.9rem; color:#10B981; }

/* Total Box */
.gv-total-box {
    background:rgba(16,185,129,0.06); border:1.5px solid rgba(16,185,129,0.12);
    border-radius:1rem; padding:1.25rem 1.5rem; margin:1.5rem 0 2rem;
    display:flex; justify-content:space-between; align-items:center;
}
.gv-total-label { font-weight:700; color:#546067; font-size:0.9rem; }
.gv-total-value { font-family:'Noto Serif',serif; font-size:1.5rem; font-weight:700; color:#10B981; }

/* Buttons */
.gv-btn-confirm {
    width:100%; padding:1rem; background:linear-gradient(135deg,#e9c176,#ca9028); color:#3d2a00;
    border:none; border-radius:0.75rem; font-weight:700; font-size:1.05rem; cursor:pointer;
    transition:all 0.3s; box-shadow:0 10px 25px -5px rgba(233,193,118,0.4);
    font-family:'Manrope',sans-serif; display:flex; align-items:center; justify-content:center; gap:0.5rem;
}
.gv-btn-confirm:hover { transform:translateY(-2px); box-shadow:0 15px 35px -5px rgba(233,193,118,0.5); }
.gv-btn-cancel-link {
    display:block; text-align:center; margin-top:0.75rem; color:#707975; font-weight:600;
    font-size:0.9rem; text-decoration:none; padding:0.6rem; border-radius:0.5rem; transition:all 0.2s;
}
.gv-btn-cancel-link:hover { background:rgba(0,52,45,0.04); color:#00342d; }

.gv-waitlist-notice { background:rgba(233,193,118,0.1); border:1.5px solid rgba(233,193,118,0.3); border-radius:1rem; padding:1.25rem; margin:1.5rem 0; display:flex; gap:0.75rem; color:#92400e; }
.gv-waitlist-notice .material-symbols-outlined { color:#ca9028; font-size:1.5rem; flex-shrink:0; }
.gv-waitlist-text { font-size:0.85rem; font-weight:600; line-height:1.4; }

/* ─── Pricing & Payment ─── */
.gv-pricing-card { background:rgba(0,52,45,0.03); border:1px solid rgba(0,52,45,0.06); border-radius:1rem; padding:1.25rem; margin:1.5rem 0; }
.gv-price-item { display:flex; justify-content:space-between; margin-bottom:0.5rem; font-size:0.85rem; }
.gv-price-item.discount { color:#10B981; font-weight:600; }
.gv-price-item.extra { color:#ba1a1a; font-weight:600; }
.gv-price-item.total { border-top:1px solid rgba(0,52,45,0.1); margin-top:0.75rem; padding-top:0.75rem; font-weight:800; color:#00342d; font-size:1rem; }

.gv-input-promo { width:100%; padding:0.8rem 1rem; border-radius:0.75rem; border:1.5px solid rgba(0,52,45,0.08); font-family:'Manrope',sans-serif; font-weight:700; font-size:0.9rem; text-transform:uppercase; margin-bottom:1.5rem; }
.gv-input-promo:focus { border-color:#10B981; outline:none; background:rgba(16,185,129,0.02); }

.gv-credit-toggle { background:rgba(233,193,118,0.1); border:1.5px solid rgba(233,193,118,0.3); border-radius:1rem; padding:1rem; margin-bottom:1.5rem; display:flex; align-items:center; justify-content:space-between; }
.gv-credit-info { display:flex; align-items:center; gap:0.6rem; color:#92400e; font-size:0.85rem; font-weight:700; }
.gv-switch { position:relative; display:inline-block; width:44px; height:24px; }
.gv-switch input { opacity:0; width:0; height:0; }
.gv-slider { position:absolute; cursor:pointer; inset:0; background-color:#ccc; transition:.4s; border-radius:24px; }
.gv-slider:before { position:absolute; content:""; height:18px; width:18px; left:3px; bottom:3px; background-color:white; transition:.4s; border-radius:50%; }
input:checked + .gv-slider { background-color:#ca9028; }
input:checked + .gv-slider:before { transform:translateX(20px); }
</style>
{% endblock %}

{% block body %}
<div class="gv-book-hero">
    <span class="material-symbols-outlined gv-hero-icon-bg">confirmation_number</span>
    <div class="container">
        <span class="gv-hero-step">
            <span class="material-symbols-outlined" style="font-size:0.85rem;">bookmark_add</span> Étape de réservation
        </span>
        <h1>Confirmez votre <em>Réservation</em></h1>
        <p>{{ activite.name }} — {{ activite.localisation }}</p>
    </div>
</div>

<div class="gv-book-container">
    <div class="gv-split-card">
        <!-- Sidebar -->
        <div class="gv-book-sidebar">
            <span class="material-symbols-outlined gv-sidebar-icon">calendar_month</span>
            <div class="gv-sidebar-label">Détails du créneau</div>
            <div class="gv-sidebar-title">{{ activite.name }}</div>
            <div class="gv-sidebar-detail">
                <span class="material-symbols-outlined">event</span>
                {{ session.date|date('d/m/Y') }}
            </div>
            <div class="gv-sidebar-detail">
                <span class="material-symbols-outlined">schedule</span>
                {{ session.heure|date('H:i') }}
            </div>
            <div class="gv-sidebar-detail">
                <span class="material-symbols-outlined">location_on</span>
                {{ activite.localisation }}
            </div>

            <div class="gv-sidebar-price-section">
                <div class="gv-sidebar-label">Prix unitaire</div>
                <div class="gv-sidebar-price">{{ activite.prix }} <small>DT</small></div>
            </div>
        </div>

        <!-- Form -->
        <div class="gv-book-form">
            <div class="gv-form-title">
                <span class="material-symbols-outlined">group_add</span> Informations de réservation
            </div>

            <form action="{{ path('app_reservation_session_reserve', {'idSession': session.idSession}) }}" method="post" id="bookingForm">
                <label class="gv-form-label">Nombre de participants</label>
                <div class="gv-stepper">
                    <button type="button" class="gv-stepper-btn" id="btnMinus">
                        <span class="material-symbols-outlined">remove</span>
                    </button>
                    <input type="number" name="nbPlaces" id="nbPlaces" class="gv-stepper-input" value="1" min="1">
                    <button type="button" class="gv-stepper-btn" id="btnPlus">
                        <span class="material-symbols-outlined">add</span>
                    </button>
                </div>

                <div class="gv-pricing-card">
                    <div class="gv-price-item">
                        <span>Prix de base unit.</span>
                        <span>{{ pricing.basePrice }} DT</span>
                    </div>
                    {% for item in pricing.breakdown %}
                        <div class="gv-price-item {{ item|contains('-') ? 'discount' : 'extra' }}">
                            {{ item }}
                        </div>
                    {% endfor %}
                    <div class="gv-price-item total">
                        <span>Prix unitaire réduit</span>
                        <span id="unitReduced">{{ pricing.finalPrice }} DT</span>
                    </div>
                </div>

                <label class="gv-form-label">Code Promo</label>
                <input type="text" name="couponCode" class="gv-input-promo" placeholder="ENTRER LE CODE ICI">

                {% if user and user.sessionCredits > 0 %}
                <div class="gv-credit-toggle">
                    <div class="gv-credit-info">
                        <span class="material-symbols-outlined">payments</span>
                        Payer avec mes crédits ({{ user.sessionCredits }} restants)
                    </div>
                    <label class="gv-switch">
                        <input type="checkbox" name="useCredits" id="useCredits">
                        <span class="gv-slider"></span>
                    </label>
                </div>
                {% endif %}

                <div id="waitlistNotice" class="gv-waitlist-notice {{ session.nbrPlacesRestant > 0 ? 'd-none' : '' }}">
                    <span class="material-symbols-outlined">hourglass_empty</span>
                    <div class="gv-waitlist-text">
                        Attention : Cette session est complète. En validant, vous serez inscrit(e) sur la liste d'attente.
                    </div>
                </div>

                <div class="gv-total-box">
                    <span class="gv-total-label">Total à payer</span>
                    <span class="gv-total-value" id="totalPrice">{{ pricing.finalPrice }} DT</span>
                </div>

                <button type="submit" class="gv-btn-confirm">
                    <span class="material-symbols-outlined" style="font-size:1.1rem;">check_circle</span>
                    Confirmer la réservation
                </button>
                <a href="{{ path('app_activite_show', {'id': activite.id}) }}" class="gv-btn-cancel-link">Annuler</a>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const nbInput = document.getElementById('nbPlaces');
    const btnMinus = document.getElementById('btnMinus');
    const btnPlus = document.getElementById('btnPlus');
    const totalSpan = document.getElementById('totalPrice');
    const waitlistNotice = document.getElementById('waitlistNotice');
    const creditToggle = document.getElementById('useCredits');
    
    // Pricing data from backend
    const unitPrice = parseFloat("{{ pricing.finalPrice }}");
    const maxPlaces = parseInt("{{ session.nbrPlacesRestant }}");

    function updateTotal() {
        const count = parseInt(nbInput.value) || 1;
        const total = (count * unitPrice).toFixed(2);
        
        if (creditToggle && creditToggle.checked) {
            totalSpan.textContent = '0.00 DT (Crédits)';
        } else {
            totalSpan.textContent = total + ' DT';
        }

        // Update waitlist notice
        if (count > maxPlaces) {
            waitlistNotice.classList.remove('d-none');
            if (maxPlaces <= 0) {
                waitlistNotice.querySelector('.gv-waitlist-text').textContent = 'La session est complète. Vous serez placé(e) en liste d\'attente.';
            } else {
                waitlistNotice.querySelector('.gv-waitlist-text').textContent = 'Il ne reste que ' + maxPlaces + ' places. Les ' + (count - maxPlaces) + ' places supplémentaires seront en liste d\'attente.';
            }
        } else {
            waitlistNotice.classList.add('d-none');
        }
    }

    btnMinus.addEventListener('click', () => { if (nbInput.value > 1) { nbInput.value--; updateTotal(); } });
    btnPlus.addEventListener('click', () => { nbInput.value++; updateTotal(); });
    nbInput.addEventListener('change', () => {
        if (nbInput.value < 1) nbInput.value = 1;
        updateTotal();
    });
    
    if (creditToggle) {
        creditToggle.addEventListener('change', updateTotal);
    }
    
    updateTotal();
});
</script>
{% endblock %}

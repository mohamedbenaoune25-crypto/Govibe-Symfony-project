{% extends is_granted('ROLE_ADMIN') ? 'admin/base_admin.html.twig' : 'base.html.twig' %}

{% block title %}Tableau de Bord - Statistiques - GoVibe{% endblock %}

{% block body %}
<div class="container-fluid py-5 text-center mb-5 border-bottom rounded-bottom-5 px-lg-5 shadow-sm bg-white">
    <div class="d-flex align-items-center justify-content-center gap-3 mb-3">
        <span class="badge rounded-pill bg-light text-dark border px-3">Analyse de vos Aventures</span>
    </div>
    <h1 class="display-3 fw-bold text-dark mb-2">Mes <span style="color: #2ECC71;">Statistiques</span></h1>
    <p class="text-secondary fs-5">Un aperçu de vos activités et réservations</p>
</div>

<div class="container mb-5 pb-5 px-lg-5">
    <!-- Key KPIs -->
    <div class="row g-4 mb-5">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-5 p-4 bg-white h-100 transition-all hover-lift-2">
                <div class="d-flex align-items-center gap-4">
                    <div class="p-4 bg-light rounded-circle text-success shadow-sm">
                        <i class="bi bi-calendar-check fs-1"></i>
                    </div>
                    <div>
                        <h5 class="text-muted small text-uppercase fw-bold mb-1">Total Réservations</h5>
                        <p class="display-5 fw-bold text-dark mb-0">{{ totalReservations }}</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-5 p-4 bg-white h-100 transition-all hover-lift-2">
                <div class="d-flex align-items-center gap-4">
                    <div class="p-4 bg-light rounded-circle text-primary shadow-sm" style="color: #3498DB !important;">
                        <i class="bi bi-people fs-1"></i>
                    </div>
                    <div>
                        <h5 class="text-muted small text-uppercase fw-bold mb-1">Total Participants</h5>
                        <p class="display-5 fw-bold text-dark mb-0">{{ totalParticipants }}</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Popular Activities & Insights -->
    <div class="row g-5">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-5 p-5 bg-white h-100 animate-fade-in-up">
                <h3 class="h4 fw-bold mb-4 border-bottom pb-2">Activités les plus réservées</h3>
                <div class="mt-4">
                    {% for item in popularActivities %}
                        <div class="mb-4">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="fw-bold">{{ item.activityName }}</span>
                                <span class="text-muted">{{ item.totalCount }} réservation(s)</span>
                            </div>
                            <div class="progress rounded-pill shadow-sm" style="height: 12px; background-color: #f1f1f1;">
                                {% set percent = (item.totalCount / totalReservations * 100)|round %}
                                <div class="progress-bar rounded-pill" role="progressbar" 
                                     style="width: {{ percent }}%; background: linear-gradient(90deg, #2ECC71, #27AE60);" 
                                     aria-valuenow="{{ percent }}" aria-valuemin="0" aria-valuemax="100">
                                </div>
                            </div>
                        </div>
                    {% else %}
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-bar-chart fs-1 opacity-25"></i>
                            <p class="mt-2">Aucune donnée disponible pour le moment.</p>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-5 p-4 bg-success text-white h-100 d-flex flex-column justify-content-center text-center" style="background: linear-gradient(135deg, #2ECC71, #27AE60) !important;">
                <div class="mb-4">
                    <i class="bi bi-trophy display-1 opacity-50"></i>
                </div>
                <h4 class="fw-bold mb-3">Continuez l'aventure !</h4>
                <p class="opacity-75 mb-4">Chaque réservation est une nouvelle expérience. Explorez de nouvelles destinations.</p>
                <a href="{{ path('app_activite_index') }}" class="btn btn-light rounded-pill px-4 fw-bold text-success border-0 shadow-sm">
                    Découvrir plus
                </a>
            </div>
        </div>
    </div>

    <div class="text-center mt-5">
        <a href="{{ path('app_reservation_session_index') }}" class="btn btn-outline-secondary rounded-pill px-5 border-2 fw-bold">
            <i class="bi bi-arrow-left me-2"></i> Retour aux réservations
        </a>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
<style>
    body { background-color: #F8F9F9 !important; }
    .rounded-bottom-5 { border-bottom-left-radius: 4rem !important; border-bottom-right-radius: 4rem !important; }
    .hover-lift-2:hover { transform: translateY(-5px); box-shadow: 0 10px 25px rgba(0,0,0,0.05) !important; }
    .animate-fade-in-up { animation: fadeInUp 0.6s ease-out; }
    @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
</style>
{% endblock %}

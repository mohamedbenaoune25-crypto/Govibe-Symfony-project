{% extends is_granted('ROLE_ADMIN') ? 'admin/base_admin.html.twig' : 'base.html.twig' %}

{% block title %}Statistiques — GoVibe{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Manrope:wght@200..800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
<style>
body { font-family: 'Manrope', sans-serif !important; background: #fcf9f8 !important; }
.material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24; }

/* ─── Hero ─── */
.gv-stats-hero {
    position: relative; padding: 170px 0 110px;
    background: linear-gradient(160deg, #00342d 0%, #013220 40%, #001a12 100%);
    overflow: hidden; text-align: center; border-radius: 0 0 3rem 3rem;
    box-shadow: 0 20px 50px rgba(0,52,45,0.15);
}
.gv-stats-hero::before { content:''; position:absolute; inset:0; background: radial-gradient(ellipse at 25% 85%, rgba(16,185,129,0.18) 0%, transparent 55%), radial-gradient(ellipse at 75% 15%, rgba(233,193,118,0.1) 0%, transparent 45%); pointer-events:none; }
.gv-stats-hero::after { content:''; position:absolute; inset:0; background-image: radial-gradient(rgba(160,242,225,0.06) 1px, transparent 1px); background-size:24px 24px; pointer-events:none; }
.gv-hero-icon-bg { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); font-size:20rem; color:rgba(255,255,255,0.015); pointer-events:none; font-variation-settings:'FILL' 1; }

.gv-hero-badge { display:inline-flex; align-items:center; gap:0.3rem; padding:0.4rem 1rem; border-radius:2rem; font-size:0.72rem; font-weight:800; background:rgba(160,242,225,0.12); color:#a0f2e1; border:1px solid rgba(160,242,225,0.2); position:relative; z-index:2; text-transform:uppercase; letter-spacing:0.06em; margin-bottom:0.75rem; }
.gv-hero-title { font-family:'Noto Serif',serif; font-size:clamp(2.2rem,4.5vw,3.5rem); color:#fff; font-weight:700; margin-bottom:0.5rem; position:relative; z-index:2; }
.gv-hero-title em { color:#a0f2e1; font-style:italic; font-weight:300; }
.gv-hero-sub { color:rgba(160,242,225,0.7); font-size:1.05rem; position:relative; z-index:2; max-width:500px; margin:0 auto; }

/* ─── Container ─── */
.gv-stats-container { max-width:1100px; margin:-45px auto 80px; position:relative; z-index:10; padding:0 2rem; }

/* ─── KPI Cards ─── */
.gv-kpi-grid { display:grid; grid-template-columns:1fr 1fr; gap:1.5rem; margin-bottom:2.5rem; }
@media (max-width:768px) { .gv-kpi-grid { grid-template-columns:1fr; } }

.gv-kpi-card {
    background:rgba(255,255,255,0.97); backdrop-filter:blur(20px) saturate(180%);
    border:1px solid rgba(0,52,45,0.06); border-radius:1.25rem; padding:2rem;
    box-shadow:0 15px 40px rgba(0,52,45,0.06); display:flex; align-items:center; gap:1.5rem;
    transition:all 0.35s;
}
.gv-kpi-card:hover { transform:translateY(-5px); box-shadow:0 24px 50px rgba(0,52,45,0.1); }

.gv-kpi-icon-box {
    width:68px; height:68px; border-radius:1rem; display:flex; align-items:center; justify-content:center;
    flex-shrink:0;
}
.gv-kpi-icon-box.emerald { background:rgba(16,185,129,0.1); }
.gv-kpi-icon-box.gold { background:rgba(233,193,118,0.15); }
.gv-kpi-icon-box .material-symbols-outlined { font-size:1.8rem; font-variation-settings:'FILL' 1; }
.gv-kpi-icon-box.emerald .material-symbols-outlined { color:#10B981; }
.gv-kpi-icon-box.gold .material-symbols-outlined { color:#e9c176; }

.gv-kpi-label { font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:#546067; margin-bottom:0.2rem; }
.gv-kpi-value { font-family:'Noto Serif',serif; font-size:2.5rem; font-weight:700; color:#00342d; line-height:1; }

/* ─── Content Grid ─── */
.gv-content-grid { display:grid; grid-template-columns:5fr 3fr; gap:2rem; }
@media (max-width:992px) { .gv-content-grid { grid-template-columns:1fr; } }

.gv-card {
    background:rgba(255,255,255,0.97); backdrop-filter:blur(20px) saturate(180%);
    border:1px solid rgba(0,52,45,0.06); border-radius:1.5rem; padding:2rem;
    box-shadow:0 20px 60px rgba(0,52,45,0.06);
}
.gv-card-title { font-family:'Noto Serif',serif; font-size:1.1rem; font-weight:700; color:#00342d; display:flex; align-items:center; gap:0.5rem; margin-bottom:1.5rem; padding-bottom:0.75rem; border-bottom:2px solid rgba(16,185,129,0.15); }
.gv-card-title .material-symbols-outlined { font-size:1.15rem; color:#10B981; }

/* ─── Progress bars ─── */
.gv-activity-list { display:flex; flex-direction:column; gap:1.5rem; }
.gv-activity-item-name { display:flex; justify-content:space-between; align-items:center; margin-bottom:0.5rem; }
.gv-activity-name { font-weight:700; color:#00342d; font-size:0.95rem; }
.gv-activity-count { font-size:0.85rem; color:#707975; }

.gv-progress-track { height:10px; background:rgba(0,52,45,0.04); border-radius:2rem; overflow:hidden; }
.gv-progress-bar { height:100%; border-radius:2rem; background:linear-gradient(90deg,#10B981,#046b5e); transition:width 0.8s cubic-bezier(0.4,0,0.2,1); }

.gv-empty-chart { text-align:center; padding:3rem 1rem; }
.gv-empty-chart .material-symbols-outlined { font-size:3rem; color:#cde1db; font-variation-settings:'FILL' 1; }
.gv-empty-chart p { color:#707975; margin-top:0.5rem; }

/* ─── CTA Card ─── */
.gv-cta-card {
    background: linear-gradient(160deg, #00342d 0%, #013220 100%);
    border-radius:1.5rem; padding:2.5rem; text-align:center; color:#fff;
    position:relative; overflow:hidden; display:flex; flex-direction:column;
    justify-content:center; align-items:center;
}
.gv-cta-card::before { content:''; position:absolute; inset:0; background: radial-gradient(circle at 50% 80%, rgba(16,185,129,0.2), transparent 60%); pointer-events:none; }
.gv-cta-icon { font-size:3.5rem; color:rgba(233,193,118,0.6); font-variation-settings:'FILL' 1; position:relative; z-index:2; margin-bottom:1rem; }
.gv-cta-card h4 { font-family:'Noto Serif',serif; font-weight:700; font-size:1.15rem; position:relative; z-index:2; margin-bottom:0.5rem; }
.gv-cta-card p { color:rgba(160,242,225,0.7); font-size:0.9rem; position:relative; z-index:2; margin-bottom:1.5rem; }
.gv-cta-btn {
    display:inline-flex; align-items:center; gap:0.5rem; padding:0.85rem 2rem;
    background:linear-gradient(135deg,#e9c176,#ca9028); color:#3d2a00; border:none;
    border-radius:0.75rem; font-weight:700; font-size:0.95rem; text-decoration:none;
    transition:all 0.3s; box-shadow:0 10px 25px -5px rgba(233,193,118,0.4);
    font-family:'Manrope',sans-serif; position:relative; z-index:2;
}
.gv-cta-btn:hover { transform:translateY(-2px); box-shadow:0 15px 35px -5px rgba(233,193,118,0.5); color:#3d2a00; }

/* ─── Back ─── */
.gv-back-bar { text-align:center; margin-top:2.5rem; }
.gv-back-link { display:inline-flex; align-items:center; gap:0.4rem; font-weight:700; font-size:0.9rem; color:#546067; text-decoration:none; padding:0.75rem 1.5rem; border-radius:0.75rem; border:1.5px solid rgba(0,52,45,0.08); transition:all 0.25s; font-family:'Manrope',sans-serif; }
.gv-back-link:hover { border-color:rgba(0,52,45,0.2); background:rgba(0,52,45,0.03); color:#00342d; }
</style>
{% endblock %}

{% block body %}
<div class="gv-stats-hero">
    <span class="material-symbols-outlined gv-hero-icon-bg">bar_chart</span>
    <div class="container">
        <span class="gv-hero-badge">
            <span class="material-symbols-outlined" style="font-size:0.85rem;">analytics</span> Analyse de vos aventures
        </span>
        <h1 class="gv-hero-title">Mes <em>Statistiques</em></h1>
        <p class="gv-hero-sub">Un aperçu de vos activités et réservations</p>
    </div>
</div>

<div class="gv-stats-container">
    <!-- KPI Cards -->
    <div class="gv-kpi-grid">
        <div class="gv-kpi-card">
            <div class="gv-kpi-icon-box emerald">
                <span class="material-symbols-outlined">confirmation_number</span>
            </div>
            <div>
                <div class="gv-kpi-label">Total Réservations</div>
                <div class="gv-kpi-value">{{ totalReservations }}</div>
            </div>
        </div>
        <div class="gv-kpi-card">
            <div class="gv-kpi-icon-box gold">
                <span class="material-symbols-outlined">groups</span>
            </div>
            <div>
                <div class="gv-kpi-label">Total Participants</div>
                <div class="gv-kpi-value">{{ totalParticipants }}</div>
            </div>
        </div>
    </div>

    <!-- Content -->
    <div class="gv-content-grid">
        <!-- Popular Activities -->
        <div class="gv-card">
            <div class="gv-card-title">
                <span class="material-symbols-outlined">trending_up</span> Activités les plus réservées
            </div>
            <div class="gv-activity-list">
                {% for item in popularActivities %}
                    <div>
                        <div class="gv-activity-item-name">
                            <span class="gv-activity-name">{{ item.activityName }}</span>
                            <span class="gv-activity-count">{{ item.totalCount }} réservation{{ item.totalCount > 1 ? 's' : '' }}</span>
                        </div>
                        <div class="gv-progress-track">
                            {% set percent = totalReservations > 0 ? (item.totalCount / totalReservations * 100)|round : 0 %}
                            <div class="gv-progress-bar" style="width: {{ percent }}%;"></div>
                        </div>
                    </div>
                {% else %}
                    <div class="gv-empty-chart">
                        <span class="material-symbols-outlined">bar_chart</span>
                        <p>Aucune donnée disponible pour le moment.</p>
                    </div>
                {% endfor %}
            </div>
        </div>

        <!-- CTA Card -->
        <div class="gv-cta-card">
            <span class="material-symbols-outlined gv-cta-icon">emoji_events</span>
            <h4>Continuez l'aventure !</h4>
            <p>Chaque réservation est une nouvelle expérience. Explorez de nouvelles destinations.</p>
            <a href="{{ path('app_activite_index') }}" class="gv-cta-btn">
                <span class="material-symbols-outlined" style="font-size:1rem;">explore</span>
                Découvrir plus
            </a>
        </div>
    </div>

    <div class="gv-back-bar">
        <a href="{{ path('app_reservation_session_index') }}" class="gv-back-link">
            <span class="material-symbols-outlined" style="font-size:1rem;">arrow_back</span>
            Retour aux réservations
        </a>
    </div>
</div>
{% endblock %}

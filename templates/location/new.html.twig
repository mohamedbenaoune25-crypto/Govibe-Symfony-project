{% extends 'base.html.twig' %}

{% block title %}Nouvelle Location — GoVibe{% endblock %}

{% block body %}
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Manrope:wght@200..800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
<style>
body { font-family: 'Manrope', sans-serif !important; background: #fcf9f8 !important; }
.material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24; }

.gv-form-hero {
    position: relative; padding: 160px 0 100px;
    background: linear-gradient(160deg, #00342d 0%, #013220 40%, #001a12 100%);
    overflow: hidden; text-align: center; border-radius: 0 0 3rem 3rem;
    box-shadow: 0 20px 50px rgba(0,52,45,0.15);
}
.gv-form-hero::before { content:''; position:absolute; inset:0; background: radial-gradient(ellipse at 30% 80%, rgba(16,185,129,0.15) 0%, transparent 60%), radial-gradient(ellipse at 80% 20%, rgba(233,193,118,0.08) 0%, transparent 50%); pointer-events:none; }
.gv-form-hero::after { content:''; position:absolute; inset:0; background-image: radial-gradient(rgba(160,242,225,0.06) 1px, transparent 1px); background-size:24px 24px; pointer-events:none; }
.gv-hero-icon-bg { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); font-size:20rem; color:rgba(255,255,255,0.02); pointer-events:none; font-variation-settings:'FILL' 1; }
.gv-form-hero h1 { font-family:'Noto Serif',serif; font-size:clamp(2rem,4vw,3rem); color:#fff; font-weight:700; margin-bottom:0.5rem; position:relative; z-index:2; }
.gv-form-hero h1 em { color:#a0f2e1; font-style:italic; font-weight:300; }
.gv-form-hero p { color:rgba(160,242,225,0.7); font-size:1.05rem; position:relative; z-index:2; }

.gv-form-container { max-width:750px; margin:-50px auto 80px; position:relative; z-index:10; padding:0 2rem; }

.gv-form-card {
    background:rgba(255,255,255,0.97); backdrop-filter:blur(20px) saturate(180%);
    border:1px solid rgba(0,52,45,0.06); border-radius:1.5rem; padding:2.5rem;
    box-shadow:0 20px 60px rgba(0,52,45,0.08);
}

.gv-section-title {
    font-family:'Noto Serif',serif; font-size:1.1rem; font-weight:700; color:#00342d;
    margin-bottom:1.25rem; padding-bottom:0.75rem; display:flex; align-items:center; gap:0.5rem;
    border-bottom:2px solid rgba(16,185,129,0.2);
}
.gv-section-title .material-symbols-outlined { font-size:1.2rem; color:#10B981; }

.gv-form-section { margin-bottom:2rem; }

.form-label { font-weight:700 !important; color:#00342d !important; font-size:0.85rem !important; text-transform:uppercase; letter-spacing:0.06em; }
.form-control, .form-select {
    border:1.5px solid rgba(0,52,45,0.08) !important; border-radius:0.75rem !important;
    padding:0.85rem 1rem !important; font-family:'Manrope',sans-serif !important;
    font-weight:500 !important; font-size:0.95rem !important; transition:all 0.25s ease !important;
}
.form-control:focus, .form-select:focus { border-color:#10B981 !important; box-shadow:0 0 0 3px rgba(16,185,129,0.12) !important; }

.form-error { color:#93000a; font-size:0.85rem; margin-top:5px; }
.form-help { font-size:0.85rem; color:#707975; margin-top:5px; }

.gv-price-display {
    background:rgba(0,52,45,0.03); border:1px solid rgba(0,52,45,0.06);
    padding:1rem 1.25rem; border-radius:1rem; margin-top:0.75rem;
}
.gv-price-item { display:flex; justify-content:space-between; align-items:center; margin:0.5rem 0; }
.gv-price-label { color:#546067; font-size:0.9rem; }
.gv-price-value { font-weight:700; color:#10B981; font-size:1.05rem; }

.gv-summary {
    background:rgba(255,255,255,0.97); border-radius:1rem; padding:1.5rem;
    margin-top:1.5rem; border:2px solid rgba(16,185,129,0.15);
}
.gv-summary-title { font-family:'Noto Serif',serif; font-weight:700; color:#00342d; margin-bottom:1rem; font-size:1.05rem; }
.gv-summary-item { display:flex; justify-content:space-between; padding:0.75rem 0; border-bottom:1px solid rgba(0,52,45,0.04); }
.gv-summary-item:last-child { border-bottom:none; }
.gv-summary-label { color:#546067; }
.gv-summary-value { font-weight:700; color:#00342d; }
.gv-summary-total {
    display:flex; justify-content:space-between; padding:1rem 0 0; margin-top:0.75rem;
    border-top:2px solid rgba(16,185,129,0.2); font-size:1.15rem; font-weight:700;
    font-family:'Noto Serif',serif; color:#10B981;
}

.gv-btn-group { display:flex; gap:1rem; margin-top:2rem; }
.gv-btn-group > * { flex:1; }
.gv-btn-cancel {
    padding:0.85rem; background:rgba(0,52,45,0.05); color:#546067; border:1.5px solid rgba(0,52,45,0.08);
    border-radius:0.75rem; font-weight:700; text-decoration:none; text-align:center;
    display:inline-flex; align-items:center; justify-content:center; gap:0.4rem;
    transition:all 0.25s; font-family:'Manrope',sans-serif;
}
.gv-btn-cancel:hover { border-color:rgba(0,52,45,0.2); background:rgba(0,52,45,0.08); color:#00342d; }
.gv-btn-submit {
    padding:0.85rem; background:linear-gradient(135deg,#e9c176,#ca9028); color:#3d2a00;
    border:none; border-radius:0.75rem; font-weight:700; font-size:1rem; cursor:pointer;
    transition:all 0.3s; box-shadow:0 10px 25px -5px rgba(233,193,118,0.4);
    font-family:'Manrope',sans-serif; display:inline-flex; align-items:center; justify-content:center; gap:0.5rem;
}
.gv-btn-submit:hover { transform:translateY(-2px); box-shadow:0 15px 35px -5px rgba(233,193,118,0.5); }

.dates-container { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
.alert-danger { background:#fef2f2 !important; color:#93000a !important; border:1px solid rgba(186,26,26,0.15) !important; border-radius:1rem !important; }
</style>

<div class="gv-form-hero">
    <span class="material-symbols-outlined gv-hero-icon-bg">directions_car</span>
    <div class="container">
        <h1>Nouvelle <em>Location</em></h1>
        <p>Créez une nouvelle location de voiture</p>
    </div>
</div>

<div class="gv-form-container">
    {{ form_start(form, {'attr': {'class': 'gv-form-card needs-validation', 'novalidate': 'novalidate'}}) }}

    {% if form.vars.errors|length > 0 %}
    <div class="alert alert-danger">
        <span class="material-symbols-outlined" style="font-size:1.1rem; vertical-align:-3px;">error</span>
        <strong>Erreur :</strong> Veuillez vérifier les champs ci-dessous
    </div>
    {% endif %}

    <!-- Section Voiture -->
    <div class="gv-form-section">
        <div class="gv-section-title">
            <span class="material-symbols-outlined">directions_car</span> Sélectionner une Voiture
        </div>
        <div class="form-group">
            {{ form_label(form.voiture) }}
            {{ form_widget(form.voiture) }}
            {% if form.voiture.vars.errors|length %}
            <div class="form-error">
                {% for error in form.voiture.vars.errors %}
                    <span class="material-symbols-outlined" style="font-size:0.9rem; vertical-align:-2px;">error</span> {{ error.message }}
                {% endfor %}
            </div>
            {% endif %}
        </div>

        <div id="voiture-details" style="display:none;" class="gv-price-display">
            <div class="gv-price-item">
                <span class="gv-price-label">Prix journalier:</span>
                <span class="gv-price-value" id="prix-jour">-</span>
            </div>
        </div>
    </div>

    <!-- Section Dates -->
    <div class="gv-form-section">
        <div class="gv-section-title">
            <span class="material-symbols-outlined">date_range</span> Période de Location
        </div>
        <div class="dates-container">
            <div class="form-group">
                {{ form_label(form.dateDebut) }}
                {{ form_widget(form.dateDebut) }}
                {% if form.dateDebut.vars.errors|length %}
                <div class="form-error">{% for error in form.dateDebut.vars.errors %}<span class="material-symbols-outlined" style="font-size:0.9rem; vertical-align:-2px;">error</span> {{ error.message }}{% endfor %}</div>
                {% endif %}
            </div>
            <div class="form-group">
                {{ form_label(form.dateFin) }}
                {{ form_widget(form.dateFin) }}
                {% if form.dateFin.vars.errors|length %}
                <div class="form-error">{% for error in form.dateFin.vars.errors %}<span class="material-symbols-outlined" style="font-size:0.9rem; vertical-align:-2px;">error</span> {{ error.message }}{% endfor %}</div>
                {% endif %}
            </div>
        </div>

        <div id="days-info" style="display:none;" class="gv-price-display" style="margin-top:0.75rem;">
            <div class="gv-price-item">
                <span class="gv-price-label">Nombre de jours:</span>
                <span class="gv-price-value" id="nb-jours">0</span>
            </div>
        </div>
    </div>

    <!-- Section Montant -->
    <div class="gv-form-section">
        <div class="gv-section-title">
            <span class="material-symbols-outlined">payments</span> Montant
        </div>
        <div class="form-group">
            {{ form_label(form.montantTotal) }}
            {{ form_widget(form.montantTotal) }}
            {% if form.montantTotal.vars.errors|length %}
            <div class="form-error">{% for error in form.montantTotal.vars.errors %}<span class="material-symbols-outlined" style="font-size:0.9rem; vertical-align:-2px;">error</span> {{ error.message }}{% endfor %}</div>
            {% endif %}
        </div>

        <div class="gv-summary">
            <div class="gv-summary-title">Résumé du Devis</div>
            <div class="gv-summary-item"><span class="gv-summary-label">Voiture:</span><span class="gv-summary-value" id="resume-voiture">-</span></div>
            <div class="gv-summary-item"><span class="gv-summary-label">Période:</span><span class="gv-summary-value" id="resume-periode">-</span></div>
            <div class="gv-summary-item"><span class="gv-summary-label">Nombre de jours:</span><span class="gv-summary-value" id="resume-jours">0</span></div>
            <div class="gv-summary-item"><span class="gv-summary-label">Prix journalier:</span><span class="gv-summary-value" id="resume-prix-jour">-</span></div>
            <div class="gv-summary-total"><span>Montant Total:</span><span id="resume-montant">0,00 DT</span></div>
        </div>
    </div>

    <!-- Boutons -->
    <div class="gv-btn-group">
        <a href="{{ path('app_location_index') }}" class="gv-btn-cancel">
            <span class="material-symbols-outlined" style="font-size:1rem;">arrow_back</span> Annuler
        </a>
        <button type="submit" class="gv-btn-submit" id="submitBtn">
            <span class="material-symbols-outlined" style="font-size:1.1rem;">check_circle</span> Créer la Location
        </button>
    </div>

    {{ form_end(form) }}
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const voitureSelect = document.querySelector('select[name*="voiture"]');
    const dateDebutInput = document.querySelector('input[name*="dateDebut"]');
    const dateFinInput = document.querySelector('input[name*="dateFin"]');
    const montantTotalInput = document.querySelector('input[name*="montantTotal"]');

    function updateQuote() {
        const voitureId = voitureSelect.value;
        const dateDebut = new Date(dateDebutInput.value);
        const dateFin = new Date(dateFinInput.value);

        if (!voitureId || !dateDebutInput.value || !dateFinInput.value) {
            document.getElementById('days-info').style.display = 'none';
            document.getElementById('voiture-details').style.display = 'none';
            return;
        }

        if (dateFin > dateDebut) {
            const timeDiff = dateFin.getTime() - dateDebut.getTime();
            const nbJours = Math.ceil(timeDiff / (1000 * 3600 * 24)) + 1;
            document.getElementById('nb-jours').innerText = nbJours;
            document.getElementById('resume-jours').innerText = nbJours;
            document.getElementById('days-info').style.display = 'block';
            document.getElementById('resume-periode').innerText = dateDebut.toLocaleDateString('fr-FR') + ' → ' + dateFin.toLocaleDateString('fr-FR');
        }

        const selectedOption = voitureSelect.options[voitureSelect.selectedIndex];
        if (selectedOption) {
            const voitureText = selectedOption.text;
            document.getElementById('resume-voiture').innerText = voitureText.split(' - ')[0];
            const prixMatch = voitureText.match(/(\d+(?:\.\d+)?)\s*DT/);
            if (prixMatch) {
                const prixJour = parseFloat(prixMatch[1]);
                document.getElementById('prix-jour').innerText = prixJour.toFixed(2) + ' DT';
                document.getElementById('resume-prix-jour').innerText = prixJour.toFixed(2) + ' DT';
                if (dateFin > dateDebut) {
                    const timeDiff = dateFin.getTime() - dateDebut.getTime();
                    const nbJours = Math.ceil(timeDiff / (1000 * 3600 * 24)) + 1;
                    const montantTotal = prixJour * nbJours;
                    montantTotalInput.value = montantTotal.toFixed(2);
                    document.getElementById('resume-montant').innerText = montantTotal.toFixed(2) + ' DT';
                }
            }
            document.getElementById('voiture-details').style.display = 'block';
        }
    }

    voitureSelect?.addEventListener('change', updateQuote);
    dateDebutInput?.addEventListener('change', updateQuote);
    dateFinInput?.addEventListener('change', updateQuote);
    updateQuote();

    const form = document.querySelector('form');
    form?.addEventListener('submit', function(e) {
        if (!form.checkValidity()) { e.preventDefault(); e.stopPropagation(); form.classList.add('was-validated'); return; }
        const dateDebut = new Date(dateDebutInput.value);
        const dateFin = new Date(dateFinInput.value);
        if (dateFin <= dateDebut) { e.preventDefault(); alert('La date de fin doit être après la date de début'); return; }
        form.classList.add('was-validated');
    });
});
</script>
{% endblock %}

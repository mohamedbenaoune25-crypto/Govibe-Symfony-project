{% extends 'base.html.twig' %}

{% block title %}Détails Location - GoVibe{% endblock %}

{% block body %}
<style>
    :root {
        --primary-emerald: #50C878;
        --dark-green: #013220;
        --light-green: #2E8B57;
    }

    .detail-hero {
        background: linear-gradient(135deg, var(--dark-green) 0%, var(--light-green) 100%);
        color: white;
        padding: 50px 0;
        margin-bottom: 40px;
    }

    .detail-hero h1 {
        font-size: 2rem;
        font-weight: 700;
    }

    .detail-container {
        max-width: 900px;
        margin: 0 auto;
    }

    .detail-card {
        background: white;
        border-radius: 12px;
        padding: 30px;
        margin-bottom: 20px;
        box-shadow: 0 2px 15px rgba(0, 0, 0, 0.1);
    }

    .card-title {
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--dark-green);
        margin-bottom: 20px;
        padding-bottom: 15px;
        border-bottom: 2px solid var(--primary-emerald);
    }

    .detail-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
    }

    .detail-item {
        padding: 15px;
        background: #f8f9fa;
        border-radius: 8px;
        border-left: 4px solid var(--primary-emerald);
    }

    .detail-label {
        font-size: 0.85rem;
        color: #666;
        text-transform: uppercase;
        font-weight: 600;
        margin-bottom: 5px;
    }

    .detail-value {
        font-size: 1.2rem;
        color: var(--dark-green);
        font-weight: 700;
    }

    .status-badge {
        display: inline-block;
        padding: 8px 16px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .status-en_attente {
        background-color: #fff3cd;
        color: #856404;
    }

    .status-confirmee {
        background-color: #d4edda;
        color: #155724;
    }

    .status-annulee {
        background-color: #f8d7da;
        color: #721c24;
    }

    .status-terminee {
        background-color: #d1ecf1;
        color: #0c5460;
    }

    .action-buttons {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 20px;
    }

    .btn-action {
        padding: 10px 16px;
        border: none;
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-primary {
        background-color: var(--primary-emerald);
        color: white;
    }

    .btn-primary:hover {
        background-color: var(--light-green);
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(80, 200, 120, 0.3);
    }

    .btn-secondary {
        background-color: #6c757d;
        color: white;
    }

    .btn-secondary:hover {
        background-color: #5a6268;
    }

    .btn-danger {
        background-color: #dc3545;
        color: white;
    }

    .btn-danger:hover {
        background-color: #c82333;
    }

    .btn-info {
        background-color: #17a2b8;
        color: white;
    }

    .btn-info:hover {
        background-color: #138496;
    }

    .stats-box {
        background: linear-gradient(135deg, rgba(80, 200, 120, 0.1) 0%, rgba(46, 139, 87, 0.1) 100%);
        padding: 20px;
        border-radius: 8px;
        border: 2px solid var(--primary-emerald);
    }

    .stat-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid rgba(80, 200, 120, 0.2);
    }

    .stat-row:last-child {
        border-bottom: none;
    }

    .stat-label {
        color: #666;
        font-size: 0.95rem;
    }

    .stat-value {
        font-weight: 700;
        color: var(--primary-emerald);
        font-size: 1.1rem;
    }

    .total-stat {
        display: flex;
        justify-content: space-between;
        padding: 15px 0;
        border-top: 2px solid var(--primary-emerald);
        margin-top: 10px;
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--primary-emerald);
    }

    .document-link {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 8px 14px;
        background-color: #f0f0f0;
        border-radius: 6px;
        border: 1px solid #ddd;
        text-decoration: none;
        color: #333;
        transition: all 0.2s ease;
        margin: 5px;
    }

    .document-link:hover {
        background-color: var(--primary-emerald);
        color: white;
        border-color: var(--primary-emerald);
        text-decoration: none;
    }

    .alert {
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 20px;
    }

    .back-button {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        color: var(--primary-emerald);
        font-weight: 600;
        margin-bottom: 20px;
        transition: all 0.2s ease;
    }

    .back-button:hover {
        color: var(--light-green);
        text-decoration: none;
    }
</style>

<div class="detail-hero">
    <div class="container">
        <h1><i class="bi bi-file-earmark-text"></i> Détails de Location</h1>
        <p>{{ location.reference }}</p>
    </div>
</div>

<div class="container detail-container">
    <a href="{{ path('app_location_index') }}" class="back-button">
        <i class="bi bi-arrow-left"></i> Retour à mes locations
    </a>

    <!-- Alerte info -->
    {% if location.statut == 'EN_ATTENTE' %}
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>
        Cette location est en attente de confirmation par l'administrateur.
    </div>
    {% elseif location.statut == 'CONFIRMEE' %}
    <div class="alert alert-success">
        <i class="bi bi-check-circle me-2"></i>
        Cette location a été confirmée.
    </div>
    {% elseif location.statut == 'ANNULEE' %}
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-circle me-2"></i>
        Cette location a été annulée.
    </div>
    {% endif %}

    <!-- Infos principales -->
    <div class="detail-card">
        <div class="card-title">
            <i class="bi bi-info-circle" style="color: var(--primary-emerald);"></i> Informations Principales
        </div>

        <div class="detail-grid">
            <div class="detail-item">
                <div class="detail-label">Référence</div>
                <div class="detail-value">{{ location.reference }}</div>
            </div>
            <div class="detail-item">
                <div class="detail-label">Statut</div>
                <div> 
                    <span class="status-badge status-{{ location.statut|lower|replace({'_': ''}) }}">
                        {{ location.statut }}
                    </span>
                </div>
            </div>
            <div class="detail-item">
                <div class="detail-label">Date de création</div>
                <div class="detail-value">{{ location.dateCreation|date('d/m/Y H:i') }}</div>
            </div>
        </div>
    </div>

    <!-- Infos voiture -->
    <div class="detail-card">
        <div class="card-title">
            <i class="bi bi-car-front-fill" style="color: var(--primary-emerald);"></i> Voiture Louée
        </div>

        {% set voiture = location.voiture %}
        <div class="detail-grid">
            <div class="detail-item">
                <div class="detail-label">Marque & Modèle</div>
                <div class="detail-value">{{ voiture.marque }} {{ voiture.modele }}</div>
            </div>
            <div class="detail-item">
                <div class="detail-label">Matricule</div>
                <div class="detail-value">{{ voiture.matricule }}</div>
            </div>
            <div class="detail-item">
                <div class="detail-label">Année</div>
                <div class="detail-value">{{ voiture.annee }}</div>
            </div>
            <div class="detail-item">
                <div class="detail-label">Type Carburant</div>
                <div class="detail-value">{{ voiture.typeCarburant }}</div>
            </div>
            <div class="detail-item">
                <div class="detail-label">Prix/Jour</div>
                <div class="detail-value">{{ '%0.2f'|format(voiture.prixJour) }} DT</div>
            </div>
            <div class="detail-item">
                <div class="detail-label">Adresse Agence</div>
                <div style="font-size: 0.95rem; color: var(--dark-green);">{{ voiture.adresseAgence }}</div>
            </div>
        </div>
    </div>

    <!-- Infos location -->
    <div class="detail-card">
        <div class="card-title">
            <i class="bi bi-calendar-event" style="color: var(--primary-emerald);"></i> Période de Location
        </div>

        <div class="detail-grid">
            <div class="detail-item">
                <div class="detail-label">Date de début</div>
                <div class="detail-value">{{ location.dateDebut|date('d/m/Y') }}</div>
            </div>
            <div class="detail-item">
                <div class="detail-label">Date de fin</div>
                <div class="detail-value">{{ location.dateFin|date('d/m/Y') }}</div>
            </div>
            <div class="detail-item">
                <div class="detail-label">Nombre de jours</div>
                <div class="detail-value">{{ location.nbJours }} jour(s)</div>
            </div>
        </div>
    </div>

    <!-- Statistiques financières -->
    <div class="detail-card">
        <div class="card-title">
            <i class="bi bi-cash-coin" style="color: var(--primary-emerald);"></i> Résumé Financier
        </div>

        <div class="stats-box">
            <div class="stat-row">
                <span class="stat-label">Prix journalier</span>
                <span class="stat-value">{{ '%0.2f'|format(stats.prixJournier) }} DT</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">Nombre de jours</span>
                <span class="stat-value">× {{ stats.nbJours }}</span>
            </div>
            <div class="total-stat">
                <span>Montant Total</span>
                <span>{{ '%0.2f'|format(stats.prixTotal) }} DT</span>
            </div>
        </div>
    </div>

    <!-- Documents -->
    <div class="detail-card">
        <div class="card-title">
            <i class="bi bi-file-earmark" style="color: var(--primary-emerald);"></i> Documents
        </div>

        <div style="display: flex; flex-wrap: wrap;">
            {% if location.contratPdf %}
            <a href="{{ path('app_location_contrat', {id: location.idLocation}) }}" class="document-link">
                <i class="bi bi-file-pdf"></i> Télécharger Contrat
            </a>
            {% endif %}


            <a href="{{ path('app_location_pdf', {id: location.idLocation}) }}" class="document-link">
                <i class="bi bi-file-earmark-pdf"></i> Détails PDF
            </a>

            <a href="{{ path('app_location_excel', {id: location.idLocation}) }}" class="document-link">
                <i class="bi bi-file-earmark-spreadsheet"></i> Détails Excel
            </a>
        </div>
    </div>

    <!-- Actions -->
    <div class="detail-card">
        <div class="action-buttons">
            <a href="{{ path('app_location_index') }}" class="btn-action btn-secondary">
                <i class="bi bi-arrow-left"></i> Retour
            </a>

            {% if location.statut == 'EN_ATTENTE' %}
            <a href="{{ path('app_location_edit', {id: location.idLocation}) }}" class="btn-action btn-info">
                <i class="bi bi-pencil"></i> Modifier
            </a>

            <form method="POST" action="{{ path('app_location_cancel', {id: location.idLocation}) }}" style="display: inline;">
                <input type="hidden" name="_token" value="{{ csrf_token('cancel' ~ location.idLocation) }}">
                <button type="submit" class="btn-action btn-danger" onclick="return confirm('Êtes-vous sûr de vouloir annuler cette location?');">
                    <i class="bi bi-x-circle"></i> Annuler
                </button>
            </form>
            {% endif %}

            <form method="POST" action="{{ path('app_location_delete', {id: location.idLocation}) }}" style="display: inline;">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ location.idLocation) }}">
                <button type="submit" class="btn-action btn-danger" onclick="return confirm('Cette action supprimera définitivement la location. Continuer ?');">
                    <i class="bi bi-trash"></i> Supprimer
                </button>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% extends 'base.html.twig' %}
{% block title %}Location {{ location.reference }} — GoVibe{% endblock %}
{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Manrope:wght@200..800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
<style>
body{font-family:'Manrope',sans-serif!important;background:#fcf9f8!important}.material-symbols-outlined{font-variation-settings:'FILL' 0,'wght' 300,'GRAD' 0,'opsz' 24}
.gv-hero{position:relative;padding:170px 0 110px;background:linear-gradient(160deg,#00342d,#013220 40%,#001a12);overflow:hidden;text-align:center;border-radius:0 0 3rem 3rem;box-shadow:0 20px 50px rgba(0,52,45,.15)}
.gv-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 30% 80%,rgba(16,185,129,.15),transparent 60%),radial-gradient(ellipse at 80% 20%,rgba(233,193,118,.08),transparent 50%);pointer-events:none}
.gv-hero::after{content:'';position:absolute;inset:0;background-image:radial-gradient(rgba(160,242,225,.06) 1px,transparent 1px);background-size:24px 24px;pointer-events:none}
.gv-hib{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-size:20rem;color:rgba(255,255,255,.015);pointer-events:none;font-variation-settings:'FILL' 1}
.gv-ht{font-family:'Noto Serif',serif;font-size:clamp(2rem,4vw,3rem);color:#fff;font-weight:700;position:relative;z-index:2;margin-bottom:.3rem}
.gv-ht em{color:#a0f2e1;font-style:italic;font-weight:300}
.gv-hs{color:rgba(160,242,225,.7);font-size:1rem;position:relative;z-index:2}
.gv-sb-hero{display:inline-flex;align-items:center;gap:.3rem;padding:.45rem 1.25rem;border-radius:2rem;font-size:.72rem;font-weight:800;text-transform:uppercase;letter-spacing:.06em;backdrop-filter:blur(8px);position:relative;z-index:2;margin-bottom:1rem}
.st-wait{background:rgba(233,193,118,.15);color:#fde68a;border:1px solid rgba(233,193,118,.25)}
.st-conf{background:rgba(160,242,225,.15);color:#a0f2e1;border:1px solid rgba(160,242,225,.25)}
.st-cancel{background:rgba(239,68,68,.15);color:#fca5a5;border:1px solid rgba(239,68,68,.25)}
.st-done{background:rgba(96,165,250,.15);color:#93c5fd;border:1px solid rgba(96,165,250,.25)}
.gv-c{max-width:900px;margin:-45px auto 80px;position:relative;z-index:10;padding:0 2rem}
.gv-alert{padding:1rem 1.5rem;border-radius:1rem;margin-bottom:1.5rem;display:flex;align-items:center;gap:.6rem;font-size:.9rem;font-weight:600}
.gv-alert-info{background:rgba(96,165,250,.08);border:1px solid rgba(96,165,250,.15);color:#2563eb}
.gv-alert-ok{background:rgba(16,185,129,.08);border:1px solid rgba(16,185,129,.15);color:#047857}
.gv-alert-err{background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.15);color:#b91c1c}
.gv-card{background:rgba(255,255,255,.97);backdrop-filter:blur(20px) saturate(180%);border:1px solid rgba(0,52,45,.06);border-radius:1.5rem;padding:2rem;box-shadow:0 20px 60px rgba(0,52,45,.06);margin-bottom:2rem}
.gv-ct{font-family:'Noto Serif',serif;font-size:1.05rem;font-weight:700;color:#00342d;display:flex;align-items:center;gap:.5rem;margin-bottom:1.25rem;padding-bottom:.75rem;border-bottom:2px solid rgba(16,185,129,.15)}
.gv-ct .material-symbols-outlined{font-size:1.1rem;color:#10B981}
.gv-ig{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1rem}
.gv-ii{padding:1rem;background:rgba(0,52,45,.02);border-radius:.75rem;border:1px solid rgba(0,52,45,.04)}
.gv-il{font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#546067;margin-bottom:.25rem}
.gv-iv{font-weight:700;color:#00342d;font-size:.95rem}
.gv-fb{background:rgba(16,185,129,.06);border:1.5px solid rgba(16,185,129,.12);border-radius:1rem;padding:1.25rem}
.gv-fr{display:flex;justify-content:space-between;align-items:center;padding:.5rem 0;border-bottom:1px solid rgba(16,185,129,.1)}
.gv-fr:last-child{border-bottom:none}
.gv-fl{color:#546067;font-size:.9rem}
.gv-fv{font-weight:700;color:#10B981;font-size:.95rem}
.gv-ft{display:flex;justify-content:space-between;padding:.75rem 0 0;border-top:2px solid rgba(16,185,129,.2);margin-top:.5rem;font-size:1.15rem;font-weight:700}
.gv-ft span:last-child{font-family:'Noto Serif',serif;color:#10B981}
.gv-docs{display:flex;flex-wrap:wrap;gap:.75rem}
.gv-doc{display:inline-flex;align-items:center;gap:.4rem;padding:.65rem 1.25rem;border-radius:.75rem;font-weight:700;font-size:.85rem;text-decoration:none;transition:all .25s;border:1.5px solid rgba(0,52,45,.08);color:#00342d;font-family:'Manrope',sans-serif}
.gv-doc:hover{border-color:#10B981;background:rgba(16,185,129,.06);color:#047857}
.gv-actions{display:flex;flex-wrap:wrap;gap:.75rem}
.gv-ab{display:inline-flex;align-items:center;gap:.5rem;padding:.75rem 1.5rem;border-radius:.75rem;font-weight:700;font-size:.88rem;text-decoration:none;transition:all .3s;font-family:'Manrope',sans-serif;border:none;cursor:pointer}
.gv-ao{background:transparent;color:#546067;border:1.5px solid rgba(0,52,45,.08)}.gv-ao:hover{border-color:rgba(0,52,45,.2);background:rgba(0,52,45,.03);color:#00342d}
.gv-ag{background:linear-gradient(135deg,#00342d,#046b5e);color:#fff;box-shadow:0 6px 15px rgba(0,52,45,.25)}.gv-ag:hover{transform:translateY(-2px);box-shadow:0 10px 25px rgba(0,52,45,.35);color:#fff}
.gv-ad{background:rgba(186,26,26,.06);color:#93000a;border:1px solid rgba(186,26,26,.1)}.gv-ad:hover{background:#ba1a1a;color:#fff;border-color:transparent}
.gv-map{height:360px;border:1px solid rgba(0,52,45,.1);border-radius:1rem}
.gv-map-stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:.75rem;margin:1rem 0}
.gv-map-stat{background:rgba(0,52,45,.03);border:1px solid rgba(0,52,45,.06);border-radius:.8rem;padding:.75rem .9rem}
.gv-map-status{font-size:.88rem;color:#546067}
</style>
{% endblock %}
{% block body %}
<div class="gv-hero">
    <span class="material-symbols-outlined gv-hib">directions_car</span>
    <div class="container">
        {% if location.statut == 'EN_ATTENTE' %}<span class="gv-sb-hero st-wait"><span class="material-symbols-outlined" style="font-size:.85rem">pending</span> En attente</span>
        {% elseif location.statut == 'CONFIRMEE' %}<span class="gv-sb-hero st-conf"><span class="material-symbols-outlined" style="font-size:.85rem">verified</span> Confirmée</span>
        {% elseif location.statut == 'ANNULEE' %}<span class="gv-sb-hero st-cancel"><span class="material-symbols-outlined" style="font-size:.85rem">cancel</span> Annulée</span>
        {% elseif location.statut == 'TERMINEE' %}<span class="gv-sb-hero st-done"><span class="material-symbols-outlined" style="font-size:.85rem">task_alt</span> Terminée</span>
        {% endif %}
        <h1 class="gv-ht">Détails de <em>Location</em></h1>
        <p class="gv-hs">{{ location.reference }}</p>
    </div>
</div>
<div class="gv-c">
    {% if location.statut == 'EN_ATTENTE' %}<div class="gv-alert gv-alert-info"><span class="material-symbols-outlined" style="font-size:1.1rem">info</span> En attente de confirmation par l'administrateur.</div>
    {% elseif location.statut == 'CONFIRMEE' %}<div class="gv-alert gv-alert-ok"><span class="material-symbols-outlined" style="font-size:1.1rem">check_circle</span> Location confirmée.</div>
    {% elseif location.statut == 'ANNULEE' %}<div class="gv-alert gv-alert-err"><span class="material-symbols-outlined" style="font-size:1.1rem">error</span> Location annulée.</div>{% endif %}

    <div class="gv-card">
        <div class="gv-ct"><span class="material-symbols-outlined">info</span> Informations Principales</div>
        <div class="gv-ig">
            <div class="gv-ii"><div class="gv-il">Référence</div><div class="gv-iv">{{ location.reference }}</div></div>
            <div class="gv-ii"><div class="gv-il">Statut</div><div class="gv-iv">{{ location.statut }}</div></div>
            <div class="gv-ii"><div class="gv-il">Date de création</div><div class="gv-iv">{{ location.dateCreation|date('d/m/Y H:i') }}</div></div>
        </div>
    </div>
    {% set voiture = location.voiture %}
    <div class="gv-card">
        <div class="gv-ct"><span class="material-symbols-outlined">directions_car</span> Voiture Louée</div>
        <div class="gv-ig">
            <div class="gv-ii"><div class="gv-il">Marque & Modèle</div><div class="gv-iv">{{ voiture.marque }} {{ voiture.modele }}</div></div>
            <div class="gv-ii"><div class="gv-il">Matricule</div><div class="gv-iv">{{ voiture.matricule }}</div></div>
            <div class="gv-ii"><div class="gv-il">Année</div><div class="gv-iv">{{ voiture.annee }}</div></div>
            <div class="gv-ii"><div class="gv-il">Carburant</div><div class="gv-iv">{{ voiture.typeCarburant }}</div></div>
            <div class="gv-ii"><div class="gv-il">Prix/Jour</div><div class="gv-iv">{{ '%0.2f'|format(voiture.prixJour) }} DT</div></div>
            <div class="gv-ii"><div class="gv-il">Adresse Agence</div><div class="gv-iv">{{ voiture.adresseAgence }}</div></div>
        </div>
    </div>
    <div class="gv-card">
        <div class="gv-ct"><span class="material-symbols-outlined">date_range</span> Période de Location</div>
        <div class="gv-ig">
            <div class="gv-ii"><div class="gv-il">Date de début</div><div class="gv-iv">{{ location.dateDebut|date('d/m/Y') }}</div></div>
            <div class="gv-ii"><div class="gv-il">Date de fin</div><div class="gv-iv">{{ location.dateFin|date('d/m/Y') }}</div></div>
            <div class="gv-ii"><div class="gv-il">Nombre de jours</div><div class="gv-iv">{{ location.nbJours }} jour(s)</div></div>
        </div>
    </div>
    <div class="gv-card">
        <div class="gv-ct"><span class="material-symbols-outlined">payments</span> Résumé Financier</div>
        <div class="gv-fb">
            <div class="gv-fr"><span class="gv-fl">Prix journalier</span><span class="gv-fv">{{ '%0.2f'|format(stats.prixJournier) }} DT</span></div>
            <div class="gv-fr"><span class="gv-fl">Nombre de jours</span><span class="gv-fv">× {{ stats.nbJours }}</span></div>
            <div class="gv-ft"><span>Montant Total</span><span>{{ '%0.2f'|format(stats.prixTotal) }} DT</span></div>
        </div>
            <!-- Début Widget Conversion de Devises (Frankfurter) -->
            <div class="gv-fb" style="margin-top:1.5rem; background:#f7fafc; border:1.5px solid #e5e7eb; border-radius:1rem;">
                <div style="font-weight:700; color:#00342d; margin-bottom:0.5rem; display:flex; align-items:center; gap:0.5rem;">
                    <span class="material-symbols-outlined" style="font-size:1.1rem; color:#10B981;">currency_exchange</span>
                    Convertisseur de devises (open source, Frankfurter)
                </div>
                <div style="display:flex; flex-wrap:wrap; gap:0.5rem; align-items:center; margin-bottom:0.5rem;">
                    <input type="number" id="conv-amount" value="{{ '%0.2f'|format(stats.prixTotal) }}" min="0" step="0.01" style="width:110px; padding:0.5rem 0.7rem; border-radius:0.5rem; border:1px solid #d1d5db; font-size:1rem;">
                    <span style="font-weight:700; color:#10B981;">DT</span>
                    <span style="margin:0 0.5rem;">→</span>
                    <select id="conv-currency" style="padding:0.5rem 0.7rem; border-radius:0.5rem; border:1px solid #d1d5db; font-size:1rem;">
                        <option value="USD">Dollar ($)</option>
                        <option value="GBP">Livre (£)</option>
                        <option value="CAD">Dollar CA</option>
                        <option value="CHF">Franc Suisse</option>
                        <option value="JPY">Yen (¥)</option>
                        <option value="SAR">Riyal SAR</option>
                        <option value="AED">Dirham AED</option>
                        <option value="MAD">Dirham MAD</option>
                        <option value="DZD">Dinar DZD</option>
                        <option value="LYD">Dinar LYD</option>
                    </select>
                    <button id="conv-btn" type="button" style="background:#10B981; color:#fff; border:none; border-radius:0.5rem; padding:0.5rem 1.2rem; font-weight:700; cursor:pointer;">Convertir</button>
                </div>
                <div id="conv-result" style="font-size:1.1rem; color:#00342d; font-weight:700;"></div>
                <div style="font-size:0.85rem; color:#546067; margin-top:0.3rem;">Taux via <a href="https://frankfurter.dev/" target="_blank" rel="noopener" style="color:#10B981; text-decoration:underline;">frankfurter.dev</a> (open source, pas de clé API)</div>
            </div>
            <!-- Fin Widget Conversion de Devises (Frankfurter) -->
    </div>
    <div class="gv-card">
        <div class="gv-ct"><span class="material-symbols-outlined">description</span> Documents</div>
        <div class="gv-docs">
            {% if location.contratPdf %}<a href="{{ path('app_location_contrat', {id: location.idLocation}) }}" class="gv-doc"><span class="material-symbols-outlined" style="font-size:1rem">picture_as_pdf</span> Contrat PDF</a>{% endif %}
            <a href="{{ path('app_location_pdf', {id: location.idLocation}) }}" class="gv-doc"><span class="material-symbols-outlined" style="font-size:1rem">picture_as_pdf</span> Détails PDF</a>
            <a href="{{ path('app_location_excel', {id: location.idLocation}) }}" class="gv-doc"><span class="material-symbols-outlined" style="font-size:1rem">table_chart</span> Détails Excel</a>
        </div>
    </div>
    {% if voiture.latitude and voiture.longitude %}
    <div class="gv-card">
        <div class="gv-ct"><span class="material-symbols-outlined">map</span> Distance et Itineraire vers la voiture</div>
        <p class="gv-map-status" id="clientMapStatus">Utilisez votre position pour calculer l'itineraire. Service gratuit sans cle API.</p>
        <button type="button" class="gv-ab gv-ag" id="clientLocateBtn"><span class="material-symbols-outlined" style="font-size:1rem">my_location</span> Calculer depuis ma position</button>
        <div class="gv-map-stats">
            <div class="gv-map-stat"><strong>Distance</strong><div id="clientRouteDistance">-</div></div>
            <div class="gv-map-stat"><strong>Duree estimee</strong><div id="clientRouteDuration">-</div></div>
        </div>
        <div id="clientLocationMap" class="gv-map"></div>
    </div>
    {% endif %}
    <div class="gv-card">
        <div class="gv-actions">
            <a href="{{ path('app_location_index') }}" class="gv-ab gv-ao"><span class="material-symbols-outlined" style="font-size:1rem">arrow_back</span> Retour</a>
            {% if location.statut == 'EN_ATTENTE' %}
            <a href="{{ path('app_location_edit', {id: location.idLocation}) }}" class="gv-ab gv-ag"><span class="material-symbols-outlined" style="font-size:1rem">edit</span> Modifier</a>
            <form method="POST" action="{{ path('app_location_cancel', {id: location.idLocation}) }}" style="display:inline"><input type="hidden" name="_token" value="{{ csrf_token('cancel' ~ location.idLocation) }}"><button type="submit" class="gv-ab gv-ad" onclick="return confirm('Annuler cette location ?')"><span class="material-symbols-outlined" style="font-size:1rem">close</span> Annuler</button></form>
            {% endif %}
            <form method="POST" action="{{ path('app_location_delete', {id: location.idLocation}) }}" style="display:inline"><input type="hidden" name="_token" value="{{ csrf_token('delete' ~ location.idLocation) }}"><button type="submit" class="gv-ab gv-ad" onclick="return confirm('Supprimer définitivement ?')"><span class="material-symbols-outlined" style="font-size:1rem">delete</span> Supprimer</button></form>
        </div>
    </div>
</div>
{% if voiture.latitude and voiture.longitude %}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    // --- Conversion de devises (Frankfurter) ---
    const convBtn = document.getElementById('conv-btn');
    const convAmount = document.getElementById('conv-amount');
    const convCurrency = document.getElementById('conv-currency');
    const convResult = document.getElementById('conv-result');

    // Liste des devises supportées par Frankfurter
    // TND (dinar tunisien) n'est pas supporté directement, conversion via EUR
    // On utilise le taux EUR->TND et EUR->[devise]
    async function convertCurrency() {
        const amount = parseFloat(convAmount.value);
        const to = convCurrency.value;
        if (isNaN(amount) || amount <= 0) {
            convResult.textContent = 'Veuillez entrer un montant valide.';
            return;
        }
        convResult.textContent = 'Conversion...';
        try {
            // 1. Récupérer le taux EUR->TND
            const tndRateResp = await fetch('https://api.frankfurter.dev/v2/rate/EUR/TND');
            const tndRateData = await tndRateResp.json();
            if (!tndRateData.rate) {
                convResult.textContent = 'Taux EUR/TND non disponible.';
                return;
            }
            // 2. Récupérer le taux EUR->[devise]
            const toRateResp = await fetch(`https://api.frankfurter.dev/v2/rate/EUR/${to}`);
            const toRateData = await toRateResp.json();
            if (!toRateData.rate) {
                convResult.textContent = 'Taux EUR/' + to + ' non disponible.';
                return;
            }
            // 3. Conversion : montant DT -> EUR -> [devise]
            const montantEur = amount / tndRateData.rate;
            const montantFinal = montantEur * toRateData.rate;
            convResult.textContent = amount.toLocaleString('fr-FR', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' DT = '
                + montantFinal.toLocaleString('fr-FR', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' ' + to;
        } catch (e) {
            convResult.textContent = 'Erreur de connexion.';
        }
    }
    if (convBtn) {
        convBtn.addEventListener('click', convertCurrency);
        convCurrency.addEventListener('change', convertCurrency);
    }
    // Conversion initiale
    if (convBtn) convertCurrency();
    const destinationLat = parseFloat('{{ voiture.latitude }}');
    const destinationLng = parseFloat('{{ voiture.longitude }}');
    const statusEl = document.getElementById('clientMapStatus');
    const locateBtn = document.getElementById('clientLocateBtn');
    const distanceEl = document.getElementById('clientRouteDistance');
    const durationEl = document.getElementById('clientRouteDuration');

    const map = L.map('clientLocationMap').setView([destinationLat, destinationLng], 13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '&copy; OpenStreetMap contributors'
    }).addTo(map);

    L.marker([destinationLat, destinationLng]).addTo(map)
        .bindPopup('Voiture louee: {{ voiture.marque|e('js') }} {{ voiture.modele|e('js') }}')
        .openPopup();

    let userMarker = null;
    let routeLayer = null;

    function formatDuration(seconds) {
        const minutes = Math.round(seconds / 60);
        const hours = Math.floor(minutes / 60);
        const remainingMinutes = minutes % 60;
        if (hours <= 0) {
            return minutes + ' min';
        }
        return hours + ' h ' + remainingMinutes + ' min';
    }

    async function drawRoute(userLat, userLng) {
        const url = 'https://router.project-osrm.org/route/v1/driving/'
            + userLng + ',' + userLat + ';' + destinationLng + ',' + destinationLat
            + '?overview=full&geometries=geojson';
        const response = await fetch(url);
        const data = await response.json();

        if (!data.routes || !data.routes.length) {
            throw new Error('No route');
        }

        const route = data.routes[0];
        if (routeLayer) {
            map.removeLayer(routeLayer);
        }

        routeLayer = L.geoJSON(route.geometry, {
            style: { color: '#10B981', weight: 5, opacity: 0.85 }
        }).addTo(map);

        distanceEl.textContent = (route.distance / 1000).toFixed(2) + ' km';
        durationEl.textContent = formatDuration(route.duration);

        const bounds = L.latLngBounds([
            [userLat, userLng],
            [destinationLat, destinationLng]
        ]);
        map.fitBounds(bounds.pad(0.2));
    }

    locateBtn?.addEventListener('click', function () {
        if (!navigator.geolocation) {
            statusEl.textContent = 'Geolocalisation non supportee par ce navigateur.';
            return;
        }

        statusEl.textContent = 'Localisation en cours...';
        navigator.geolocation.getCurrentPosition(async function (position) {
            const userLat = position.coords.latitude;
            const userLng = position.coords.longitude;

            if (userMarker) {
                map.removeLayer(userMarker);
            }

            userMarker = L.marker([userLat, userLng]).addTo(map).bindPopup('Votre position');

            try {
                await drawRoute(userLat, userLng);
                statusEl.textContent = 'Itineraire calcule avec succes.';
            } catch (error) {
                statusEl.textContent = 'Impossible de calculer l\'itineraire pour le moment.';
            }
        }, function () {
            statusEl.textContent = 'Autorisation de localisation refusee ou indisponible.';
        }, {
            enableHighAccuracy: true,
            timeout: 15000,
            maximumAge: 0,
        });
    });

    setTimeout(function () { map.invalidateSize(); }, 200);
});
</script>
{% endif %}
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Mes Locations — GoVibe | Location de Véhicules{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Manrope:wght@200..800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════════
   GoVibe Locations — Ultra Premium Design
═══════════════════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; }

body {
    font-family: 'Manrope', sans-serif !important;
    background: #fcf9f8 !important;
    color: #1c1b1b !important;
    overflow-x: hidden !important;
}

.material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24; }

/* ─── Hero Section ─── */
.gv-loc-hero {
    position: relative;
    padding: 180px 0 120px;
    background: linear-gradient(160deg, #00342d 0%, #013220 40%, #001a12 100%);
    overflow: hidden;
    text-align: center;
    border-radius: 0 0 3rem 3rem;
    box-shadow: 0 20px 50px rgba(0, 52, 45, 0.15);
}

.gv-loc-hero::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse at 25% 75%, rgba(16, 185, 129, 0.15) 0%, transparent 60%),
                radial-gradient(ellipse at 75% 25%, rgba(233, 193, 118, 0.08) 0%, transparent 50%);
    pointer-events: none;
}

.gv-loc-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(160, 242, 225, 0.06) 1px, transparent 1px);
    background-size: 24px 24px;
    pointer-events: none;
}

.gv-hero-icon-bg {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font-size: 22rem;
    color: rgba(255, 255, 255, 0.02);
    z-index: 0;
    pointer-events: none;
    font-variation-settings: 'FILL' 1;
}

.gv-hero-title {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: #fff;
    font-weight: 700;
    margin-bottom: 1rem;
    position: relative;
    z-index: 2;
    animation: heroFadeIn 0.8s ease both;
}
.gv-hero-title em { color: #a0f2e1; font-style: italic; font-weight: 300; }

.gv-hero-sub {
    color: rgba(160, 242, 225, 0.7);
    font-size: 1.15rem;
    max-width: 600px;
    margin: 0 auto 2rem;
    line-height: 1.6;
    position: relative;
    z-index: 2;
    animation: heroFadeIn 0.8s ease 0.2s both;
}

@keyframes heroFadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}

.gv-hero-actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    position: relative;
    z-index: 2;
    animation: heroFadeIn 0.8s ease 0.4s both;
}

.gv-btn-primary {
    padding: 1rem 2rem;
    background: linear-gradient(135deg, #e9c176 0%, #ca9028 100%);
    color: #3d2a00;
    border: none;
    border-radius: 0.75rem;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s ease;
    box-shadow: 0 10px 25px -5px rgba(233, 193, 118, 0.4);
    font-family: 'Manrope', sans-serif;
}
.gv-btn-primary:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 15px 35px -5px rgba(233, 193, 118, 0.5);
    color: #3d2a00;
}

/* ─── Main Content Container ─── */
.gv-loc-container {
    max-width: 1200px;
    margin: -50px auto 80px;
    position: relative;
    z-index: 10;
    padding: 0 2rem;
}

/* ─── Filter Bar ─── */
.gv-filter-shell {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px) saturate(180%);
    border: 1px solid rgba(0, 52, 45, 0.06);
    border-radius: 1.5rem;
    padding: 1.25rem 1.5rem;
    box-shadow: 0 20px 50px rgba(0, 52, 45, 0.08);
    margin-bottom: 2.5rem;
}

.gv-filter-form {
    display: grid;
    grid-template-columns: 2fr 1.5fr 1fr 1fr auto;
    gap: 0.75rem;
    align-items: end;
}
@media (max-width: 992px) {
    .gv-filter-form { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 576px) {
    .gv-filter-form { grid-template-columns: 1fr; }
}

.gv-filter-label {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #546067;
    margin-bottom: 0.35rem;
    display: block;
}

.gv-filter-input {
    border: 1.5px solid rgba(0, 52, 45, 0.08);
    border-radius: 0.75rem;
    padding: 0.75rem 1rem;
    font-size: 0.9rem;
    font-family: 'Manrope', sans-serif;
    font-weight: 500;
    color: #1c1b1b;
    background: #fff;
    transition: all 0.25s ease;
    width: 100%;
    outline: none;
}
.gv-filter-input:focus {
    border-color: #10B981;
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.12);
}

.gv-filter-btn {
    padding: 0.75rem 1.75rem;
    background: linear-gradient(135deg, #00342d 0%, #004d43 70%, #046b5e 100%);
    color: #fff;
    border: none;
    border-radius: 0.75rem;
    font-weight: 700;
    font-family: 'Manrope', sans-serif;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s ease;
    box-shadow: 0 8px 20px -6px rgba(0, 52, 45, 0.4);
    white-space: nowrap;
    justify-content: center;
}
.gv-filter-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 30px -6px rgba(0, 52, 45, 0.5);
}

/* ─── AI Car Search ─── */
.gv-ai-shell {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px) saturate(180%);
    border: 1px solid rgba(0, 52, 45, 0.06);
    border-radius: 1.5rem;
    padding: 1.5rem;
    box-shadow: 0 20px 50px rgba(0, 52, 45, 0.08);
    margin-bottom: 2rem;
}

.gv-ai-title {
    font-family: 'Noto Serif', serif;
    font-size: 1.15rem;
    color: #00342d;
    font-weight: 700;
    margin-bottom: 0.35rem;
}

.gv-ai-sub {
    color: #546067;
    font-size: 0.9rem;
    margin-bottom: 1rem;
}

.gv-ai-form {
    display: grid;
    grid-template-columns: 2fr 1fr auto;
    gap: 0.75rem;
    align-items: end;
}

@media (max-width: 768px) {
    .gv-ai-form {
        grid-template-columns: 1fr;
    }
}

.gv-ai-results {
    margin-top: 1rem;
    display: grid;
    gap: 0.75rem;
}

.gv-ai-result-card {
    border: 1px solid rgba(0, 52, 45, 0.08);
    border-radius: 1rem;
    padding: 0.9rem 1rem;
    background: rgba(0, 52, 45, 0.02);
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr auto;
    gap: 0.7rem;
    align-items: center;
}

@media (max-width: 992px) {
    .gv-ai-result-card {
        grid-template-columns: 1fr;
    }
}

.gv-ai-col-label {
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #546067;
    font-weight: 700;
}

.gv-ai-col-value {
    font-size: 0.9rem;
    color: #00342d;
    font-weight: 700;
}

.gv-ai-source-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.25rem 0.55rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 700;
    background: rgba(0, 52, 45, 0.08);
    color: #00342d;
}

.gv-ai-empty {
    color: #546067;
    font-size: 0.9rem;
    padding: 0.75rem 0;
}

/* ─── Results Count ─── */
.gv-results-info {
    color: #546067;
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
    font-weight: 500;
}
.gv-results-info strong { color: #00342d; }

/* ─── Location Cards ─── */
.gv-loc-card {
    background: #fff;
    border-radius: 1.5rem;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
    margin-bottom: 1.5rem;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    border-left: 5px solid transparent;
    border-image: linear-gradient(180deg, #00342d, #10B981) 1;
}
.gv-loc-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 3px;
    background: linear-gradient(90deg, #00342d, #046b5e, #10B981);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s ease;
}
.gv-loc-card:hover::before { transform: scaleX(1); }
.gv-loc-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 50px -10px rgba(0, 0, 0, 0.1);
}

.gv-loc-card-inner {
    padding: 1.75rem;
}

.gv-loc-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid rgba(0, 52, 45, 0.06);
}

.gv-loc-ref {
    font-family: 'Noto Serif', serif;
    font-weight: 700;
    font-size: 1.15rem;
    color: #00342d;
}

.gv-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.5rem 1rem;
    border-radius: 2rem;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}
.gv-badge-pending {
    background: rgba(233, 193, 118, 0.15);
    color: #92400e;
    border: 1px solid rgba(233, 193, 118, 0.3);
}
.gv-badge-confirmed {
    background: rgba(16, 185, 129, 0.1);
    color: #005046;
    border: 1px solid rgba(160, 242, 225, 0.5);
}
.gv-badge-canceled {
    background: rgba(186, 26, 26, 0.08);
    color: #93000a;
    border: 1px solid rgba(186, 26, 26, 0.15);
}
.gv-badge-finished {
    background: rgba(0, 52, 45, 0.08);
    color: #00342d;
    border: 1px solid rgba(0, 52, 45, 0.15);
}

.gv-loc-details {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
}

.gv-detail-item {
    padding: 1rem;
    background: rgba(0, 52, 45, 0.02);
    border-radius: 1rem;
    border: 1px solid rgba(0, 52, 45, 0.04);
}

.gv-detail-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #546067;
    margin-bottom: 0.4rem;
    display: flex;
    align-items: center;
    gap: 0.3rem;
}
.gv-detail-label .material-symbols-outlined { font-size: 1rem; color: #10B981; }

.gv-detail-value {
    font-weight: 700;
    color: #00342d;
    font-size: 1rem;
}

.gv-detail-sub {
    font-size: 0.8rem;
    color: #707975;
    margin-top: 0.2rem;
}

.gv-loc-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
}

.gv-action-btn {
    padding: 0.6rem 1.1rem;
    font-size: 0.8rem;
    border-radius: 0.6rem;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition: all 0.25s ease;
    border: none;
    cursor: pointer;
    font-weight: 700;
    font-family: 'Manrope', sans-serif;
}
.gv-action-btn:hover { transform: translateY(-2px); }

.gv-action-view {
    background: linear-gradient(135deg, #00342d, #046b5e);
    color: white;
    box-shadow: 0 4px 12px rgba(0, 52, 45, 0.2);
}
.gv-action-view:hover { color: white; box-shadow: 0 8px 20px rgba(0, 52, 45, 0.3); }

.gv-action-edit {
    background: rgba(0, 122, 196, 0.1);
    color: #0c5460;
}
.gv-action-edit:hover { background: #17a2b8; color: white; }

.gv-action-delete {
    background: rgba(186, 26, 26, 0.08);
    color: #93000a;
}
.gv-action-delete:hover { background: #ba1a1a; color: white; }

.gv-action-download {
    background: rgba(0, 52, 45, 0.06);
    color: #546067;
}
.gv-action-download:hover { background: rgba(0, 52, 45, 0.12); color: #00342d; }

/* ─── Pagination ─── */
.gv-pagination {
    margin-top: 2.5rem;
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
}
.gv-page-btn {
    padding: 0.6rem 1rem;
    border-radius: 0.6rem;
    font-weight: 700;
    font-size: 0.85rem;
    text-decoration: none;
    color: #00342d;
    background: rgba(0, 52, 45, 0.04);
    border: 1px solid rgba(0, 52, 45, 0.08);
    transition: all 0.25s ease;
}
.gv-page-btn:hover { background: rgba(0, 52, 45, 0.1); color: #00342d; }
.gv-page-btn.active {
    background: linear-gradient(135deg, #00342d, #046b5e);
    color: #fff;
    border-color: transparent;
}

/* ─── Export ─── */
.gv-export-bar {
    margin-top: 2rem;
    text-align: center;
}

/* ─── Empty State ─── */
.gv-empty {
    text-align: center;
    padding: 5rem 2rem;
    background: #fff;
    border-radius: 1.5rem;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.04);
}
.gv-empty-icon {
    font-size: 4rem;
    color: #cde1db;
    margin-bottom: 1.5rem;
    font-variation-settings: 'FILL' 1;
}
.gv-empty h4 {
    font-family: 'Noto Serif', serif;
    font-size: 1.5rem;
    color: #00342d;
    font-weight: 700;
    margin-bottom: 0.5rem;
}
.gv-empty p {
    color: #546067;
    margin-bottom: 2rem;
}

/* ─── Reveal ─── */
.gv-reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s cubic-bezier(0.4, 0, 0.2, 1), transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
}
.gv-reveal.is-visible { opacity: 1; transform: translateY(0); }
</style>
{% endblock %}

{% block body %}
<!-- ─── HERO ─── -->
<div class="gv-loc-hero">
    <span class="material-symbols-outlined gv-hero-icon-bg">directions_car</span>
    <div class="container">
        <h1 class="gv-hero-title">Mes <em>Locations</em></h1>
        <p class="gv-hero-sub">Gérez vos locations de véhicules avec élégance. Chaque trajet est une nouvelle aventure.</p>
        <div class="gv-hero-actions">
            <a href="{{ path('app_location_new') }}" class="gv-btn-primary">
                <span class="material-symbols-outlined" style="font-size:1.2rem;">add_circle</span>
                Nouvelle Location
            </a>
        </div>
    </div>
</div>

<!-- ─── MAIN CONTENT ─── -->
<div class="gv-loc-container">

    <!-- Filter Bar -->
    <div class="gv-filter-shell">
        <form method="GET" class="gv-filter-form">
            <div>
                <label class="gv-filter-label">Référence</label>
                <input type="text" name="reference" class="gv-filter-input" placeholder="Rechercher par référence…" value="{{ searchRef }}">
            </div>
            <div>
                <label class="gv-filter-label">Statut</label>
                <select name="statut" class="gv-filter-input">
                    <option value="">Tous les statuts</option>
                    {% for s in statutes %}
                    <option value="{{ s }}" {% if statut == s %}selected{% endif %}>{{ s }}</option>
                    {% endfor %}
                </select>
            </div>
            <div>
                <label class="gv-filter-label">Trier par</label>
                <select name="sort" class="gv-filter-input">
                    <option value="dateDebut" {% if sortBy == 'dateDebut' %}selected{% endif %}>Date début</option>
                    <option value="montantTotal" {% if sortBy == 'montantTotal' %}selected{% endif %}>Montant</option>
                    <option value="dateCreation" {% if sortBy == 'dateCreation' %}selected{% endif %}>Récente</option>
                </select>
            </div>
            <div>
                <label class="gv-filter-label">Ordre</label>
                <select name="order" class="gv-filter-input">
                    <option value="DESC" {% if sortOrder == 'DESC' %}selected{% endif %}>DESC</option>
                    <option value="ASC" {% if sortOrder == 'ASC' %}selected{% endif %}>ASC</option>
                </select>
            </div>
            <div>
                <button type="submit" class="gv-filter-btn">
                    <span class="material-symbols-outlined" style="font-size:1.1rem;">filter_alt</span>
                    Filtrer
                </button>
            </div>
        </form>
    </div>

    <div class="gv-ai-shell">
        <div class="gv-ai-title">Assistant IA: trouver une voiture disponible</div>
        <div class="gv-ai-sub">Saisissez une localisation (ex: Tunis, Sousse) et un budget max pour obtenir une liste intelligente.</div>

        <form id="gvAiSearchForm" class="gv-ai-form">
            <div>
                <label class="gv-filter-label">Localisation</label>
                <input type="text" id="gvAiLocation" class="gv-filter-input" placeholder="Tunis, Sousse, Sfax..." required>
            </div>
            <div>
                <label class="gv-filter-label">Prix max (DT/jour)</label>
                <input type="number" id="gvAiMaxPrice" class="gv-filter-input" min="0" step="1" placeholder="200">
            </div>
            <div>
                <button type="submit" class="gv-filter-btn" id="gvAiSearchBtn">
                    <span class="material-symbols-outlined" style="font-size:1.1rem;">auto_awesome</span>
                    Rechercher
                </button>
            </div>
        </form>

        <div id="gvAiStatus" class="gv-ai-empty">Aucune recherche lancée.</div>
        <div id="gvAiResults" class="gv-ai-results" aria-live="polite"></div>
    </div>

    <!-- Flash Messages -->
    {% for message in app.flashes('success') %}
    <div class="alert alert-success rounded-4 border-0 mb-4" style="background:#eafaf1; color:#005046; border:1px solid #a0f2e1!important; font-weight:600;">
        <i class="bi bi-check-circle-fill me-2"></i> {{ message }}
    </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
    <div class="alert alert-danger rounded-4 border-0 mb-4" style="background:#fef2f2; color:#93000a; border:1px solid rgba(186,26,26,0.15)!important; font-weight:600;">
        <i class="bi bi-exclamation-circle-fill me-2"></i> {{ message }}
    </div>
    {% endfor %}

    <!-- Location List -->
    {% if locations|length > 0 %}
    <p class="gv-results-info">
        Affichage <strong>{{ (page - 1) * 10 + 1 }}</strong> à <strong>{{ min(page * 10, total) }}</strong> sur <strong>{{ total }}</strong> locations
    </p>

    {% for location in locations %}
    <div class="gv-loc-card gv-reveal">
        <div class="gv-loc-card-inner">
            <div class="gv-loc-card-header">
                <span class="gv-loc-ref">{{ location.reference }}</span>
                {% set statusLower = location.statut|lower|replace({'_': '', ' ': ''}) %}
                {% if statusLower == 'enattente' %}
                    <span class="gv-badge gv-badge-pending">
                        <span class="material-symbols-outlined" style="font-size:1rem;">pending</span> {{ location.statut }}
                    </span>
                {% elseif statusLower == 'confirmee' or statusLower == 'confirmée' %}
                    <span class="gv-badge gv-badge-confirmed">
                        <span class="material-symbols-outlined" style="font-size:1rem;">verified</span> {{ location.statut }}
                    </span>
                {% elseif statusLower == 'annulee' or statusLower == 'annulée' %}
                    <span class="gv-badge gv-badge-canceled">
                        <span class="material-symbols-outlined" style="font-size:1rem;">cancel</span> {{ location.statut }}
                    </span>
                {% elseif statusLower == 'terminee' or statusLower == 'terminée' %}
                    <span class="gv-badge gv-badge-finished">
                        <span class="material-symbols-outlined" style="font-size:1rem;">task_alt</span> {{ location.statut }}
                    </span>
                {% else %}
                    <span class="gv-badge gv-badge-finished">{{ location.statut }}</span>
                {% endif %}
            </div>

            <div class="gv-loc-details">
                <div class="gv-detail-item">
                    <div class="gv-detail-label">
                        <span class="material-symbols-outlined">directions_car</span> Voiture
                    </div>
                    <div class="gv-detail-value">{{ location.voiture.marque }} {{ location.voiture.modele }}</div>
                    <div class="gv-detail-sub">{{ location.voiture.matricule }}</div>
                </div>
                <div class="gv-detail-item">
                    <div class="gv-detail-label">
                        <span class="material-symbols-outlined">date_range</span> Période
                    </div>
                    <div class="gv-detail-value">{{ location.dateDebut|date('d/m/Y') }} → {{ location.dateFin|date('d/m/Y') }}</div>
                    <div class="gv-detail-sub">{{ location.nbJours }} jour(s)</div>
                </div>
                <div class="gv-detail-item">
                    <div class="gv-detail-label">
                        <span class="material-symbols-outlined">payments</span> Montant
                    </div>
                    <div class="gv-detail-value">{{ '%0.2f'|format(location.montantTotal) }} DT</div>
                    <div class="gv-detail-sub">Prix/jour: {{ '%0.2f'|format(location.voiture.prixJour) }} DT</div>
                </div>
                <div class="gv-detail-item">
                    <div class="gv-detail-label">
                        <span class="material-symbols-outlined">schedule</span> Créé le
                    </div>
                    <div class="gv-detail-value">{{ location.dateCreation|date('d/m/Y') }}</div>
                    <div class="gv-detail-sub">{{ location.dateCreation|date('H:i') }}</div>
                </div>
            </div>

            <div class="gv-loc-actions">
                <a href="{{ path('app_location_show', {id: location.idLocation}) }}" class="gv-action-btn gv-action-view">
                    <span class="material-symbols-outlined" style="font-size:1rem;">visibility</span> Voir détails
                </a>
                {% if location.statut == 'EN_ATTENTE' %}
                <a href="{{ path('app_location_edit', {id: location.idLocation}) }}" class="gv-action-btn gv-action-edit">
                    <span class="material-symbols-outlined" style="font-size:1rem;">edit</span> Modifier
                </a>
                {% endif %}
                <form method="POST" action="{{ path('app_location_delete', {id: location.idLocation}) }}" style="display: inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ location.idLocation) }}">
                    <button type="submit" class="gv-action-btn gv-action-delete" onclick="return confirm('Cette action supprimera définitivement la location. Continuer ?');">
                        <span class="material-symbols-outlined" style="font-size:1rem;">delete</span> Supprimer
                    </button>
                </form>
                {% if location.contratPdf %}
                <a href="{{ path('app_location_contrat', {id: location.idLocation}) }}" class="gv-action-btn gv-action-download">
                    <span class="material-symbols-outlined" style="font-size:1rem;">description</span> Contrat
                </a>
                {% endif %}
                <a href="{{ path('app_location_pdf', {id: location.idLocation}) }}" class="gv-action-btn gv-action-download">
                    <span class="material-symbols-outlined" style="font-size:1rem;">picture_as_pdf</span> PDF
                </a>
                <a href="{{ path('app_location_excel', {id: location.idLocation}) }}" class="gv-action-btn gv-action-download">
                    <span class="material-symbols-outlined" style="font-size:1rem;">table_chart</span> Excel
                </a>
            </div>
        </div>
    </div>
    {% endfor %}

    <!-- Pagination -->
    {% if totalPages > 1 %}
    <nav class="gv-pagination">
        {% if page > 1 %}
            <a class="gv-page-btn" href="{{ path('app_location_index', {page: 1, reference: searchRef, statut: statut, sort: sortBy, order: sortOrder}) }}">Première</a>
            <a class="gv-page-btn" href="{{ path('app_location_index', {page: page - 1, reference: searchRef, statut: statut, sort: sortBy, order: sortOrder}) }}">‹</a>
        {% endif %}
        {% for p in range(max(1, page - 2), min(totalPages, page + 2)) %}
            <a class="gv-page-btn {% if p == page %}active{% endif %}" href="{{ path('app_location_index', {page: p, reference: searchRef, statut: statut, sort: sortBy, order: sortOrder}) }}">{{ p }}</a>
        {% endfor %}
        {% if page < totalPages %}
            <a class="gv-page-btn" href="{{ path('app_location_index', {page: page + 1, reference: searchRef, statut: statut, sort: sortBy, order: sortOrder}) }}">›</a>
            <a class="gv-page-btn" href="{{ path('app_location_index', {page: totalPages, reference: searchRef, statut: statut, sort: sortBy, order: sortOrder}) }}">Dernière</a>
        {% endif %}
    </nav>
    {% endif %}

    <!-- Export -->
    <div class="gv-export-bar">
        <a href="{{ path('app_location_stats_export') }}" class="gv-btn-primary" style="background: linear-gradient(135deg, #00342d 0%, #004d43 70%, #046b5e 100%); color: #fff; box-shadow: 0 10px 25px -5px rgba(0, 52, 45, 0.4);">
            <span class="material-symbols-outlined" style="font-size:1.2rem;">download</span>
            Exporter en Excel
        </a>
    </div>

    {% else %}
    <div class="gv-empty">
        <span class="material-symbols-outlined gv-empty-icon">directions_car</span>
        <h4>Aucune location enregistrée</h4>
        <p>Vous n'avez pas encore effectué de location. Commencez votre première aventure.</p>
        <a href="{{ path('app_location_new') }}" class="gv-btn-primary">
            <span class="material-symbols-outlined" style="font-size:1.2rem;">add_circle</span>
            Créer une nouvelle location
        </a>
    </div>
    {% endif %}
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    var reveals = document.querySelectorAll('.gv-reveal');
    if (reveals.length) {
        var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
                if (entry.isIntersecting) {
                    entry.target.classList.add('is-visible');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });

        reveals.forEach(function(el, i) {
            el.style.transitionDelay = (i * 80) + 'ms';
            observer.observe(el);
        });
    }

    const aiForm = document.getElementById('gvAiSearchForm');
    const aiLocation = document.getElementById('gvAiLocation');
    const aiMaxPrice = document.getElementById('gvAiMaxPrice');
    const aiStatus = document.getElementById('gvAiStatus');
    const aiResults = document.getElementById('gvAiResults');
    const aiEndpoint = '{{ path('app_api_ai_cars_recommendations') }}';

    function renderAiResults(cars) {
        aiResults.innerHTML = '';

        if (!cars.length) {
            aiResults.innerHTML = '<div class="gv-ai-empty">Aucune voiture disponible pour ces critères.</div>';
            return;
        }

        cars.forEach(function(car) {
            const canRent = car.rentable !== false;
            const actionHtml = canRent
                ? '<a href="{{ path('app_location_new') }}?recommendedCar=' + car.id + '" class="gv-action-btn gv-action-view" style="justify-content:center;">Louer</a>'
                : '<span class="gv-ai-source-chip">Externe: affichage seul</span>';

            const card = document.createElement('div');
            card.className = 'gv-ai-result-card';
            card.innerHTML = ''
                + '<div><div class="gv-ai-col-label">Modele</div><div class="gv-ai-col-value">' + car.modele + '</div></div>'
                + '<div><div class="gv-ai-col-label">Prix</div><div class="gv-ai-col-value">' + Number(car.prix).toFixed(2) + ' DT/jour</div></div>'
                + '<div><div class="gv-ai-col-label">Agence</div><div class="gv-ai-col-value">' + car.agence + '</div></div>'
                + '<div><div class="gv-ai-col-label">Localisation</div><div class="gv-ai-col-value">' + car.localisation + ' <span class="gv-ai-source-chip">' + (car.source || 'unknown') + '</span></div></div>'
                + '<div>' + actionHtml + '</div>';
            aiResults.appendChild(card);
        });
    }

    aiForm?.addEventListener('submit', async function(e) {
        e.preventDefault();

        const locationValue = (aiLocation?.value || '').trim();
        const maxPriceValue = (aiMaxPrice?.value || '').trim();

        if (!locationValue) {
            aiStatus.textContent = 'Veuillez saisir une localisation.';
            return;
        }

        aiStatus.textContent = 'Recherche IA en cours...';
        aiResults.innerHTML = '';

        try {
            const query = new URLSearchParams({
                location: locationValue,
                maxPrice: maxPriceValue || '0'
            });
            const response = await fetch(aiEndpoint + '?' + query.toString(), {
                method: 'GET',
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });

            if (!response.ok) {
                throw new Error('API error');
            }

            const payload = await response.json();
            const provider = payload.provider || 'local-fallback';
            const externalCount = Number(payload.externalCount || 0);
            aiStatus.textContent = payload.count + ' voiture(s) recommandee(s) pour "' + locationValue + '" (IA: ' + provider + ', externes: ' + externalCount + ').';
            renderAiResults(payload.cars || []);
        } catch (error) {
            aiStatus.textContent = 'La recherche IA est indisponible pour le moment. Veuillez reessayer.';
        }
    });
});
</script>
{% endblock %}

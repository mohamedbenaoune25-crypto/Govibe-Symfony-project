{% extends is_granted('ROLE_ADMIN') ? 'admin/base_admin.html.twig' : 'base.html.twig' %}

{% block title %}{{ activite.name }} - Détails - GoVibe{% endblock %}

{% block body %}
<div class="container-fluid py-5 text-center mb-5 border-bottom rounded-bottom-5 px-lg-5 shadow-sm bg-white">
    <div class="d-flex align-items-center justify-content-center gap-3 mb-3">
        <span class="badge rounded-pill bg-success px-3 fs-6" style="background-color: #52BE80;">{{ activite.type }}</span>
        <span class="badge rounded-pill bg-light text-dark shadow-sm px-3 fs-6 border">{{ activite.status }}</span>
    </div>
    <h1 class="display-3 fw-bold text-dark mb-2">{{ activite.name }}</h1>
    <p class="text-secondary fs-5"><i class="bi bi-pin-map me-2"></i>{{ activite.localisation }}</p>
</div>

<div class="container mb-5 px-lg-5">
    <div class="row g-5">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-5 p-5 bg-white mb-5 animate-fade-in-up">
                <h3 class="h4 fw-bold mb-4 border-bottom pb-2">Description de l'activité</h3>
                <p class="text-muted fs-5 lh-lg">{{ activite.description|nl2br }}</p>
                
                <div class="pt-4 mt-4 border-top mt-5">
                    <div class="row text-center g-4">
                        <div class="col-6 col-md-4">
                            <div class="p-3 rounded-4 bg-light shadow-sm border border-white">
                                <h5 class="small text-uppercase text-secondary mb-1">Tarif</h5>
                                <p class="h4 fw-bold mb-0" style="color: #52BE80;">{{ activite.prix }} TND</p>
                            </div>
                        </div>
                        <div class="col-6 col-md-4">
                            <div class="p-3 rounded-4 bg-light shadow-sm border border-white">
                                <h5 class="small text-uppercase text-secondary mb-1">Type</h5>
                                <p class="h4 fw-bold mb-0">{{ activite.type }}</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow rounded-5 p-4 bg-white mb-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="h4 fw-bold mb-0">Sessions de l'activité</h3>
                    <a href="{{ path('app_activite_session_new') }}" class="btn btn-outline-success btn-sm rounded-pill px-3 border-2 fw-bold">
                        <i class="bi bi-plus-lg"></i> Créer
                    </a>
                </div>
                
                <div class="list-group list-group-flush gap-3 mt-3">
                    {% for session in activite.sessions %}
                        <div class="list-group-item rounded-4 border p-3 shadow-sm hover-lift-2 transition-all">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <p class="fw-bold mb-1"><i class="bi bi-calendar-event me-2"></i> {{ session.date|date('d/m/Y') }}</p>
                                    <p class="text-muted small mb-0"><i class="bi bi-clock me-2"></i> {{ session.heure|date('H:i') }}</p>
                                </div>
                                <div class="text-end">
                                    <span class="badge rounded-pill bg-light text-dark border mb-2 d-block">
                                        {{ session.nbrPlacesRestant }}/{{ session.capacite }} places
                                    </span>
                                    
                                    {% if session.canReserve(1) %}
                                        <a href="{{ path('app_reservation_session_booking', {'idSession': session.idSession}) }}" class="btn btn-success btn-sm rounded-pill px-3 shadow-sm border-0 transition-all hover-lift-2" style="background-color: #2ECC71;">
                                            Réserver
                                        </a>
                                    {% else %}
                                        <button class="btn btn-secondary btn-sm rounded-pill px-3 shadow-sm border-0 disabled">
                                            Complet
                                        </button>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    {% else %}
                        <div class="text-center py-4 bg-light rounded-4">
                            <p class="text-muted mb-0">Aucune session programmée</p>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-center gap-3 mt-5">
        <a href="{{ path('app_activite_index') }}" class="btn btn-outline-secondary rounded-pill px-5 border-2 fw-bold d-flex align-items-center gap-2">
            <i class="bi bi-arrow-left"></i> Liste des activités
        </a>
        {% if is_granted('ROLE_ADMIN') %}
            {% if activite.status == 'Pending' %}
                <form method="post" action="{{ path('app_activite_validate', {'id': activite.id}) }}" class="d-inline">
                    <button class="btn btn-success rounded-pill px-4 border-0 shadow py-2 fw-bold transition-all hover-lift-2" style="background-color: #2ECC71;">
                        <i class="bi bi-check-lg me-2"></i> Accepter
                    </button>
                </form>
                <form method="post" action="{{ path('app_activite_reject', {'id': activite.id}) }}" class="d-inline">
                    <button class="btn btn-danger rounded-pill px-4 border-0 shadow py-2 fw-bold transition-all hover-lift-2">
                        <i class="bi bi-x-lg me-2"></i> Refuser
                    </button>
                </form>
            {% endif %}
            <a href="{{ path('app_activite_edit', {'id': activite.id}) }}" class="btn btn-success rounded-pill px-5 border-0 shadow py-2 fw-bold transition-all hover-lift-2" style="background-color: #52BE80;">
                <i class="bi bi-pencil-square me-2"></i> Modifier
            </a>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block stylesheets %}
<style>
    body { background-color: #F8F9F9 !important; }
    .rounded-bottom-5 { border-bottom-left-radius: 4rem !important; border-bottom-right-radius: 4rem !important; }
    .animate-fade-in-up { animation: fadeInUp 0.6s ease-out; }
    @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    .hover-lift-2:hover { transform: translateY(-3px); box-shadow: 0 5px 15px rgba(0,0,0,0.05) !important; }
</style>
{% endblock %}

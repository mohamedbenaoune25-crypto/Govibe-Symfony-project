{% extends is_granted('ROLE_ADMIN') ? 'admin/base_admin.html.twig' : 'base.html.twig' %}

{% block title %}Activités — GoVibe | Expériences Premium{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Manrope:wght@200..800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
<style>
/* ═══════════════════════════════════════════════════
   GoVibe Activities — Ultra Premium Design
═══════════════════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; }

body {
    font-family: 'Manrope', sans-serif !important;
    background: #fcf9f8 !important;
    color: #1c1b1b !important;
    overflow-x: hidden !important;
}

.material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24; }

/* ─── Hero Section ─── */
.gv-act-hero {
    position: relative;
    padding: 180px 0 120px;
    background: linear-gradient(160deg, #00342d 0%, #013220 40%, #001a12 100%);
    overflow: hidden;
    text-align: center;
    border-radius: 0 0 3rem 3rem;
    box-shadow: 0 20px 50px rgba(0, 52, 45, 0.15);
}

.gv-act-hero::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse at 30% 80%, rgba(16, 185, 129, 0.15) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 20%, rgba(233, 193, 118, 0.08) 0%, transparent 50%);
    pointer-events: none;
}

.gv-act-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(160, 242, 225, 0.06) 1px, transparent 1px);
    background-size: 24px 24px;
    pointer-events: none;
}

.gv-hero-icon-bg {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font-size: 22rem;
    color: rgba(255, 255, 255, 0.02);
    z-index: 0;
    pointer-events: none;
    font-variation-settings: 'FILL' 1;
}

.gv-hero-title {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: #fff;
    font-weight: 700;
    margin-bottom: 1rem;
    position: relative;
    z-index: 2;
    animation: heroFadeIn 0.8s ease both;
}
.gv-hero-title em { color: #a0f2e1; font-style: italic; font-weight: 300; }

.gv-hero-sub {
    color: rgba(160, 242, 225, 0.7);
    font-size: 1.15rem;
    max-width: 600px;
    margin: 0 auto 2rem;
    line-height: 1.6;
    position: relative;
    z-index: 2;
    animation: heroFadeIn 0.8s ease 0.2s both;
}

@keyframes heroFadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}

/* ─── Hero Actions ─── */
.gv-hero-actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    position: relative;
    z-index: 2;
    animation: heroFadeIn 0.8s ease 0.4s both;
}

.gv-btn-primary {
    padding: 1rem 2rem;
    background: linear-gradient(135deg, #e9c176 0%, #ca9028 100%);
    color: #3d2a00;
    border: none;
    border-radius: 0.75rem;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s ease;
    box-shadow: 0 10px 25px -5px rgba(233, 193, 118, 0.4);
    font-family: 'Manrope', sans-serif;
}
.gv-btn-primary:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 15px 35px -5px rgba(233, 193, 118, 0.5);
    color: #3d2a00;
}

.gv-btn-secondary {
    padding: 1rem 2rem;
    background: transparent;
    color: #a0f2e1;
    border: 1.5px solid rgba(160, 242, 225, 0.25);
    border-radius: 0.75rem;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s ease;
    font-family: 'Manrope', sans-serif;
}
.gv-btn-secondary:hover {
    background: rgba(255, 255, 255, 0.08);
    color: #a0f2e1;
}

/* ─── Main Content Container ─── */
.gv-act-container {
    max-width: 1200px;
    margin: -50px auto 80px;
    position: relative;
    z-index: 10;
    padding: 0 2rem;
}

/* ─── Search Bar ─── */
.gv-search-shell {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px) saturate(180%);
    border: 1px solid rgba(0, 52, 45, 0.06);
    border-radius: 1.5rem;
    padding: 0.75rem;
    box-shadow: 0 20px 50px rgba(0, 52, 45, 0.08);
    margin-bottom: 3rem;
}

.gv-search-inner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: rgba(255, 255, 255, 0.95);
    border-radius: 1rem;
    padding: 0.5rem 1rem;
}

.gv-search-inner .material-symbols-outlined { color: #546067; font-size: 1.3rem; }

.gv-search-input {
    border: none;
    outline: none;
    background: transparent;
    width: 100%;
    font-size: 1rem;
    font-weight: 500;
    color: #1c1b1b;
    font-family: 'Manrope', sans-serif;
    padding: 0.75rem 0;
}
.gv-search-input::placeholder { color: #bfc9c4; }

.gv-search-btn {
    padding: 0.85rem 2rem;
    background: linear-gradient(135deg, #00342d 0%, #004d43 70%, #046b5e 100%);
    color: #fff;
    border: none;
    border-radius: 0.75rem;
    font-weight: 700;
    font-family: 'Manrope', sans-serif;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s ease;
    box-shadow: 0 8px 20px -6px rgba(0, 52, 45, 0.4);
    white-space: nowrap;
}
.gv-search-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 30px -6px rgba(0, 52, 45, 0.5);
}

.gv-search-reset {
    color: #ba1a1a;
    text-decoration: none;
    display: flex;
    align-items: center;
    padding: 0.5rem;
    border-radius: 50%;
    transition: background 0.2s;
}
.gv-search-reset:hover { background: rgba(186, 26, 26, 0.08); }

/* ─── Section Header ─── */
.gv-section-header {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 2.5rem;
    gap: 1rem;
}

.gv-section-title {
    font-family: 'Noto Serif', serif;
    font-size: 1.8rem;
    color: #00342d;
    font-weight: 700;
}

.gv-count-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    font-weight: 700;
    padding: 0.5rem 1.25rem;
    border-radius: 2rem;
    background: rgba(0, 52, 45, 0.06);
    color: #00342d;
}

/* ─── Activity Cards ─── */
.gv-act-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 2rem;
}
@media (max-width: 768px) { .gv-act-grid { grid-template-columns: 1fr; } }

.gv-act-card {
    background: #fff;
    border-radius: 1.5rem;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
}
.gv-act-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 4px;
    background: linear-gradient(90deg, #00342d, #046b5e, #10B981);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s ease;
}
.gv-act-card:hover::before { transform: scaleX(1); }
.gv-act-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 30px 60px -15px rgba(0, 0, 0, 0.1);
}

.gv-act-card-header {
    height: 200px;
    background: linear-gradient(135deg, #00342d 0%, #004d43 50%, #046b5e 100%);
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
}

.gv-act-card-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 30% 70%, rgba(160, 242, 225, 0.15), transparent 50%),
                radial-gradient(circle at 80% 20%, rgba(233, 193, 118, 0.1), transparent 40%);
}

.gv-act-card-header .material-symbols-outlined {
    font-size: 4rem;
    color: rgba(255, 255, 255, 0.1);
    font-variation-settings: 'FILL' 1;
}

.gv-act-badges {
    position: absolute;
    top: 1rem; left: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    z-index: 2;
}

.gv-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.4rem 0.85rem;
    border-radius: 2rem;
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    backdrop-filter: blur(12px);
}

.gv-badge-type {
    background: rgba(255, 255, 255, 0.2);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.15);
}

.gv-badge-pending {
    background: rgba(233, 193, 118, 0.2);
    color: #fde68a;
    border: 1px solid rgba(233, 193, 118, 0.3);
}

.gv-badge-rejected {
    background: rgba(186, 26, 26, 0.2);
    color: #fca5a5;
    border: 1px solid rgba(186, 26, 26, 0.3);
}

.gv-act-card-body {
    padding: 1.75rem;
}

.gv-act-name {
    font-family: 'Noto Serif', serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #00342d;
    margin-bottom: 0.5rem;
}

.gv-act-desc {
    color: #546067;
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 1.25rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.gv-act-meta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
}

.gv-act-meta-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.85rem;
    color: #546067;
    font-weight: 600;
}
.gv-act-meta-item .material-symbols-outlined { font-size: 1rem; color: #10B981; }

.gv-act-card-footer {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
}

.gv-btn-details {
    flex: 1;
    padding: 0.75rem 1.25rem;
    background: rgba(0, 52, 45, 0.06);
    color: #00342d;
    border: none;
    border-radius: 0.75rem;
    font-weight: 700;
    font-size: 0.9rem;
    text-decoration: none;
    text-align: center;
    transition: all 0.3s ease;
    font-family: 'Manrope', sans-serif;
}
.gv-btn-details:hover {
    background: linear-gradient(135deg, #00342d, #046b5e);
    color: #fff;
    transform: translateY(-2px);
}

.gv-btn-icon {
    width: 42px; height: 42px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    font-size: 0.9rem;
}
.gv-btn-icon:hover { transform: translateY(-2px); }

.gv-btn-approve {
    background: rgba(16, 185, 129, 0.12);
    color: #046b5e;
}
.gv-btn-approve:hover { background: #10B981; color: #fff; }

.gv-btn-reject {
    background: rgba(186, 26, 26, 0.08);
    color: #93000a;
}
.gv-btn-reject:hover { background: #ba1a1a; color: #fff; }

.gv-btn-edit {
    background: rgba(0, 52, 45, 0.06);
    color: #00342d;
    text-decoration: none;
}
.gv-btn-edit:hover { background: #00342d; color: #fff; }

/* ─── Empty State ─── */
.gv-empty {
    text-align: center;
    padding: 5rem 2rem;
    background: #fff;
    border-radius: 1.5rem;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.04);
    grid-column: 1 / -1;
}
.gv-empty-icon {
    font-size: 4rem;
    color: #cde1db;
    margin-bottom: 1.5rem;
    font-variation-settings: 'FILL' 1;
}
.gv-empty h4 {
    font-family: 'Noto Serif', serif;
    font-size: 1.5rem;
    color: #00342d;
    font-weight: 700;
    margin-bottom: 0.5rem;
}
.gv-empty p {
    color: #546067;
    margin-bottom: 2rem;
}

/* ─── Reveal Animations ─── */
.gv-reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s cubic-bezier(0.4, 0, 0.2, 1), transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
}
.gv-reveal.is-visible { opacity: 1; transform: translateY(0); }

/* ─── Recommendations ─── */
.gv-rec-section { margin-bottom:4rem; }
.gv-rec-title { font-family:'Noto Serif',serif; color:#00342d; font-size:1.5rem; margin-bottom:1.5rem; display:flex; align-items:center; gap:0.6rem; }
.gv-rec-slider { display:flex; gap:1.5rem; overflow-x:auto; padding:0.5rem 0.5rem 1.5rem; scrollbar-width:none; -ms-overflow-style:none; }
.gv-rec-slider::-webkit-scrollbar { display:none; }
.gv-rec-card { flex:0 0 300px; background:#fff; border-radius:1.25rem; border:1px solid rgba(0,52,45,0.06); box-shadow:0 10px 30px rgba(0,0,0,0.04); padding:1.25rem; transition:all 0.3s; position:relative; overflow:hidden; }
.gv-rec-card:hover { transform:translateY(-5px); border-color:#10B981; }
.gv-rec-type { position:absolute; top:0; right:0; background:rgba(16,185,129,0.1); color:#005046; padding:0.4rem 1rem; border-radius:0 0 0 1rem; font-size:0.65rem; font-weight:800; text-transform:uppercase; }

/* ─── Context Badges ─── */
.gv-ctx-badges { display:flex; flex-wrap:wrap; gap:0.4rem; margin-bottom:1rem; }
.gv-ctx-badge { display:inline-flex; align-items:center; gap:0.25rem; font-size:0.6rem; font-weight:800; text-transform:uppercase; padding:0.3rem 0.6rem; border-radius:0.4rem; }
.gv-ctx-open { background:rgba(16,185,129,0.15); color:#046b5e; border:1px solid rgba(16,185,129,0.2); }
.gv-ctx-weather { background:rgba(233,193,118,0.15); color:#92400e; border:1px solid rgba(233,193,118,0.2); }
.gv-ctx-time { background:rgba(0,52,45,0.06); color:#00342d; border:1px solid rgba(0,52,45,0.1); }

/* ─── Trending ─── */
.gv-trend-card { background:linear-gradient(135deg, #1c1b1b, #333); color:#fff; padding:1.25rem; border-radius:1rem; display:flex; gap:1rem; align-items:center; border:1px solid rgba(255,255,255,0.1); }
.gv-trend-tag { background:#e9c176; color:#3d2a00; font-size:0.6rem; font-weight:800; padding:0.2rem 0.5rem; border-radius:0.3rem; text-transform:uppercase; }

/* ─── Sorting ─── */
.gv-sort-bar { display:flex; align-items:center; gap:0.5rem; background:rgba(255,255,255,0.6); border:1px solid rgba(0,52,45,0.06); padding:0.4rem 0.8rem; border-radius:0.75rem; font-size:0.85rem; font-weight:700; color:#546067; }
.gv-sort-select { border:none; background:transparent; font-size:0.85rem; font-weight:800; color:#00342d; cursor:pointer; outline:none; }

.gv-stars { display:flex; gap:2px; color:#e9c176; margin-bottom:0.5rem; }
.gv-stars .material-symbols-outlined { font-size:1.1rem; font-variation-settings:'FILL' 1; }
.gv-stars .empty { color:#ddd; font-variation-settings:'FILL' 0; }

/* ─── Map Integration ─── */
#gv-map-container { 
    height: 0; 
    overflow: hidden; 
    transition: all 0.5s ease; 
    border-radius: 1.5rem; 
    margin-bottom: 3rem;
    border: 1px solid rgba(0,52,45,0.06);
    box-shadow: 0 20px 50px rgba(0,0,0,0.05);
}
#gv-map-container.active { height: 500px; padding: 0.5rem; background: #fff; }
#gv-map { height: 100%; border-radius: 1rem; }

.gv-map-popup { font-family: 'Manrope', sans-serif; }
.leaflet-popup-content-wrapper { border-radius: 1rem; padding: 0.5rem; }
.gv-btn-map-toggle.active { background: #00342d; color: #fff; }

/* ─── Preferences Form ─── */
.gv-pref-card { background:linear-gradient(135deg, #00342d, #01443b); color:#fff; border-radius:1.5rem; padding:2rem; margin-bottom:3rem; position:relative; overflow:hidden; }
.gv-pref-card::before { content:'tuning'; font-family:'Material Symbols Outlined'; position:absolute; bottom:-20px; right:-20px; font-size:8rem; opacity:0.1; }
.gv-pref-tags { display:flex; flex-wrap:wrap; gap:0.75rem; margin:1.5rem 0; }
.gv-pref-check { display:none; }
.gv-pref-label { padding:0.6rem 1.25rem; border-radius:2rem; border:1.5px solid rgba(255,255,255,0.2); cursor:pointer; font-size:0.85rem; font-weight:700; transition:all 0.2s; }
.gv-pref-check:checked + .gv-pref-label { background:#e9c176; border-color:#e9c176; color:#3d2a00; box-shadow:0 5px 15px rgba(233,193,118,0.3); }
</style>
{% endblock %}

{% block body %}
<!-- ─── HERO ─── -->
<div class="gv-act-hero">
    <span class="material-symbols-outlined gv-hero-icon-bg">hiking</span>
    <div class="container">
        <h1 class="gv-hero-title">Nos <em>Activités</em></h1>
        <p class="gv-hero-sub">Découvrez des expériences inoubliables soigneusement sélectionnées. Chaque aventure est une invitation à l'extraordinaire.</p>
        <div class="gv-hero-actions">
            <a href="{{ path('app_activite_new') }}" class="gv-btn-primary">
                <span class="material-symbols-outlined" style="font-size:1.2rem;">add_circle</span>
                {{ is_granted('ROLE_ADMIN') ? 'Nouvelle Activité' : 'Proposer une Activité' }}
            </a>
            <a href="{{ path('app_activite_session_index') }}" class="gv-btn-secondary">
                <span class="material-symbols-outlined" style="font-size:1.2rem;">calendar_month</span>
                Gérer les Sessions
            </a>
        </div>
    </div>
</div>

<!-- ─── MAIN CONTENT ─── -->
<div class="gv-act-container">

    <!-- Search Bar -->
    <div class="gv-search-shell">
        <form method="get" action="{{ path('app_activite_index') }}" class="gv-search-inner">
            <span class="material-symbols-outlined">search</span>
            <input type="text" name="q" value="{{ search_query }}" class="gv-search-input" placeholder="Rechercher par nom d'activité...">
            {% if search_query %}
                <a href="{{ path('app_activite_index') }}" class="gv-search-reset" title="Réinitialiser">
                    <span class="material-symbols-outlined" style="font-size:1.2rem; color: #ba1a1a;">close</span>
                </a>
            {% endif %}
            <button type="submit" class="gv-search-btn">
                <span class="material-symbols-outlined" style="font-size:1.1rem;">search</span>
                Rechercher
            </button>
        </form>
    </div>

    {% if recommendations is defined and recommendations|length > 0 %}
    <!-- Recommendations Section -->
    <div class="gv-rec-section">
        <h3 class="gv-rec-title">
            <span class="material-symbols-outlined" style="color:#ca9028; font-variation-settings:'FILL' 1;">auto_awesome</span>
            Sélectionné pour vous
        </h3>
        <div class="gv-rec-slider">
            {% for rec in recommendations %}
            <a href="{{ path('app_activite_show', {'id': rec.id}) }}" class="gv-rec-card" style="text-decoration:none;">
                <span class="gv-rec-type">{{ rec.type }}</span>
                <h4 style="font-family:'Noto Serif',serif; font-size:1.1rem; color:#00342d; margin-bottom:0.75rem;">{{ rec.name }}</h4>
                
                <div class="gv-ctx-badges">
                    {% if rec.isCurrentlyOpen is defined and rec.isCurrentlyOpen %}
                        <span class="gv-ctx-badge gv-ctx-open">
                            <span class="material-symbols-outlined" style="font-size:0.8rem;">fiber_manual_record</span> Ouvert
                        </span>
                    {% endif %}
                    {% if rec.weatherMatch is defined and rec.weatherMatch %}
                        <span class="gv-ctx-badge gv-ctx-weather">
                            <span class="material-symbols-outlined" style="font-size:0.8rem;">partly_cloudy_day</span> Météo Idéale
                        </span>
                    {% endif %}
                    {% if rec.timeMatch is defined and rec.timeMatch %}
                        <span class="gv-ctx-badge gv-ctx-time">
                            <span class="material-symbols-outlined" style="font-size:0.8rem;">schedule</span> Timing Parfait
                        </span>
                    {% endif %}
                </div>

                <p style="font-size:0.8rem; color:#546067; margin-bottom:1rem; display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{{ rec.description }}</p>
                <div style="display:flex; align-items:center; gap:0.5rem; color:#10B981; font-weight:700; font-size:0.85rem;">
                    <span class="material-symbols-outlined" style="font-size:1rem;">location_on</span>
                    {{ rec.localisation }}
                </div>
            </a>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    <!-- Preferences Onboarding (Simple version) -->
    {% if not is_granted('ROLE_ADMIN') %}
    <div class="gv-pref-card">
        <h3 style="font-family:'Noto Serif',serif; font-weight:700; margin-bottom:0.5rem;">Affinez vos recommandations</h3>
        <p style="opacity:0.8; font-size:0.9rem;">Dites-nous ce que vous aimez pour que nous puissions vous proposer les meilleures expériences.</p>
        
        {# Ce formulaire pourrait être géré via AJAX ou une méthode POST dédiée #}
        <form action="#" method="get">
            <div class="gv-pref-tags">
                {% set cats = ['Sport', 'Espace de loisirs', 'Culture', 'Restaurant', 'Nature', 'Bien-être'] %}
                {% for cat in cats %}
                    <input type="checkbox" id="pref_{{ loop.index }}" class="gv-pref-check">
                    <label for="pref_{{ loop.index }}" class="gv-pref-label">{{ cat }}</label>
                {% endfor %}
            </div>
            <button type="button" class="gv-btn-primary" style="background:#fff; color:#00342d; box-shadow:none;" onclick="alert('Préférences enregistrées ! (Simulation)')">
                Enregistrer mes goûts
            </button>
        </form>
    </div>
    {% endif %}

    <!-- Flash Messages -->
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} rounded-4 border-0 shadow-sm mb-4" style="background:#eafaf1; color:#005046; border:1px solid #a0f2e1!important; font-weight:600;">
                <i class="bi bi-check-circle-fill me-2"></i> {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {% if trending is defined and trending|length > 0 %}
    <!-- Trending Section -->
    <div style="margin-bottom:4rem;">
        <h3 class="gv-rec-title">
            <span class="material-symbols-outlined" style="color:#ba1a1a; font-variation-settings:'FILL' 1;">local_fire_department</span>
            En ce moment
        </h3>
        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(300px, 1fr)); gap:1.5rem;">
            {% for trend in trending %}
                <a href="{{ path('app_activite_show', {'id': trend.id}) }}" class="gv-trend-card" style="text-decoration:none;">
                    <div style="flex-shrink:0; width:60px; height:60px; background:rgba(255,255,255,0.1); border-radius:0.75rem; display:flex; align-items:center; justify-content:center;">
                        <span class="material-symbols-outlined">rocket_launch</span>
                    </div>
                    <div>
                        <span class="gv-trend-tag">Populaire</span>
                        <h4 style="margin:0.2rem 0; font-size:0.95rem;">{{ trend.name }}</h4>
                        <div style="display:flex; align-items:center; gap:0.3rem; font-size:0.75rem; color:#aaa;">
                            <span class="material-symbols-outlined" style="font-size:0.9rem;">map</span> {{ trend.localisation }}
                        </div>
                    </div>
                </a>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    <!-- Section Header -->
    <div class="gv-section-header">
        <h2 class="gv-section-title">Explorez les expériences</h2>
        
        <div style="display:flex; align-items:center; gap:1rem;">
            <div class="gv-sort-bar">
                <span class="material-symbols-outlined" style="font-size:1rem;">swap_vert</span>
                Trier par :
                <select class="gv-sort-select" onchange="window.location.href='{{ path('app_activite_index') }}?sort=' + this.value">
                    <option value="rank" {{ current_sort == 'rank' ? 'selected' : '' }}>Recommandations</option>
                    <option value="rating" {{ current_sort == 'rating' ? 'selected' : '' }}>Mieux notés</option>
                    <option value="popular" {{ current_sort == 'popular' ? 'selected' : '' }}>Les plus populaires</option>
                </select>
            </div>
            <button class="gv-btn-primary gv-btn-map-toggle" id="mapModeToggle" style="background: rgba(0,52,45,0.06); color: #00342d; box-shadow: none;">
                <span class="material-symbols-outlined">map</span>
                Mode Carte
            </button>
            <span class="gv-count-badge">
                <span class="material-symbols-outlined" style="font-size:1rem;">grid_view</span>
                {{ activites|length }} activité{{ activites|length > 1 ? 's' : '' }}
            </span>
        </div>
    </div>

    <!-- Map Container -->
    <div id="gv-map-container">
        <div id="gv-map"></div>
    </div>

    <!-- Activities Grid -->
    <div class="gv-act-grid">
        {% for activite in activites %}
            <div class="gv-act-card gv-reveal">
                <div class="gv-act-card-header">
                    <span class="material-symbols-outlined">landscape</span>
                    <div class="gv-act-badges">
                        <span class="gv-badge gv-badge-type">{{ activite.type }}</span>
                        {% if is_granted('ROLE_ADMIN') %}
                            {% if activite.status == 'Pending' %}
                                <span class="gv-badge gv-badge-pending">
                                    <span class="material-symbols-outlined" style="font-size:0.9rem;">pending</span> En attente
                                </span>
                            {% elseif activite.status == 'Rejected' %}
                                <span class="gv-badge gv-badge-rejected">
                                    <span class="material-symbols-outlined" style="font-size:0.9rem;">cancel</span> Rejetée
                                </span>
                            {% endif %}
                        {% endif %}
                    </div>
                </div>
                <div class="gv-act-card-body">
                    {% if activite.averageRating > 0 %}
                    <div class="gv-stars" title="Note moyenne : {{ activite.averageRating }}">
                        {% set fullStars = activite.averageRating|round(0, 'floor') %}
                        {% for i in 1..5 %}
                            <span class="material-symbols-outlined {{ i > fullStars ? 'empty' : '' }}">star</span>
                        {% endfor %}
                        <span style="font-size:0.75rem; color:#546067; margin-left:0.4rem; font-weight:800;">({{ activite.reviewCount }})</span>
                    </div>
                    {% endif %}
                    <h3 class="gv-act-name">{{ activite.name }}</h3>
                    <p class="gv-act-desc">{{ activite.description }}</p>
                    <div class="gv-act-meta">
                        <span class="gv-act-meta-item">
                            <span class="material-symbols-outlined">location_on</span>
                            {{ activite.localisation }}
                        </span>
                        <span class="gv-act-meta-item">
                            <span class="material-symbols-outlined">payments</span>
                            {{ activite.prix }} TND
                        </span>
                    </div>
                    <div class="gv-act-card-footer">
                        <a href="{{ path('app_activite_show', {'id': activite.id}) }}" class="gv-btn-details">Voir les détails</a>
                        {% if is_granted('ROLE_ADMIN') %}
                            {% if activite.status == 'Pending' %}
                                <form method="post" action="{{ path('app_activite_validate', {'id': activite.id}) }}" style="display:inline;">
                                    <button class="gv-btn-icon gv-btn-approve" title="Valider"><i class="bi bi-check-lg"></i></button>
                                </form>
                                <form method="post" action="{{ path('app_activite_reject', {'id': activite.id}) }}" style="display:inline;">
                                    <button class="gv-btn-icon gv-btn-reject" title="Rejeter"><i class="bi bi-x-lg"></i></button>
                                </form>
                            {% endif %}
                            <a href="{{ path('app_activite_edit', {'id': activite.id}) }}" class="gv-btn-icon gv-btn-edit" title="Modifier"><i class="bi bi-pencil"></i></a>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% else %}
            <div class="gv-empty">
                <span class="material-symbols-outlined gv-empty-icon">{{ search_query ? 'search_off' : 'sentiment_neutral' }}</span>
                <h4>{{ search_query ? 'Aucun résultat pour "' ~ search_query ~ '"' : 'Aucune activité disponible' }}</h4>
                <p>{{ search_query ? 'Essayez avec d\'autres mots-clés ou réinitialisez la recherche.' : 'Commencez par en créer une dès maintenant.' }}</p>
                {% if search_query %}
                    <a href="{{ path('app_activite_index') }}" class="gv-btn-primary" style="background: linear-gradient(135deg, #00342d 0%, #004d43 70%, #046b5e 100%); color: #fff; box-shadow: 0 10px 25px -5px rgba(0, 52, 45, 0.4);">Voir tout</a>
                {% else %}
                    <a href="{{ path('app_activite_new') }}" class="gv-btn-primary">
                        <span class="material-symbols-outlined" style="font-size:1.2rem;">add_circle</span>
                        Créer une activité
                    </a>
                {% endif %}
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // ─── Animations ───
    var reveals = document.querySelectorAll('.gv-reveal');
    if (reveals.length) {
        var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
                if (entry.isIntersecting) {
                    entry.target.classList.add('is-visible');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });

        reveals.forEach(function(el, i) {
            el.style.transitionDelay = (i * 80) + 'ms';
            observer.observe(el);
        });
    }

    // ─── Map Logic ───
    const mapToggle = document.getElementById('mapModeToggle');
    const mapContainer = document.getElementById('gv-map-container');
    let mapInitialized = false;
    let map;

    const activities = [
        {% for a in activites %}
            {% if a.latitude and a.longitude %}
            {
                id: {{ a.id }},
                name: "{{ a.name|escape('js') }}",
                lat: {{ a.latitude }},
                lng: {{ a.longitude }},
                price: "{{ a.prix }}",
                url: "{{ path('app_activite_show', {id: a.id}) }}"
            },
            {% endif %}
        {% endfor %}
    ];

    mapToggle.addEventListener('click', function() {
        mapContainer.classList.toggle('active');
        mapToggle.classList.toggle('active');

        if (mapContainer.classList.contains('active')) {
            if (!mapInitialized) {
                initMap();
                mapInitialized = true;
            } else {
                setTimeout(() => map.invalidateSize(), 300);
            }
        }
    });

    function initMap() {
        // Center on Tunisia by default
        map = L.map('gv-map').setView([36.8065, 10.1815], 7);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap'
        }).addTo(map);

        const markers = [];
        activities.forEach(a => {
            const marker = L.marker([a.lat, a.lng]).addTo(map);
            marker.bindPopup(`
                <div class="gv-map-popup">
                    <h5 style="margin:0 0 5px; font-weight:700;">${a.name}</h5>
                    <p style="margin:0 0 10px; color:#10B981; font-weight:800;">${a.price} TND</p>
                    <a href="${a.url}" class="gv-btn-primary" style="padding:0.4rem 0.8rem; font-size:0.8rem; height:auto; width:100%; justify-content:center;">Détails</a>
                </div>
            `);
            markers.push([a.lat, a.lng]);
        });

        if (markers.length > 0) {
            const bounds = L.latLngBounds(markers);
            map.fitBounds(bounds, { padding: [50, 50] });
        }
    }
});
</script>
{% endblock %}

{% extends is_granted('ROLE_ADMIN') ? 'admin/base_admin.html.twig' : 'base.html.twig' %}

{% block title %}Nouvelle Activité — GoVibe{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Manrope:wght@200..800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
<style>
body { font-family: 'Manrope', sans-serif !important; background: #fcf9f8 !important; }
.material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24; }

.gv-form-hero {
    position: relative;
    padding: 160px 0 100px;
    background: linear-gradient(160deg, #00342d 0%, #013220 40%, #001a12 100%);
    overflow: hidden;
    text-align: center;
    border-radius: 0 0 3rem 3rem;
    box-shadow: 0 20px 50px rgba(0, 52, 45, 0.15);
}
.gv-form-hero::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse at 30% 80%, rgba(16, 185, 129, 0.15) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 20%, rgba(233, 193, 118, 0.08) 0%, transparent 50%);
    pointer-events: none;
}
.gv-form-hero::after {
    content: ''; position: absolute; inset: 0;
    background-image: radial-gradient(rgba(160, 242, 225, 0.06) 1px, transparent 1px);
    background-size: 24px 24px;
    pointer-events: none;
}
.gv-hero-icon-bg {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    font-size: 20rem; color: rgba(255,255,255,0.02); z-index: 0; pointer-events: none;
    font-variation-settings: 'FILL' 1;
}
.gv-form-hero h1 {
    font-family: 'Noto Serif', serif; font-size: clamp(2rem, 4vw, 3rem); color: #fff;
    font-weight: 700; margin-bottom: 0.5rem; position: relative; z-index: 2;
    animation: heroFadeIn 0.8s ease both;
}
.gv-form-hero h1 em { color: #a0f2e1; font-style: italic; font-weight: 300; }
.gv-form-hero p {
    color: rgba(160, 242, 225, 0.7); font-size: 1.05rem; position: relative; z-index: 2;
    animation: heroFadeIn 0.8s ease 0.2s both;
}
@keyframes heroFadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

.gv-form-container {
    max-width: 800px; margin: -50px auto 80px; position: relative; z-index: 10; padding: 0 2rem;
}

.gv-form-card {
    background: rgba(255,255,255,0.97);
    backdrop-filter: blur(20px) saturate(180%);
    border: 1px solid rgba(0, 52, 45, 0.06);
    border-radius: 1.5rem;
    padding: 3rem;
    box-shadow: 0 20px 60px rgba(0, 52, 45, 0.08);
}

.gv-form-card .form-label { font-weight: 700; color: #00342d; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.5rem; }
.gv-form-card .form-control, .gv-form-card .form-select {
    border: 1.5px solid rgba(0, 52, 45, 0.08); border-radius: 0.75rem; padding: 0.85rem 1rem;
    font-family: 'Manrope', sans-serif; font-weight: 500; color: #1c1b1b; font-size: 0.95rem;
    transition: all 0.25s ease; background: #fff;
}
.gv-form-card .form-control:focus, .gv-form-card .form-select:focus {
    border-color: #10B981; box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.12); outline: none;
}
.gv-form-card textarea.form-control { min-height: 120px; resize: vertical; }

.gv-form-submit {
    padding: 1rem 2.5rem;
    background: linear-gradient(135deg, #e9c176 0%, #ca9028 100%);
    color: #3d2a00; border: none; border-radius: 0.75rem; font-weight: 700;
    font-size: 1.05rem; cursor: pointer; transition: all 0.3s ease;
    box-shadow: 0 10px 25px -5px rgba(233, 193, 118, 0.4); font-family: 'Manrope', sans-serif;
    display: inline-flex; align-items: center; gap: 0.5rem;
}
.gv-form-submit:hover { transform: translateY(-2px); box-shadow: 0 15px 35px -5px rgba(233, 193, 118, 0.5); }

.gv-back-link {
    display: inline-flex; align-items: center; gap: 0.4rem; font-weight: 700; font-size: 0.9rem;
    color: #546067; text-decoration: none; padding: 0.7rem 1.5rem; border-radius: 0.75rem;
    border: 1.5px solid rgba(0, 52, 45, 0.08); transition: all 0.25s ease;
}
.gv-back-link:hover { border-color: rgba(0, 52, 45, 0.2); background: rgba(0, 52, 45, 0.03); color: #00342d; }
</style>
{% endblock %}

{% block body %}
<div class="gv-form-hero">
    <span class="material-symbols-outlined gv-hero-icon-bg">add_circle</span>
    <div class="container">
        <h1>Créer une <em>Activité</em></h1>
        <p>Ajoutez une nouvelle expérience au catalogue GoVibe.</p>
    </div>
</div>

<div class="gv-form-container">
    <div class="gv-form-card">
        {{ form_start(form) }}
            {{ include('activite/_form.html.twig') }}
        {{ form_end(form) }}

        <div class="text-center mt-4">
            <a href="{{ path('app_activite_index') }}" class="gv-back-link">
                <span class="material-symbols-outlined" style="font-size:1rem;">arrow_back</span>
                Retour à la liste
            </a>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const latInp = document.getElementById('activite_latitude');
    const lngInp = document.getElementById('activite_longitude');
    const locInp = document.getElementById('activite_localisation');
    const geocodeBtn = document.getElementById('btn-geocode');

    if (!latInp || !lngInp || !geocodeBtn) return;

    // Default: Tunis center
    const defaultLat = latInp.value || 36.8065;
    const defaultLng = lngInp.value || 10.1815;

    const map = L.map('gv-map-picker').setView([defaultLat, defaultLng], 12);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OpenStreetMap' }).addTo(map);

    let marker = L.marker([defaultLat, defaultLng], { draggable: true }).addTo(map);

    function updateInputs(lat, lng) {
        latInp.value = parseFloat(lat).toFixed(8);
        lngInp.value = parseFloat(lng).toFixed(8);
    }

    marker.on('dragend', function(e) {
        const pos = marker.getLatLng();
        updateInputs(pos.lat, pos.lng);
    });

    map.on('click', function(e) {
        marker.setLatLng(e.latlng);
        updateInputs(e.latlng.lat, e.latlng.lng);
    });

    geocodeBtn.addEventListener('click', function() {
        const query = locInp.value;
        if (!query) return alert('Veuillez saisir une localisation.');

        geocodeBtn.disabled = true;
        geocodeBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

        fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}`)
            .then(res => res.json())
            .then(data => {
                if (data.length > 0) {
                    const res = data[0];
                    const lat = res.lat;
                    const lng = res.lon;
                    map.setView([lat, lng], 13);
                    marker.setLatLng([lat, lng]);
                    updateInputs(lat, lng);
                } else {
                    alert('Lieu non trouvé. Essayez d\'être plus précis.');
                }
            })
            .finally(() => {
                geocodeBtn.disabled = false;
                geocodeBtn.innerHTML = '<span class="material-symbols-outlined" style="font-size:1.1rem; vertical-align:middle;">my_location</span>';
            });
    });
});
</script>
{% endblock %}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GoVibe - Mot de passe oublié</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; min-height: 100vh; display: flex; align-items: center; justify-content: center; position: relative; }
        .login-background { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; }
        .login-background img { width: 100%; height: 100%; object-fit: cover; filter: brightness(0.6); }
        .login-background::after { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.40); z-index: 1; }
        
        .login-card {
            position: relative; z-index: 10; width: 420px; padding: 48px 40px;
            background: rgba(255, 255, 255, 0.12); backdrop-filter: blur(24px); border: 1px solid rgba(255, 255, 255, 0.25);
            border-radius: 24px; box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
            animation: card-appear 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
        @keyframes card-appear { from { opacity: 0; transform: translateY(30px) scale(0.96); } to { opacity: 1; transform: translateY(0) scale(1); } }
        
        .login-logo {
            width: 70px; height: 70px; border-radius: 50%; background: linear-gradient(135deg, #50C878, #2E8B57);
            display: flex; align-items: center; justify-content: center; margin: 0 auto 15px; box-shadow: 0 8px 25px rgba(80, 200, 120, 0.4);
        }
        .login-logo span { font-family: 'Outfit', sans-serif; font-size: 26px; font-weight: 700; color: #fff; }
        .login-title { font-family: 'Outfit', sans-serif; font-size: 26px; font-weight: 700; color: #ffffff; text-align: center; margin-bottom: 5px; }
        .login-subtitle { font-size: 14px; color: rgba(255, 255, 255, 0.85); text-align: center; margin-bottom: 25px; }

        .form-group { margin-bottom: 20px; }
        .form-group label { display: block; font-size: 12px; font-weight: 600; color: rgba(255, 255, 255, 0.90); margin-bottom: 6px; letter-spacing: 0.5px; text-transform: uppercase; }
        .form-control { width: 100%; padding: 14px 18px; background: rgba(255, 255, 255, 0.15); border: 1.5px solid rgba(255, 255, 255, 0.30); border-radius: 12px; color: #ffffff; font-size: 14px; outline: none; transition: all 0.3s ease; }
        .form-control::placeholder { color: rgba(255, 255, 255, 0.50); }
        .form-control:focus { border-color: #50C878; background: rgba(255, 255, 255, 0.20); box-shadow: 0 0 0 3px rgba(80, 200, 120, 0.25); }

        .form-control.is-invalid { border-color: #ff9a9a; background: rgba(198, 40, 40, 0.1); animation: shake 0.4s; }
        .form-control.is-valid { border-color: #50C878; background: rgba(80, 200, 120, 0.1); }
        .invalid-feedback { color: #ff9a9a; font-size: 12px; margin-top: 5px; display: none; text-align: left; }
        .form-control.is-invalid ~ .invalid-feedback { display: block; }
        
        .alert-error { background: rgba(198, 40, 40, 0.2); border: 1px solid rgba(198, 40, 40, 0.4); color: #ff9a9a; padding: 12px 16px; border-radius: 10px; font-size: 13px; margin-bottom: 20px; text-align: center; }
        
        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            20% { transform: translateX(-8px); }
            40% { transform: translateX(8px); }
            60% { transform: translateX(-5px); }
            80% { transform: translateX(5px); }
        }

        .btn-signin { width: 100%; padding: 14px; background: linear-gradient(135deg, #50C878, #2E8B57); border: none; border-radius: 12px; color: #ffffff; font-family: 'Outfit', sans-serif; font-size: 16px; font-weight: 600; cursor: pointer; transition: all 0.3s ease; margin-top: 10px; }
        .btn-signin:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(80, 200, 120, 0.50); }

        .signup-link { text-align: center; margin-top: 25px; padding-top: 20px; border-top: 1px solid rgba(255, 255, 255, 0.15); }
        .signup-link a { color: #50C878; text-decoration: none; font-weight: 600; font-size: 14px; }
        .invalid-feedback { color: #ff9a9a; font-size: 12px; margin-top: 5px; display: block; }

        .alert-success { background: rgba(80, 200, 120, 0.2); border: 1px solid rgba(80, 200, 120, 0.4); color: #a0f0c0; padding: 12px 16px; border-radius: 10px; font-size: 13px; margin-bottom: 20px; text-align: center; }
    </style>
</head>
<body>
    <div class="login-background"><img src="{{ asset('images/go_vibe_bg.png') }}" alt="GoVibe Background"></div>
    <div class="login-card">
        <div style="text-align: center; margin-bottom: 20px;">
            <img src="{{ asset('images/logo.png') }}" alt="GoVibe Logo" style="width: 100px; height: auto;">
        </div>
        <h1 class="login-title">Réinitialisation</h1>
        <p class="login-subtitle">Entrez votre email pour recevoir un code</p>

        {% for message in app.flashes('success') %}
            <div class="alert-success">{{ message }}</div>
        {% endfor %}

        {{ form_start(requestForm, {'attr': {'id': 'ultra-forgot-form', 'novalidate': 'novalidate'}}) }}
            <div class="form-group">
                {{ form_label(requestForm.email, 'Email address') }}
                {{ form_widget(requestForm.email, {'attr': {'class': 'form-control', 'placeholder': 'votre.email@exemple.com'}}) }}
                <div class="invalid-feedback">
                    {{ form_errors(requestForm.email) }}
                </div>
            </div>

            <button type="submit" class="btn-signin">Envoyer le code</button>

            <div class="signup-link">
                <a href="{{ path('app_login') }}">Retour à la connexion</a>
            </div>
        {{ form_end(requestForm) }}
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const form = document.getElementById('ultra-forgot-form');
            const emailInput = form.querySelector('input[type="email"]');

            const validate = () => {
                let isValid = true;
                let message = '';
                const val = emailInput.value.trim();

                if (!val) { isValid = false; message = 'L\'adresse email est requise.'; }
                else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val)) { isValid = false; message = 'Format email invalide.'; }

                let feedback = emailInput.parentElement.querySelector('.invalid-feedback');
                
                if (!isValid) {
                    emailInput.classList.remove('is-valid');
                    emailInput.classList.add('is-invalid');
                    if (feedback && message) feedback.textContent = message;
                } else {
                    emailInput.classList.remove('is-invalid');
                    emailInput.classList.add('is-valid');
                    if (feedback) feedback.textContent = '';
                }

                return isValid;
            };

            emailInput.addEventListener('blur', validate);
            emailInput.addEventListener('input', () => {
                if (emailInput.classList.contains('is-invalid')) validate();
            });

            form.addEventListener('submit', (e) => {
                if (!validate()) {
                    e.preventDefault();
                } else {
                    const btn = form.querySelector('button[type="submit"]');
                    btn.textContent = 'Envoi en cours...';
                    btn.style.opacity = '0.7';
                }
            });
        });
    </script>
</body>
</html>

{% extends 'base.html.twig' %}

{% block title %}Mes Réclamations - GoVibe{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet" />
<style>
    :root {
        --glass-bg: rgba(255, 255, 255, 0.05);
        --glass-border: rgba(255, 255, 255, 0.1);
        --glass-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
        --emerald-glow: rgba(16, 185, 129, 0.4);
    }

    body {
        background-color: #050505;
        background-image: 
            radial-gradient(circle at 15% 50%, rgba(16, 185, 129, 0.15), transparent 25%),
            radial-gradient(circle at 85% 30%, rgba(6, 78, 59, 0.2), transparent 25%);
        color: #f3f4f6;
        font-family: 'Inter', sans-serif;
    }

    /* Hero header for reclamations */
    .reclamation-hero {
        position: relative;
        padding: 150px 0 80px;
        text-align: center;
        overflow: hidden;
    }

    .reclamation-hero::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: linear-gradient(180deg, rgba(6, 78, 59, 0.8) 0%, #050505 100%);
        z-index: -2;
    }

    .hero-title {
        font-size: 4rem;
        font-weight: 900;
        background: linear-gradient(to right, #ffffff, #A7F3D0);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 20px;
        letter-spacing: -1px;
    }

    .hero-subtitle {
        font-size: 1.2rem;
        color: #9CA3AF;
        max-width: 600px;
        margin: 0 auto;
    }

    /* Dashboard Glass Container */
    .dashboard-glass {
        background: var(--glass-bg);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        border-radius: 24px;
        box-shadow: var(--glass-shadow);
        padding: 40px;
        margin-top: -40px;
        position: relative;
        z-index: 10;
        margin-bottom: 100px;
        transition: transform 0.4s ease, box-shadow 0.4s ease;
    }

    .dashboard-glass:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 45px rgba(16, 185, 129, 0.15);
        border-color: rgba(16, 185, 129, 0.3);
    }

    /* New Reclamation Button */
    .btn-cyber {
        background: linear-gradient(135deg, #10B981, #064E3B);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 12px 30px;
        font-weight: 700;
        letter-spacing: 0.5px;
        transition: all 0.3s ease;
        box-shadow: 0 10px 20px var(--emerald-glow);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

    .btn-cyber:hover {
        transform: translateY(-3px) scale(1.02);
        box-shadow: 0 15px 30px rgba(16, 185, 129, 0.6);
        color: white;
    }

    /* Glass Table */
    .glass-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 15px;
        margin-top: 20px;
    }

    .glass-table th {
        color: #9CA3AF;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 1px;
        padding: 0 20px 10px;
        border: none;
    }

    .glass-table td {
        background: rgba(255, 255, 255, 0.03);
        padding: 20px;
        vertical-align: middle;
        color: #E5E7EB;
        transition: all 0.3s ease;
        border-top: 1px solid rgba(255,255,255,0.05);
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .glass-table tr td:first-child {
        border-radius: 16px 0 0 16px;
        border-left: 1px solid rgba(255,255,255,0.05);
    }

    .glass-table tr td:last-child {
        border-radius: 0 16px 16px 0;
        border-right: 1px solid rgba(255,255,255,0.05);
    }

    .glass-table tbody tr {
        transition: all 0.3s ease;
    }

    .glass-table tbody tr:hover td {
        background: rgba(16, 185, 129, 0.08);
        border-color: rgba(16, 185, 129, 0.3);
        transform: scale(1.01);
    }

    /* Status Badges - Cyberpunk style */
    .cyber-badge {
        padding: 8px 16px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        box-shadow: 0 0 10px rgba(0,0,0,0.5);
    }

    .status-en-attente { 
        background: rgba(245, 158, 11, 0.1); 
        color: #FCD34D; 
        border: 1px solid #F59E0B;
        box-shadow: 0 0 15px rgba(245, 158, 11, 0.2);
    }
    
    .status-traitee { 
        background: rgba(16, 185, 129, 0.1); 
        color: #6EE7B7; 
        border: 1px solid #10B981;
        box-shadow: 0 0 15px rgba(16, 185, 129, 0.2);
    }
    
    .status-refusee { 
        background: rgba(239, 68, 68, 0.1); 
        color: #FCA5A5; 
        border: 1px solid #EF4444;
        box-shadow: 0 0 15px rgba(239, 68, 68, 0.2);
    }

    /* Custom Scrollbar for table */
    .table-responsive::-webkit-scrollbar {
        height: 6px;
    }
    .table-responsive::-webkit-scrollbar-track {
        background: rgba(255,255,255,0.05);
        border-radius: 10px;
    }
    .table-responsive::-webkit-scrollbar-thumb {
        background: rgba(16, 185, 129, 0.5);
        border-radius: 10px;
    }

    /* Empty State */
    .empty-cyber {
        text-align: center;
        padding: 60px 20px;
        background: rgba(255,255,255,0.02);
        border-radius: 20px;
        border: 1px dashed rgba(255,255,255,0.05);
    }

    .empty-cyber i {
        font-size: 5rem;
        background: linear-gradient(135deg, #10B981, #3B82F6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 20px;
        display: inline-block;
        animation: floatImg 4s ease-in-out infinite;
    }
    
    @keyframes floatImg {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }
</style>
{% endblock %}

{% block body %}
    <!-- Hero Section -->
    <div class="reclamation-hero">
        <div class="container" data-aos="zoom-in" data-aos-duration="1000">
            <h1 class="hero-title">Centre de Commande</h1>
            <p class="hero-subtitle">Visualisez, suivez et gérez l'ensemble de vos requêtes avec transparence et fluidité dans notre écosystème Next-Gen.</p>
        </div>
    </div>

    <!-- Main Dashboard -->
    <div class="container">
        <div class="dashboard-glass" data-aos="fade-up" data-aos-delay="200" data-aos-duration="1000">
            
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-5">
                <div>
                    <h3 style="font-weight: 800; color: white; margin:0; letter-spacing: -0.5px;">Historique des Requêtes</h3>
                    <p class="text-muted small mt-1 mb-0">Toutes vos interactions sécurisées au même endroit.</p>
                </div>
                <div class="mt-4 mt-md-0">
                    <a href="{{ path('app_reclamation_new') }}" class="btn-cyber">
                        <i class="bi bi-rocket-takeoff-fill"></i> Nouvelle Requête
                    </a>
                </div>
            </div>
            
            {% for message in app.flashes('success') %}
                <div class="alert alert-success border-0 rounded-4 mb-4" style="background: rgba(16, 185, 129, 0.2); color: #A7F3D0; border: 1px solid #10B981;" data-aos="fade-in">
                    <i class="bi bi-check-circle-fill me-2"></i> {{ message }}
                </div>
            {% endfor %}

            {% if reclamations|length > 0 %}
            <div class="table-responsive">
                <table class="glass-table">
                    <thead>
                        <tr>
                            <th>Chronologie</th>
                            <th>Objet de la Requête</th>
                            <th class="text-center">État du Traitement</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for rec in reclamations %}
                        <tr data-aos="fade-up" data-aos-delay="{{ loop.index * 100 }}">
                            <td style="width: 20%;">
                                <div style="color: #10B981; font-weight: 700; font-size: 1.1rem;">{{ rec.dateEnvoi ? rec.dateEnvoi|date('d M Y') : '' }}</div>
                                <div class="text-muted small"><i class="bi bi-clock"></i> {{ rec.dateEnvoi ? rec.dateEnvoi|date('H:i') : '' }}</div>
                            </td>
                            <td style="width: 55%;">
                                <div class="fw-bold mb-1" style="color: white; font-size: 1.1rem;">{{ rec.sujet }}</div>
                                <div class="text-muted small text-truncate" style="max-width: 400px; line-height: 1.5;">{{ rec.message }}</div>
                            </td>
                            <td class="text-center" style="width: 25%;">
                                {% if rec.status|lower == 'en attente' or rec.status|lower == 'en_attente' %}
                                    <span class="cyber-badge status-en-attente">
                                        <i class="bi bi-hourglass-split me-1"></i> En Attente
                                    </span>
                                {% elseif rec.status|lower == 'traitee' or rec.status|lower == 'traitée' %}
                                    <span class="cyber-badge status-traitee">
                                        <i class="bi bi-check2-all me-1"></i> Traitée
                                    </span>
                                {% else %}
                                    <span class="cyber-badge status-refusee">
                                        <i class="bi bi-x-octagon me-1"></i> {{ rec.status }}
                                    </span>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
            {% else %}
                <div class="empty-cyber" data-aos="zoom-in" data-aos-delay="300">
                    <i class="bi bi-box-seam"></i>
                    <h4 style="color: white; font-weight: 700;">Aucune anomalie détectée</h4>
                    <p class="text-muted">Votre historique de requêtes est actuellement vierge.</p>
                    <a href="{{ path('app_reclamation_new') }}" class="btn-cyber mt-3">Initier une requête</a>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        AOS.init({
            once: true,
            offset: 50
        });
    });
</script>
{% endblock %}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="GoVibe - Créer un compte">
    <title>GoVibe - S'inscrire</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow-x: hidden;
            position: relative;
        }

        .login-background {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%; z-index: 0;
        }
        .login-background img {
            width: 100%; height: 100%; object-fit: cover; filter: brightness(0.6);
        }
        .login-background::after {
            content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0, 0, 0, 0.40); z-index: 1;
        }

        .login-card {
            position: relative; z-index: 10;
            width: 470px; padding: 35px 40px;
            background: rgba(255, 255, 255, 0.12);
            backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
            border: 1px solid rgba(255, 255, 255, 0.25);
            border-radius: 24px; box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
            animation: card-appear 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            margin: 20px 0;
        }

        @keyframes card-appear {
            from { opacity: 0; transform: translateY(30px) scale(0.96); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }

        .login-logo {
            width: 70px; height: 70px; border-radius: 50%;
            background: linear-gradient(135deg, #50C878, #2E8B57);
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 15px; box-shadow: 0 8px 25px rgba(80, 200, 120, 0.4);
        }
        .login-logo span { font-family: 'Outfit', sans-serif; font-size: 26px; font-weight: 700; color: #fff; }

        .login-title {
            font-family: 'Outfit', sans-serif; font-size: 26px; font-weight: 700;
            color: #ffffff; text-align: center; margin-bottom: 5px;
        }
        .login-subtitle { font-size: 14px; color: rgba(255, 255, 255, 0.85); text-align: center; margin-bottom: 25px; }

        .form-row { display: flex; gap: 15px; margin-bottom: 15px; }
        .form-row .form-group { width: 50%; margin-bottom: 0; }

        .form-group { margin-bottom: 15px; }
        .form-group label {
            display: block; font-size: 12px; font-weight: 600; color: rgba(255, 255, 255, 0.90);
            margin-bottom: 6px; letter-spacing: 0.5px; text-transform: uppercase;
        }
        .form-control {
            width: 100%; padding: 12px 16px; background: rgba(255, 255, 255, 0.15);
            border: 1.5px solid rgba(255, 255, 255, 0.30); border-radius: 12px;
            color: #ffffff; font-size: 14px; outline: none; transition: all 0.3s ease;
        }
        .form-control::placeholder { color: rgba(255, 255, 255, 0.50); }
        .form-control:focus {
            border-color: #50C878; background: rgba(255, 255, 255, 0.20);
            box-shadow: 0 0 0 3px rgba(80, 200, 120, 0.25);
        }

        .role-selector {
            display: flex; gap: 20px; align-items: center;
            background: rgba(255, 255, 255, 0.1); padding: 10px 15px;
            border-radius: 12px; border: 1px solid rgba(255,255,255,0.2);
        }
        .form-check { display: flex; align-items: center; gap: 8px; cursor: pointer; }
        .form-check input { cursor: pointer; accent-color: #50C878; width: 16px; height: 16px; }
        .form-check label { margin-bottom: 0; cursor: pointer; font-size: 13px; text-transform: none; }

        .btn-signin {
            width: 100%; padding: 14px; background: linear-gradient(135deg, #50C878, #2E8B57);
            border: none; border-radius: 12px; color: #ffffff;
            font-family: 'Outfit', sans-serif; font-size: 16px; font-weight: 600;
            cursor: pointer; transition: all 0.3s ease; margin-top: 15px;
        }
        .btn-signin:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(80, 200, 120, 0.50); }

        .signup-link { text-align: center; margin-top: 20px; padding-top: 20px; border-top: 1px solid rgba(255, 255, 255, 0.15); }
        .signup-link span { font-size: 14px; color: rgba(255, 255, 255, 0.70); }
        .signup-link a { color: #50C878; text-decoration: none; font-weight: 600; }
        
        .invalid-feedback {
            color: #ff9a9a; font-size: 12px; margin-top: 5px; display: block; text-align: left;
        }
        .form-control.is-invalid { border-color: #ff9a9a; background: rgba(198, 40, 40, 0.1); animation: shake 0.4s; }
        .form-control.is-valid { border-color: #50C878; background: rgba(80, 200, 120, 0.1); }
        
        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            20% { transform: translateX(-8px); }
            40% { transform: translateX(8px); }
            60% { transform: translateX(-5px); }
            80% { transform: translateX(5px); }
        }

        /* Required field asterisk */
        .form-group label.required::after { content: " *"; color: #50C878; }

        ul.form-errors { list-style: none; color: #ff9a9a; background: rgba(198, 40, 40, 0.2); padding: 10px; border-radius: 8px; font-size: 13px; margin-bottom: 15px; }

    </style>
</head>
<body>
    <div class="login-background">
        <img src="{{ asset('images/go_vibe_bg.png') }}" alt="GoVibe Background">
    </div>

    <div class="login-card">
        <div style="text-align: center; margin-bottom: 20px;">
            <img src="{{ asset('images/logo.png') }}" alt="GoVibe Logo" style="width: 110px; height: auto;">
        </div>
        <h1 class="login-title">Créer un compte</h1>
        <p class="login-subtitle">Rejoignez GoVibe dès maintenant</p>

        {{ form_start(registrationForm, {'attr': {'novalidate': 'novalidate'}}) }}
            {{ form_errors(registrationForm) }}
            
            <div class="form-row">
                <div class="form-group">
                    {{ form_label(registrationForm.nom, 'Nom *') }}
                    {{ form_widget(registrationForm.nom, {'attr': {'class': 'form-control', 'placeholder': 'Votre nom'}}) }}
                    {{ form_errors(registrationForm.nom) }}
                </div>
                <div class="form-group">
                    {{ form_label(registrationForm.prenom, 'Prénom *') }}
                    {{ form_widget(registrationForm.prenom, {'attr': {'class': 'form-control', 'placeholder': 'Votre prénom'}}) }}
                    {{ form_errors(registrationForm.prenom) }}
                </div>
            </div>

            <div class="form-group">
                {{ form_label(registrationForm.email, 'Email *') }}
                {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control', 'placeholder': 'votre.email@exemple.com'}}) }}
                {{ form_errors(registrationForm.email) }}
            </div>

            <div class="form-group">
                {{ form_label(registrationForm.plainPassword, 'Mot de passe *') }}
                {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'form-control', 'placeholder': 'Min 8 car., majuscule et chiffre'}}) }}
                <div class="invalid-feedback">
                    {{ form_errors(registrationForm.plainPassword) }}
                </div>
            </div>

            <button type="submit" class="btn-signin">S'inscrire</button>

            <div class="signup-link">
                <span>Déjà un compte ? </span>
                <a href="{{ path('app_login') }}">Se connecter</a>
            </div>
        {{ form_end(registrationForm) }}
    </div>
</body>
</html>

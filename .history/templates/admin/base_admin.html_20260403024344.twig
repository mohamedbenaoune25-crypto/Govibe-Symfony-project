<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}GoVibe Administration{% endblock %}</title>
    
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <!-- AOS CSS -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet" />
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        :root {
            --admin-primary: #050505;
            --admin-secondary: #0a0a0a;
            --admin-accent: #10B981;
            --admin-accent-glow: rgba(16, 185, 129, 0.4);
            --bg-light: #000000;
            --glass-bg: rgba(255, 255, 255, 0.03);
            --glass-border: rgba(255, 255, 255, 0.08);
            --text-main: #f3f4f6;
            --text-muted: #9CA3AF;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-light);
            background-image: 
                radial-gradient(circle at 10% 20%, rgba(16, 185, 129, 0.1), transparent 30%),
                radial-gradient(circle at 90% 80%, rgba(6, 78, 59, 0.15), transparent 30%);
            color: var(--text-main);
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
            margin: 0;
        }

        /* Sidebar Styling - Futuristic Glass */
        .sidebar {
            width: 280px;
            background: rgba(5, 5, 5, 0.7);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-right: 1px solid var(--glass-border);
            color: var(--text-muted);
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
            transition: all 0.3s;
            z-index: 1000;
        }

        .sidebar-brand {
            padding: 30px 25px;
            font-family: 'Outfit', sans-serif;
            font-size: 26px;
            font-weight: 800;
            color: white;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 15px;
            border-bottom: 1px solid var(--glass-border);
            background: transparent;
            letter-spacing: -0.5px;
        }
        
        .sidebar-brand span.gv {
            color: var(--admin-accent);
            text-shadow: 0 0 15px var(--admin-accent-glow);
        }

        .sidebar-nav {
            padding: 25px 0;
            list-style: none;
            margin: 0;
            flex: 1;
        }

        .sidebar-nav-item {
            padding: 0 20px;
            margin-bottom: 8px;
        }

        .sidebar-nav-link {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 14px 20px;
            color: var(--text-muted);
            text-decoration: none;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 500;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            border: 1px solid transparent;
        }

        .sidebar-nav-link i {
            font-size: 20px;
            transition: transform 0.3s ease;
        }

        .sidebar-nav-link:hover, .sidebar-nav-link.active {
            color: white;
            background: linear-gradient(90deg, rgba(16, 185, 129, 0.15) 0%, transparent 100%);
            border: 1px solid rgba(16, 185, 129, 0.2);
            border-left: 4px solid var(--admin-accent);
            box-shadow: inset 20px 0 20px -20px var(--admin-accent-glow);
        }
        
        .sidebar-nav-link:hover i {
            transform: scale(1.1);
            color: var(--admin-accent);
        }

        /* Main Content Wrapper */
        .main-content {
            margin-left: 280px;
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* Top Header inside main content - Glass */
        .admin-header {
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border-bottom: 1px solid var(--glass-border);
            height: 80px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 40px;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .header-title {
            margin: 0;
            font-family: 'Outfit', sans-serif;
            font-weight: 700;
            color: white;
            font-size: 22px;
            letter-spacing: -0.5px;
        }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 20px;
        }
        
        .admin-badge {
            background: rgba(16, 185, 129, 0.1);
            border: 1px solid rgba(16, 185, 129, 0.3);
            color: var(--admin-accent);
            padding: 8px 20px;
            border-radius: 50px;
            font-size: 13px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            box-shadow: 0 0 15px var(--admin-accent-glow);
        }

        /* Content Area */
        .content-area {
            padding: 40px;
            flex: 1;
        }

        /* Custom Futuristic Cards */
        .admin-card {
            background: var(--glass-bg);
            backdrop-filter: blur(10px);
            border: 1px solid var(--glass-border);
            border-radius: 20px;
            overflow: hidden;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            margin-bottom: 25px;
        }
        
        .admin-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.5), 0 0 20px rgba(16, 185, 129, 0.1);
            border-color: rgba(16, 185, 129, 0.2);
        }
        
        .admin-card-header {
            padding: 20px 25px;
            border-bottom: 1px solid var(--glass-border);
            background: rgba(0,0,0,0.2);
            font-weight: 700;
            color: white;
            font-family: 'Outfit';
            letter-spacing: 0.5px;
        }
        
        .admin-card-body {
            padding: 25px;
        }

        /* Admin Table */
        .admin-table {
            color: var(--text-main);
        }

        .admin-table th {
            font-size: 13px;
            text-transform: uppercase;
            color: var(--text-muted);
            font-weight: 700;
            padding: 15px 20px;
            background: rgba(255,255,255,0.02);
            border-top: none;
            border-bottom: 1px solid var(--glass-border);
            letter-spacing: 1px;
        }
        
        .admin-table td {
            vertical-align: middle;
            padding: 15px 20px;
            color: var(--text-main);
            border-bottom: 1px solid rgba(255,255,255,0.05);
            background: transparent;
        }
        
        .admin-table tr:hover td {
            background: rgba(255,255,255,0.05);
        }

        /* Buttons Cyber */
        .btn-cyber {
            background: rgba(16, 185, 129, 0.1);
            border: 1px solid var(--admin-accent);
            color: var(--admin-accent);
            border-radius: 8px;
            transition: all 0.3s;
        }
        
        .btn-cyber:hover {
            background: var(--admin-accent);
            color: #000;
            box-shadow: 0 0 15px var(--admin-accent-glow);
        }

        {% block stylesheets %}{% endblock %}
    </style>
</head>
<body>

    <!-- Sidebar -->
    <aside class="sidebar" data-aos="fade-right" data-aos-duration="800">
        <a href="{{ path('app_user_home') }}" class="sidebar-brand">
            <i class="bi bi-rocket-takeoff"></i> GoVibe <span class="gv">Panel</span>
        </a>
        <ul class="sidebar-nav">
            <li class="sidebar-nav-item">
                <a href="{{ path('app_admin_dashboard') }}" class="sidebar-nav-link {% if app.request.attributes.get('_route') == 'app_admin_dashboard' %}active{% endif %}">
                    <i class="bi bi-grid-1x2"></i> Dashboard
                </a>
            </li>
            <li class="sidebar-nav-item">
                <a href="{{ path('app_admin_users') }}" class="sidebar-nav-link {% if app.request.attributes.get('_route') == 'app_admin_users' %}active{% endif %}">
                    <i class="bi bi-people"></i> Utilisateurs
                </a>
            </li>
            <li class="sidebar-nav-item">
                <a href="{{ path('app_admin_reclamations') }}" class="sidebar-nav-link {% if app.request.attributes.get('_route') == 'app_admin_reclamations' %}active{% endif %}">
                    <i class="bi bi-envelope-exclamation"></i> Réclamations
                </a>
            </li>
            <li class="sidebar-nav-item pt-4">
                <a href="{{ path('app_logout') }}" class="sidebar-nav-link text-danger mt-2">
                    <i class="bi bi-box-arrow-right"></i> Déconnexion
                </a>
            </li>
        </ul>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
        <!-- Header -->
        <header class="admin-header">
            <h1 class="header-title">{% block page_title %}Dashboard{% endblock %}</h1>
            <div class="header-actions">
                <div class="admin-badge"><i class="bi bi-shield-check me-2"></i>Espace Sécurisé</div>
                <div class="fw-bold text-dark">{{ app.user.prenom }} {{ app.user.nom }}</div>
            </div>
        </header>

        <!-- Dynamic Content -->
        <div class="content-area">
            {% for message in app.flashes('success') %}
                <div class="alert alert-success border-0 rounded-3 shadow-sm">{{ message }}</div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="alert alert-danger border-0 rounded-3 shadow-sm">{{ message }}</div>
            {% endfor %}

            {% block body %}{% endblock %}
        </div>
    </main>

    <!-- Bootstrap Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    {% block javascripts %}{% endblock %}
</body>
</html>

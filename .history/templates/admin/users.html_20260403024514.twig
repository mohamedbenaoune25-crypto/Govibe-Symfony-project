{% extends 'admin/base_admin.html.twig' %}

{% block page_title %}Registre des Agents{% endblock %}

{% block body %}
<div class="admin-card" data-aos="fade-up" data-aos-duration="800">
    <div class="admin-card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-fingerprint me-2 text-success"></i> Identités Biométriques</span>
        <button class="btn btn-cyber py-1 px-3"><i class="bi bi-person-plus-fill me-2"></i> Nouvel Agent</button>
    </div>
    <div class="admin-card-body p-0 table-responsive">
        <table class="table admin-table mb-0">
            <thead>
                <tr>
                    <th style="padding-left: 25px;"><i class="bi bi-hash"></i> MATRICULE</th>
                    <th><i class="bi bi-person-bounding-box"></i> PROFIL</th>
                    <th><i class="bi bi-envelope"></i> CANAL COM</th>
                    <th><i class="bi bi-shield-lock"></i> NIVEAU D'ACCÈS</th>
                    <th class="text-end" style="padding-right: 25px;">COMMANDES</th>
                </tr>
            </thead>
            <tbody>
                {% for u in users %}
                <tr style="transition: all 0.2s;" onmouseover="this.style.background='rgba(16, 185, 129, 0.05)'" onmouseout="this.style.background='transparent'">
                    <td style="padding-left: 25px; font-family: monospace; color: #9CA3AF;">#{{ "%04d"|format(u.id) }}</td>
                    <td>
                        <div class="d-flex align-items-center gap-3">
                            <div style="width:40px;height:40px;border-radius:12px;background:rgba(255,255,255,0.05);color:#fff;border:1px solid rgba(255,255,255,0.1);display:flex;align-items:center;justify-content:center;font-weight:800;font-size:16px;">
                                {{ u.prenom|first|upper }}
                            </div>
                            <span class="fw-bold" style="color:#fff; letter-spacing: 0.5px;">{{ u.prenom }} {{ u.nom }}</span>
                        </div>
                    </td>
                    <td style="color: #10B981; font-family: monospace;">{{ u.email }}</td>
                    <td>
                        {% if 'ROLE_ADMIN' in u.role %}
                            <span class="badge" style="background:rgba(139, 92, 246, 0.15);color:#A78BFA;border:1px solid rgba(139, 92, 246, 0.3);padding:6px 12px;box-shadow: 0 0 10px rgba(139, 92, 246, 0.2);">SUPERVISEUR</span>
                        {% else %}
                            <span class="badge" style="background:rgba(156, 163, 175, 0.1);color:#9CA3AF;border:1px solid rgba(156, 163, 175, 0.2);padding:6px 12px;">STANDARD</span>
                        {% endif %}
                    </td>
                    <td class="text-end" style="padding-right: 25px;">
                        <div class="d-flex justify-content-end gap-2">
                            <!-- Role change form -->
                            <form method="post" action="{{ path('app_admin_user_role', {'id': u.id}) }}" class="d-inline">
                                {% if 'ROLE_ADMIN' in u.role %}
                                    <input type="hidden" name="role" value="ROLE_USER">
                                    <button class="btn btn-sm" style="background:rgba(245, 158, 11, 0.1);color:#FCD34D;border:1px solid rgba(245, 158, 11, 0.3);" title="Rétrograder en Utilisateur" {% if u == app.user %}disabled{% endif %}><i class="bi bi-arrow-down-circle"></i></button>
                                {% else %}
                                    <input type="hidden" name="role" value="ROLE_ADMIN">
                                    <button class="btn btn-sm" style="background:rgba(59, 130, 246, 0.1);color:#60A5FA;border:1px solid rgba(59, 130, 246, 0.3);" title="Promouvoir Administrateur"><i class="bi bi-arrow-up-circle"></i></button>
                                {% endif %}
                            </form>
                            
                            <!-- Delete user form -->
                            <form method="post" action="{{ path('app_admin_user_delete', {'id': u.id}) }}" class="d-inline" onsubmit="return confirm('ALERTE SYSTÈME : Confirmation de la désintégration de l\'agent {{ u.prenom }} ? Cette action effacera ses données du réseau.');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ u.id) }}">
                                <button class="btn btn-sm" style="background:rgba(239, 68, 68, 0.1);color:#FCA5A5;border:1px solid rgba(239, 68, 68, 0.3);" {% if u == app.user %}disabled{% endif %}><i class="bi bi-trash3"></i></button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

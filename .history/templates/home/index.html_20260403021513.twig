{% extends 'base.html.twig' %}

{% block title %}Accueil - GoVibe{% endblock %}

{% block stylesheets %}
<style>
    .hero-section {
        height: 650px;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
    }

    .hero-bg {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        object-fit: cover;
        z-index: 0;
        /* Image generated via generate_image (hot air balloons) */
    }

    .hero-overlay {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(1, 50, 32, 0.4); /* Dark green overlay */
        z-index: 1;
    }

    .hero-content {
        position: relative;
        z-index: 2;
        color: white;
        margin-top: 50px; /* Offset for navbar */
    }

    .hero-title {
        font-size: 56px;
        font-weight: 700;
        text-shadow: 0 4px 20px rgba(0,0,0,0.5);
        margin-bottom: 20px;
    }

    /* Search Bar */
    .search-bar-container {
        position: relative;
        z-index: 3;
        margin-top: -45px; /* Pull up to overlap hero */
        max-width: 900px;
        margin-left: auto;
        margin-right: auto;
        background: white;
        border-radius: 100px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.15);
        padding: 10px 15px;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .search-input-group {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 20px;
        border-right: 1px solid #eee;
    }
    .search-input-group:last-child { border-right: none; }
    
    .search-input-group i { color: var(--primary-emerald); font-size: 20px; }
    .search-input-group div { display: flex; flex-direction: column; text-align: left; }
    .search-input-group label { font-size: 13px; font-weight: 600; color: #333; margin: 0; }
    .search-input-group input { border: none; padding: 0; font-size: 14px; color: #666; outline: none; background: transparent; }
    
    .btn-search {
        background: var(--primary-emerald);
        color: white;
        border: none;
        border-radius: 50px;
        padding: 15px 30px;
        font-weight: 600;
        transition: all 0.3s;
    }
    .btn-search:hover { background: var(--mid-green); transform: scale(1.05); }

    /* Stats Bar */
    .stats-bar {
        background-color: var(--dark-green);
        padding: 40px 0;
        margin-top: 60px;
    }
    .stat-item {
        text-align: center;
        color: white;
    }
    .stat-number { font-size: 36px; font-weight: 700; color: var(--primary-emerald); font-family: 'Outfit', sans-serif; }
    .stat-label { font-size: 15px; opacity: 0.8; }

    /* Categories */
    .categories-section {
        padding: 80px 0;
    }
    .section-title {
        font-size: 32px;
        font-weight: 700;
        color: var(--dark-green);
        text-align: center;
        margin-bottom: 40px;
    }
    
    .category-bubbles {
        display: flex;
        justify-content: center;
        gap: 40px;
        flex-wrap: wrap;
    }
    
    .category-bubble {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 15px;
        text-decoration: none;
        transition: all 0.3s;
    }
    .category-bubble:hover { transform: translateY(-10px); }
    
    .bubble-icon {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background-color: white;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
        color: var(--primary-emerald);
        transition: all 0.3s;
    }
    .category-bubble:hover .bubble-icon {
        background-color: var(--primary-emerald);
        color: white;
        box-shadow: 0 15px 35px rgba(80, 200, 120, 0.4);
    }
    .bubble-label {
        font-weight: 600;
        color: #444;
        font-size: 16px;
    }

    /* Activities Grid */
    .activities-section {
        padding: 60px 0 100px;
        background-color: white;
    }
    
    .activity-card {
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.06);
        transition: all 0.3s;
        height: 100%;
        background: var(--bg-creme);
    }
    .activity-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 40px rgba(0,0,0,0.12);
    }
    .activity-img {
        height: 250px;
        width: 100%;
        background-color: #ddd; /* Skeleton bg */
        object-fit: cover;
    }
    .activity-body {
        padding: 25px;
    }
    .activity-category {
        font-size: 12px;
        text-transform: uppercase;
        font-weight: 700;
        color: var(--primary-emerald);
        margin-bottom: 10px;
        display: block;
    }
    .activity-title {
        font-size: 20px;
        font-weight: 700;
        color: var(--dark-green);
        margin-bottom: 15px;
    }
    .activity-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-top: 1px solid rgba(0,0,0,0.1);
        padding-top: 15px;
        margin-top: 15px;
    }
    .activity-price {
        font-weight: 700;
        font-size: 18px;
    }
</style>
{% endblock %}

